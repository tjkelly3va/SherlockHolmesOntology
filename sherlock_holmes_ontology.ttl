:wilsonCanaryTrainer a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Wilson" ;
    ex:prefLabel "Wilson" ;
    skos:altLabel "Wilson the canary-trainer" ;
    ex:description "The notorious canary-trainer whose arrest by Holmes in 1895 removed a plague-spot from the East End of London. Referenced only; no further details given." ;
    ex:occupation "canary-trainer" ;
    ex:memberOfOntology ex:SherlockOntology ;
