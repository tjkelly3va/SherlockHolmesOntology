:johnHorner a ex:FictionalPerson, ex:Plumber, ex:Victim ;
    ex:firstName "John" ;
    ex:lastName "Horner" ;
    ex:prefLabel "John Horner" ;
    ex:description "John Horner is a 26-year-old plumber who was falsely accused of stealing the blue carbuncle from the Countess of Morcar's jewel-case at the Hotel Cosmopolitan. He had been called to solder a loose bar in the grate of the Countess's dressing-room. He had a previous conviction for robbery, which made suspicion fall readily upon him. He was arrested by Inspector Bradstreet, protested his innocence frantically, and fainted in court. His case was referred to the Assizes. He was entirely innocent, having been framed by James Ryder and Catherine Cusack." ;
    ex:occupation "plumber" ;
    ex:age 26 ;
    ex:framedBy :jamesRyder, :catherineCusack ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:johnOpenshaw a ex:FictionalPerson, ex:Client, ex:Victim ;
    ex:firstName "John" ;
    ex:lastName "Openshaw" ;
    ex:prefLabel "John Openshaw" ;
    skos:altLabel "young Openshaw" ;
    ex:description "A young man of about twenty-two years, well-groomed and trimly clad, wearing a golden pince-nez. Client of Sherlock Holmes. Grandson of the unnamed Openshaw patriarch and nephew of Colonel Elias Openshaw. Son of Joseph Openshaw. Sent to live with his uncle Elias at age twelve in 1878, became master of the household by sixteen. Inherited the Horsham estate after the deaths of both his uncle and father. Received five orange pips with the inscription 'K.K.K.' and the instruction 'Put the papers on the sundial' from London (eastern division) in September 1887. Referred to Holmes by Major Prendergast. Found dead near Waterloo Bridge, pushed into the Thames by Calhoun's gang. The official inquest concluded it was an accident." ;
    ex:age "22" ;
    ex:causeOfDeath "Drowned in the Thames near Waterloo Bridge, pushed by agents of Captain James Calhoun" ;
    ex:childOf :josephOpenshaw ;
    ex:clientOf :sherlockHolmes ;
    ex:grandchildOf :openshawGrandfather ;
    ex:isVictimOf :murderOfJohnOpenshaw ;
    ex:knows :majorPrendergast, :majorFreebody ;
    ex:livesAt :openshawEstate ;
    ex:nephewOf :eliasOpenshaw ;
    ex:referredBy :majorPrendergast ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

