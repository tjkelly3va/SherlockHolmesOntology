# ============================================================================
# OBJECT PROPERTY DEFINITIONS (Sorted Alphabetically)
# ============================================================================

ex:abducted a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    ex:prefLabel "Abducted" ;
    ex:description "An Abducted is a relationship that connects a person to the person that was taken away by force or deception." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

ex:abductedBy a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    ex:prefLabel "Abducted By" ;
    ex:description "An 'Abducted By' is a relationship that connects a person to the person who abducted or kidnapped them." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

ex:accompliceIn a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Crime ;
    ex:prefLabel "Accomplice In" ;
    ex:description "An 'Accomplice In' is a relationship that connects a person to a crime in which they served as an accomplice." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

ex:accompliceOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    ex:prefLabel "Accomplice Of" ;
    ex:description "An 'Accomplice Of' is a relationship that connects a person to another person for whom they served as an accomplice in committing a crime." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

ex:accusedOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Event ;
    ex:prefLabel "Accused Of" ;
    ex:description "An 'Accused Of' is a relationship that connects a person to a crime or event of which they were accused." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

ex:adopted a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:adoptedBy ;
    ex:prefLabel "Adopted" ;
    ex:description "An Adopted is a relationship that connects a person to another person whom they adopted." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

ex:adoptedBy a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:adopted ;
    ex:prefLabel "Adopted By" ;
    ex:description "An 'Adopted By' is a relationship that connects a person to the person who adopted them." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

ex:adoptedByPerson a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:adoptiveParentOf ;
    ex:prefLabel "Adopted By" ;
    ex:description "An 'Adopted By' is a relationship that connects an adopted child to their adoptive parent." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

ex:adoptiveParentOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:adoptedByPerson ;
    ex:prefLabel "Adoptive Parent Of" ;
    ex:description "An 'Adoptive Parent Of' is a relationship that connects a person to a child they adopted." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

ex:agentOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:hasAgent ;
    ex:prefLabel "Agent Of" ;
    ex:description "An 'Agent Of' is a relationship that connects a person who serves as a secret agent to the person or entity they serve." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

ex:aliases a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    ex:prefLabel "Aliases" ;
    ex:description "An Aliases is a relationship that connects a person URI to another person URI representing the same individual under a different identity." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

ex:aliasOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    ex:prefLabel "Alias Of" ;
    ex:description "An 'Alias Of' is a relationship that connects a person's assumed identity to their true identity, used when the same individual has two distinct persona URIs in the ontology." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

ex:alliedTo a owl:ObjectProperty ;
    rdfs:domain ex:Organization ;
    rdfs:range ex:Organization ;
    owl:inverseOf ex:alliedWith ;
    ex:prefLabel "Allied To" ;
    ex:description "An 'Allied To' is a relationship that connects an organization to another organization it is allied or affiliated with." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

ex:alliedWith a owl:ObjectProperty ;
    rdfs:domain ex:Organization ;
    rdfs:range ex:Organization ;
    owl:inverseOf ex:alliedTo ;
    ex:prefLabel "Allied With" ;
    ex:description "An 'Allied With' is a relationship that connects an organization to another organization that is allied with it." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

ex:alumniOf a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Organization ;
    ex:prefLabel "Alumni Of" ;
    ex:description "An 'Alumni Of' is a relationship that connects a person to an educational or medical institution they attended or trained at." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

ex:ancestorOf a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:descendantOf ;
    ex:prefLabel "Ancestor Of" ;
    ex:description "An 'Ancestor Of' is a relationship that connects a person to a descendant." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

ex:arrested a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:arrestedBy ;
    ex:prefLabel "Arrested" ;
    ex:description "An Arrested is a relationship that connects a person to another person whom they arrested." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

ex:arrestedAt a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Location ;
    ex:prefLabel "Arrested At" ;
    ex:description "An 'Arrested At' is a relationship that connects a person to the location where they were arrested." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

ex:arrestedBy a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:arrested ;
    ex:prefLabel "Arrested By" ;
    ex:description "An 'Arrested By' is a relationship that connects a person to the person who arrested them." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

ex:arrestedIn a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Event ;
    ex:prefLabel "Arrested In" ;
    ex:description "An 'Arrested In' is a relationship that connects a person to the arrest event in which they were apprehended." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

ex:arrivedFrom a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Location ;
    ex:prefLabel "Arrived From" ;
    ex:description "An 'Arrived From' is a relationship that connects a person to a location from which they traveled." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

ex:arrivesAt a owl:ObjectProperty ;
    rdfs:domain ex:Event ;
    rdfs:range ex:Location ;
    ex:prefLabel "Arrives At" ;
    ex:description "An 'Arrives At' is a relationship that connects a journey or travel event to its destination location." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .


ex:assaulted a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:assaultedBy ;
    ex:prefLabel "Assaulted" ;
    ex:description "An Assaulted is a relationship that connects a person to the person they physically assaulted." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

ex:assaultedBy a owl:ObjectProperty ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person ;
    owl:inverseOf ex:assaulted ;
    ex:prefLabel "Assaulted By" ;
    ex:description "An 'Assaulted By' is a relationship that connects a person to the person who physically assaulted them." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

ex:assistedBy a owl:ObjectProperty ;
    rdfs:domain ex:Investigation ;
    rdfs:range ex:Person ;
    ex:prefLabel "Assisted By" ;
    ex:description "An 'Assisted By' is a relationship that connects an investigation to a person who provided assistance." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

ex:associatedWith a owl:ObjectProperty ;
    rdfs:domain ex:Organization ;
    rdfs:range ex:Location ;
    ex:prefLabel "Associated With" ;
    ex:description "An 'Associated With' is a relationship that connects an organization to a location or entity with which it is associated." ;
