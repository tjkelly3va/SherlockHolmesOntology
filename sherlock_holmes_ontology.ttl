:deduction_scarlet_holmes_07 a ex:Deduction ;
    ex:prefLabel "Holmes Interprets RACHE as German for Revenge" ;
    ex:description "Holmes recognizes the blood-written word RACHE as the German word for revenge and identifies it as a deliberate red herring planted by a non-German writer." ;
    ex:deductionSequence 7 ;
    ex:deductionSummary "RACHE is a deliberate red herring meaning revenge in German, not an unfinished name" ;
    ex:deductionReasoning "Holmes recognized the word as German for revenge and deduced it was written by a non-German imitator because the letter A was rendered in Gothic style, whereas real Germans write in Latin characters, intended to mislead police toward secret societies." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :racheInscription ;
    ex:confirmedBy :jeffersonHopeConfession ;
