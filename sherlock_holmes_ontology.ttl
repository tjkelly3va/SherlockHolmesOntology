    ex:knows :sherlockHolmes ;
    ex:knows :thaddeusSholto ;
    ex:livesAt :lowerCamberwell ;
    ex:owns :agraPlan ;
    ex:owns :marysPearls ;
    ex:memberOfOntology ex:SherlockOntology ;
