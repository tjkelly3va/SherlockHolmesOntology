# ============================================================================
# NAMESPACE DECLARATIONS
# ============================================================================
#  :   is used for instances of the ontology classes, object properties, and
#      data type properties
#  ex: is used for ontological definitions of classes, object properties, and
#      data type properties

@prefix : <http://example.org/sherlock/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/sherlock#> .

# ============================================================================
# ONTOLOGY DECLARATION
# ============================================================================
# dc:source is used to identify the Sherlock Holmes novel or short story that;
# introduced the statements about the ontological term (or individual) defined
# in this ontology. Additional stories may supplement these statements, so more
# than one source may be associated with a particular term or individual.

ex:SherlockOntology a owl:Ontology ;
    dc:title "Sherlock Holmes Narrative Ontology" ;
    dc:creator "OWL Knowledge Engineer" ;
    dc:description "An ontology extracted from Arthur Conan Doyle's Sherlock Holmes stories." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc ;
    dc:source :berylCoronetDoc ;
    dc:source :blackPeterDoc ;
    dc:source :blanchedSoldierDoc ;
