:georgeCuvier a ex:RealPerson ;
    ex:lastName "Cuvier" ;
    ex:prefLabel "Cuvier" ;
    skos:altLabel "Baron Cuvier" ;
    skos:altLabel "Georges Cuvier" ;
    ex:description "A real historical scientist referenced by Sherlock Holmes. Holmes compared his own deductive method to Cuvier's ability to correctly describe a whole animal by the contemplation of a single bone." ;
    ex:occupation "naturalist, anatomist" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:georgeMeredith a ex:RealPerson ;
    ex:firstName "George" ;
    ex:lastName "Meredith" ;
    ex:prefLabel "George Meredith" ;
    ex:description "Real historical person — Victorian-era English novelist and poet. Mentioned by Holmes at the end of the train journey to Ross: Holmes suggested they talk about George Meredith and leave the case until the morrow." ;
    ex:occupation "novelist, poet" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

