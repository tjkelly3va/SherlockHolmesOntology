:tollerCB a ex:FictionalPerson ;
    ex:lastName "Toller" ;
    ex:prefLabel "Toller" ;
    ex:description """Toller is a manservant and groom at the Copper Beeches. He is a rough, uncouth man with grizzled hair and whiskers, and a perpetual smell of drink. He is frequently quite drunk, yet Mr. Rucastle takes no notice. He is the only person who can handle the mastiff Carlo and is responsible for letting the dog loose every night. Mr. Fowler kept him supplied with drink to facilitate Alice's escape. He was found snoring on the kitchen rug during Holmes's visit.""" ;
    ex:occupation "groom, manservant" ;
    ex:isMarriedTo :mrsTollerCB ;
    ex:employedBy :jephroRucastle ;
    ex:knows :jephroRucastle, :mrFowler, :violetHunter ;
    ex:hasParticipatedIn :escapeOfAliceRucastle ;
    ex:livesAt :copperBeeches ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:tomBellamy a ex:FictionalPerson ;
    ex:firstName "Tom" ;
    ex:lastName "Bellamy" ;
    ex:prefLabel "Tom Bellamy" ;
    skos:altLabel "Mr. Bellamy" ;
    ex:description "Tom Bellamy is a middle-aged man with a flaming red beard who owns all the boats and bathing-cots at Fulworth. Originally a fisherman, he is now a man of some substance. He and his son William run the business together. He is the father of Maud Bellamy and disapproves of McPherson's attentions to her, objecting to his daughter associating with men outside her station. His face was soon as florid as his hair when confronted about the matter." ;
    ex:occupation "Boat and bathing-cot owner; former fisherman" ;
    ex:knows :fitzroyMcPherson, :ianMurdoch ;
    ex:livesAt :theHaven ;
    ex:parentOf :maudBellamy, :williamBellamy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:trelawneyHope a ex:FictionalPerson, ex:Secretary, ex:Noble ;
    ex:lastName "Hope" ;
    ex:prefLabel "Trelawney Hope" ;
    skos:altLabel "The European Secretary" ;
    skos:altLabel "The Right Honourable Trelawney Hope" ;
    skos:altLabel "Mr. Trelawney Hope" ;
    ex:description "The Right Honourable Trelawney Hope, Secretary for European Affairs and the most rising statesman in the country. Dark, clear-cut, and elegant, hardly yet of middle age, endowed with every beauty of body and mind. Pulls nervously at his moustache and fidgets with watch-chain seals. Handsome face distorted by despair at loss of the letter. Impulsive, ardent, keenly sensitive beneath his aristocratic mask. Husband of Lady Hilda, youngest daughter of the Duke of Belminster. Lives at Whitehall Terrace. Keeps the despatch-box key on his watch-chain. His sense of honour is so high he could not forgive a lapse in another." ;
    ex:occupation "Secretary for European Affairs" ;
    ex:livesAt :whitehallTerrace ;
    ex:isMarriedTo :ladyHildaTrelawneyHope ;
    ex:knows :lordBellinger ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:clientOf :sherlockHolmes ;
    ex:owns :despatchBoxSecondStain ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

