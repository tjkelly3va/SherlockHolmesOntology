:jackWoodley a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "Jack" ;
    ex:lastName "Woodley" ;
    ex:prefLabel "Jack Woodley" ;
    skos:altLabel "Mr. Woodley" ;
    skos:altLabel "Roaring Jack Woodley" ;
    ex:description "Coarse, puffy-faced, red-moustached young man with hair plastered down on each side of his forehead. A dangerous ruffian and bully whose name was a holy terror from Kimberley to Johannesburg. Came from South Africa with Carruthers after Ralph Smith's death. Won the card game on the voyage for who would marry Violet. Made odious advances to Violet, seized her after dinner at Chiltern Grange. Was thrown out by Carruthers and knocked Carruthers down. Later conspired with Williamson to abduct and forcibly marry Violet. Was disfigured by Holmes in a boxing match at a country pub. Was shot by Carruthers during the forced marriage but survived. Tried for abduction and assault, sentenced to ten years." ;
    ex:sentenceDuration "ten years" ;
    ex:gender "male" ;
    ex:abducted :violetSmith ;
    ex:hasParticipatedIn :abductionOfVioletSmith ;
    ex:hasParticipatedIn :forcedMarriageOfVioletSmith ;
    ex:hasParticipatedIn :shootingOfWoodley ;
