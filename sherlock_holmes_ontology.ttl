:theMafia a ex:SecretSociety ;
    ex:prefLabel "The Mafia" ;
    ex:description "A secret political society that enforces its decrees by murder. Pietro Venucci was connected to the Mafia. Lestrade theorized the Mafia was behind the murder at Pitt Street." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:theRedCircle a ex:SecretSociety ;
    ex:prefLabel "The Red Circle" ;
    skos:altLabel "Red Circle" ;
    ex:description "The Red Circle is a Neapolitan secret society allied to the old Carbonari. Its oaths and secrets are frightful, and once within its rule no escape is possible. It raises funds by blackmailing rich Italians and threatening violence upon refusal. Giuseppe Gorgiano, known as 'Death', is a prominent leader. Gennaro Lucca was a member, having been initiated by Gorgiano in Naples. Gorgiano established a branch in New York. The society resolved to blow up Tito Castalotte with dynamite after he refused their blackmail and reported them to the police." ;
    ex:locatedIn :naples ;
    ex:locatedIn :newYork ;
    ex:alliedTo :carbonari ;
    ex:hasMember :giuseppeGorgiano ;
    ex:hasMember :gennaroLucca ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

