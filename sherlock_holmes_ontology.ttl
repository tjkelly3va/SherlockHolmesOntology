:godfreyEmsworth a ex:FictionalPerson, ex:Soldier, ex:Victim ;
    ex:firstName "Godfrey" ;
    ex:lastName "Emsworth" ;
    ex:prefLabel "Godfrey Emsworth" ;
    skos:altLabel "Lance-Corporal Emsworth" ;
    skos:altLabel "Mr. Godfrey" ;
    skos:altLabel "Master Godfrey" ;
    ex:description "Godfrey Emsworth is the only son of Colonel Emsworth and Mrs. Emsworth. He served as Lance-Corporal in B Squadron of the Imperial Yeomanry during the Boer War. He was wounded by an elephant gun bullet through his shoulder at the Battle of Buffelsspruit outside Pretoria. After being wounded, he stumbled into a leper hospital near Pretoria and slept in a leper's bed. He was treated at the hospital and then moved to the general hospital at Pretoria. Upon returning home, he developed whitish patches on his skin which he feared was leprosy. He was hidden at Tuxbury Old Park in a detached lodge under the care of Mr. Kent, a surgeon. Sir James Saunders eventually diagnosed his condition as pseudo-leprosy or ichthyosis, a scale-like skin affection that is unsightly but curable and noninfective." ;
    ex:militaryRank "Lance-Corporal" ;
    ex:medicalCondition "ichthyosis (pseudo-leprosy)" ;
    ex:diagnosis "pseudo-leprosy or ichthyosis, a scale-like affection of the skin, unsightly, obstinate, but possibly curable, and certainly noninfective" ;
    ex:childOf :colonelEmsworth ;
    ex:childOf :mrsEmsworth ;
    ex:hasFosterFather :ralphButler ;
    ex:hasNurse :ralphWife ;
    ex:friendOf :jamesDodd ;
    ex:knows :jamesDodd ;
    ex:knows :baldySimpson ;
    ex:knows :andersonSoldier ;
    ex:knows :mrKent ;
    ex:livesAt :tuxburyOldPark ;
    ex:memberOfUnit :bSquadron ;
    ex:treatedBy :mrKent ;
    ex:treatedBy :sirJamesSaunders ;
    ex:treatedBy :leperHospitalSuperintendent ;
    ex:diagnosedBy :sirJamesSaunders ;
    ex:woundedAt :battleOfBuffelsspruit ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

