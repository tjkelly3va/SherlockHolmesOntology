:yorkshire a ex:County ;
    ex:prefLabel "Yorkshire" ;
    ex:description "County in northern England. Location of St. Oliver's School where Stapleton (Vandeleur) ran his private school." ;
    ex:locatedIn :england ;
    ex:locatedIn :unitedKingdom ;
    ex:inRegion :england ;
    ex:inCountry :unitedKingdom ;
