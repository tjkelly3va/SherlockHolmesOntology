:duchessOfHoldernesse a ex:FictionalPerson, ex:Nobleman ;
    ex:firstName "Edith" ;
    ex:prefLabel "Duchess of Holdernesse" ;
    skos:altLabel "Edith" ;
    skos:altLabel "the Duchess" ;
    ex:description "Edith, Duchess of Holdernesse, nee Appledore. Daughter of Sir Charles Appledore. Married the Duke of Holdernesse in 1888. Separated from the Duke by mutual consent, taking up residence in the South of France. Mother of Lord Saltire (Arthur). Her name was used by James Wilder in a forged note to lure Lord Saltire from the Priory School. The Duke agreed to write to her to resume relations after the case was resolved." ;
    ex:isMarriedTo :dukeOfHoldernesse ;
    ex:parentOf :lordSaltire ;
    ex:childOf :sirCharlesAppledore ;
    ex:livesAt :southOfFrance ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:dukeOfHoldernesse a ex:FictionalPerson, ex:Nobleman, ex:Politician ;
    ex:prefLabel "Duke of Holdernesse" ;
    skos:altLabel "His Grace" ;
    skos:altLabel "6th Duke of Holdernesse" ;
    skos:altLabel "Baron Beverley" ;
    skos:altLabel "Earl of Carston" ;
    ex:description "6th Duke of Holdernesse, KG, PC, Baron Beverley, Earl of Carston. Lord Lieutenant of Hallamshire since 1900. Former Lord of the Admiralty (1872) and former Chief Secretary of State. Late Cabinet Minister. Married Edith, daughter of Sir Charles Appledore, in 1888. Owns about two hundred and fifty thousand acres with minerals in Lancashire and Wales. Tall, stately person, scrupulously dressed, drawn thin face, grotesquely curved and long nose, dead pallor, vivid red dwindling beard flowing over white waistcoat with watch-chain. Completely immersed in large public questions, rather inaccessible to ordinary emotions. Father of Lord Saltire (legitimate heir) and James Wilder (illegitimate son). Separated from the Duchess by mutual consent. Offers reward of 5000 pounds for son's whereabouts and 1000 for naming kidnapper. Extremely desirous to avoid public scandal. Pays Holmes 6000 pounds. Referenced in The Adventure of Black Peter as one of Holmes's illustrious clients in whose case Holmes claimed a large reward, a rare occurrence." ;
    ex:honorific "KG, PC, 6th Duke" ;
    ex:occupation "statesman, landowner" ;
    ex:livesAt :holdernesseHall ;
    ex:livesAt :carltonHouseTerrace ;
    ex:livesAt :carstonCastle ;
    ex:isMarriedTo :duchessOfHoldernesse ;
    ex:fatherOf :lordSaltire ;
    ex:fatherOf :jamesWilder ;
    ex:hasSecretary :jamesWilder ;
    ex:owns :holdernesseHall ;
    ex:owns :carstonCastle ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:knows :thorneycroftHuxtable ;
    ex:clientOf :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc  ;
    dc:source :blackPeterDoc .

