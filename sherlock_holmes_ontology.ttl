    ex:prefLabel "Prince of Colonna" ;
    ex:description "An Italian prince from whom the famous black pearl of the Borgias was stolen. The pearl was taken from his bedroom at the Dacre Hotel in London. Its disappearance caused a sensation." ;
    ex:isMarriedTo :princessOfColonna ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:princessOfColonna a ex:FictionalPerson, ex:Princess ;
    ex:prefLabel "Princess of Colonna" ;
    ex:description "Wife of the Prince of Colonna. Her maid was Lucretia Venucci, an Italian woman who came under suspicion in connection with the theft of the black pearl of the Borgias." ;
