:worthingdonBank a ex:Building ;
    ex:prefLabel "Worthingdon Bank" ;
    ex:description "A bank in England that was robbed in 1875 by a gang of five men including Biddle, Hayward, Moffat, Cartwright, and Sutton/Blessington. The caretaker Tobin was murdered during the robbery and seven thousand pounds were stolen." ;
    ex:locatedIn :england ;
    ex:locatedIn :unitedKingdom ;
    ex:inRegion :england ;
    ex:inCountry :unitedKingdom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:yewAlley a ex:Location ;
    ex:prefLabel "Yew Alley" ;
    skos:altLabel "the Alley" ;
    ex:description "Walk at Baskerville Hall consisting of two lines of old yew hedge, twelve feet high and impenetrable, with a strip of grass about six feet broad on either side. A moor-gate at the far end leads to the moor. Sir Charles Baskerville died here on the night of May 4th." ;
    ex:locatedIn :baskervilleHall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:york a ex:City ;
    ex:prefLabel "York" ;
    ex:description "City in Yorkshire. The photograph of Mr. and Mrs. Vandeleur was taken here four years before the Baskerville case." ;
    ex:locatedIn :england ;
    ex:locatedIn :unitedKingdom ;
    ex:locatedIn :yorkshire ;
    ex:inRegion :yorkshire ;
    ex:inCountry :unitedKingdom ;
    ex:memberOfOntology ex:SherlockOntology ;
