    ex:prefLabel "Godfrey Staunton's Wife's Mother" ;
    skos:altLabel "the landlady" ;
    ex:description "London landlady whose daughter Godfrey Staunton married. Godfrey lodged at her establishment about a year before the story and became passionately attached to her daughter. Her name is not given in the text." ;
    ex:occupation "Landlady" ;
    ex:livesAt :london ;
    ex:parentOf :godfreyStauntonWife ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

