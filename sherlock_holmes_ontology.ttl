# ============================================================================
# CORE PROPERTY DEFINITIONS
# ============================================================================

ex:prefLabel a owl:AnnotationProperty ;
    rdfs:subPropertyOf skos:prefLabel ;
    ex:description "A 'Preferred Label' is an annotation providing the human-readable display name for any ontological term or individual." ;
    ex:memberOfOntology ex:SherlockOntology .

ex:description a owl:AnnotationProperty ;
    rdfs:subPropertyOf dc:description ;
    ex:prefLabel "Description" ;
    ex:memberOfOntology ex:SherlockOntology .

ex:memberOfOntology a owl:AnnotationProperty ;
    ex:prefLabel "Member Of Ontology" ;
    ex:description "A 'Member Of Ontology' is an annotation that declares an entity's membership in a specific ontology." .

ex:plotSummary a owl:DatatypeProperty ;
    rdfs:domain schema:CreativeWork ;
    rdfs:range xsd:string ;
    ex:prefLabel "Plot Summary" ;
    ex:description "A 'Plot Summary' is a string providing a concise, objective overview of a story's main events, covering the introduction, central conflict, rising action, climax, and resolution." ;
    ex:memberOfOntology ex:SherlockOntology .

ex:reviewersNotes a owl:DatatypeProperty ;
    rdfs:domain schema:CreativeWork ;
    rdfs:range xsd:string ;
    ex:prefLabel "Reviewer's Notes" ;
    ex:description "'Reviewer's Notes' is a string capturing the reviewer's thoughts and insights that may be described in detail in their critical review of the Sherlock Holmes story." ;
    ex:memberOfOntology ex:SherlockOntology .

ex:reviewDetailed  a owl:DatatypeProperty ;
    rdfs:domain schema:CreativeWork ;
    rdfs:range xsd:string ;
    ex:prefLabel "Review Detailed" ;
    ex:description "'Review Detailed' is a string containing a detailed analysis, evaluation, and interpretation of a Sherlock Holmes novel or short story." ;
    ex:memberOfOntology ex:SherlockOntology .



