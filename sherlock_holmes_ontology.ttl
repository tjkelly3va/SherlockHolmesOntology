    ex:lastName "Wilson" ;
    ex:prefLabel "General Wilson" ;
    skos:altLabel "Wilson" ;
    ex:description "Real historical military figure. Took Delhi during the Indian Mutiny." ;
    ex:gender "male" ;
    ex:rank "General" ;
    ex:memberOfOntology ex:SherlockOntology ;
