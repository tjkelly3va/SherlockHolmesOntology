    ex:isSolved "true" ;
    ex:rewardAmount "6000 pounds" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:marriageDukeHoldernesse a ex:Marriage ;
    ex:prefLabel "Marriage of the Duke and Duchess of Holdernesse" ;
    ex:description "The Duke of Holdernesse married Edith, daughter of Sir Charles Appledore, in 1888. The marriage was not peaceful and ended in a separation by mutual consent." ;
    ex:hasParticipant :dukeOfHoldernesse ;
    ex:hasParticipant :duchessOfHoldernesse ;
    ex:narrativeDate "1888" ;
    ex:memberOfOntology ex:SherlockOntology ;
