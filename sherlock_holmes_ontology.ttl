:josephStangerson a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Joseph" ;
    ex:lastName "Stangerson" ;
    ex:prefLabel "Joseph Stangerson" ;
    skos:altLabel "Stangerson" ;
    ex:description "Joseph Stangerson is the private secretary to Enoch Drebber. American. Quiet, reserved man. Son of Elder Stangerson. As a young Mormon, he shot John Ferrier during the pursuit from Salt Lake City. Competed with young Drebber for Lucy Ferrier's hand. Had four wives. Father had tanning yard and leather factory. Left the Mormon Church with Drebber. Murdered by Jefferson Hope at Halliday's Private Hotel, Little George Street, stabbed in the left side penetrating the heart. RACHE written in blood above the body." ;
    ex:occupation "private secretary" ;
    ex:causeOfDeath "stabbed in left side, penetrating heart" ;
