    ex:occupation "Policeman" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:popesCourtLandlord a ex:FictionalPerson, ex:Accountant ;
    ex:prefLabel "Pope's Court Landlord" ;
    ex:description "An unnamed accountant living on the ground floor of the building at Pope's Court, Fleet Street. When Wilson inquired about the Red-headed League after finding the dissolution notice, this landlord told him the man at No. 4 was named William Morris, a solicitor using the room temporarily, who had moved to 17 King Edward Street. Name not given in text." ;
    ex:occupation "accountant; landlord" ;
    ex:livesAt :7PopesCourt ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:pycroftLandlady a ex:FictionalPerson ;
    ex:prefLabel "Pycroft's Landlady" ;
    ex:description "An unnamed woman who is Hall Pycroft's landlady at 17 Potter's Terrace, Hampstead. She brought Arthur Pinner's visiting card up to Pycroft when he called." ;
    ex:occupation "landlady" ;
    ex:livesAt :17PottersTerrace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:rachelHowells a ex:FictionalPerson, ex:Criminal, ex:Maid ;
    ex:firstName "Rachel" ;
    ex:lastName "Howells" ;
    ex:prefLabel "Rachel Howells" ;
    skos:altLabel "Howells" ;
    ex:description "Second housemaid at Hurlstone Manor House. She is Welsh with an excitable temperament, described as having black eyes. She was engaged to Richard Brunton the butler but was jilted when he took up with Janet Tregellis. She suffered a sharp touch of brain-fever and became a shadow of her former self. After Brunton's disappearance she became hysterical, screaming and sobbing. A nurse was employed to sit with her at night. On the third night after Brunton's disappearance, she escaped through her window, her footprints leading across the lawn to the mere where they vanished. Holmes deduced she had helped Brunton lift the cellar flagstone and then trapped him inside as vengeance, taking the treasure and throwing it into the mere. She was never heard from again; Holmes believed she fled England." ;
    ex:occupation "Second housemaid" ;
    ex:ethnicity "Welsh" ;
    ex:worksAt :hurlstone ;
    ex:employedBy :reginaldMusgrave ;
    ex:formerEngagedTo :richardBrunton ;
    ex:killed :richardBrunton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:rachelHowellsNurse a ex:FictionalPerson ;
    ex:prefLabel "Rachel Howells's Nurse" ;
    ex:description "A nurse employed to sit up with Rachel Howells at night after her mental breakdown following Brunton's disappearance. On the third night, she fell asleep in an armchair and woke to find Rachel gone, the bed empty, and the window open. Her name is not given in the text." ;
    ex:occupation "Nurse" ;
    ex:worksAt :hurlstone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:rearAdmiralBaskerville a ex:FictionalPerson ;
    ex:lastName "Baskerville" ;
    ex:prefLabel "Rear-Admiral Baskerville" ;
    ex:description "Baskerville ancestor depicted in a portrait at the Hall. Served under Rodney in the West Indies. Shown with a telescope in his portrait." ;
    ex:occupation "naval officer, rear-admiral" ;
    ex:memberOf :baskervilleFamily ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:reginaldMusgrave a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Reginald" ;
    ex:lastName "Musgrave" ;
    ex:prefLabel "Reginald Musgrave" ;
    skos:altLabel "Musgrave" ;
    ex:description "A college acquaintance of Sherlock Holmes and client in the Musgrave Ritual case. He is a scion of one of the very oldest families in the kingdom, from a cadet branch that separated from the northern Musgraves in the sixteenth century and established itself in western Sussex. He manages the Hurlstone estate and serves as member of parliament for his district. Described as exceedingly aristocratic in appearance — thin, high-nosed, and large-eyed, with languid yet courtly manners. A bachelor who maintains a large staff of servants. He dressed like a young man of fashion and was always a bit of a dandy. His father died about two years before the case." ;
    ex:occupation "Landowner and Member of Parliament" ;
    ex:maritalStatus "Bachelor" ;
    ex:livesAt :hurlstone ;
    ex:owns :hurlstone ;
    ex:knows :sherlockHolmes ;
    ex:memberOf :musgraveFamily ;
    ex:childOf :reginaldMusgraveFather ;
    ex:descendantOf :sirRalphMusgrave ;
    ex:dismissed :richardBrunton ;
    ex:hasInvestigation :musgraveRitualInvestigation ;
    ex:clientOf :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:reginaldMusgraveFather a ex:FictionalPerson ;
    ex:lastName "Musgrave" ;
    ex:prefLabel "Reginald Musgrave's Father" ;
    ex:description "Father of Reginald Musgrave, who died about two years before the events of the case. He originally hired Richard Brunton as butler when Brunton was a young schoolmaster out of place. His name is not given in the text." ;
    ex:parentOf :reginaldMusgrave ;
    ex:memberOf :musgraveFamily ;
    ex:employs :richardBrunton ;
    ex:livesAt :hurlstone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:reillyLawyer a ex:FictionalPerson ;
    ex:lastName "Reilly" ;
    ex:prefLabel "Reilly (Lawyer)" ;
    skos:altLabel "Reilly" ;
    ex:description "Lawyer engaged by McGinty to defend McMurdo and the others after their arrest for the Stanger beating." ;
    ex:occupation "Lawyer" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:richardBaxter a ex:RealPerson ;
    ex:firstName "Richard" ;
    ex:lastName "Baxter" ;
    ex:prefLabel "Richard Baxter" ;
    skos:altLabel "Baxter" ;
    ex:description "Real historical person referenced at the end of the story when Holmes says he thinks of Baxter's words: 'There, but for the grace of God, goes Sherlock Holmes.' Historically, Richard Baxter was a 17th-century English Puritan church leader, though the quote is more commonly attributed to John Bradford." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:richardBrunton a ex:FictionalPerson, ex:Victim, ex:Criminal ;
    ex:firstName "Richard" ;
    ex:lastName "Brunton" ;
    ex:prefLabel "Richard Brunton" ;
    skos:altLabel "Brunton" ;
    skos:altLabel "butler Brunton" ;
    ex:description "Butler at Hurlstone Manor House who served the Musgrave family for twenty years. He was originally a young schoolmaster out of place when first taken up by Reginald Musgrave's father. Described as a well-grown, handsome man with a splendid forehead, about forty years old. He could speak several languages and play nearly every musical instrument. A widower with a reputation as a Don Juan. He was engaged to Rachel Howells, the second housemaid, but threw her over for Janet Tregellis, daughter of the head game-keeper. He was caught reading the Musgrave Ritual document in the library at night and was dismissed with one week's notice. He disappeared on the third morning and was later found dead in a cellar chamber beneath a flagstone, beside an ancient chest. He had decoded the Ritual's directions and enlisted Rachel Howells to help lift the flagstone, but was trapped inside when the stone fell back, presumably through Rachel's action." ;
    ex:occupation "Butler" ;
    ex:formerOccupation "Schoolmaster" ;
    ex:maritalStatus "Widower" ;
    ex:worksAt :hurlstone ;
    ex:employedBy :reginaldMusgrave ;
    ex:formerEngagedTo :rachelHowells ;
    ex:engagedTo :janetTregellis ;
    ex:dismissedBy :reginaldMusgrave ;
    ex:killedBy :rachelHowells ;
    ex:diedAt :hurlstoneCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:ricoletti a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Ricoletti" ;
    ex:prefLabel "Ricoletti" ;
    skos:altLabel "Ricoletti of the club-foot" ;
    ex:description "A man with a club-foot mentioned by Holmes as the subject of one of his early cases. Described as having an 'abominable wife.' No further details are given in the text." ;
    ex:isMarriedTo :ricolettiWife ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:ricolettiWife a ex:FictionalPerson, ex:Criminal ;
    ex:prefLabel "Ricoletti's Wife" ;
    ex:description "Wife of Ricoletti of the club-foot, described by Holmes as 'abominable.' Subject of one of Holmes's early cases. Her name is not given in the text." ;
    ex:isMarriedTo :ricoletti ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:rodgerBaskerville a ex:FictionalPerson ;
    ex:firstName "Rodger" ;
    ex:lastName "Baskerville" ;
    ex:prefLabel "Rodger Baskerville" ;
    skos:altLabel "Rodger" ;
    ex:description "Youngest of three Baskerville brothers (the elder being Sir Charles, the middle being Henry's father). The black sheep of the family, resembling the portrait of old Hugo. Made England too hot to hold him. Fled to Central America (later specified as South America). Officially reported to have died in 1876 of yellow fever and unmarried. Actually married and had one child: the man who became known as Vandeleur and then Stapleton." ;
    ex:memberOf :baskervilleFamily ;
    ex:parentOf :jackStapleton ;
    ex:siblingOf :charlesBaskerville ;
    ex:siblingOf :henryBaskFather ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:rodgerBaskerville1742 a ex:FictionalPerson ;
    ex:firstName "Rodger" ;
    ex:lastName "Baskerville" ;
    ex:prefLabel "Rodger Baskerville (1742 manuscript)" ;
    ex:description "Son of Hugo Baskerville, mentioned in the 1742 manuscript. The manuscript was addressed to him and his brother John, with instructions to say nothing to their sister Elizabeth." ;
    ex:childOf :hugoBaskerville ;
    ex:memberOf :baskervilleFamily ;
    ex:siblingOf :elizabethBaskerville ;
    ex:siblingOf :johnBaskerville1742 ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:roylottButler a ex:FictionalPerson, ex:Servant, ex:Victim ;
    ex:prefLabel "Roylott's Native Butler" ;
    ex:description "An unnamed native butler in the service of Dr. Grimesby Roylott in India. He was beaten to death by Roylott in a fit of anger caused by robberies in the house. His death led to Roylott's imprisonment." ;
    ex:occupation "Butler" ;
    ex:causeOfDeath "Beaten to death by Dr. Roylott" ;
    ex:employedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
