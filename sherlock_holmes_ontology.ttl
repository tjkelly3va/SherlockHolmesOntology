:signOfTheFourConspiracy a ex:CriminalOrganization ;
    ex:prefLabel "The Sign of the Four" ;
    skos:altLabel "The Four" ;
    ex:description "Criminal pact between Jonathan Small, Abdullah Khan, Mahomet Singh, and Dost Akbar. Formed at the Agra Fort during the Indian Mutiny to murder merchant Achmet and steal a rajah's treasure of jewels and pearls. Sealed by solemn oaths. The four signed charts with 'the sign of the four' which became their calling card left at crime scenes. All four were arrested, tried for murder, and sentenced to penal servitude for life." ;
    ex:hasMember :jonathanSmall ;
    ex:hasMember :abdullahKhan ;
    ex:hasMember :mahometSingh ;
    ex:hasMember :dostAkbar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

