:trevelyanMaid a ex:FictionalPerson, ex:Maid ;
    ex:prefLabel "Trevelyan's maid" ;
    ex:description "A maid employed at Dr. Trevelyan's practice at 403 Brook Street. She brought Blessington his morning tea and discovered his body hanging in his room at about seven o'clock. She also searched for the missing page boy after the murder." ;
    ex:workedAt :403BrookStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
