:deduction_redHeadedLeague_holmes_04 a ex:Deduction ;
    ex:prefLabel "Holmes Deduces Wilson Has Been in China" ;
    ex:description "Holmes deduces that Wilson has spent time in China, which astonishes the pawnbroker who cannot imagine how Holmes could know this." ;
    ex:deductionSequence 4 ;
    ex:deductionSummary "Wilson has been in China." ;
    ex:deductionReasoning "Holmes observed a fish tattoo immediately above Wilson's right wrist with scales stained a delicate pink, a technique peculiar to China according to Holmes's study of tattoo marks. The deduction was further supported by a Chinese coin hanging from Wilson's watch-chain." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :jabezWilson ;
    ex:deductionBasedOn :wilsonChineseCoin ;
