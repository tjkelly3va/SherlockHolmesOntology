    rdfs:subClassOf ex:Church ;
    ex:prefLabel "Abbey" ;
    ex:description "An Abbey is a class representing the building or buildings occupied by a community of monks or nuns." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

ex:Abduction a owl:Class ;
    rdfs:subClassOf ex:Crime ;
    ex:prefLabel "Abduction" ;
