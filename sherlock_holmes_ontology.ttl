:deduction_redHeadedLeague_holmes_05 a ex:Deduction ;
    ex:prefLabel "Holmes Deduces Wilson Has Done Considerable Writing Lately" ;
    ex:description "Holmes completes his initial reading of Wilson by observing that the pawnbroker has recently been doing a great deal of writing, which Wilson confirms relates to his work copying the Encyclopaedia Britannica." ;
    ex:deductionSequence 5 ;
    ex:deductionSummary "Wilson has done a considerable amount of writing lately." ;
    ex:deductionReasoning "Holmes observed that Wilson's right cuff is very shiny for five inches and his left sleeve has a smooth patch near the elbow where he rests it upon the desk, both consistent with prolonged writing at a desk." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :jabezWilson ;
    ex:confirmedBy :jabezWilson ;
    ex:memberOfOntology ex:SherlockOntology ;
