:titoCastalotte a ex:FictionalPerson ;
    ex:firstName "Tito" ;
    ex:lastName "Castalotte" ;
    ex:prefLabel "Tito Castalotte" ;
    skos:altLabel "Signor Castalotte" ;
    ex:description "Tito Castalotte is an Italian gentleman in New York and the senior partner of Castalotte and Zamba, the chief fruit importers of New York employing more than three hundred men. He is a bachelor. He was rescued by Gennaro Lucca from ruffians in the Bowery and became a powerful friend, treating Gennaro like a son and being treated like a father by the Luccas. He refused to yield to Red Circle blackmail threats and handed their notices to the police. The Red Circle resolved to blow up him and his house with dynamite as an example, with Gennaro drawing the lot to carry out the deed. Gennaro instead warned Castalotte of the danger before fleeing to London." ;
    ex:nationality "Italian" ;
    ex:livesAt :newYork ;
    ex:seniorPartnerOf :castalotteAndZamba ;
    ex:knows :gennaroLucca ;
    ex:knows :emiliaLucca ;
    ex:rescuedBy :gennaroLucca ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

