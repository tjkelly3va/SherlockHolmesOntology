:professorCoram a ex:FictionalPerson, ex:Criminal, ex:Academic ;
    ex:firstName "Sergius" ;
    ex:prefLabel "Professor Coram" ;
    skos:altLabel "Sergius" ;
    skos:altLabel "Professor" ;
    ex:description "Elderly invalid living at Yoxley Old Place in Kent under the assumed name Professor Coram. Real first name is Sergius; he is Russian. Gaunt, aquiline face with piercing dark eyes, white hair and beard stained yellow from nicotine. Keeps to bed half the time, hobbles with stick or pushed in bath-chair by gardener. Writing a scholarly work analyzing documents from Coptic monasteries of Syria and Egypt, described as his magnum opus. Smokes specially prepared cigarettes from Ionides of Alexandria, consuming a thousand every fortnight. Former Nihilist revolutionary who betrayed his wife Anna and companions to police to save his own life and earn a reward, leading to executions and Siberian exile. Fled to England with ill-gotten gains. Tried to have Anna's friend Alexis convicted using Anna's diary and letters. Hid Anna behind a secret bookcase in his bedroom after she killed Willoughby Smith. Speaks English with a curious mincing accent." ;
    ex:occupation "professor, scholar" ;
    ex:nationality "Russian" ;
    ex:livesAt :yoxleyOldPlace ;
    ex:employs :willoughbySmith ;
    ex:employs :mrsMarker ;
    ex:employs :susanTarlton ;
    ex:employs :mortimer ;
    ex:isMarriedTo :annaCoram ;
    ex:memberOf :nihilistBrotherhood ;
    ex:participantIn :nihilistBetrayal ;
    ex:participantIn :goldenPinceNezInvestigation ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:railwayCompanyOfficial a ex:FictionalPerson ;
    ex:prefLabel "Railway Company Official at Aldgate" ;
    ex:description "Unnamed courteous red-faced old gentleman who represented the railway company at Aldgate Station. Showed Holmes where the body was found and confirmed the train must have passed about midnight Monday." ;
    ex:occupation "railway company official" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:queenVictoria a ex:RealPerson ;
