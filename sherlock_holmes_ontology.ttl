    ex:occupation "Coal owner" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:andrews a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Andrews" ;
    ex:prefLabel "Andrews" ;
    ex:description "Young assassin from Merton County Lodge. Frank-faced and cheerful, little more than a boy. Total abstainer. Had carried out three commissions. Shot manager Josiah Dunn at Crow Hill mine." ;
    ex:memberOf :eminentOrderOfFreemen, :lodge249Merton ;
