    ex:memberOf :bagatellCardClub ;
    ex:livesAt :427ParkLane ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:roseSpender a ex:FictionalPerson, ex:Victim, ex:Nurse ;
    ex:prefLabel "Rose Spender" ;
    ex:firstName "Rose" ;
    ex:lastName "Spender" ;
    ex:description "Rose Spender is an old nurse claimed by Peters to have been his wife's former nurse. She was an imbecile old woman found in the Brixton Workhouse Infirmary. Peters and Fraser took her from the infirmary under the pretense of charity, brought her to 36 Poultney Square, and she died there of senile decay as certified by Dr. Horsom. She was approximately ninety years old, emaciated, and aged. Her body was placed in an oversized coffin designed to also conceal the living Lady Frances Carfax beneath it." ;
    ex:age "approximately 90" ;
    ex:isDeceased "true"^^xsd:boolean ;
    ex:formerNurseOf :annieFraser ;
    ex:attendedBy :drHorsom ;
    ex:previouslyAt :brixtonWorkhouseInfirmary ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:roundhay a ex:FictionalPerson, ex:Clergyman ;
    ex:lastName "Roundhay" ;
    ex:prefLabel "Mr. Roundhay" ;
    skos:altLabel "Roundhay" ;
    skos:altLabel "the vicar" ;
    ex:description "Vicar of the parish of Tredannick Wollas in Cornwall. A middle-aged, portly, and affable bachelor with a considerable fund of local lore. Something of an archaeologist, through which interest he made Holmes's acquaintance. Lodged Mortimer Tregennis in his large, straggling vicarage. Was in the confidence of Dr. Leon Sterndale and Brenda Tregennis regarding their love affair, and sent the telegram to Sterndale at Plymouth informing him of the tragedy." ;
    ex:occupation "vicar, archaeologist" ;
    ex:livesAt :tredannickWollasVicarage ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:knows :mortimerTregennis ;
    ex:knows :leonSterndale ;
    ex:knows :brendaTregennis ;
    ex:hasRole :cornishHorrorInvestigation ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:samMerton a ex:FictionalPerson, ex:Criminal, ex:Boxer ;
    ex:firstName "Sam" ;
    ex:lastName "Merton" ;
    ex:prefLabel "Sam Merton" ;
    skos:altLabel "Merton" ;
    ex:description "Sam Merton is a prize-fighter and boxer who serves as Count Negretto Sylvius's associate in the theft of the Mazarin Stone. He is described as a heavily built young man with a stupid, obstinate, slab-sided face and a deep raucous voice. Holmes describes him as not a bad fellow but used by the Count, calling him a great big silly bull-headed gudgeon. He waits outside Baker Street while Sylvius visits Holmes and is later brought inside. He suggests they attack Holmes but is overruled by Sylvius. He is arrested along with Sylvius when the police arrive." ;
    ex:occupation "prize-fighter, boxer" ;
    ex:confederateOf :countNegrettoSylvius ;
    ex:arrestedIn :arrestOfSylviusAndMerton ;
    ex:knows :countNegrettoSylvius ;
    ex:hasParticipantIn :theftOfMazarinStone ;
    ex:hasParticipantIn :arrestOfSylviusAndMerton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:sarahCushing a ex:FictionalPerson ;
    ex:firstName "Sarah" ;
    ex:lastName "Cushing" ;
    ex:prefLabel "Sarah Cushing" ;
    skos:altLabel "Miss Sarah Cushing" ;
    ex:description "Second sister, middle sister. Thirty-three when Mary married. Lived with Susan in Croydon, parted 2 months ago. Previously went to Liverpool to be near the Browners. Meddlesome, hard to please. Fell in love with Jim Browner, rejected, turned to hatred. Poisoned Mary's mind against Jim. Fine tall woman, black and quick and fierce, proud. After leaving Jim's house, took a house two streets off and let lodgings to sailors. Couldn't make living in Liverpool, returned to Croydon. Now lives at New Street, Wallington. Extremely ill with brain fever after hearing about the packet." ;
    ex:gender "female" ;
    ex:siblingOf :susanCushing ;
    ex:siblingOf :maryBrowner ;
    ex:livesAt :newStreetWallington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:sarahCushingDoctor a ex:FictionalPerson, ex:Doctor ;
    ex:firstName "Sarah" ;
    ex:lastName "adviser" ;
    ex:prefLabel "Sarah Cushing's medical adviser" ;
    ex:description "Unnamed. Grave young gentleman in black with a very shiny hat. Refuses Holmes and Watson entry to see Sarah. Says she has brain symptoms of great severity." ;
    ex:gender "male" ;
    ex:occupation "medical adviser" ;
    ex:knows :sarahCushing ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:shinwellJohnson a ex:FictionalPerson, ex:Criminal, ex:Informant ;
    ex:firstName "Shinwell" ;
    ex:lastName "Johnson" ;
    ex:prefLabel "Shinwell Johnson" ;
    skos:altLabel "Porky Shinwell" ;
    skos:altLabel "Porky" ;
    skos:altLabel "Johnson" ;
    ex:description """Shinwell Johnson is a huge, coarse, red-faced, scorbutic man with a pair of vivid black eyes which are the only external sign of his very cunning mind. He was formerly a very dangerous villain who served two terms at Parkhurst prison. He repented and allied himself with Holmes during the first years of the twentieth century, acting as Holmes's agent in the huge criminal underworld of London, obtaining vital information. He has the entree of every night-club, doss house, and gambling-den in London due to the glamour of his two convictions. He has quick observation and an active brain. He is an old mate of Kitty Winter and introduces her to Holmes. He helps arrange for Kitty Winter's safety after Holmes is attacked.""" ;
    ex:occupation "criminal informant, Holmes's agent" ;
    ex:agentOf :sherlockHolmes ;
    ex:knows :sherlockHolmes ;
    ex:knows :kittyWinter ;
    ex:knows :johnWatson ;
    ex:prisonedAt :parkhurst ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:sidneyJohnson a ex:FictionalPerson ;
    ex:firstName "Sidney" ;
    ex:lastName "Johnson" ;
    ex:prefLabel "Sidney Johnson" ;
    skos:altLabel "Mr. Sidney Johnson" ;
    ex:description "Senior clerk and draughtsman at Woolwich Arsenal. A man of about forty, married with five children. A thin, gruff, bespectacled man of middle age with haggard cheeks and twitching hands from nervous strain. Silent and morose but with excellent record in public service. Unpopular with colleagues but a hard worker. Has key to the safe only (not the doors). Always the last man to leave the office. Put the plans in the safe himself on Monday. Claims to have been at home Monday evening, corroborated by his wife. Met Holmes at the office and was visibly distressed by the chief's death and the theft." ;
    ex:age "approximately 40" ;
    ex:occupation "senior clerk and draughtsman" ;
    ex:employedBy :woolwichArsenalOrg ;
    ex:isMarriedTo :mrsJohnson ;
    ex:knows :sirJamesWalter ;
    ex:knows :arthurCadoganWest ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

