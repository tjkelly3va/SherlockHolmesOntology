:deduction_redHeadedLeague_holmes_03 a ex:Deduction ;
    ex:prefLabel "Holmes Deduces Wilson Is a Freemason" ;
    ex:description "Holmes identifies Wilson as a Freemason during his initial reading of the client's appearance at 221B Baker Street." ;
    ex:deductionSequence 3 ;
    ex:deductionSummary "Wilson is a Freemason." ;
    ex:deductionReasoning "Holmes observed that Wilson wears an arc-and-compass breastpin, a symbol of the Freemasons, noting that this was worn rather against the strict rules of the order." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :jabezWilson ;
