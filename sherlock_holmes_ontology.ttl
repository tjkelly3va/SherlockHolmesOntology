:victorHatherley a ex:FictionalPerson, ex:Victim, ex:Client, ex:Engineer ;
    ex:firstName "Victor" ;
    ex:lastName "Hatherley" ;
    ex:prefLabel "Victor Hatherley" ;
    skos:altLabel "Mr. Hatherley" ;
    skos:altLabel "the hydraulic engineer" ;
    skos:altLabel "the engineer" ;
    ex:description "A young hydraulic engineer, aged about twenty-five, orphan and bachelor, residing alone in lodgings in London. He served a seven-year apprenticeship at Venner & Matheson in Greenwich, then started his own practice at 16A Victoria Street. After two years of very little business, he was hired by Colonel Lysander Stark for fifty guineas to examine a hydraulic press near Eyford, Berkshire. The press was actually used for counterfeiting. Stark attempted to kill him by crushing him in the press, but he was saved by a woman named Elise who opened a secret panel. During his escape through a window, Stark cut off his thumb with a cleaver. He fainted in the garden and was carried to the roadside near Eyford Station. Watson treated his wound and brought him to Holmes. He had a strong, masculine face, was exceedingly pale from shock, and wore heather tweed." ;
    ex:occupation "hydraulic engineer" ;
    ex:age "approximately 25" ;
    ex:hasPhysicalDescription "Young man of about twenty-five with a strong, masculine face; exceedingly pale; dressed in heather tweed with a soft cloth cap. Missing his right thumb after the attack." ;
    ex:livesAt :16aVictoriaStreet ;
    ex:formerEmployer :vennerAndMatheson ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:knows :lysanderStark ;
    ex:victimOf :hatherleyAttack ;
    ex:rescuedBy :elise ;
    ex:childOf :hatherleyFather ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:victorTrevor a ex:FictionalPerson ;
    ex:firstName "Victor" ;
    ex:lastName "Trevor" ;
    ex:prefLabel "Victor Trevor" ;
    skos:altLabel "Trevor" ;
    skos:altLabel "young Trevor" ;
    ex:description "Holmes's only friend during his two years at college. A hearty, full-blooded fellow, full of spirits and energy, the very opposite of Holmes in most respects. His bull terrier bit Holmes's ankle, leading to their friendship. Son of old Mr. Trevor (James Armitage), a J.P. and landed proprietor at Donnithorpe, Norfolk. Victor was as friendless as Holmes. After Hudson's arrival and his father's death from apoplexy upon receiving a coded letter, Victor was heart-broken and went out to the Terai for tea planting, where Holmes heard he was doing well." ;
    ex:occupation "Tea planter" ;
    ex:childOf :jamesArmitage ;
    ex:knows :sherlockHolmes ;
    ex:livesAt :donnithorpe ;
    ex:livesAt :terai ;
    ex:owns :trevorBullTerrier ;
    ex:friendOf :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:wallenstein a ex:RealPerson ;
    ex:lastName "Wallenstein" ;
    ex:prefLabel "Wallenstein" ;
    ex:description "Wallenstein is a real historical figure whose death at Egria is noted in the Continental Gazetteer. Referenced only as a geographic note about Egria." ;
    ex:memberOfOntology ex:SherlockOntology ;
