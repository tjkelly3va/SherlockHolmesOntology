:enochDrebber a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Enoch" ;
    ex:lastName "Drebber" ;
    ex:prefLabel "Enoch J. Drebber" ;
    skos:altLabel "Drebber" ;
    skos:altLabel "E. J. D." ;
    ex:description "Enoch J. Drebber is an American from Cleveland, Ohio, found murdered at 3 Lauriston Gardens, Brixton Road. About forty-three or forty-four years old, middle-sized, broad-shouldered, with crisp curling black hair and a short stubbly beard. Low forehead, blunt nose, prognathous jaw. Wore broadcloth frock coat, light-coloured trousers, top hat, patent leather boots. Son of Elder Drebber, one of the four principal Mormon Elders. As a young Mormon, competed with young Stangerson for Lucy Ferrier's hand. Forced Lucy into marriage after her father's murder. Coarse, brutish, and a drunkard. Left the Mormon Church as part of a schism, became wealthy. Boarded at Madame Charpentier's, Torquay Terrace, Camberwell. Attempted to abduct Alice Charpentier. Poisoned by Jefferson Hope." ;
    ex:age "about 43-44" ;
    ex:causeOfDeath "poisoned by alkaloid" ;
    ex:nationality "American" ;
    ex:livesAt :charpentiersBoardingHouse ;
    ex:childOf :elderDrebber ;
    ex:isMarriedTo :lucyFerrier ;
    ex:murderedBy :jeffersonHope ;
    ex:knows :josephStangerson ;
    ex:victimOf :murderOfDrebber ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

