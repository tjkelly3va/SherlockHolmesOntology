    ex:firstName "Arthur" ;
    ex:lastName "Doyle" ;
    ex:prefLabel "Arthur Conan Doyle" ;
    ex:description "Arthur Conan Doyle is the author of A Study in Scarlet and the Sherlock Holmes stories." ;
    ex:title "Sir" ;
    ex:memberOfOntology ex:SherlockOntology ;
