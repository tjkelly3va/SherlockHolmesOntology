# ============================================================================
# OBJECTS — Full Individual Definitions
# ============================================================================

:abbeyGrangeBellRope a ex:Object ;
    ex:prefLabel "Abbey Grange Bell-Rope" ;
    skos:altLabel "crimson cord" ;
    skos:altLabel "red cord" ;
    ex:description """A crimson/red cord bell-rope in the dining room of Abbey Grange. Captain Croker climbed to the mantelpiece, used the wooden bracket to reach it, and cut it with his knife (fraying the visible end to disguise the cut). Used to tie Lady Brackenstall to the oaken chair as part of the burglary cover story. Holmes's examination revealed the rope was cut cleanly at the top (not frayed), proving someone had climbed up and cut it rather than pulling it down.""" ;
    ex:locatedIn :abbeyGrangeDiningRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeOakenChair a ex:Furniture ;
    ex:prefLabel "Abbey Grange Oaken Chair" ;
    ex:description """A heavy oaken chair with arms and cross-bars at the bottom, standing at the head of the dining-room table at Abbey Grange. Lady Brackenstall was tied to it by Croker using the bell-rope cord woven through the open woodwork. Blood found on the seat proved she was placed in the chair after the murder, not during it.""" ;
    ex:locatedIn :abbeyGrangeDiningRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangePoker a ex:Weapon ;
    ex:prefLabel "Abbey Grange Poker" ;
    ex:description """A heavy poker from the fireplace grate of the Abbey Grange dining room. Used by Captain Croker to kill Sir Eustace Brackenstall. Bent into a curve by the force of the blow. Found beside Sir Eustace's body.""" ;
    ex:locatedIn :abbeyGrangeDiningRoom ;
    ex:usedAsWeapon :murderOfEustaceBrackenstall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeSilverPlate a ex:Object ;
    ex:prefLabel "Abbey Grange Silver Plate" ;
    ex:description """Half a dozen articles of silver plate from the sideboard at Abbey Grange. Taken by Captain Croker as part of the staged burglary, then dumped into the frozen pond in the park. Recovered by Hopkins on Holmes's hint.""" ;
    ex:locatedIn :abbeyGrangePond ;
    ex:ownedBy :eustaceBrackenstall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeStolenSilver a ex:Evidence ;
    ex:prefLabel "Stolen Silver Plate from Abbey Grange" ;
    ex:description "Half-dozen articles of silver plate taken from the sideboard in the Abbey Grange dining room by Captain Croker as part of the staged burglary. He dropped the silver into the frozen park pond through a hole in the ice left for a solitary swan. Found by Inspector Hopkins after Holmes suggested he examine the pond." ;
    ex:locatedAt :abbeyGrange ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeTigerSkinRug a ex:Object ;
    ex:prefLabel "Tiger-Skin Hearthrug" ;
    ex:description """A tiger-skin hearthrug in front of the fireplace in the Abbey Grange dining room. Sir Eustace Brackenstall's body was found lying upon it.""" ;
    ex:locatedIn :abbeyGrangeDiningRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeWineBottle a ex:Beverage ;
    ex:prefLabel "Wine Bottle" ;
    ex:description """A bottle of vintage wine from the sideboard of the Abbey Grange dining room. Two-thirds full, with a long deeply-stained cork. Holmes noted it was opened with a pocket-screw (about an inch and a half long, driven in three times) rather than the large corkscrew found in the drawer, indicating a pocket knife was used.""" ;
    ex:locatedIn :abbeyGrangeDiningRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeWineGlasses a ex:Object ;
    ex:prefLabel "Three Wine Glasses" ;
    ex:description """Three wine glasses on the sideboard in the Abbey Grange dining room, grouped together and tinged with wine. One contained dregs of bees-wing. Key clue: Holmes deduced that only two glasses were actually used and the dregs were poured into a third to simulate three drinkers, proving the Randall gang story was fabricated.""" ;
    ex:locatedIn :abbeyGrangeDiningRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:adairCardSheet a ex:Document ;
    ex:prefLabel "Adair's card accounting sheet" ;
    ex:description "Sheet of paper found on Ronald Adair's table with names of club friends and figures opposite them, from which it was conjectured he was working out card losses or winnings before his death." ;
    ex:ownedBy :ronaldAdair ;
    ex:locatedIn :427ParkLane ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:adairMoneyPiles a ex:Object ;
    ex:prefLabel "Adair's money piles" ;
    ex:description "Two bank-notes for ten pounds each and seventeen pounds ten in silver and gold, arranged in little piles of varying amount on Ronald Adair's table at the time of his death." ;
    ex:locatedIn :427ParkLane ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:agonyColumnBook a ex:Document ;
    ex:prefLabel "Agony Column Book" ;
    ex:description "A great book in which Sherlock Holmes files the agony columns of the various London journals day by day. He uses it to search for coded messages related to Mrs. Warren's mysterious lodger." ;
    ex:locatedIn :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:aliceRucastleHair a ex:FictionalObject ;
    ex:prefLabel "Alice Rucastle's hair" ;
    skos:altLabel "coil of hair" ;
    ex:description """A coil of hair found by Violet Hunter in a locked drawer of an old chest of drawers in her room at the Copper Beeches. It was of the same peculiar chestnut tint and the same thickness as Violet's own hair. It had been cut from Alice Rucastle during her illness with brain-fever. Its discovery was a key clue indicating that Violet had been hired to impersonate Alice.""" ;
    ex:ownedBy :aliceRucastle ;
    ex:locatedIn :copperBeeches ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:altamontTelegram a ex:Object, ex:Document, ex:Telegram ;
    ex:prefLabel "Altamont's Telegram" ;
    ex:description "Telegram sent from Portsmouth at midday reading: 'Will come without fail to-night and bring new sparking plugs. --Altamont.' In Von Bork's code, sparking plugs meant naval signals, radiator meant battleship, and oil pump meant cruiser." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:amberleyDeedBox a ex:Object ;
    ex:prefLabel "Amberley's Deed-Box" ;
    ex:description "A deed-box belonging to Josiah Amberley kept in his strong-room. Supposedly taken by Mrs. Amberley and Dr. Ernest when they eloped, containing approximately seven thousand pounds' worth of cash and securities. In reality the securities were hidden by Amberley himself as part of his scheme to disguise the murders as an elopement." ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:amberleyStrongRoom a ex:Object ;
    ex:prefLabel "Amberley's Strong-Room" ;
    skos:altLabel "the strong-room" ;
    skos:altLabel "the death-chamber" ;
    ex:description "A room in The Haven with an iron door and shutter, described as like a bank and claimed to be burglar-proof. Josiah Amberley used it as a gas chamber to murder his wife and Dr. Ernest. The room contained a concealed gas pipe ending in a plaster rose in the ceiling. The walls bore the dying message 'We we--' written by Dr. Ernest. The room was hermetically sealed when the door and shutter were closed." ;
    ex:locatedIn :theHavenLewisham ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:amberleyVisitingCard a ex:Document ;
    ex:prefLabel "Amberley's Visiting Card" ;
    ex:description "A rather soiled card belonging to Josiah Amberley, taken by Holmes from the table. Identified Amberley as the client." ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:annaDiaryAndLetters a ex:Document ;
    ex:prefLabel "Anna's Diary and Letters" ;
    skos:altLabel "the packet" ;
    ex:description "A diary kept by Anna documenting her feelings towards Alexis and the views each member of the Nihilist group had taken, plus letters written by Alexis dissuading the group from violence. These documents could prove Alexis's innocence and procure his release from the Siberian salt mine if sent to the Russian Government. Kept by Sergius (Professor Coram) in the locked bureau cupboard. Anna recovered them during her break-in. She entrusted the packet to Holmes and Watson to deliver to the Russian Embassy." ;
    ex:ownedBy :annaCoram ;
    ex:locatedIn :coramBureau ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:annaPoison a ex:Object ;
    ex:prefLabel "Anna's Poison Phial" ;
    ex:description "A small phial of poison taken by Anna before she left her hiding place behind the bookcase. Holmes bounded across the room and wrenched it from her hand, but it was too late. She sank back on the bed and died." ;
    ex:ownedBy :annaCoram ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:anonymousLetterToMary a ex:Document ;
    ex:prefLabel "Anonymous Letter to Mary Morstan" ;
    ex:description "Letter received by Mary Morstan on the morning of the case. Postmarked London S.W., dated July 7. Written on best quality paper, sixpence-a-packet envelopes. Instructed her to be at the third pillar from the left outside the Lyceum Theatre at seven o'clock, to bring two friends but no police. Promised justice for a wronged woman. Written by Thaddeus Sholto." ;
    ex:sentTo :maryMorstan ;
    ex:authoredBy :thaddeusSholto ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:anthropologicalJournal a ex:Journal ;
    ex:prefLabel "Anthropological Journal" ;
    ex:description "Journal. Contains two short monographs by Holmes on the human ear, published last year." ;
    ex:hasAuthor :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:armstrongBrougham a ex:Vehicle ;
    ex:prefLabel "Dr. Armstrong's Brougham" ;
    ex:description "A brougham pulled by a pair of grey horses, used by Dr. Armstrong for his daily journeys from Cambridge to the cottage near Trumpington. Has a window at the back which allowed Armstrong to detect Holmes following him. Armstrong used an elaborate detour through side roads to prevent being tracked." ;
    ex:ownedBy :leslieArmstrong ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:armstrongNote a ex:Letter ;
    ex:prefLabel "Dr. Armstrong's Note to Holmes" ;
    ex:description "Note delivered to Holmes at the inn the morning after his failed bicycle pursuit. Armstrong warned Holmes that following him was futile, that his brougham had a rear window, and advised Holmes to return to London." ;
    ex:receivedBy :sherlockHolmes ;
    ex:sentBy :leslieArmstrong ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:armstrongReceiptedBill a ex:Document ;
    ex:prefLabel "Receipted Bill for Thirteen Guineas" ;
    ex:description "A receipted bill for thirteen guineas paid by Godfrey Staunton last month to Dr. Leslie Armstrong of Cambridge. Found by Holmes among Staunton's papers at Bentley's Hotel. Holmes used it to confront Dr. Armstrong about his relationship with Staunton." ;
    ex:discoveredBy :sherlockHolmes ;
    ex:locatedAt :bentleysHotel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:attackSticks a ex:Weapon ;
    ex:prefLabel "Attack Sticks" ;
    skos:altLabel "sticks" ;
    skos:altLabel "cudgels" ;
    ex:description """Sticks used by two respectably dressed men to attack Sherlock Holmes in Regent Street outside the Cafe Royal. Holmes notes he is a single-stick expert and took most blows on his guard, but the second man was too much for him.""" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:attackNewspaper a ex:Document ;
    ex:prefLabel "Evening Paper (Attack Report)" ;
    ex:description """An evening newspaper with a placard reading 'Murderous Attack Upon Sherlock Holmes' displayed by a one-legged news-vender between the Grand Hotel and Charing Cross Station. Contains a report of the attack on Holmes in Regent Street.""" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:autographLetter a ex:Letter ;
    ex:prefLabel "Autograph Letter from French President" ;
    ex:description "An autograph letter of thanks sent by the French President to Sherlock Holmes for the tracking and arrest of Huret the Boulevard assassin in 1894." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:avengerPhotograph a ex:FictionalObject, ex:Photograph ;
    ex:prefLabel "Photograph of Milverton's Avenger" ;
    ex:description "A photograph displayed in a shop window near Regent Circus showing a regal and stately lady in Court dress with a high diamond tiara on her noble head. Features a delicately-curved nose, marked eyebrows, straight mouth, and strong little chin. Beneath it is 'the time-honoured title of the great nobleman and statesman whose wife she had been'. Holmes identifies her as the woman who killed Milverton." ;
    ex:locatedIn :photographShop ;
    ex:depicts :milvertonAvenger ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:avengerRevolver a ex:FictionalObject, ex:Firearm ;
    ex:prefLabel "Avenger's Revolver" ;
    ex:description "A little, gleaming revolver drawn by the unnamed woman who murders Milverton. She empties barrel after barrel into Milverton's body at close range, the muzzle within two feet of his shirt front." ;
    ex:ownedBy :milvertonAvenger ;
    ex:usedIn :murderOfMilverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:bannistersKey a ex:Object ;
    ex:prefLabel "Bannister's Key" ;
    ex:description "The duplicate key to Soames's rooms, belonging to his servant Bannister. The only duplicate that existed. Bannister accidentally left it in the outer door when he came to check if Soames wanted tea. This enabled the intruder to enter the room. Holmes notes this carelessness was the enabling factor of the crime." ;
    ex:ownedBy :bannisterServant ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:bassRock a ex:Vessel ;
    ex:prefLabel "Bass Rock" ;
    ex:description """A new ship of the Adelaide-Southampton shipping line. Captain Jack Croker was to take charge of her, sailing in two days' time from Southampton.""" ;
    ex:operatedBy :adelaideSouthamptonLine ;
    ex:captainedBy :jackCroker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:beardedManNote a ex:Letter ;
    ex:prefLabel "Note Delivered to Godfrey Staunton" ;
    ex:description "A note brought to Godfrey Staunton at Bentley's Hotel at half-past ten at night by a rough-looking bearded man (later revealed to be his father-in-law). The note caused Godfrey to fall back in his chair as if pole-axed. After reading it, he went downstairs and left with the messenger, disappearing into the night toward the Strand." ;
    ex:receivedBy :godfreyStaunton ;
    ex:deliveredBy :stauntonWifeFather ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:beatriceSpaniel a ex:Animal ;
    ex:prefLabel "Lady Beatrice's Spaniel" ;
    ex:description "A black Shoscombe breed spaniel belonging to Lady Beatrice Falder, loved by her as if it were her child. The dog howled outside the old well-house where Lady Beatrice's body was first hidden. Sir Robert, in a tantrum, had Sandy Bain take the dog to Josiah Barnes at the Green Dragon. Holmes borrows the spaniel and releases it near Lady Beatrice's carriage as a test; the dog initially greets the carriage joyously but then reacts with furious rage upon recognizing a stranger, confirming the impersonation." ;
    ex:ownedBy :beatriceFalder ;
    ex:locatedIn :greenDragon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:beecherPortrait a ex:Portrait ;
    ex:prefLabel "Portrait of Henry Ward Beecher" ;
    ex:description "Unframed portrait standing on top of Watson's books at 221B. Watson contemplates it." ;
    ex:ownedBy :johnWatson ;
    ex:locatedIn :221bBakerStreet ;
    ex:depictsSubject :henryWardBeecher ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:bennettDiary a ex:FictionalObject, ex:Document ;
    ex:prefLabel "Bennett's Diary" ;
    skos:altLabel "Bennett's notebook" ;
    ex:description "A little diary book carried by Trevor Bennett in his pocket. It records dates of Professor Presbury's abnormal incidents: July 2nd (box incident and first Roy attack), July 11th (second Roy attack), July 20th (third Roy attack), August 26th, September 3rd, 4th, and 5th. Holmes borrowed it to check dates and discovered the nine-day cycle pattern." ;
    ex:ownedBy :trevorBennett ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:beppoDarkLantern a ex:Lantern ;
    ex:prefLabel "Beppo's Dark Lantern" ;
    ex:description "A dark lantern used by Beppo inside Josiah Brown's house during the Chiswick break-in. Its flash was seen through the blinds by Holmes, Watson, and Lestrade as Beppo searched for the bust." ;
    ex:ownedBy :beppo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:beppoPhotograph a ex:Photograph ;
    ex:prefLabel "Photograph of Beppo" ;
    ex:description "A snapshot photograph taken with a small camera, found in Pietro Venucci's pocket. Shows an alert, sharp-featured simian man with thick eyebrows and a peculiar projection of the lower part of the face like the muzzle of a baboon. Used to identify Beppo. Pietro carried it as a means of tracing Beppo through third persons." ;
    ex:depictsEntity :beppo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:beppoSheathKnife a ex:Knife ;
    ex:prefLabel "Beppo's Sheath Knife" ;
    ex:description "A long sheath knife found on Beppo when he was arrested at Chiswick. The handle bore copious traces of recent blood, linking him to Pietro Venucci's murder." ;
    ex:ownedBy :beppo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:binomialTheoremTreatise a ex:FictionalObject, ex:Treatise ;
    ex:prefLabel "Treatise upon the Binomial Theorem" ;
    ex:description "A mathematical treatise written by Professor Moriarty at the age of twenty-one. It had a European vogue and on the strength of it he won the Mathematical Chair at one of the smaller universities." ;
    ex:authoredBy :professorMoriarty ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:birdBow a ex:FictionalObject, ex:Weapon ;
    ex:prefLabel "Bird-Bow" ;
    skos:altLabel "small bird-bow" ;
    ex:description "A small bird-bow among the South American weapons collection at Cheeseman's. It has an empty quiver beside it, the arrows having been removed by Jack Ferguson to poison the baby. The arrows were dipped in curare or another deadly drug. Holmes identifies the empty quiver as key evidence confirming his theory." ;
    ex:locatedAt :cheesemansMainRoom ;
    ex:partOf :southAmericanWeapons ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:birdBowAndQuiver a ex:FictionalObject, ex:Weapon ;
    ex:prefLabel "Bird-Bow and Quiver" ;
    ex:description "A small bird-bow with a quiver, part of the South American weapons collection at Cheeseman's. The arrows were dipped in curare or similar poison. Jack Ferguson used one of these arrows to prick the baby, and the empty quiver beside the bow alerts Holmes to the means of poisoning. Holmes notes that if a child were pricked with one of these arrows, death would follow unless the venom were sucked out." ;
    ex:partOf :southAmericanWeaponsCollection ;
    ex:locatedAt :cheesemans ;
    ex:usedBy :jackFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:blackClayPellets a ex:Object ;
    ex:prefLabel "Black Clay Pellets" ;
    skos:altLabel "black dough" ;
    skos:altLabel "clay pyramids" ;
    ex:description "Three small pyramids of black, putty-like or doughy clay with specks of sawdust or tan in them. Two were found in Soames's rooms — one on the central table (roughly pyramidal and hollowed out) and one on the bedroom floor. Holmes collected a third specimen from the jumping pit at the athletic grounds the next morning, proving the clay's origin. The clay came from the spikes on Gilchrist's jumping shoes." ;
    ex:relatedTo :fortescueExamTampering ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:blackKidGlove a ex:Glove ;
    ex:prefLabel "Black Kid Glove" ;
    ex:description "A black kid glove found near Giuseppe Gorgiano's body at the murder scene in the Howe Street flats." ;
    ex:locatedIn :howeStreetFlats ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:blackPearlOfBorgias a ex:Pearl ;
    ex:prefLabel "Black Pearl of the Borgias" ;
    skos:altLabel "the famous black pearl of the Borgias" ;
    skos:altLabel "the Borgia pearl" ;
    ex:description "The most famous pearl existing in the world at the time. Stolen from the Prince of Colonna's bedroom at the Dacre Hotel. Its disappearance caused a sensation and the London police failed to recover it. Beppo concealed it in a wet plaster Napoleon bust at Gelder & Co. before his arrest. Found by Holmes when he smashed the sixth and final bust at 221B Baker Street." ;
    ex:stolenFrom :princeOfColonna ;
    ex:hiddenIn :sixNapoleonBusts ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:blackPeterHarpoon a ex:Object, ex:Weapon ;
    ex:prefLabel "Black Peter murder harpoon" ;
    skos:altLabel "the harpoon" ;
    ex:description "A steel harpoon that was the murder weapon in the death of Captain Peter Carey. Snatched from a rack on the cabin wall where three harpoons hung; two others remained. Engraved 'S.S. Sea Unicorn, Dundee' on the stock. Driven through Carey's broad breast with such violence that it sank deep into the wood of the wall behind him, pinning him like a beetle on a card. Patrick Cairns used it in self-defense when Carey attacked him with a clasp-knife." ;
    ex:locatedIn :peterCareyCabin ;
    ex:usedBy :patrickCairns ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:blackSilkMasks a ex:FictionalObject, ex:Clothing ;
    ex:prefLabel "Black Silk Masks" ;
    skos:altLabel "face-coverings" ;
    ex:description "Two masks made by Watson from black silk for the burglary of Appledore Towers. Described as turning Holmes and Watson into 'two of the most truculent figures in London'." ;
    ex:createdBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:blottingPad a ex:Object ;
    ex:prefLabel "Blotting Pad" ;
    ex:description "A blotting pad in Godfrey Staunton's room at Bentley's Hotel. Holmes tore off a strip to recover the impression of Staunton's telegram, which read backwards: 'Stand by us for God's sake!'" ;
    ex:locatedAt :bentleysHotel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:blottingPadImpression a ex:Evidence ;
    ex:prefLabel "Blotting-Pad Impression" ;
    ex:description "Impression found by Holmes on a blotting-pad in Godfrey Staunton's room at Bentley's Hotel. Written with a broad-pointed quill pen, the reversed impression revealed the tail end of the telegram Staunton had dispatched, reading 'Stand by us for God's sake!' This proved someone else was involved in Staunton's troubles." ;
    ex:locatedAt :bentleysHotel ;
    ex:discoveredBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:bonfireAnimalBones a ex:Object ;
    ex:prefLabel "Animal Bones from Bonfire" ;
    ex:description "Charred organic remains found in the timber-yard bonfire, initially believed to be the remains of Jonas Oldacre. Later determined to be animal bones, planted by Oldacre as part of his faked murder scheme." ;
    ex:locatedIn :oldacreTimberYard ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:brackenstallBlackthornCudgel a ex:Weapon ;
    ex:prefLabel "Sir Eustace's Blackthorn Cudgel" ;
    skos:altLabel "blackthorn stick" ;
    ex:description "Sir Eustace Brackenstall's favourite blackthorn cudgel. He carried it when he rushed into the dining room to confront Captain Croker. Used it to strike Lady Brackenstall across the face, giving her a hideous plum-coloured swelling over one eye. Also struck Croker on the arm. Found lying across Sir Eustace's clenched hands after his death." ;
    ex:ownedBy :eustaceBrackenstall ;
    ex:locatedAt :abbeyGrangeDiningRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:brendaTregennisPhotograph a ex:Photograph ;
    ex:prefLabel "Photograph of Brenda Tregennis" ;
    ex:description "A photograph showing the bust and face of Brenda Tregennis, described as a very beautiful woman. Carried in Dr. Leon Sterndale's breast-pocket. He produced it during his confrontation with Holmes as evidence of his motive for killing Mortimer Tregennis, saying 'That is why I have done it.'" ;
    ex:ownedBy :leonSterndale ;
    ex:depictsEntity :brendaTregennis ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:britishBirdsBook a ex:Document ;
    ex:prefLabel "British Birds" ;
    ex:description "Book offered for sale by Holmes in his book-collector disguise to Watson." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:brownerBoat a ex:RowingBoat ;
    ex:prefLabel "Browner's hired boat" ;
    ex:description "Rowing boat hired by Jim Browner to pursue Fairbairn and Mary at New Brighton." ;
    ex:locatedIn :newBrighton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:brownerConfession a ex:Document ;
    ex:prefLabel "Browner's confession document" ;
    ex:description "Statement made before Inspector Montgomery at Shadwell Police Station. Taken down by shorthand man. Three typewritten copies made. One enclosed in Lestrade's letter to Holmes." ;
    ex:locatedIn :shadwellPoliceStation ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:brownPaperParcel a ex:Object ;
    ex:prefLabel "Brown Paper Parcel" ;
    ex:description "A small brown-paper parcel carried by Holmes in his Altamont disguise, supposedly containing the naval signals but actually containing the Practical Handbook of Bee Culture. Wrapped in string and two wrappers of paper." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:brownPaperWrapper a ex:Object ;
    ex:prefLabel "Brown paper wrapper" ;
    ex:description "Wrapping of the parcel. Distinct smell of coffee. Address printed in straggling characters: 'Miss S. Cushing, Cross Street, Croydon'. Broad-pointed pen (probably a J). Inferior ink. Croydon originally spelled with 'i'." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:burglaryTools a ex:Object ;
    ex:prefLabel "Holmes's Burglary Tools" ;
    ex:description "Set of tools requested by Holmes via note to Watson: a jemmy, a dark lantern, a chisel, and a revolver. Watson carried them discreetly in his overcoat to Goldini's Restaurant and they were used to break into Oberstein's house at 13 Caulfield Gardens." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:brucePartingtonPlans a ex:Document ;
    ex:prefLabel "Bruce-Partington Plans" ;
    skos:altLabel "the Bruce-Partington submarine plans" ;
    skos:altLabel "the plans" ;
    ex:description "Plans for the Bruce-Partington submarine. The most jealously guarded of all government secrets. Comprising some thirty separate patents, each essential to the working of the whole. Naval warfare becomes impossible within the radius of a Bruce-Partington's operation. A very large sum was smuggled through the Estimates two years prior to acquire monopoly of the invention. Kept in an elaborate safe in a confidential office adjoining the Woolwich Arsenal. Ten papers were stolen on Monday night by Colonel Valentine Walter and taken to Hugo Oberstein. Seven were found in Cadogan West's pocket; three most essential were kept by Oberstein. The double valves with automatic self-adjusting slots drawn in one returned paper were key to construction. Eventually recovered from Oberstein's trunk after his capture." ;
    ex:stolenBy :colonelValentineWalter ;
    ex:locatedIn :submarineDepartmentOffice ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:burglingKit a ex:FictionalObject, ex:Tool ;
    ex:prefLabel "Holmes's Burgling Kit" ;
    skos:altLabel "burgling kit" ;
    ex:description "A neat little leather case containing Holmes's burglary tools: a nickel-plated jemmy, a diamond-tipped glass-cutter, adaptable keys, skeleton keys, two drills, a dark lantern, and other modern improvements. Described as 'a first-class, up-to-date burgling kit'. Holmes uses it to crack Milverton's safe." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:bustOfAthene a ex:FictionalObject, ex:Statue ;
    ex:prefLabel "Bust of Athene" ;
    ex:description "A marble bust of the Greek goddess Athene sitting on top of the bookcase in Milverton's study at Appledore Towers." ;
    ex:locatedIn :milvertonStudy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:bustTransferDocument a ex:Document ;
    ex:prefLabel "Bust Transfer Document" ;
    ex:description "A paper prepared by Holmes and signed by Mr. Sandeford in the presence of witnesses, transferring all possible rights in the sixth Napoleon bust to Holmes. Holmes paid ten pounds for it." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:cabAdvertisement a ex:Advertisement ;
    ex:prefLabel "Cab Advertisement" ;
    ex:description "A newspaper advertisement placed by Holmes in every London evening paper, sent by telegram from Woking station. Offered a £10 reward for the number of the cab which dropped a fare at or about the door of the Foreign Office in Charles Street at quarter to ten on the evening of May 23rd. Replies directed to 221B Baker Street. No answer was received." ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:cadoganWestCheckBook a ex:Document ;
    ex:prefLabel "Cadogan West's Check-Book" ;
    ex:description "Check-book on the Woolwich branch of the Capital and Counties Bank. Found on Cadogan West's body. Used to establish his identity." ;
    ex:ownedBy :arthurCadoganWest ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:cairnsTobaccoPouch a ex:Object ;
    ex:prefLabel "Tobacco pouch (P.C.)" ;
    skos:altLabel "seal-skin tobacco pouch" ;
    skos:altLabel "baccy-pouch" ;
    ex:description "A tobacco pouch of coarse seal-skin (straight-haired skin) with a leather thong to bind it. Initials P.C. on the flap, containing half an ounce of strong ship's tobacco. Found on the table in Peter Carey's cabin. Initially assumed to belong to Peter Carey due to the matching initials, but Holmes deduced it belonged to the murderer (Patrick Cairns) since Carey seldom smoked and no pipe was found. Cairns confirmed he left it behind by accident." ;
    ex:locatedIn :peterCareyCabin ;
    ex:ownedBy :patrickCairns ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:cardboardBoxEars a ex:BodyOfEvidence ;
    ex:prefLabel "Cardboard box" ;
    ex:description "Yellow, half-pound honeydew tobacco box. Contained two severed human ears embedded in coarse salt. Two thumb marks at left bottom corner. Central object of the case." ;
    ex:postedFrom :belfast ;
    ex:sentTo :susanCushing ;
    ex:locatedIn :crossStreetCroydon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:careyClaspKnife a ex:Object, ex:Weapon ;
    ex:prefLabel "Peter Carey's clasp-knife" ;
    skos:altLabel "great clasp-knife" ;
    ex:description "A great clasp-knife that Peter Carey pulled on Patrick Cairns during their confrontation on the night of the murder. Carey did not have time to draw it from the sheath before Cairns drove the harpoon through him." ;
    ex:ownedBy :peterCarey ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:careyMapsAndCharts a ex:Object, ex:Document ;
    ex:prefLabel "Maps and charts" ;
    ex:description "Maps and charts kept in Peter Carey's cabin at Woodman's Lee, consistent with the nautical furnishing of the room." ;
    ex:locatedIn :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:careyRumBottle a ex:Object ;
    ex:prefLabel "Rum bottle and glasses" ;
    ex:description "A bottle of rum and two dirty glasses found on the table in Peter Carey's cabin. Evidence that Carey had been drinking with his murderer on the night of the crime." ;
    ex:locatedIn :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:careySeaChest a ex:Object ;
    ex:prefLabel "Peter Carey's sea-chest" ;
    skos:altLabel "sea-chest" ;
    ex:description "A sea-chest in Peter Carey's cabin. A tantalus containing brandy and whisky stood upon it." ;
    ex:locatedIn :peterCareyCabin ;
    ex:ownedBy :peterCarey ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:careySheathKnife a ex:Object, ex:Weapon ;
    ex:prefLabel "Peter Carey's sheath-knife" ;
    skos:altLabel "sheath-knife" ;
    ex:description "A sheath-knife, still in its sheath, found at the feet of the dead man Peter Carey. Identified by Mrs. Carey as her husband's property." ;
    ex:locatedIn :peterCareyCabin ;
    ex:ownedBy :peterCarey ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:careyTantalus a ex:Object ;
    ex:prefLabel "Tantalus" ;
    ex:description "A tantalus containing brandy and whisky, standing on the sea-chest in Peter Carey's cabin. The decanters were full, indicating the spirits had not been used, which Holmes noted as significant — suggesting the visitor preferred rum over finer spirits." ;
    ex:locatedIn :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:carlo a ex:FictionalObject, ex:Animal ;
    ex:prefLabel "Carlo" ;
    ex:description "Carlo is the Ferguson family's spaniel dog at Cheeseman's. He lies in a basket in the corner of the central room. His hind legs move irregularly, his tail drags on the ground, and he walks with difficulty due to paralysis. A veterinarian diagnosed the condition as spinal meningitis, but it was caused by Jack Ferguson testing curare poison on the dog. The onset was sudden, occurring in a single night approximately four months before the story. The condition is slowly passing and Carlo is improving. He licks Ferguson's hand and responds to discussion about his case." ;
    ex:locatedAt :cheesemans ;
    ex:ownedBy :robertFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:carloMastiff a ex:FictionalObject, ex:Animal ;
    ex:prefLabel "Carlo (Rucastle's mastiff)" ;
    skos:altLabel "Carlo" ;
    ex:description """Carlo is the mastiff guard dog at the Copper Beeches, owned by Jephro Rucastle. He is a giant dog, as large as a calf, tawny tinted, with hanging jowl, black muzzle, and huge projecting bones. He is kept in an outhouse near the kitchen door, fed only once a day and not too much then, to keep him aggressive. Only Toller can handle him, and Toller lets him loose every night. Rucastle warns that it is as much as one's life is worth to set foot outside at night. Carlo attacked and horribly mangled Jephro Rucastle when someone loosed him unfed for two days. Watson shot the dog dead. Distinct from Carlo the spaniel in 'The Adventure of the Sussex Vampire'.""" ;
    ex:ownedBy :jephroRucastle ;
    ex:locatedIn :copperBeeches ;
    ex:hasParticipatedIn :maulingOfJephroRucastle ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:carrutherssBicycle a ex:Vehicle ;
    ex:prefLabel "Carruthers's bicycle" ;
    ex:description "Bicycle used by Bob Carruthers to secretly follow Violet Smith on her rides, while disguised with a false beard." ;
    ex:ownedBy :bobCarruthers ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:carrutherssFalseBeard a ex:Disguise ;
    ex:prefLabel "Carruthers's false beard" ;
    ex:description "A dark/coal-black false beard worn by Bob Carruthers as a disguise while following Violet Smith on his bicycle. He snatched it off and threw it on the ground during the confrontation at Charlington Hall." ;
    ex:ownedBy :bobCarruthers ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:carrutherssPistol a ex:Firearm ;
    ex:prefLabel "Carruthers's revolver" ;
    skos:altLabel "Carruthers's pistol" ;
    ex:description "A revolver/pistol owned by Bob Carruthers. Initially drawn on Holmes when they met on the road. Later used to shoot Jack Woodley in the front of his waistcoat during the forced marriage confrontation. Surrendered to Holmes." ;
    ex:ownedBy :bobCarruthers ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:caseOfRazors a ex:Object ;
    ex:prefLabel "Case of Razors" ;
    skos:altLabel "small case of razors" ;
    ex:description "A small case of razors, among several of Eduardo Lucas's possessions found in John Mitton's boxes. Mitton explained they were presents from the deceased, corroborated by the housekeeper Mrs. Pringle." ;
    ex:ownedBy :johnMitton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:catullusBook a ex:Document ;
    ex:prefLabel "Catullus" ;
    ex:description "Book offered for sale by Holmes in his book-collector disguise to Watson." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:charredBoneFragment a ex:Object ;
    ex:prefLabel "Charred Bone Fragment" ;
    ex:description "A charred fragment of bone found by Harvey while raking out the cinders of the central heating furnace at Shoscombe Old Place. It was burned to a black cinder. Watson identifies it as the upper condyle of a human femur. It turns out to be from the ancient mummy remains that were displaced from a coffin in the crypt to make room for Lady Beatrice's body." ;
    ex:foundAt :shoscombeFurnaceCellar ;
    ex:foundBy :harvey ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:charredBones a ex:Object ;
    ex:prefLabel "Charred bones" ;
    ex:description "Small pieces of charred bone raked from the kitchen fire at Wisteria Lodge. A doctor confirmed they were not human. Holmes suggested they were from a lamb or kid. Part of the voodoo ritual." ;
    ex:locatedAt :wisteriaLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:chloroformCarfax a ex:Poison ;
    ex:prefLabel "Chloroform" ;
    ex:description "Chloroform used by Peters and Fraser to drug Lady Frances Carfax. Cotton-wool soaked in chloroform was wrapped around her head inside the coffin. Additional chloroform was poured into the coffin to ensure she would not wake. The stupefying and overpowering smell was evident when the coffin lid was removed." ;
    ex:usedBy :henryPeters, :annieFraser ;
    ex:usedOn :ladyFrancesCarfax ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:chloroformRag a ex:FictionalObject , ex:Weapon ;
    ex:prefLabel "Chloroform Rag" ;
    ex:description "A rag soaked in chloroform used on Mrs. Maberley during the burglary of The Three Gables, rendering her unconscious." ;
    ex:usedIn :burglaryThreeGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:chloroformSponge a ex:Object, ex:Weapon ;
    ex:prefLabel "Chloroform Sponge" ;
    ex:description "A chloroformed sponge used by Holmes to subdue Von Bork. Holmes gripped Von Bork at the back of the neck with a grasp of iron and held the sponge in front of his writhing face." ;
    ex:usedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:chubbKey a ex:Object ;
    ex:prefLabel "Chubb's Key" ;
    ex:description "A Chubb's key used to lock the central cupboard of Professor Coram's bureau. Kept on the Professor's watch-chain. Anna's agent (the second secretary) obtained an impression of this key which Anna later used to open the cupboard." ;
    ex:ownedBy :professorCoram ;
    ex:locatedIn :coramBureau ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:cigaretteEvidence a ex:Object ;
    ex:prefLabel "Cigarette Evidence" ;
    ex:description "Two burnt matches and a cigarette-end found on the lodger's breakfast tray at Mrs. Warren's house and brought to Holmes by Mrs. Warren. Holmes observes that the cigarette stub was smoked by a clean-shaven person (not the bearded man who took the rooms), providing evidence for his theory of substitution of lodgers." ;
    ex:locatedIn :mrsWarrensHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:cipherTelegramSecondStain a ex:Telegram ;
    ex:prefLabel "Cipher Telegram (Second Stain)" ;
    ex:description "A cipher telegram despatched to the foreign potentate informing him of the loss of his letter." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:coramBureau a ex:Object ;
    ex:prefLabel "Professor Coram's Bureau" ;
    skos:altLabel "the bureau" ;
    skos:altLabel "the writing-table" ;
    ex:description "Large writing-table with a fixed bureau in Professor Coram's study. Consists of a double column of drawers with a central small cupboard between them. The drawers were always open with nothing of value. The cupboard was locked with a Chubb's key kept on the Professor's watch-chain, containing family papers, letters from his wife, and university diplomas. Anna attempted to open it to retrieve her diary and letters. A fresh scratch on the brass keyhole plate showed where she had hurried to withdraw the key." ;
    ex:ownedBy :professorCoram ;
    ex:locatedIn :yoxleyStudy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:coramManuscript a ex:Document ;
    ex:prefLabel "Professor Coram's Manuscript" ;
    skos:altLabel "the magnum opus" ;
    ex:description "A scholarly analysis of documents found in the Coptic monasteries of Syria and Egypt, described by Professor Coram as his magnum opus. A work which he claims will cut deep at the very foundations of revealed religion. Piled on a side table in his bedroom. He fears he may never complete it with his enfeebled health and the loss of his secretary." ;
    ex:ownedBy :professorCoram ;
    ex:locatedIn :professorCoramBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:crockfordsDirectory a ex:Document ;
    ex:prefLabel "Crockford's Clerical Directory" ;
    skos:altLabel "Crockford" ;
    ex:description "A clerical directory consulted by Holmes to find the name of the vicar of Little Purlington. Listed J.C. Elman, M.A., Living of Moosmoor cum Little Purlington. Holmes used the vicar's name on the forged telegram." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:crownDerbyTeaSet a ex:FictionalObject , ex:Jewelry ;
    ex:prefLabel "Crown Derby Tea-Set" ;
    ex:description "Mrs. Maberley's most valuable possession, mentioned when Holmes asked if she had anything rare in the house. A Crown Derby tea-set, which Mrs. Maberley considered her rarest item." ;
    ex:ownedBy :maryMaberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:curareArrows a ex:FictionalObject, ex:Weapon ;
    ex:prefLabel "Curare Arrows" ;
    skos:altLabel "poisoned arrows" ;
    ex:description "Arrows from the quiver beside the small bird-bow in the South American weapons collection at Cheeseman's. They are dipped in curare or another devilish drug. Jack Ferguson used them to prick the baby, causing the wound on the neck from which Mrs. Ferguson sucked the poison. Jack also used the poison to test on the dog Carlo approximately four months before the story." ;
    ex:partOf :southAmericanWeapons ;
    ex:usedBy :jackFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:cushingAntimacassar a ex:Object ;
    ex:prefLabel "Antimacassar" ;
    ex:description "Worked antimacassar on Miss Susan Cushing's lap. She was quietly working on it with coloured silks." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:cushingSistersPortrait a ex:Portrait ;
    ex:prefLabel "Portrait group of three sisters" ;
    ex:description "On Susan Cushing's mantelpiece. Shows Susan, Sarah, and Mary Cushing." ;
    ex:locatedIn :crossStreetCroydon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:cutInLeatherDesk a ex:Object ;
    ex:prefLabel "Cut in Red Leather Desk" ;
    ex:description "A clean cut about three inches long in the fine red leather surface of Soames's new writing-table. Not a mere scratch but a positive tear — slight at one side but deepening toward the bedroom door. Caused by the spike on Gilchrist's jumping shoe when he placed it on the desk, then dragged it as he fled toward the bedroom." ;
    ex:relatedTo :fortescueExamTampering ;
    ex:locatedAt :soamesSittingRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:cutOutPortrait a ex:Portrait ;
    ex:prefLabel "Cut-Out Portrait Face" ;
    ex:description "A small piece of cardboard being the face of a woman cut out of a portrait. Carried by Holmes because he thought it might be useful. Shown to Constable MacPherson on the doorstep, who recognised it with amazement, confirming that the woman who visited the crime scene was Lady Hilda." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:cutterAlicia a ex:Vessel ;
    ex:prefLabel "Cutter Alicia" ;
    skos:altLabel "the Alicia" ;
    ex:description "The cutter Alicia is mentioned in the preamble as one of Watson's remarkable unsolved cases. She sailed one spring morning into a small patch of mist from where she never again emerged, nor was anything further ever heard of herself and her crew." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:cyaneaCapillata a ex:Animal ;
    ex:prefLabel "Cyanea Capillata" ;
    skos:altLabel "Lion's Mane Jellyfish" ;
    skos:altLabel "The Lion's Mane" ;
    skos:altLabel "Cyanea" ;
    ex:description "A Cyanea capillata, or Lion's Mane jellyfish, found in the tidal pool near Fulworth. Described as a tangled mass of tawny membranes and fibres resembling a lion's mane, with streaks of silver among its yellow tresses, pulsating with slow heavy dilation and contraction. It lay on a rocky shelf about three feet under the water. Its nearly invisible filaments extend up to fifty feet and inflict wounds appearing as scarlet lines with dots of extravasated blood, causing extreme cardiac distress. It killed Fitzroy McPherson and his dog, and severely injured Ian Murdoch. Holmes and Stackhurst destroyed it by pushing a boulder onto it. It may have been brought to the area by a severe southwest gale." ;
    ex:locatedIn :fulworthBathingPool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:dailyChronicle a ex:Object ;
    ex:prefLabel "Daily Chronicle" ;
    ex:description "Newspaper. Contains the article about the gruesome packet sent to Miss Cushing." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:dailyGazette a ex:Newspaper ;
    ex:prefLabel "Daily Gazette" ;
    skos:altLabel "The Daily Gazette" ;
    ex:description "The Daily Gazette is a London newspaper whose agony column is used by Gennaro Lucca to communicate with his wife Emilia while she is in hiding at Mrs. Warren's lodging house. Holmes identifies the relevant messages signed 'G' in the paper's personal column, which contain coded instructions including the signal arrangement for candle-flash communication." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:dailyTelegraphNorwood a ex:Newspaper ;
    ex:prefLabel "Daily Telegraph (Norwood case)" ;
    ex:description "Newspaper that reported on the mysterious murder in Lower Norwood. Holmes reads the account at breakfast, noting the absence of Moriarty's organizing genius in London crime." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:dameryLetter a ex:Letter ;
    ex:prefLabel "Damery's Letter to Holmes" ;
    ex:description """A letter from Sir James Damery at the Carlton Club to Sherlock Holmes, dated the evening before the story begins. It presents Damery's compliments and requests an appointment at 4.30 the next day to consult on a very delicate and important matter.""" ;
    ex:author :jamesDamery ;
    ex:recipient :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:deJureInterGentes a ex:Document ;
    ex:prefLabel "De Jure inter Gentes" ;
    ex:description "An old Latin book purchased by Holmes at a stall. Published in Liege in the Lowlands in 1642 by Philippe de Croy. Inscription 'Ex libris Guliolmi Whyte' on the fly-leaf, suggesting a seventeenth-century lawyer as a previous owner. Holmes examines it while waiting for the ring advertisement respondent at 221B Baker Street." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:despatchBoxSecondStain a ex:DespatchBox ;
    ex:prefLabel "Trelawney Hope's Despatch-Box" ;
    skos:altLabel "the despatch-box" ;
    ex:description "A red flat lockable box used by Trelawney Hope to carry official documents. Kept in his bedroom on the dressing-table at Whitehall Terrace. Key kept on Hope's watch-chain. Lady Hilda took an impression of the key and Lucas furnished a duplicate. Contained various official papers including letters from Lord Merrow, Sir Charles Hardy, Lord Flowers, and memoranda from Belgrade and Madrid. The diplomatic letter was stolen from it and later secretly returned to it by Holmes." ;
    ex:locatedIn :whitehallTerrace ;
    ex:ownedBy :trelawneyHope ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:devilsFootRoot a ex:Poison ;
    ex:prefLabel "Devil's-Foot Root" ;
    skos:altLabel "Radix pedis diaboli" ;
    skos:altLabel "devil's-foot powder" ;
    ex:description "A rare and deadly poison in the form of a reddish-brown, snuff-like powder derived from a root shaped like a foot, half human and half goatlike, hence the fanciful name given by a botanical missionary. Used as an ordeal poison by the medicine-men in certain districts of West Africa and kept as a secret among them. Stimulates the brain centres which control the emotion of fear, causing either madness or death. When burned, it produces a thick, musky odour that induces terrifying hallucinations of black clouds and monstrous entities. Save for one sample in a laboratory at Buda, Dr. Sterndale's specimen was the only one in Europe. Not yet found in the pharmacopoeia or literature of toxicology. Obtained by Sterndale in the Ubangi country under extraordinary circumstances. Mortimer Tregennis stole some during a visit to Sterndale's bungalow and used it to poison his siblings. Sterndale later used the remaining powder to kill Mortimer in revenge." ;
    ex:ownedBy :leonSterndale ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:devineNapoleonMarble a ex:Sculpture ;
    ex:prefLabel "Devine's Marble Napoleon" ;
    skos:altLabel "Devine's head of Napoleon" ;
    ex:description "A marble sculpture of Napoleon's head created by the French sculptor Devine. Hundreds of plaster casts were taken from this original at Gelder & Co." ;
    ex:sculptedBy :devine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:diamondTiara a ex:FictionalObject, ex:Jewelry ;
    ex:prefLabel "Diamond Tiara" ;
    ex:description "A high diamond tiara worn by the avenger in her photograph displayed in the shop window near Regent Circus. It sits on her noble head in the Court dress photograph." ;
    ex:ownedBy :milvertonAvenger ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:diplomaticLetterSecondStain a ex:Letter ;
    ex:prefLabel "Diplomatic Letter (Second Stain)" ;
    skos:altLabel "the letter" ;
    skos:altLabel "the document" ;
    ex:description "A letter from a foreign potentate ruffled by recent Colonial developments of Britain. Written hurriedly and on his own responsibility without his Ministers' knowledge. Couched in unfortunate manner with provocative phrases. Its publication would lead to war and the expenditure of a thousand millions and lives of a hundred thousand men. Contained in a long, thin pale blue envelope with a seal of red wax stamped with a crouching lion, addressed in large bold handwriting. Received six days before it was stolen. Kept in Trelawney Hope's despatch-box. Stolen by Lady Hilda and given to Eduardo Lucas in exchange for her compromising letter. Hidden by Lucas under a floorboard beneath the drugget. Recovered by Lady Hilda from the hiding-place. Returned by Holmes to the despatch-box." ;
    ex:locatedIn :whitehallTerrace ;
    ex:ownedBy :trelawneyHope ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:dogKennel a ex:Object ;
    ex:prefLabel "Dog-Kennel" ;
    ex:description "A dog-kennel in the grounds of The Haven that cleverly concealed a disused well where Josiah Amberley hid the bodies of his wife and Dr. Ray Ernest after murdering them." ;
    ex:locatedIn :theHavenLewisham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:dorakLetters a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Dorak's Letters" ;
    ex:description "Several letters from A. Dorak to Professor Presbury found in the wooden box. Written in a crabbed, foreign hand. The envelopes are marked with a cross under the stamp and bear the E.C. postmark. Each is dated from Commercial Road and signed 'A. Dorak'. They consist of mere invoices announcing fresh bottles being sent and receipts acknowledging money received. These are the marked letters that Presbury instructed Bennett to set aside for his eyes only." ;
    ex:locatedAt :presburyWoodenBox ;
    ex:authoredBy :dorak ;
    ex:sentTo :professorPresbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:douglasTrunks a ex:FictionalObject , ex:PersonalEffects ;
    ex:prefLabel "Douglas Maberley's Trunks" ;
    ex:description "Several trunks and cases containing Douglas Maberley's effects, returned from Italy after his death. Bore labels from Milano and Lucerne. Arrived at The Three Gables the week before Holmes's visit. Contained the manuscript that was the target of the burglary." ;
    ex:locatedAt :theThreeGables ;
    ex:ownedBy :douglasMaberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:druggetSecondStain a ex:Carpet ;
    ex:prefLabel "Drugget (Second Stain)" ;
    skos:altLabel "the drugget" ;
    skos:altLabel "the carpet" ;
    ex:description "A small square drugget carpet in the centre of the room at 16 Godolphin Street, surrounded by beautiful old-fashioned wood-flooring. Not fastened down, just laid there on a polished floor. Had a blood stain from Lucas's murder. The carpet was turned around (the second stain did not correspond with the first because the carpet had been rotated). Beneath it was the hinged floorboard hiding-place where Lucas concealed the diplomatic letter. Lady Hilda turned the carpet to access the hiding-place and retrieve the letter." ;
    ex:locatedIn :16GodolphinStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:dunbarNote a ex:Letter ;
    ex:prefLabel "Dunbar's Note" ;
    ex:description "A short note written by Grace Dunbar reading 'I will be at Thor Bridge at nine o'clock. G. Dunbar.' Written in response to Mrs. Gibson's request for a meeting. Found clutched in the dead woman's left hand so tightly the fingers could hardly be opened. Holmes notes this proves it was not placed after death." ;
    ex:authoredBy :graceDunbar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:duplicateKeySecondStain a ex:Key ;
    ex:prefLabel "Duplicate Key to Despatch-Box" ;
    ex:description "A duplicate key to Trelawney Hope's despatch-box. Lady Hilda took an impression of her husband's key; Eduardo Lucas furnished the duplicate. Lady Hilda kept it in her bosom. Used to open the despatch-box to steal and later return the diplomatic letter." ;
    ex:ownedBy :ladyHildaTrelawneyHope ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:dyingDetectiveIvoryBox a ex:Object ;
    ex:prefLabel "Poisoned Ivory Box" ;
    skos:altLabel "ivory box" ;
    skos:altLabel "the box" ;
    ex:description "A small black and white ivory box with a sliding lid, sent to Holmes by post on a Wednesday by Culverton Smith. Inside is a sharp spring mechanism that delivers poison, described as emerging 'like a viper's tooth' when the box is opened. It is the murder weapon used by Smith — the same device was used to kill Victor Savage. Holmes places it on his mantelpiece among papers as part of his trap. Smith attempts to pocket it as evidence but it is recovered by Inspector Morton." ;
    ex:ownedBy :culvertonSmith ;
    ex:usedIn :murderOfVictorSavage ;
    ex:usedIn :attemptedMurderOfHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:earTelegram a ex:Telegram ;
    ex:prefLabel "Telegram about Shlessinger's Ear" ;
    ex:description "A telegram from Baden answering Holmes's query about Dr. Shlessinger's left ear. The message read 'Jagged or torn.' This confirmed Holmes's suspicion that Shlessinger was actually Holy Peters, who had been badly bitten in a saloon fight in Adelaide in 1889." ;
    ex:sentFrom :badenBaden ;
    ex:receivedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:ecclesLetter a ex:Object, ex:Letter ;
    ex:prefLabel "Scott Eccles's letter to Garcia" ;
    ex:description "A letter from John Scott Eccles found in the dead Garcia's pocket, confirming that Eccles would be staying at Wisteria Lodge. The envelope gave police Garcia's name and address." ;
    ex:sentBy :johnScottEccles ;
    ex:sentTo :aloysiusGarcia ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:ecclesTelegram a ex:Object, ex:Telegram ;
    ex:prefLabel "Scott Eccles's telegram to Holmes" ;
    ex:description "A telegram sent by John Scott Eccles from Charing Cross Post Office to Sherlock Holmes requesting a consultation about his 'most incredible and grotesque experience.'" ;
    ex:sentBy :johnScottEccles ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:electricBlueDress a ex:Clothing ;
    ex:prefLabel "Electric-blue dress" ;
    skos:altLabel "Alice's blue dress" ;
    ex:description """A dress of a peculiar shade of electric blue, made of excellent beige material. It belonged to Alice Rucastle and bore unmistakable signs of having been worn before. Violet Hunter was required to wear it while sitting in the drawing-room window with her back to the glass, as part of the scheme to impersonate Alice for Mr. Fowler watching from the Southampton Road. Mrs. Rucastle was said to be fond of this particular shade.""" ;
    ex:ownedBy :aliceRucastle ;
    ex:locatedIn :copperBeeches ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:enlargedPhotographWounds a ex:Photograph ;
    ex:prefLabel "Enlarged Photograph of McPherson's Wounds" ;
    ex:description "An enlarged photograph of the wounds on Fitzroy McPherson's body, taken by Holmes as part of his investigative method. Holmes showed it to Inspector Bardle, pointing out the peculiar dots of extravasated blood within the weal marks, which were consistent with jellyfish stinger marks rather than a whip or scourge." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:evansRevolver a ex:Object, ex:Weapon, ex:Firearm ;
    ex:prefLabel "Evans's Revolver" ;
    ex:description "A revolver carried by Killer Evans, whisked from his breast pocket during the confrontation at 136 Little Ryder Street. He fired two shots, wounding Watson in the thigh." ;
    ex:ownedBy :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:evansKey a ex:Object, ex:Tool ;
    ex:prefLabel "Evans's Key" ;
    ex:description "A key used by Killer Evans to enter 136 Little Ryder Street. Its sharp metallic snap was heard by Holmes and Watson as Evans entered the premises to access the hidden cellar." ;
    ex:ownedBy :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:evansJemmy a ex:Object, ex:Tool ;
    ex:prefLabel "Evans's Jemmy" ;
    ex:description "A jemmy (crowbar) carried by Killer Evans in his inside pocket, used to pry open the floorboards to access the secret cellar beneath 136 Little Ryder Street." ;
    ex:ownedBy :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:evansDossier a ex:Object, ex:Document ;
    ex:prefLabel "Evans's Dossier" ;
    ex:description "Scotland Yard's criminal record and rogues' portrait gallery entry for Killer Evans. The inscription read 'James Winter, alias Morecroft, alias Killer Evans.' Holmes scribbled down key points: aged forty-four, native of Chicago, known to have shot three men in the States, escaped from penitentiary through political influence, came to London in 1893, shot Prescott in January 1895." ;
    ex:heldBy :scotlandYard ;
    ex:isAbout :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:familyHerald a ex:Publication ;
    ex:prefLabel "The Family Herald" ;
    skos:altLabel "Family Herald" ;
    ex:description "The Family Herald is a periodical observed by Holmes on the hall-table at 221B Baker Street. It contains love romances. Holmes attributes the new cook's overcooked hard-boiled eggs to her being absorbed in the magazine, noting that cooking eggs demands attention incompatible with reading love romances." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:fergusonLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Ferguson's Letter to Holmes" ;
    ex:description "A letter from Robert Ferguson to Sherlock Holmes, headed with the address Cheeseman's, Lamberley. It describes his wife's apparent vampirism in detail, initially framing the case as concerning 'a friend.' The letter details the wife's attacks on both the baby and stepson Jack, the nurse's discovery of the wife apparently biting the baby's neck, and the culminating scene witnessed by Ferguson himself. The postscript mentions Watson's Rugby connection with Ferguson through Blackheath and Richmond." ;
    ex:locatedAt :221bBakerStreet ;
    ex:sentBy :robertFerguson ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:fishingTackle a ex:Object ;
    ex:prefLabel "Fishing Tackle" ;
    ex:description "A formidable litter of rods, reels, and baskets that Holmes and Watson bring as cover for their visit to Shoscombe. They fill the rack above them in the first-class carriage. They actually use the tackle to catch trout in the mill-stream." ;
    ex:ownedBy :sherlockHolmes, :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:fiveClawedClub a ex:Weapon ;
    ex:prefLabel "Five-Clawed Club" ;
    ex:description "The five-clawed club is a murder weapon crafted by Leonardo. It consists of a club with a leaden head in which five long steel nails are fastened with points outward, with a spread matching a lion's paw. It was designed to give Ronder his death-blow while leaving evidence consistent with a lion attack. Holmes describes it as the most singular and ingenious part of the story. It was possibly disposed of in the chalk-pit pool near the Abbas Parva camp." ;
    ex:createdBy :leonardo ;
    ex:usedIn :abbasParvaIncident ;
    ex:usedBy :leonardo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:forgedTelegram a ex:Telegram ;
    ex:prefLabel "Forged Telegram" ;
    ex:description "A telegram forged by Sherlock Holmes and dispatched at 2:10 from Little Purlington, signed 'Elman' and purporting to come from The Vicarage. The message read 'Come at once without fail. Can give you information as to your recent loss.' Used to lure Josiah Amberley away from The Haven so Holmes could search the house." ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:garridebWill a ex:Object, ex:Document ;
    ex:prefLabel "Alexander Hamilton Garrideb's Will" ;
    ex:description "The will of Alexander Hamilton Garrideb, described as the queerest will ever filed in the State of Kansas. It divided his property into three parts, each worth five million dollars, to be shared among three adult men named Garrideb. Part of the story told by Killer Evans, and the entire inheritance scheme may have been fabricated." ;
    ex:createdBy :alexanderHamiltonGarrideb ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:garridebFoolscapDocument a ex:Object, ex:Document ;
    ex:prefLabel "Garrideb Foolscap Document" ;
    ex:description "A long foolscap document held by Holmes at the start of the Three Garridebs case. It contained Nathan Garrideb's narrative about the Garrideb inheritance and was the basis for Holmes's initial investigation." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:gasPipe a ex:Object ;
    ex:prefLabel "Gas Pipe" ;
    ex:description "A gas pipe running along the skirting of Amberley's strong-room, rising in the angle of the wall with a tap in the corner. The pipe runs into the strong-room and ends in a plaster rose in the centre of the ceiling, concealed by ornamentation. The wide-open end allowed the room to be flooded with gas by turning the outside tap, serving as the murder weapon." ;
    ex:locatedIn :theHavenLewisham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:gibsonFirearmsCollection a ex:Object ;
    ex:prefLabel "Gibson's Firearms Collection" ;
    ex:description "A formidable array of firearms of various shapes and sizes accumulated by Neil Gibson in the course of an adventurous life. Kept at Thor Place. Includes a pair of pistols in a box (from which the murder and suicide revolvers came). Gibson also sleeps with a loaded revolver in the drawer beside his bed. Shown to Holmes and Watson by Marlow Bates." ;
    ex:ownedBy :neilGibson ;
    ex:locatedAt :thorPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:gibsonLetterToHolmes a ex:Letter ;
    ex:prefLabel "Gibson's Letter to Holmes" ;
    ex:description "A letter written by Neil Gibson to Sherlock Holmes in a bold, masterful hand, from Claridge's Hotel, dated October 3rd, signed 'J. Neil Gibson.' It pleads for Holmes's help in saving Grace Dunbar, declaring her innocent and offering all his resources." ;
    ex:authoredBy :neilGibson ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:greenPaint a ex:Object ;
    ex:prefLabel "Green Paint" ;
    ex:description "A great pot of green paint standing in the centre of the hall at The Haven. Amberley used it with a thick brush to paint the woodwork and passage, ostensibly to ease an aching heart but actually to cover the smell of gas used in the murders." ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:greuzePainting a ex:ArtWork ;
    ex:prefLabel "Greuze Painting" ;
    skos:altLabel "La Jeune Fille a l'Agneau" ;
    ex:description "Painting by Jean Baptiste Greuze hanging over Professor Moriarty's writing desk. Depicts a young woman with her head on her hands peeping sideways. Holmes uses it to demonstrate Moriarty's hidden wealth, noting that a Greuze entitled La Jeune Fille a l'Agneau fetched over forty thousand pounds at the Portalis sale in 1865, far beyond what Moriarty's seven-hundred-pound salary could afford." ;
    ex:createdBy :jeanBaptisteGreuze ;
    ex:ownedBy :professorMoriarty ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:hainesJohnsonCard a ex:FictionalObject , ex:Document ;
    ex:prefLabel "Haines-Johnson's Business Card" ;
    ex:description "A business card left by Haines-Johnson identifying himself as an auctioneer and valuer. Contained no address, only his name and occupation." ;
    ex:ownedBy :hainesJohnson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:holmesBees a ex:Animal ;
    ex:prefLabel "Holmes's Bees" ;
    ex:description "Sherlock Holmes's bees at his Sussex retirement villa. Along with Holmes and his old housekeeper, the bees have the estate to themselves. Beekeeping is part of Holmes's soothing retirement life of Nature." ;
    ex:locatedIn :holmesSussexVilla ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:holmesFinalLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Holmes's Final Letter" ;
    ex:description "A letter written by Holmes from Baker Street, dated November 21st, in reply to the Morrison, Morrison, and Dodd letter of November 19th. Addressed 'Re Vampires,' it states that Holmes has looked into the inquiry of their client Robert Ferguson of Ferguson and Muirhead, tea brokers of Mincing Lane, and that the matter has been brought to a satisfactory conclusion." ;
    ex:dateWritten "November 21" ;
    ex:locatedAt :221bBakerStreet ;
    ex:sentBy :sherlockHolmes ;
    ex:sentTo :morrisonMorrisonAndDodd ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:holmesHypodermicSyringe a ex:FictionalObject, ex:MedicalInstrument ;
    ex:prefLabel "Holmes's Hypodermic Syringe" ;
    ex:description "Holmes's tiny hypodermic syringe, which Watson associates with Holmes's drug habit and 'the single weakness of his nature.' In the Missing Three-Quarter case, Holmes uses it to spray aniseed over the hind wheel of Dr. Armstrong's brougham, creating a scent trail for the draghound Pompey to follow." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:holmesIndexVolume a ex:FictionalObject, ex:Document ;
    ex:prefLabel "Holmes's Index Volume" ;
    ex:description "A great index volume kept by Holmes containing a record of old cases mixed with the accumulated information of a lifetime. Watson takes it down from the shelf at Holmes's request. Under the letter V, it contains entries for the Voyage of the Gloria Scott, Victor Lynch the forger, a venomous lizard or gila, Vittoria the circus belle, Vanderbilt and the Yeggman, Vipers, Vigor the Hammersmith wonder, Vampirism in Hungary, and Vampires in Transylvania." ;
    ex:locatedAt :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:holmesNoteToKlein a ex:FictionalObject , ex:Letter ;
    ex:prefLabel "Holmes's Note to Isadora Klein" ;
    ex:description "A brief note scribbled by Holmes on a sheet of his notebook and sent to Isadora Klein via her footman. Read: 'Shall it be the police, then?' This note gained Holmes and Watson immediate entry to her house." ;
    ex:authoredBy :sherlockHolmes ;
    ex:sentTo :isadoraKlein ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:holmesNoteToMrsFerguson a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Holmes's Note to Mrs. Ferguson" ;
    ex:description "A note scribbled by Holmes on a sheet of paper and delivered to Mrs. Ferguson by Watson via Dolores. The note indicates that Holmes knows the truth about the situation. Upon reading it, Mrs. Ferguson cries out in a blend of joy and surprise and agrees to see Holmes and Ferguson." ;
    ex:locatedAt :cheesemans ;
    ex:sentBy :sherlockHolmes ;
    ex:sentTo :mrsFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:holmesTelegramToFerguson a ex:FictionalObject, ex:Telegram ;
    ex:prefLabel "Holmes's Telegram to Ferguson" ;
    ex:description "A telegram sent by Holmes (dictated to Watson) to Ferguson at Cheeseman's, Lamberley, reading 'Will examine your case with pleasure.' Holmes deliberately uses 'your case' rather than 'your friend's case' to signal he sees through Ferguson's pretense of acting for another." ;
    ex:sentBy :sherlockHolmes ;
    ex:sentTo :robertFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:hopkinsAbbeyGrangeNote a ex:Letter ;
    ex:prefLabel "Hopkins's Note from Abbey Grange" ;
    ex:description "Note sent by Inspector Stanley Hopkins to Holmes at 3:30 AM from Abbey Grange, Marsham, Kent. Written on crackling paper with an 'E.B.' monogram and coat-of-arms. Hopkins requests immediate assistance in a most remarkable case, mentions releasing the lady and the difficulty of leaving Sir Eustace there." ;
    ex:sentBy :stanleyHopkins ;
    ex:receivedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:housePurchaseAgreement a ex:FictionalObject , ex:LegalDocument ;
    ex:prefLabel "House Purchase Agreement" ;
    ex:description "A purchase agreement drawn up by Haines-Johnson for the sale of The Three Gables. Contained a clause that would have prevented Mrs. Maberley from legally taking anything out of the house, including personal possessions. Mr. Sutro identified the problematic clause." ;
    ex:authoredBy :hainesJohnson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:howardGarridebAdvertisement a ex:Object, ex:Document ;
    ex:prefLabel "Howard Garrideb Advertisement" ;
    ex:description "A fake newspaper advertisement planted by Killer Evans in a local Birmingham paper. It advertised Howard Garrideb as a constructor of agricultural machinery at Grosvenor Buildings, Aston, offering binders, reapers, steam and hand plows, drills, harrows, farmers' carts, buckboards, and artesian wells. Holmes identified it as fraudulent due to American spellings and terminology in a supposedly English advertisement." ;
    ex:createdBy :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:hypodermicSyringe a ex:FictionalObject, ex:MedicalInstrument ;
    ex:prefLabel "Hypodermic Syringe" ;
    ex:description "A hypodermic syringe found in Professor Presbury's wooden box, used to administer the langur monkey rejuvenation serum." ;
    ex:locatedAt :presburyWoodenBox ;
    ex:ownedBy :professorPresbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc  ;
    dc:source :signOfTheFourDoc .

:ironFireplaceScreen a ex:FictionalObject ;
    ex:prefLabel "Iron Fireplace Screen" ;
    ex:description "An iron screen behind the fireplace in the central room at Cheeseman's, dated 1670. It is part of the huge old-fashioned fireplace where a splendid log fire blazes." ;
    ex:locatedAt :cheesemansMainRoom ;
    ex:yearMade "1670" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:jephroRucastleLetter a ex:Letter ;
    ex:prefLabel "Jephro Rucastle's letter to Violet Hunter" ;
    ex:description """A letter written by Jephro Rucastle from the Copper Beeches near Winchester to Violet Hunter, offering her the governess position at 120 pounds a year (30 pounds a quarter). It specified conditions: wearing an electric-blue dress belonging to his daughter Alice (said to be in Philadelphia), sitting where directed, and cutting her hair short. Miss Stoper had provided Violet's address.""" ;
    ex:createdBy :jephroRucastle ;
    ex:sentTo :violetHunter ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:johnGarridebCard a ex:FictionalObject, ex:Document ;
    ex:prefLabel "John Garrideb's Visiting Card" ;
    ex:description "A visiting card brought in by Mrs. Hudson on a tray. It reads 'John Garrideb, Counsellor at Law, Moorville, Kansas, U.S.A.' The card belongs to Killer Evans, who is posing as an American lawyer named John Garrideb as part of his elaborate scheme to access Prescott's hidden counterfeiting press." ;
    ex:ownedBy :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:johnGarridebVisitingCard a ex:Object, ex:Document ;
    ex:prefLabel "John Garrideb's Visiting Card" ;
    ex:description "A visiting card brought by Mrs. Hudson on a tray, reading 'John Garrideb, Counsellor at Law, Moorville, Kansas, U.S.A.' It was part of Killer Evans's false identity." ;
    ex:ownedBy :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:japaneseVase a ex:Object ;
    ex:prefLabel "Japanese Vase" ;
    ex:description "A Japanese vase in Nathan Garrideb's collection. Watson was asked to put it to one side when taking a seat during their visit." ;
    ex:ownedBy :nathanGarrideb ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:kleinCheck a ex:FictionalObject , ex:Document ;
    ex:prefLabel "Check for Five Thousand Pounds" ;
    ex:description "A check for five thousand pounds signed by Isadora Klein at Holmes's insistence, to be given to Mrs. Maberley to fund a round-the-world trip in first-class style." ;
    ex:authoredBy :isadoraKlein ;
    ex:sentTo :maryMaberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:elephantGunBullet a ex:Weapon ;
    ex:prefLabel "Elephant Gun Bullet" ;
    ex:description "A bullet from an elephant gun that struck Godfrey Emsworth through the shoulder during the Battle of Buffelsspruit outside Pretoria. The wound caused him to fall from his horse after galloping several miles." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:leadenCoffin a ex:Object ;
    ex:prefLabel "Leaden Coffin" ;
    ex:description "A lead coffin standing on end before the entrance to the vault in the crypt beneath the old chapel at Shoscombe Park. Holmes examines its edges with his lens and opens it using a short jemmy. Inside is the body of Lady Beatrice Falder, swathed in a sheet." ;
    ex:locatedIn :shoscombeChapel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:lowensteinLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Lowenstein's Letter" ;
    ex:description "A letter from H. Lowenstein to Professor Presbury found in the wooden box. It bears an Austrian stamp with a Prague postmark and is written in an educated hand. The letter discusses the langur serum treatment, cautions about danger, mentions that anthropoid serum would have been better, notes one other client in England, and identifies Dorak as Lowenstein's agent for both clients. It is signed 'H. Lowenstein' and addressed to 'Honoured Colleague'." ;
    ex:locatedAt :presburyWoodenBox ;
    ex:authoredBy :lowenstein ;
    ex:sentTo :professorPresbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:maberleyLetter a ex:FictionalObject , ex:Letter ;
    ex:prefLabel "Mrs. Maberley's Letter to Holmes" ;
    ex:description "A letter from Mrs. Mary Maberley to Sherlock Holmes requesting his help with strange incidents at her house. Had a ten o'clock PM postmark. Susan posted the letter but also informed Barney Stockdale." ;
    ex:authoredBy :maryMaberley ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:maberleyManuscript a ex:FictionalObject , ex:Document ;
    ex:prefLabel "Douglas Maberley's Manuscript" ;
    ex:description "A novel written by Douglas Maberley describing his love affair with Isadora Klein under thinly disguised names. At least two hundred and forty-five pages long. Two copies were made: one sent to Isadora Klein as a torment, one intended for his publisher. The copy among Douglas's effects was stolen during the burglary of The Three Gables. Isadora Klein burned the stolen manuscript in her fireplace." ;
    ex:authoredBy :douglasMaberley ;
    ex:ownedBy :maryMaberley ;
    ex:stolenIn :burglaryThreeGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:manuscriptFragment a ex:FictionalObject , ex:Document ;
    ex:prefLabel "Manuscript Fragment (Page 245)" ;
    ex:description "A single page torn from the burglar by Mrs. Maberley during the burglary at The Three Gables. Page two hundred and forty-five of Douglas Maberley's manuscript novel. Contains the end of the novel with passionate prose about love turning to hate. Holmes noted that the pronoun shifted from 'he' to 'my,' indicating the author imagined himself as the hero." ;
    ex:partOf :maberleyManuscript ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:emeraldTiePin a ex:Jewelry ;
    ex:prefLabel "Emerald Tie-Pin" ;
    skos:altLabel "emerald pin" ;
    ex:description "A remarkably fine emerald tie-pin. Given to Sherlock Holmes by Queen Victoria at Windsor as a reward for recovering the Bruce-Partington plans. Holmes said it was a present from 'a certain gracious lady' in whose interests he had carried out a small commission." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:escapeBrougham a ex:FictionalObject, ex:Vehicle ;
    ex:prefLabel "Escape Brougham" ;
    skos:altLabel "the brougham" ;
    ex:description "A small brougham waiting close to the curb at the far side of the Lowther Arcade as part of Holmes's evasion plan. Driven by Mycroft Holmes wearing a heavy black cloak tipped at the collar with red. Watson stepped in and was driven to Victoria Station." ;
    ex:drivenBy :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:masonLetter a ex:Letter ;
    ex:prefLabel "Mason's Letter" ;
    ex:description "A letter written by John Mason to Sherlock Holmes requesting his assistance in the Shoscombe Old Place matter. Holmes unfolds it during his conversation with Watson but notes it explained nothing, as Mason found the matter too delicate to put details on paper." ;
    ex:authoredBy :johnMason ;
    ex:addressedTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:matildaBriggs a ex:FictionalObject, ex:Vessel ;
    ex:prefLabel "Matilda Briggs" ;
    ex:description "The Matilda Briggs is a ship associated with the giant rat of Sumatra, described by Holmes as 'a story for which the world is not yet prepared.' Despite the name suggesting a woman, Holmes clarifies it was a ship. Morrison, Morrison, and Dodd reference Holmes's successful action in her case." ;
    ex:associatedWith :sumatra ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:maudNoteToMcPherson a ex:Letter ;
    ex:prefLabel "Maud's Note to McPherson" ;
    ex:description "A slip of paper found in McPherson's card-case after his death. Written in a scrawling feminine hand, it reads: 'I will be there, you may be sure. Maudie.' The note helped establish the identity of Maud Bellamy as McPherson's secret fiancée." ;
    ex:hasAuthor :maudBellamy ;
    ex:hasRecipient :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonBurberry a ex:Clothing ;
    ex:prefLabel "McPherson's Burberry Overcoat" ;
    ex:description "A Burberry overcoat worn by Fitzroy McPherson when he was found dying. It had been simply thrown round his shoulders and slipped off when he fell, exposing the terrible red weal marks on his trunk from the jellyfish sting." ;
    ex:ownedBy :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonCardCase a ex:Object ;
    ex:prefLabel "McPherson's Card-Case" ;
    ex:description "A small folding card-case found in Fitzroy McPherson's pocket after his death. It contained the note from Maud Bellamy ('Maudie') which helped establish the connection between McPherson and the Bellamy family." ;
    ex:ownedBy :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonDog a ex:Animal ;
    ex:prefLabel "McPherson's Dog" ;
    ex:description "Fitzroy McPherson's faithful Airedale terrier. After McPherson's death, the dog ate nothing for a week and was found dead on the beach at the very spot where its master had died, killed by the same Cyanea capillata jellyfish. Its body was stiff and rigid with projecting eyes and contorted limbs. The dog's death was the catalyst that triggered Holmes's solution to the case. Murdoch had once hurled this dog through a plate-glass window in a fit of temper." ;
    ex:causeOfDeath "Stung by Cyanea capillata jellyfish" ;
    ex:ownedBy :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonKnife a ex:Object ;
    ex:prefLabel "McPherson's Knife" ;
    ex:description "A large knife found in Fitzroy McPherson's pocket after his death, along with his handkerchief and card-case." ;
    ex:ownedBy :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonLetters a ex:Document ;
    ex:prefLabel "McPherson's Correspondence with Maud" ;
    ex:description "Several letters found in Fitzroy McPherson's desk at The Gables showing intimate correspondence with Maud Bellamy. The police took possession of the letters, which confirmed a serious love affair between McPherson and Maud." ;
    ex:hasAuthor :fitzroyMcPherson, :maudBellamy ;
    ex:ownedBy :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonNoteToMaud a ex:Letter ;
    ex:prefLabel "McPherson's Note to Maud" ;
    ex:description "A crumpled note from Fitzroy McPherson to Maud Bellamy, which she produced during questioning. It reads: 'Dearest, The old place on the beach just after sunset on Tuesday. It is the only time I can get away. F.M.' It arranges a meeting on the beach on Tuesday, the day McPherson died." ;
    ex:hasAuthor :fitzroyMcPherson ;
    ex:hasRecipient :maudBellamy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonWoundsPhotograph a ex:Evidence ;
    ex:prefLabel "Enlarged Photograph of McPherson's Wounds" ;
    ex:description "An enlarged photograph of Fitzroy McPherson's wound marks, taken by Sherlock Holmes as part of his investigation. The photograph revealed that the welts were unequal in intensity, with dots of extravasated blood at intervals, suggesting the marks were not made by a conventional whip but by something with a reticulated pattern. Holmes showed it to Inspector Bardle, who compared the pattern to a red-hot wire net." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedIn :holmesSussexVilla ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonTowel a ex:Object ;
    ex:prefLabel "McPherson's Towel" ;
    ex:description "A towel belonging to Fitzroy McPherson, found folded and dry on a rock beside the bathing pool. The fact that it was dry was a key clue, indicating that McPherson had never actually entered the water. This initially misled Holmes into not considering a water creature as the cause of death." ;
    ex:ownedBy :fitzroyMcPherson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mercerTelegram a ex:FictionalObject, ex:Telegram ;
    ex:prefLabel "Mercer's Telegram" ;
    ex:description "A telegram sent by Mercer to Sherlock Holmes reporting on his visit to Commercial Road to investigate A. Dorak. The telegram reads: 'Have visited the Commercial Road and seen Dorak. Suave person, Bohemian, elderly. Keeps large general store.' It was received in the evening after Holmes sent his own telegram from a post-office in Camford." ;
    ex:authoredBy :mercer ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:montrachet a ex:Object ;
    ex:prefLabel "Montrachet" ;
    ex:description "A bottle of Montrachet wine that Holmes mentions is on the sideboard, suggesting he and Watson renew their energies before visiting Mrs. Ronder." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:morrisonDoddLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Morrison, Morrison, and Dodd Letter" ;
    ex:description "A letter from the law firm Morrison, Morrison, and Dodd at 46 Old Jewry, dated November 19th, addressed to Sherlock Holmes regarding vampires. The letter states that their client Robert Ferguson of Ferguson and Muirhead, tea brokers of Mincing Lane, has made inquiries concerning vampires. As their firm specializes in assessment of machinery, they have recommended Ferguson consult Holmes. The letter mentions Holmes's successful action in the case of Matilda Briggs. Signed 'per E. J. C.'" ;
    ex:dateWritten "November 19" ;
    ex:locatedAt :221bBakerStreet ;
    ex:sentBy :morrisonMorrisonAndDodd ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:mrsAmberleyPhotograph a ex:Photograph ;
    ex:prefLabel "Mrs. Amberley's Photograph" ;
    ex:description "A photograph of Mrs. Amberley described as showing a good-looking woman. Torn up furiously by Josiah Amberley in Watson's presence in a tempest of passion, declaring he never wished to see her face again." ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:mrsGibsonNote a ex:Letter ;
    ex:prefLabel "Mrs. Gibson's Note to Dunbar" ;
    ex:description "A note from Mrs. Gibson left on the schoolroom table for Grace Dunbar. It implored Dunbar to meet her at Thor Bridge after dinner, saying she had something important to say, and asked Dunbar to leave an answer on the sundial in the garden. Mrs. Gibson asked Dunbar to destroy the note, which Dunbar burned in the schoolroom grate." ;
    ex:authoredBy :mariaGibson ;
    ex:sentTo :graceDunbar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:mrsGibsonShawl a ex:Clothing ;
    ex:prefLabel "Mrs. Gibson's Shawl" ;
    ex:description "A shawl worn by Mrs. Gibson over her shoulders when her body was found at Thor Bridge. She was clad in her dinner dress with this shawl, having come out late at night." ;
    ex:ownedBy :mariaGibson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:mummyRemains a ex:Object ;
    ex:prefLabel "Mummy Remains" ;
    ex:description "The head and bones of an ancient mummy, possibly a thousand years old. They were found by Mason and Stephens in a corner of the crypt, stowed away and covered with a board. The remains had been removed from a coffin to make room for Lady Beatrice's body. They were later burned by Norlett in the central heating furnace, leaving behind the charred bone fragment Harvey discovered." ;
    ex:locatedIn :shoscombeChapel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:nathanGarridebLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Nathan Garrideb's Letter to Holmes" ;
    ex:description "A long foolscap document sent by Nathan Garrideb to Sherlock Holmes, explaining the Garrideb inheritance case. The letter describes Alexander Hamilton Garrideb's will requiring three adult male Garridebs to share the estate, and Nathan's desire for Holmes's help in finding a third namesake. Holmes had filled up the blanks in the narrative when Killer Evans visited." ;
    ex:sentBy :nathanGarrideb ;
    ex:sentTo :sherlockHolmes ;
    ex:locatedAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:northSurreyObserver a ex:Newspaper ;
    ex:prefLabel "North Surrey Observer" ;
    ex:description "A bi-weekly newspaper that published the first consecutive account of the Amberley case under flaming headlines beginning with 'The Haven Horror' and ending with 'Brilliant Police Investigation.' The report credited Inspector MacKinnon with the deductions that solved the case." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:outOfDoorsBook a ex:Document ;
    ex:prefLabel "Out of Doors" ;
    ex:description "'Out of Doors' is a book by the famous naturalist J. G. Wood. A small chocolate and silver volume, it contains Wood's account of his near-fatal encounter with a Cyanea capillata jellyfish off the Kent coast. Holmes found the book in his garret library and it provided the key to solving the mystery of McPherson's death by identifying the Lion's Mane jellyfish as the killer." ;
    ex:hasAuthor :jgWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:pearlChaplet a ex:Jewelry ;
    ex:prefLabel "Pearl Chaplet" ;
    ex:description "Chaplet of pearls from the Agra treasure. Twelve pearls set in a gold coronet. Major Sholto took them from the treasure chest before hiding the rest. Thaddeus Sholto persuaded his brother Bartholomew to send individual pearls to Mary Morstan at fixed intervals beginning May 1882 so she might never feel destitute. Six pearls were sent. Described by an expert as a rare variety of considerable value." ;
    ex:partOf :agraTreasure ;
    ex:sentTo :maryMorstan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:persanoMatchbox a ex:Object ;
    ex:prefLabel "Persano's Matchbox" ;
    ex:description "A matchbox found in front of Isadora Persano when he was discovered stark staring mad. It contained a remarkable worm said to be unknown to science. Part of one of Watson's unsolved cases mentioned in the preamble." ;
    ex:ownedBy :isadoraPersano ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:photographOfLeonardo a ex:Photograph ;
    ex:prefLabel "Photograph of Leonardo" ;
    ex:description "A photograph showing Leonardo as a professional acrobat, a man of magnificent physique with huge arms folded across his swollen chest and a smile breaking from under his heavy moustache. It was kept by Mrs. Ronder in a drawer and shown to Holmes and Watson." ;
    ex:depictsSubject :leonardo ;
    ex:ownedBy :eugeniaRonder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:photographOfRonder a ex:Photograph ;
    ex:prefLabel "Photograph of Ronder" ;
    ex:description "A photograph of the showman Ronder showing a dreadful face resembling a human pig or wild boar, with a formidable, bestial countenance, small vicious eyes, and a heavy-jowled face. It was shown to Holmes and Watson by Mrs. Ronder." ;
    ex:depictsSubject :ronder ;
    ex:ownedBy :eugeniaRonder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:ronderPerformancePhotograph a ex:Photograph ;
    ex:prefLabel "Photograph of the Ronder Performance" ;
    ex:description "A photograph of the performance inside the lion's cage at Ronder's Wild Beast Show, found in Holmes's commonplace books. It shows Ronder as a huge porcine person and his wife as a very magnificent woman. The photograph documents both Ronder and Eugenia Ronder performing with the lion Sahara King." ;
    ex:depictsSubject :ronder, :eugeniaRonder, :saharaKing ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:plantedRevolver a ex:FictionalObject, ex:Weapon ;
    ex:prefLabel "Planted Revolver" ;
    ex:description "One of a matched pair of Neil Gibson's revolvers. Mrs. Gibson discharged one chamber and planted the weapon on the floor of Grace Dunbar's wardrobe to frame her for the murder. The calibre corresponded with the bullet found in Mrs. Gibson's body. Its discovery was the most damning evidence against Dunbar, though Holmes argued that no guilty person would leave such obvious evidence in their own wardrobe." ;
    ex:ownedBy :neilGibson ;
    ex:locatedAt :thorPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:presburyWoodenBox a ex:FictionalObject, ex:Container ;
    ex:prefLabel "Presbury's Wooden Box" ;
    ex:description "A small carved wooden box brought back by Professor Presbury from his travels. It is in the quaint German carved style. Kept in Presbury's instrument cupboard with the key on his watch-chain. When opened by Holmes, it was found to contain an empty phial, a nearly full phial of clear liquid (langur serum), a hypodermic syringe, and several letters from A. Dorak and H. Lowenstein. Presbury was very angry when Bennett accidentally touched it." ;
    ex:locatedAt :presburyHouse ;
    ex:ownedBy :professorPresbury ;
    ex:contains :rejuvenationSerum ;
    ex:contains :hypodermicSyringe ;
    ex:contains :dorakLetters ;
    ex:contains :lowensteinLetter ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:prescottCounterfeitNotes a ex:Object, ex:Document ;
    ex:prefLabel "Prescott's Counterfeit Notes" ;
    ex:description "Two thousand counterfeit banknotes worth one hundred pounds each, neatly arranged in bundles on a small table in the secret cellar beneath 136 Little Ryder Street. Produced by Rodger Prescott and described as indistinguishable from genuine Bank of England notes." ;
    ex:createdBy :rodgerPrescott ;
    ex:locatedAt :136LittleRyderStreetCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:prescottCounterfeitingPress a ex:Object ;
    ex:prefLabel "Prescott's Counterfeiting Press" ;
    ex:description "A printing press used by Rodger Prescott for counterfeiting, hidden in a secret cellar beneath 136 Little Ryder Street. The outfit included the press, great rolls of paper, a litter of bottles, and two thousand counterfeit notes worth one hundred pounds each. Scotland Yard had known of its existence but had been unable to locate it after Prescott's death until Killer Evans's scheme led to its discovery." ;
    ex:ownedBy :rodgerPrescott ;
    ex:locatedAt :136LittleRyderStreetCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:nathanGarridebCollection a ex:Object ;
    ex:prefLabel "Nathan Garrideb's Collection" ;
    ex:description "An extensive museum-like collection housed in Nathan Garrideb's rooms at 136 Little Ryder Street. It included geological and anatomical specimens, cases of butterflies and moths, ancient coins, a cabinet of flint instruments, fossil bones, plaster skulls labeled 'Neanderthal,' 'Heidelberg,' and 'Cro-Magnon,' a powerful microscope with a tall brass tube, and a Japanese vase. Nathan considered the collection good but not very valuable, and noted that adequate cataloguing of one cabinet would take three months." ;
    ex:ownedBy :nathanGarrideb ;
    ex:locatedAt :136LittleRyderStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:nathanGarridebBrassPlate a ex:Object ;
    ex:prefLabel "Nathan Garrideb's Brass Plate" ;
    ex:description "A small brass plate on the exterior of 136 Little Ryder Street bearing Nathan Garrideb's name. Holmes noted its discoloured surface, indicating it had been there for some years, confirming the name was genuine." ;
    ex:ownedBy :nathanGarrideb ;
    ex:locatedAt :136LittleRyderStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:prussicAcidBottle a ex:Poison ;
    ex:prefLabel "Prussic Acid Bottle" ;
    ex:description "A small blue bottle with a red poison label containing prussic acid (hydrogen cyanide) with a pleasant almondy odour. It was sent by post to Holmes by Eugenia Ronder with the message 'I send you my temptation. I will follow your advice.' This indicated she had abandoned her suicidal intentions at Holmes's urging." ;
    ex:sentBy :eugeniaRonder ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:purpleIndeliblePencil a ex:Object ;
    ex:prefLabel "Purple Indelible Pencil" ;
    ex:description "A purple indelible pencil used by Dr. Ray Ernest to write 'We we--' on the wall of the strong-room just above the skirting, a foot above the ground, while dying from gas poisoning. He was apparently trying to write 'We were murdered' but lost his senses before he could finish." ;
    ex:ownedBy :rayErnest ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:rejuvenationSerum a ex:FictionalObject, ex:Serum ;
    ex:prefLabel "Rejuvenation Serum" ;
    skos:altLabel "langur serum" ;
    skos:altLabel "strength-giving serum" ;
    ex:description "A rejuvenation serum created by H. Lowenstein of Prague, derived from the black-faced langur monkey because a specimen was accessible, though Lowenstein notes anthropoid serum would have been better and nearer to human. It is a clear liquid stored in phials and administered by hypodermic syringe. When taken on a nine-day cycle, it causes simian behavioral effects including crawling on hands and feet, climbing with incredible agility, thick horny knuckles, and increased energy and vitality. The serum is supplied to Presbury through A. Dorak on Commercial Road. Holmes describes it as poison and holds Lowenstein criminally responsible." ;
    ex:ownedBy :professorPresbury ;
    ex:createdBy :lowenstein ;
    ex:suppliedBy :dorak ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:ridingWhip a ex:Weapon ;
    ex:prefLabel "Riding-Whip" ;
    ex:description "A riding-whip used by Ronder to lash his wife Eugenia when she complained about his treatment of her." ;
    ex:usedBy :ronder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:roy a ex:FictionalObject, ex:Animal ;
    ex:prefLabel "Roy" ;
    ex:description "Roy is Professor Presbury's wolfhound, described as a dear and affectionate animal who was formerly devoted to his master. After Presbury began taking the langur serum, Roy repeatedly attacked him during his episodes, detecting the simian change through smell. Roy attacked on July 2nd, July 11th, and July 20th, after which he was banished to the stables and chained. His collar was originally made for a thick-necked Newfoundland. During the final observed episode, Presbury deliberately provoked Roy by throwing pebbles and prodding with a stick. The collar slipped and Roy attacked, biting Presbury's throat near the carotid artery and causing serious haemorrhage. Roy responded to Bennett's voice and was secured. Holmes concluded that it was the monkey in Presbury, not the professor himself, that Roy attacked and that had provoked Roy." ;
    ex:animalType "wolfhound" ;
    ex:locatedAt :presburyHouse ;
    ex:ownedBy :professorPresbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:saharaKing a ex:Animal ;
    ex:prefLabel "Sahara King" ;
    ex:description "Sahara King is a North African lion that was part of Ronder's Wild Beast Show. Both Ronder and his wife would give exhibitions inside its cage and feed it at night. On the night of the Abbas Parva incident, the lion was released from its cage by Eugenia Ronder as part of the murder plot. It attacked Mrs. Ronder, terribly mutilating her face. It was driven back into its cage by Leonardo, Griggs, and other circus men using poles." ;
    ex:ownedBy :rondersWildBeastShow ;
    ex:attacks :eugeniaRonder ;
    ex:hasParticipatedIn :abbasParvaIncident ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:shoscombePrince a ex:Racehorse ;
    ex:prefLabel "Shoscombe Prince" ;
    skos:altLabel "the Prince" ;
    ex:description "Shoscombe Prince is a racehorse colt owned by Sir Robert Norberton and trained by John Mason at Shoscombe Old Place. He is described as the best colt in England. Lady Beatrice loved him and would visit daily, and he would prick up his ears at the sound of her carriage wheels and trot out for a lump of sugar. Sir Robert enters him in the Derby at long odds (nearer a hundred when first backed, down to forties). The public does not know how good the horse is because Sir Robert uses the Prince's half-brother as a decoy for training spins. Shoscombe Prince ultimately wins the Derby, netting Sir Robert eighty thousand pounds in bets." ;
    ex:ownedBy :robertNorberton ;
    ex:halfSiblingOf :shoscombePrinceHalfBrother ;
    ex:locatedIn :shoscombeOldPlace ;
    ex:enteredIn :shoscombeDerbyRace ;
    ex:winnerOf :shoscombeDerbyRace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombePrinceHalfBrother a ex:Racehorse ;
    ex:prefLabel "Shoscombe Prince's Half-Brother" ;
    ex:description "An unnamed racehorse that is the half-brother of Shoscombe Prince. He is used by Sir Robert Norberton as a decoy, sent out for training spins to fool the racing touts. He is visually indistinguishable from Shoscombe Prince but is two lengths per furlong slower. His name is not given in the text." ;
    ex:ownedBy :robertNorberton ;
    ex:halfSiblingOf :shoscombePrince ;
    ex:locatedIn :shoscombeOldPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:signOfTheFourCard a ex:Document ;
    ex:prefLabel "The Sign of the Four Card" ;
    ex:description "Torn piece of paper or card with 'The sign of the four' scrawled across it. Left by Jonathan Small as a calling card. Found pinned to Major Sholto's chest after his death, and left on the table beside Bartholomew Sholto's body. Corresponds to the signature on Captain Morstan's chart. Represents the pact of the four associates: Jonathan Small, Abdullah Khan, Mahomet Singh, and Dost Akbar." ;
    ex:createdBy :jonathanSmall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:southAmericanWeapons a ex:FictionalObject, ex:WeaponCollection ;
    ex:prefLabel "South American Weapons Collection" ;
    ex:description "A fine collection of South American utensils and weapons displayed on the upper walls of the central room at Cheeseman's, on yellow plaster above the half-panelling. The collection was brought by Mrs. Ferguson, the Peruvian wife. Holmes examines them with care. The collection includes a small bird-bow with a quiver of arrows dipped in curare or similar poison." ;
    ex:locatedAt :cheesemansMainRoom ;
    ex:ownedBy :mrsFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:southAmericanWeaponsCollection a ex:FictionalObject, ex:Collection ;
    ex:prefLabel "South American Weapons Collection" ;
    ex:description "A fine collection of South American utensils and weapons displayed on the walls of the central room at Cheeseman's, Lamberley. Brought by Mrs. Ferguson, the Peruvian second wife of Robert Ferguson. Holmes examines them with quick curiosity upon arrival. The collection includes a small bird-bow with a quiver of arrows dipped in curare." ;
    ex:locatedAt :cheesemans ;
    ex:ownedBy :mrsFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:suicideRevolver a ex:FictionalObject, ex:Weapon ;
    ex:prefLabel "Suicide Revolver" ;
    ex:description "The second revolver from Neil Gibson's matched pair. Mrs. Gibson used it to shoot herself at Thor Bridge. She tied it with string to a heavy stone hung over the bridge parapet, so that upon releasing her grip after firing, the weight of the stone whisked the revolver over the parapet into Thor Mere, removing the weapon from the scene and making her suicide appear to be murder. The mechanism left a chip on the underside of the stone balustrade." ;
    ex:ownedBy :neilGibson ;
    ex:locatedAt :thorMere ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:sutroTelegram a ex:FictionalObject , ex:Telegram ;
    ex:prefLabel "Telegram from Mr. Sutro" ;
    ex:description "A telegram sent by Mr. Sutro to Sherlock Holmes the morning after the burglary. Reads: 'Please come out at once. Client's house burgled in the night. Police in possession.'" ;
    ex:authoredBy :mrSutro ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:etherCarfax a ex:Object ;
    ex:prefLabel "Injected Ether" ;
    ex:description "Ether injected by Watson as part of the emergency resuscitation of Lady Frances Carfax after she was found alive but nearly suffocated in the coffin." ;
    ex:usedBy :johnWatson ;
    ex:usedOn :ladyFrancesCarfax ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:eustaceBrackenstallCudgel a ex:Weapon ;
    ex:prefLabel "Sir Eustace's Blackthorn Cudgel" ;
    skos:altLabel "blackthorn stick" ;
    ex:description """Sir Eustace Brackenstall's favourite blackthorn cudgel. He carried it when he confronted the intruder and used it to strike Lady Brackenstall across the face. Found across his clenched hands after his death.""" ;
    ex:ownedBy :eustaceBrackenstall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:eustaceBrackenstallDecanter a ex:Object ;
    ex:prefLabel "Sir Eustace's Decanter" ;
    ex:description """A decanter thrown by Sir Eustace Brackenstall at Theresa Wright after she confronted him about calling her mistress a name. Referenced in the backstory of Sir Eustace's violent character.""" ;
    ex:ownedBy :eustaceBrackenstall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:expandingBullets a ex:Object ;
    ex:prefLabel "Expanding revolver bullets" ;
    skos:altLabel "soft-nosed bullets" ;
    skos:altLabel "soft revolver bullets" ;
    ex:description "Soft-nosed revolver bullets fired from Von Herder's air-gun. Mushroomed out upon impact. One killed Ronald Adair, another was fired at the wax bust. Holmes notes the 'genius' of firing revolver bullets from an air-gun." ;
    ex:weaponUsedIn :murderOfRonaldAdair ;
    ex:weaponUsedIn :camdenHouseStakeout ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:fairbairnMaryBoat a ex:RowingBoat ;
    ex:prefLabel "Fairbairn and Mary's hired boat" ;
    ex:description "Rowing boat hired by Fairbairn and Mary at New Brighton. Bodies tied into it, plank stoved, sank." ;
    ex:locatedIn :newBrighton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:floorboardHidingPlace a ex:Object ;
    ex:prefLabel "Floorboard Hiding-Place" ;
    skos:altLabel "the hiding-place" ;
    skos:altLabel "small black cavity" ;
    ex:description "A small black cavity concealed beneath a hinged wooden square in the flooring at 16 Godolphin Street, under the drugget carpet. Eduardo Lucas quickly thrust the diplomatic document into this hiding-place and covered it when he heard steps in the passage (Mme. Fournaye approaching). Holmes discovered it by prying up the floorboard while Lestrade questioned Constable MacPherson, but found it empty as Lady Hilda had already retrieved the letter." ;
    ex:locatedIn :16GodolphinStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:forcedMarriageLicense a ex:Document ;
    ex:prefLabel "Forced marriage license" ;
    ex:description "A marriage license obtained by Williamson for the forced marriage of Violet Smith to Jack Woodley. Holmes declared it was obtained by trickery." ;
    ex:ownedBy :williamsonExClergyman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:forgedHotelLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Forged Hotel Letter" ;
    ex:description "A forged letter bearing the mark of the Englischer Hof hotel, brought by a young Swiss messenger. Claimed an English lady in the last stage of consumption had arrived at the hotel and needed to see an English doctor. The letter was actually written by a tall Englishman (one of Moriarty's agents) who came to the hotel after Holmes and Watson left, to lure Watson away from Holmes at Reichenbach Falls." ;
    ex:locatedAt :englischerHof ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:fortescueExamPaper a ex:Document ;
    ex:prefLabel "Fortescue Scholarship Examination Paper" ;
    skos:altLabel "exam paper" ;
    skos:altLabel "proofs" ;
    ex:description "The examination paper for the Fortescue Scholarship consisting of a large passage of Greek translation — half a chapter of Thucydides — which candidates had not seen. Arrived from the printers as three long proof slips at about three o'clock. Soames was reviewing them for accuracy. The proofs were left on Soames's desk while he went to tea. One slip was found on the floor, one on the side table near the window, and the third where Soames left it, indicating they had been disturbed and partially copied." ;
    ex:relatedTo :fortescueScholarship ;
    ex:locatedAt :soamesSittingRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:garciasGuitar a ex:Object ;
    ex:prefLabel "Garcia's guitar" ;
    ex:description "A guitar found among Garcia's personal property at Wisteria Lodge." ;
    ex:ownedBy :aloysiusGarcia ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:gilchristsJumpingShoes a ex:Clothing ;
    ex:prefLabel "Gilchrist's Jumping Shoes" ;
    skos:altLabel "jumping shoes" ;
    skos:altLabel "spiked shoes" ;
    ex:description "Athletic shoes with several sharp spikes, used by Gilchrist for long jump practice. The spikes caused the three-inch cut in Soames's red leather desk surface when Gilchrist placed the shoes on the table. The clay from the jumping pit adhered to the spikes. Gilchrist grabbed the shoes when fleeing to the bedroom but forgot his gloves." ;
    ex:ownedBy :gilchrist ;
    ex:relatedTo :fortescueExamTampering ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:gilchristsLetter a ex:Letter ;
    ex:prefLabel "Gilchrist's Letter to Soames" ;
    ex:description "A letter written by Gilchrist to Soames early in the morning after the incident, during a restless night and before he knew his crime had been detected. In it, Gilchrist stated he had determined not to sit the examination and had been offered a commission in the Rhodesian Police, planning to go to South Africa at once." ;
    ex:author :gilchrist ;
    ex:recipient :hiltonSoames ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:gilchristsTanGloves a ex:Clothing ;
    ex:prefLabel "Gilchrist's Tan Gloves" ;
    skos:altLabel "gloves" ;
    ex:description "Tan-coloured gloves belonging to Gilchrist. He placed them on the chair near the window when he entered Soames's room to copy the proofs. When he fled to the bedroom, he forgot to take the gloves. Bannister recognized them immediately as Gilchrist's and sat on the chair to conceal them from Soames." ;
    ex:ownedBy :gilchrist ;
    ex:relatedTo :fortescueExamTampering ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:godfreyLettersToDodd a ex:Letter ;
    ex:prefLabel "Godfrey's Letters to Dodd" ;
    ex:description "Two letters from Godfrey Emsworth to James Dodd: one from the hospital at Cape Town and one from Southampton. These were the last communications Dodd received from Godfrey. Dodd showed them to Colonel Emsworth as proof of their friendship." ;
    ex:ownedBy :jamesDodd ;
    ex:createdBy :godfreyEmsworth ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:goldenPinceNez a ex:Object ;
    ex:prefLabel "Golden Pince-Nez" ;
    skos:altLabel "the pince-nez" ;
    skos:altLabel "the glasses" ;
    ex:description "A pair of gold-mounted pince-nez spectacles with two broken ends of black silk cord. The lenses are concave and of unusual strength, indicating the wearer was extremely short-sighted. The clips are lined with tiny bands of cork to soften pressure on the nose—one cork is discoloured and worn, the other new, indicating two visits to an optician within a few months. The clips are wide, indicating a broad nose. Found clutched in Willoughby Smith's right hand after his murder, snatched from the face of his killer Anna. Holmes deduced detailed physical characteristics of the wearer from examining them." ;
    ex:ownedBy :annaCoram ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:gordonPortrait a ex:Portrait ;
    ex:prefLabel "Portrait of General Gordon" ;
    ex:description "Newly framed picture in Watson's possession at 221B Baker Street. Triggers Watson's train of thought." ;
    ex:ownedBy :johnWatson ;
    ex:locatedIn :221bBakerStreet ;
    ex:depictsSubject :generalGordon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:gorgianoMurderKnife a ex:Weapon ;
    ex:prefLabel "Gorgiano Murder Knife" ;
    ex:description "A knife with a white haft used by Gennaro Lucca to kill Giuseppe Gorgiano. It was driven blade-deep into Gorgiano's throat and was still projecting from his body when found." ;
    ex:locatedIn :howeStreetFlats ;
    ex:usedBy :gennaroLucca ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:grunerPotteryBook a ex:Document ;
    ex:prefLabel "Gruner's Book on Chinese Pottery" ;
    ex:description "A book written by Baron Gruner on the subject of Chinese pottery, establishing him as a recognized authority on the subject. Watson claims to be aware of it during his disguise as Dr. Hill Barton." ;
    ex:author :adelbertGruner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:grunerLoveDiary a ex:Document ;
    ex:prefLabel "Gruner's Love Diary" ;
    skos:altLabel "Gruner's brown leather book" ;
    skos:altLabel "the book" ;
    ex:description """A brown leather book with a lock and Baron Gruner's arms in gold on the outside. It contains snapshot photographs, names, details, and everything about the women Gruner has ruined — described as a beastly book. Kitty Winter saw it when Gruner showed it to her while drunk. It was kept in the pigeon-hole of the old bureau in the inner study at Vernon Lodge. Holmes stole it during the burglary. Sir James Damery took it away to use in breaking off the engagement. It is in Gruner's own handwriting.""" ;
    ex:ownedBy :adelbertGruner ;
    ex:locatedIn :vernonLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:harkerNewspaperArticle a ex:Document ;
    ex:prefLabel "Harker's Newspaper Article" ;
    ex:description "A highly sensational and flowery newspaper article written by Horace Harker about the Kensington incident, headlined 'Kensington Outrage. Murder by a Madman.' Occupied two columns. Included the false theory (planted by Holmes) that the incidents arose from a homicidal lunatic with Napoleonic delusions." ;
    ex:createdBy :horaceHarker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:heavyGameBook a ex:Document ;
    ex:prefLabel "Heavy Game of the Western Himalayas" ;
    ex:description "Book authored by Colonel Sebastian Moran, published 1881." ;
    dc:date "1881"^^xsd:gYear ;
    ex:authoredBy :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:hendersonDogWhip a ex:Object, ex:Weapon ;
    ex:prefLabel "Henderson's dog-whip" ;
    ex:description "A dog-whip used by Henderson/Murillo. He twice lashed people with it, avoiding prosecution only through his long purse and heavy compensation." ;
    ex:ownedBy :donMurillo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:hildaIndiscreetLetter a ex:Letter ;
    ex:prefLabel "Lady Hilda's Indiscreet Letter" ;
    ex:description "An indiscreet letter written by Lady Hilda before her marriage. A foolish letter of an impulsive loving girl. She meant no harm but her husband would have thought it criminal and his confidence would have been forever destroyed. Came into the possession of Eduardo Lucas, who used it to blackmail Lady Hilda into stealing the diplomatic letter. Lucas returned it to her in exchange for the diplomatic document at Godolphin Street." ;
    ex:ownedBy :ladyHildaTrelawneyHope ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:hillBartonCard a ex:Document ;
    ex:prefLabel "Dr. Hill Barton Card" ;
    ex:description "A printed visiting card reading 'Dr. Hill Barton, 369 Half Moon Street.' Used by Watson as his alias identity when visiting Baron Gruner to present the Ming saucer." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:holmesAgreementPaper a ex:Object, ex:Document ;
    ex:prefLabel "Holmes's agreement paper" ;
    skos:altLabel "written paper" ;
    ex:description "A written paper that Holmes laid upon the side-table at Baker Street as bait to lure Patrick Cairns into position. When Cairns bent to sign the supposed employment agreement, Holmes handcuffed him." ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:holmesAlpineStock a ex:FictionalObject, ex:WalkingStick ;
    ex:prefLabel "Holmes's Alpine-Stock" ;
    skos:altLabel "Alpine-stock" ;
    ex:description "Holmes's walking stick, left leaning against a rock at Reichenbach Falls. Marked the spot where Holmes and Watson had stood. Watson finding it still there, with no sign of Holmes, turned him cold and sick — it meant Holmes had not gone to Rosenlaui but had remained on the narrow path." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:holmesCigaretteBox a ex:Object ;
    ex:prefLabel "Holmes's cigarette-box" ;
    ex:description "Left by Holmes with his farewell note and walking stick at Reichenbach Falls." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesCigaretteCase a ex:FictionalObject, ex:CigaretteCase ;
    ex:prefLabel "Holmes's Silver Cigarette Case" ;
    ex:description "A silver cigarette case carried by Sherlock Holmes. Left on a boulder at Reichenbach Falls to weigh down his farewell letter to Watson. The gleam of the silver caught Watson's eye from the top of the boulder." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:holmesCrimeNotebook a ex:Document ;
    ex:prefLabel "Holmes's Crime Notebook" ;
    ex:description "A squat notebook kept by Sherlock Holmes in a table drawer at 221B Baker Street. It contains detailed records of Count Negretto Sylvius's criminal activities including the death of Mrs. Harold, the life history of Miss Minnie Warrender, the Riviera train robbery, and the forged check on the Credit Lyonnais." ;
    ex:locatedAt :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:holmesEarMonographs a ex:Monograph ;
    ex:prefLabel "Holmes's monographs on the human ear" ;
    ex:description "Two short monographs by Holmes on the subject of the human ear, published in the Anthropological Journal last year." ;
    ex:hasAuthor :sherlockHolmes ;
    ex:publishedIn :anthropologicalJournal ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:holmesFarewellLetter a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Holmes's Farewell Letter" ;
    ex:description "Three pages torn from Holmes's notebook, addressed to Watson, left at Reichenbach Falls under his silver cigarette case. Written 'through the courtesy of Mr. Moriarty,' the letter mentions that Moriarty awaits Holmes's convenience for their final discussion. Holmes directs Watson to tell Inspector Patterson about papers in pigeonhole M in a blue envelope inscribed 'Moriarty.' Holmes notes he had made every disposition of his property and handed it to Mycroft. The direction was as precise and the writing as firm and clear as if written in his study." ;
    ex:authoredBy :sherlockHolmes ;
    ex:addressedTo :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:holmesFlask a ex:Object ;
    ex:prefLabel "Holmes's flask" ;
    ex:description "Flask of brandy Holmes used to revive Watson after Watson fainted upon seeing Holmes alive for the first time since Reichenbach." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesFordCar a ex:Object, ex:Vehicle ;
    ex:prefLabel "Holmes's Ford Car" ;
    skos:altLabel "the little car" ;
    ex:description "A small Ford car driven by Watson disguised as Holmes's chauffeur. Nearly passed by Von Herling's Benz in the village street. Used to transport the captured Von Bork to London and Scotland Yard." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:holmesHandcuffs a ex:Object ;
    ex:prefLabel "Holmes's handcuffs" ;
    ex:description "Handcuffs that Holmes deftly fastened upon Patrick Cairns's wrists while pretending to examine the agreement paper, leading to Cairns's capture." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:holmesIndexOfBiographies a ex:Document ;
    ex:prefLabel "Holmes's index of biographies" ;
    skos:altLabel "the index" ;
    ex:description "Holmes's personal reference index. Contains entries under 'M' including Moriarty ('one of the great brains of the century'), Morgan the poisoner, Merridew of abominable memory, Mathews, and Colonel Moran. Holmes had written 'The second most dangerous man in London' on the margin of Moran's entry. Kept on a shelf at 221B Baker Street." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesLetterToBrown a ex:Letter ;
    ex:prefLabel "Holmes's Letter to Josiah Brown" ;
    ex:description "A note sent by Holmes via express messenger to Josiah Brown, warning him and instructing him to lock every door and await developments." ;
    ex:createdBy :sherlockHolmes ;
    ex:sentTo :josiahBrown ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:holmesLetterToSandeford a ex:Letter ;
    ex:prefLabel "Holmes's Letter to Sandeford" ;
    ex:description "A letter written by Holmes to Mr. Sandeford, offering to pay ten pounds for the Napoleon bust in his possession. Sent by express messenger." ;
    ex:createdBy :sherlockHolmes ;
    ex:sentTo :mrSandeford ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:holmesMagnifyingGlass a ex:Object ;
    ex:prefLabel "Holmes's Magnifying Glass" ;
    ex:description "A large round magnifying glass used by Sherlock Holmes in his investigations. At Lauriston Gardens, Holmes trotted about the room with the magnifying glass examining marks invisible to others, and used it to examine the RACHE inscription on the wall letter by letter." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc ;
    dc:source :studyInScarletDoc .

:holmesMemorandumBook a ex:Document ;
    ex:prefLabel "Holmes's Memorandum Book" ;
    skos:altLabel "memorandum-book" ;
    ex:description "A memorandum book in which Holmes notes down Sir James Damery's private telephone number XX.31. Holmes sits with it open upon his knee." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:holmesNoteToPolice a ex:Document ;
    ex:prefLabel "Holmes's note to the police" ;
    ex:description "A note scribbled by Holmes on a leaf from his notebook, sent via the Charlington Hall groom to the superintendent at Farnham police station requesting police assistance." ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:holmesParasol a ex:Clothing ;
    ex:prefLabel "Holmes's Parasol" ;
    ex:description "A very baggy parasol used by Sherlock Holmes as part of his old woman disguise while following Count Sylvius. It leans against the sofa at 221B Baker Street. Sylvius politely handed it to the disguised Holmes in the Minories." ;
    ex:locatedAt :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:holmesRevolver a :Weapon , :Firearm ;
    ex:prefLabel "Holmes Revolver" ;
    skos:altLabel "the pistol" ;
    ex:description "A revolver kept by Sherlock Holmes in a drawer at 221B Baker Street." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc ;
    dc:source :solitaryCyclistDoc .

:holmesScrapbook a ex:Document ;
    ex:prefLabel "Holmes's Scrapbook" ;
    ex:description "A great scrapbook in which Sherlock Holmes arranges and indexes some of his recent material. He is working on it when Mrs. Warren arrives to consult him." ;
    ex:locatedIn :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:holmesStradivarius a ex:Object ;
    ex:prefLabel "Holmes's Stradivarius" ;
    ex:description "Violin. Worth at least 500 guineas. Purchased at a Jew broker's in Tottenham Court Road for 55 shillings." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:holmesTelegramHouses a ex:Object, ex:Telegram ;
    ex:prefLabel "Holmes's telegram listing large houses" ;
    ex:description "A reply telegram received by Holmes listing the large houses near Oxshott: Lord Harringby at The Dingle, Sir George Ffolliott at Oxshott Towers, Mr. Hynes Hynes at Purdley Place, Mr. James Baker Williams at Forton Old Hall, Mr. Henderson at High Gable, and Rev. Joshua Stone at Nether Walsling." ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:holmesTelegramToCroker a ex:Telegram ;
    ex:prefLabel "Holmes's Telegram to Captain Croker" ;
    ex:description """A telegram sent by Sherlock Holmes from the Charing Cross telegraph office summoning Captain Jack Croker to Baker Street. Croker confirmed he received it and came at the appointed hour.""" ;
    ex:author :sherlockHolmes ;
    ex:recipient :jackCroker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:holmesTelegramToMycroft a ex:Document ;
    ex:prefLabel "Holmes's Telegram to Mycroft" ;
    ex:description "Telegram sent by Holmes from London Bridge requesting a complete list of all foreign spies or international agents known to be in England with full addresses." ;
    ex:authorOf :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:holmesTelegramToWatson a ex:Telegram ;
    ex:prefLabel "Holmes's Telegram to Watson" ;
    ex:description "A telegram sent by Sherlock Holmes to Dr. Watson asking him to write about the Cornish Horror case, reading: 'Why not tell them of the Cornish horror--strangest case I have handled.' Sent on a Tuesday, thirteen years after the events of the story." ;
    ex:sentBy :sherlockHolmes ;
    ex:sentTo :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:holmesTestSpear a ex:Object, ex:Weapon ;
    ex:prefLabel "Holmes's barbed-headed spear" ;
    skos:altLabel "barbed-headed spear" ;
    ex:description "A huge barbed-headed spear that Holmes brought to Baker Street from Allardyce's butcher shop, tucked like an umbrella under his arm. Used to test whether a single blow could transfix a dead pig, as part of his investigation into the Black Peter case." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:holmesViolinCase a ex:Object ;
    ex:prefLabel "Holmes's violin-case" ;
    ex:description "Violin-case present in 221B Baker Street. Observed by Watson upon return, among the familiar landmarks of the room." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesVisitingCard a ex:VisitingCard ;
    ex:prefLabel "Holmes's visiting card" ;
    ex:description "Holmes scribbles Browner's name on the back and throws it to Lestrade." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:holmesWalkingStickReichenbach a ex:Object ;
    ex:prefLabel "Holmes's walking stick (Reichenbach)" ;
    ex:description "Walking stick left by Holmes with his farewell note and cigarette-box at Reichenbach Falls." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesWaxBust a ex:Object ;
    ex:prefLabel "Wax bust of Holmes" ;
    skos:altLabel "the dummy" ;
    skos:altLabel "the effigy" ;
    ex:description "Wax-coloured model of Sherlock Holmes created by Oscar Meunier of Grenoble, who spent some days doing the moulding. A perfect facsimile placed on a small pedestal table with Holmes's old dressing-gown draped round it. Mrs. Hudson moved it every quarter of an hour, working from the front on her knees. Shot through the head by Moran's air-gun bullet, which flattened itself on the wall behind." ;
    ex:constructedBy :oscarMeunier ;
    ex:depiction :sherlockHolmes ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesWaxDummy a ex:Object ;
    ex:prefLabel "Wax Dummy of Holmes" ;
    skos:altLabel "the dummy" ;
    skos:altLabel "the effigy" ;
    ex:description "A wax facsimile of Sherlock Holmes made by the French modeller Tavernier. It wears a dressing-gown and is seated in an armchair by the bow window at 221B Baker Street, with the face turned three-quarters towards the window and downward as though reading a book. The head is detachable and the figure is positioned at different angles to appear lifelike. It is used to draw potential assassins' attention while Holmes operates elsewhere in the rooms. Billy shows it to Watson and puts it at different angles." ;
    ex:locatedAt :221bBakerStreet ;
    ex:createdBy :tavernier ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:holyLandMap a ex:Document ;
    ex:prefLabel "Map of the Holy Land" ;
    ex:description "A map of the Holy Land with special reference to the kingdom of the Midianites, supposedly being prepared by Dr. Shlessinger (Holy Peters) as part of his missionary cover story at Baden." ;
    ex:createdBy :henryPeters ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:holyWarBook a ex:Document ;
    ex:prefLabel "The Holy War" ;
    ex:description "Book offered for sale by Holmes in his book-collector disguise to Watson. 'A bargain' according to Holmes." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:hopkinsChart a ex:Document ;
    ex:prefLabel "Hopkins's Chart" ;
    skos:altLabel "the rough plan" ;
    ex:description "A rough chart or plan drawn by Stanley Hopkins showing the position of Professor Coram's study and the various points of the case, including corridors and exits. Unfolded and laid across Holmes's knee." ;
    ex:ownedBy :stanleyHopkins ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:hopkinsLetterAbbeyGrange a ex:Letter ;
    ex:prefLabel "Hopkins's Letter from Abbey Grange" ;
    ex:description """A letter from Inspector Stanley Hopkins to Sherlock Holmes requesting immediate assistance at Abbey Grange, Marsham, Kent, sent at 3:30 a.m. Written on crackling paper with an E.B. monogram and coat-of-arms. Mentions releasing the lady and leaving Sir Eustace.""" ;
    ex:author :stanleyHopkins ;
    ex:recipient :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:hornHandledClaspKnife a ex:Knife ;
    ex:prefLabel "Horn-handled Clasp Knife" ;
    ex:description "A knife found lying in a pool of blood beside Pietro Venucci's body at 131 Pitt Street. Uncertain whether it was the murder weapon or belonged to the dead man." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:hornHandledDagger a ex:Weapon ;
    ex:prefLabel "Horn-Handled Dagger" ;
    ex:description "A formidable horn-handled, two-edged dagger found beside Giuseppe Gorgiano's right hand at the murder scene in the Howe Street flats. It belonged to Gorgiano." ;
    ex:locatedIn :howeStreetFlats ;
    ex:ownedBy :giuseppeGorgiano ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:howeStreetCandle a ex:Candle ;
    ex:prefLabel "Howe Street Signal Candle" ;
    ex:description "A candle used to send coded signals from the third floor window of the Howe Street flats. Gennaro Lucca used it to signal warnings ('ATTENTA' and 'PERICOLO') to Emilia Lucca across the way at Mrs. Warren's house. Holmes later used it to flash 'Vieni' ('Come') to summon Emilia." ;
    ex:locatedIn :howeStreetFlats ;
    ex:usedBy :gennaroLucca ;
    ex:usedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:imperialTokay a ex:Object ;
    ex:prefLabel "Imperial Tokay Wine" ;
    skos:altLabel "Tokay" ;
    ex:description "A heavily sealed, dust-covered bottle of Tokay wine from Franz Josef's special cellar at Schoenbrunn Palace. Served with two high glasses on a salver in Von Bork's study. Holmes and Watson drink it after capturing Von Bork. Holmes describes it as 'a remarkable wine.'" ;
    ex:locatedIn :vonBorkStudy ;
    ex:ownedBy :vonBork ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:indianDaggerSecondStain a ex:Dagger ;
    ex:prefLabel "Curved Indian Dagger" ;
    ex:description "The murder weapon used to kill Eduardo Lucas. A curved Indian dagger plucked down from a trophy of Oriental arms which adorned one of the walls at 16 Godolphin Street. Used by Mme. Fournaye to stab Lucas to the heart." ;
    ex:locatedIn :16GodolphinStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:intruderPenknife a ex:Object, ex:Weapon ;
    ex:prefLabel "Intruder's penknife" ;
    skos:altLabel "small penknife" ;
    ex:description "A very small penknife used by the intruder (John Hopley Neligan) on his first unsuccessful attempt to break into Peter Carey's cabin. Holmes deduced its use from the scratches on the lock." ;
    ex:usedBy :johnNeligan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:italianPriestDisguise a ex:FictionalObject, ex:Disguise ;
    ex:prefLabel "Italian Priest Disguise" ;
    skos:altLabel "black cassock and hat" ;
    ex:description "A disguise consisting of a black cassock and hat used by Sherlock Holmes at Victoria Station. He posed as a venerable Italian priest who spoke broken English. Watson assisted him with his luggage without recognizing him. Holmes later threw off the disguise and packed it into a hand-bag." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:johannFaberPencil a ex:Object ;
    ex:prefLabel "Johann Faber Pencil" ;
    ex:description "An unusual pencil used by the culprit to copy the examination proofs. Above the usual size, with soft lead, dark blue outer colour, and the maker's name (Johann Faber) printed in silver lettering. Only about an inch and a half remained. Holmes identified the maker from the letters 'NN' visible on the remaining fragment. Holmes sought a duplicate at four stationers in town but none kept it in regular stock." ;
    ex:relatedTo :fortescueExamTampering ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:journalDeGeneve a ex:FictionalObject, ex:Newspaper ;
    ex:prefLabel "Journal de Genève" ;
    ex:description "Swiss newspaper that published an account of the Reichenbach incident on May 6th, 1891. Watson describes this account as extremely condensed." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:ladyBrackenstallDog a ex:Animal ;
    ex:prefLabel "Lady Brackenstall's Dog" ;
    ex:description """Lady Brackenstall's dog, unnamed in the text. Sir Eustace Brackenstall drenched it with petroleum and set it on fire in a scandal that was only hushed up with difficulty.""" ;
    ex:ownedBy :maryFraser ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:ladyEvaLetters a ex:FictionalObject, ex:Letter ;
    ex:prefLabel "Lady Eva's Letters" ;
    ex:description "Several imprudent letters written by Lady Eva Brackwell to an impecunious young squire in the country. Described as 'sprightly' but not worse than imprudent. Milverton demands seven thousand pounds for their return, threatening to send them to the Earl of Dovercourt. Holmes attempts to negotiate the price down to two thousand pounds. These letters are the catalyst for the entire adventure." ;
    ex:ownedBy :charlesAugustusMilverton ;
    ex:createdBy :ladyEvaBrackwell ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:ladyFrancesJewellery a ex:Jewelry ;
    ex:prefLabel "Lady Frances's Spanish Jewellery" ;
    skos:altLabel "old Spanish jewellery" ;
    ex:description "A collection of very remarkable old Spanish jewellery consisting of silver and curiously cut diamonds, belonging to Lady Frances Carfax. She was fondly attached to it and refused to leave it with her banker, always carrying it with her. It was the target of Holy Peters and Annie Fraser's scheme. They began pawning pieces at Bovington's in Westminster Road." ;
    ex:ownedBy :ladyFrancesCarfax ;
    ex:stolenBy :henryPeters, :annieFraser ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:ladyFrancesTrunk a ex:Object ;
    ex:prefLabel "Lady Frances's Trunk" ;
    skos:altLabel "heavy trunk" ;
    ex:description "A heavy trunk belonging to Lady Frances Carfax, kept in her bedroom at the Hotel National in Lausanne. It was always scrupulously locked. The servants remarked upon it, though the hotel manager knew nothing of valuable jewellery." ;
    ex:ownedBy :ladyFrancesCarfax ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:lassusMonograph a ex:Monograph ;
    ex:prefLabel "Monograph on Polyphonic Motets of Lassus" ;
    ex:description "A monograph written by Sherlock Holmes on the Polyphonic Motets of Lassus (Orlando di Lasso). Holmes worked on it during the Bruce-Partington case and returned to it refreshed after the case concluded. Later printed for private circulation. Said by experts to be the last word upon the subject." ;
    ex:authorOf :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:leatherLeash a ex:Object ;
    ex:prefLabel "Leather Leash" ;
    ex:description "A leather leash Holmes fastened to Pompey's collar to control the draghound while tracking Dr. Armstrong's brougham." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:legionOfHonour a ex:Object ;
    ex:prefLabel "Legion of Honour" ;
    skos:altLabel "Order of the Legion of Honour" ;
    ex:description "French decoration awarded to Sherlock Holmes for the tracking and arrest of Huret the Boulevard assassin in 1894." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:leprosyNote a ex:Document ;
    ex:prefLabel "Holmes's Leprosy Note" ;
    ex:description "A scrap of loose paper from Holmes's notebook on which he wrote the single word 'Leprosy' and handed to Colonel Emsworth. This single word convinced the Colonel that Holmes had discovered his secret, leading him to relent and allow access to Godfrey." ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:lestradeNorwoodTelegram a ex:Document ;
    ex:prefLabel "Lestrade's Telegram" ;
    ex:description "Telegram sent by Inspector Lestrade to Holmes informing him of important new evidence (the thumbprint) in the Norwood Builder case." ;
    ex:createdBy :lestrade ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:lestradesArrestLetter a ex:Letter ;
    ex:prefLabel "Lestrade's arrest letter" ;
    ex:description "Letter from Lestrade to Holmes received two days after the Croydon visit. Bulky envelope containing short note and typewritten confession document." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:lestradesNoteCardboardBox a ex:Letter ;
    ex:prefLabel "Lestrade's note/letter" ;
    ex:description "Note from Lestrade to Holmes asking for help with the case. References Belfast post office inquiry and medical student theory." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:lestradeTelegramSixNapoleons a ex:Telegram ;
    ex:prefLabel "Lestrade's Telegram (Six Napoleons)" ;
    ex:description "A telegram from Lestrade to Holmes reading 'Come instantly, 131, Pitt Street, Kensington.' Summoned Holmes to the murder scene at Harker's house." ;
    ex:createdBy :lestrade ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:lodgerBrownBag a ex:Bag ;
    ex:prefLabel "Lodger's Brown Bag" ;
    ex:description "One big brown bag that was the only luggage brought by the mysterious lodger (Gennaro Lucca) when he took rooms at Mrs. Warren's house." ;
    ex:ownedBy :gennaroLucca ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:marthaBlackCat a ex:Object, ex:Animal ;
    ex:prefLabel "Martha's Black Cat" ;
    ex:description "A large black cat belonging to Martha, Von Bork's housekeeper. Sits on a stool beside her while she knits by lamplight. Name not given in text." ;
    ex:ownedBy :marthaHisLastBow ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:maryFraserDinnerDress a ex:Clothing ;
    ex:prefLabel "Lady Brackenstall's Dinner Dress" ;
    ex:description """A black sequin-covered dinner dress belonging to Lady Brackenstall. Hung upon the couch beside her in the morning room. Holmes predicted it would show a blood mark corresponding to the blood on the oaken chair seat.""" ;
    ex:ownedBy :maryFraser ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:maryLiverpoolPortrait a ex:Portrait ;
    ex:prefLabel "Liverpool portrait of Mary" ;
    ex:description "Portrait taken at Liverpool showing younger sister Mary with a man in steward's uniform (Jim Browner). Mary was unmarried at the time. At Susan Cushing's elbow." ;
    ex:locatedIn :crossStreetCroydon ;
    ex:depictsSubject :maryBrowner ;
    ex:depictsSubject :jimBrowner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:mazarinAirGun a ex:Firearm ;
    ex:prefLabel "Mazarin Air-Gun" ;
    skos:altLabel "the air-gun" ;
    ex:description "An air-gun made by Straubenzee at his workshop in the Minories. Holmes describes it as a very pretty bit of work. It is positioned in the window opposite 221B Baker Street, aimed at the wax dummy of Holmes." ;
    ex:createdBy :straubenzee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:mazarinGramophone a ex:Object ;
    ex:prefLabel "Gramophone" ;
    ex:description "A gramophone used by Sherlock Holmes during the Mazarin Stone case. Holmes plays Hoffman's Barcarole on it to make Sylvius and Merton believe he is playing the violin in his bedroom, while he actually hides behind the curtain in the sitting room to eavesdrop on their conversation. Holmes describes modern gramophones as a remarkable invention." ;
    ex:locatedAt :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:mazarinStone a ex:Jewelry ;
    ex:prefLabel "Mazarin Stone" ;
    skos:altLabel "Crown diamond" ;
    skos:altLabel "the great yellow Mazarin stone" ;
    skos:altLabel "Crown jewel" ;
    ex:description "The Mazarin Stone is a great yellow Crown diamond worth one hundred thousand pounds. It is a Crown jewel that was stolen from Whitehall by Count Negretto Sylvius and Sam Merton. Holmes was commissioned by the Prime Minister and Home Secretary to recover it. Holmes ultimately recovers the stone by snatching it from Sylvius's hand after hiding behind a curtain while Sylvius showed it to Merton. Holmes then plants it in Lord Cantlemere's overcoat pocket as a practical joke." ;
    ex:monetaryValue "100,000 pounds" ;
    ex:stolenFrom :whitehall ;
    ex:recoveredBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:mcFarlaneWalkingStick a ex:Object ;
    ex:prefLabel "McFarlane's Walking-Stick" ;
    ex:description "Oaken walking-stick belonging to John Hector McFarlane, found with blood stains. Used as evidence against him in the Norwood Builder case." ;
    ex:ownedBy :johnHectorMcFarlane ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:medicalBill a ex:Document ;
    ex:prefLabel "Receipted Medical Bill" ;
    ex:description "A receipted bill for thirteen guineas paid by Godfrey Staunton to Dr. Leslie Armstrong of Cambridge the previous month. Found by Holmes among Staunton's papers at Bentley's Hotel." ;
    ex:relatedTo :godfreyStaunton ;
    ex:relatedTo :leslieArmstrong ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:messengerNote a ex:Letter ;
    ex:prefLabel "Messenger's Note to Godfrey" ;
    ex:description "Note delivered to Godfrey Staunton at Bentley's Hotel by the bearded messenger (likely his father-in-law) around half-past ten at night. Upon reading it, Staunton fell back in his chair as if pole-axed. The note informed him of his wife's critical condition." ;
    ex:receivedBy :godfreyStaunton ;
    ex:sentBy :stauntonWifeFather ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:midianitesMonograph a ex:Document ;
    ex:prefLabel "Monograph on the Midianites" ;
    ex:description "A monograph on the kingdom of the Midianites, supposedly being written by Dr. Shlessinger (Holy Peters) as part of his missionary cover story at Baden." ;
    ex:createdBy :henryPeters ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:milvertonLegalDocument a ex:FictionalObject, ex:Document ;
    ex:prefLabel "Milverton's Legal Document" ;
    ex:description "A long legal document that Milverton reads in his study late at night, sitting in his red leather chair and blowing tobacco smoke rings. He follows the argument of the lawyer in an indolent fashion." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:milvertonNotebook a ex:FictionalObject, ex:Document ;
    ex:prefLabel "Milverton's Pocket-Book" ;
    skos:altLabel "note-book" ;
    ex:description "A bulky pocket-book carried by Milverton. He takes it out during the negotiation at 221B Baker Street. Holmes attempts to seize it but Milverton reveals his revolver. Milverton assures Holmes the compromising letters are not kept in this notebook." ;
    ex:ownedBy :charlesAugustusMilverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:milvertonRevolver a ex:FictionalObject, ex:Firearm ;
    ex:prefLabel "Milverton's Revolver" ;
    ex:description "A large revolver carried by Charles Augustus Milverton in the inside pocket of his coat. He reveals it to Holmes during the negotiation at 221B Baker Street, stating he is 'armed to the teeth' and prepared to use his weapons with the law's support." ;
    ex:ownedBy :charlesAugustusMilverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:milvertonSafe a ex:FictionalObject, ex:Object ;
    ex:prefLabel "Milverton's Safe" ;
    ex:description "A tall green safe with polished brass knobs, located in the corner between the bookcase and wall in Milverton's study at Appledore Towers. It contains numerous paper packets of blackmail materials, each tied, sealed, and inscribed. Holmes cracks it open after half an hour of work with his burgling tools, and later empties it completely, burning all the contents in the fire." ;
    ex:locatedIn :milvertonStudy ;
    ex:ownedBy :charlesAugustusMilverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:milvertonVisitingCard a ex:FictionalObject, ex:VisitingCard ;
    ex:prefLabel "Milverton's Visiting Card" ;
    ex:description "Charles Augustus Milverton's visiting card, found on the table at 221B Baker Street. It reads 'Charles Augustus Milverton, Appledore Towers, Hampstead. Agent.' On the back is written 'Will call at 6.30--C.A.M.' Holmes throws it on the floor in disgust." ;
    ex:ownedBy :charlesAugustusMilverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:mingDynastySaucer a ex:Object ;
    ex:prefLabel "Ming Dynasty Saucer" ;
    skos:altLabel "blue saucer" ;
    skos:altLabel "egg-shell pottery saucer" ;
    ex:description """A delicate little saucer of the most beautiful deep-blue colour. It is real egg-shell pottery of the Ming dynasty. Holmes states no finer piece ever passed through Christie's and a complete set would be worth a king's ransom. It comes from the illustrious client's collection and was obtained for Holmes by Sir James Damery. It is wrapped in fine Eastern silk. Watson carries it to Vernon Lodge as Dr. Hill Barton to lure Baron Gruner into examining it while Holmes burgles the inner study. Sir James takes it away at the end.""" ;
    ex:ownedBy :illustriousClient ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:moriartyBlueEnvelope a ex:FictionalObject, ex:Document ;
    ex:prefLabel "Blue Envelope Inscribed 'Moriarty'" ;
    ex:description "A blue envelope inscribed 'Moriarty' located in pigeonhole M. Contains papers needed to convict the members of Moriarty's criminal gang. Holmes mentions this in his farewell letter, directing Watson to tell Inspector Patterson about them." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:moriartyMemorandumBook a ex:FictionalObject, ex:MemorandumBook ;
    ex:prefLabel "Moriarty's Memorandum Book" ;
    ex:description "A memorandum book in which Professor Moriarty had scribbled dates recording Holmes's interference with his activities: 'You crossed my path on the 4th of January... on the 23d you incommoded me; by the middle of February I was seriously inconvenienced; at the end of March I was absolutely hampered; and now, at the close of April, I find myself placed in such a position through your continual persecution that I am in positive danger of losing my liberty.'" ;
    ex:ownedBy :professorMoriarty ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:mortimerTregennisLamp a ex:Object ;
    ex:prefLabel "Mortimer Tregennis's Lamp" ;
    ex:description "An ordinary standard lamp in Mortimer Tregennis's sitting-room at the vicarage. Had a talc shield or smoke-guard covering the top of the chimney. Was found flaring and smoking on the morning after Tregennis's murder, having burned long past daylight. Holmes examined it carefully and scraped flaky ashes and brownish powder from the talc shield, collecting half in an envelope. Dr. Sterndale had placed the devil's-foot powder on the lamp to kill Tregennis." ;
    ex:locatedIn :tredannickWollasVicarage ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:mrsMcFarlanePhotograph a ex:Photograph ;
    ex:prefLabel "Photograph of Mrs. McFarlane" ;
    ex:description "Photograph of Mrs. McFarlane (young woman) found in Oldacre's possessions. Had been defaced — slashed across with a knife — revealing Oldacre's intense hatred toward his former sweetheart. Evidence of his vindictive nature and motive for framing her son." ;
    ex:depictsSubject :mrsMcFarlaneNorwood ;
    ex:ownedBy :jonasOldacre ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:mycroftTelegram a ex:Document ;
    ex:prefLabel "Mycroft's Telegram" ;
    ex:description "Telegram from Mycroft Holmes to Sherlock Holmes: 'Must see you over Cadogen West. Coming at once. Mycroft.' Delivered by the maid at Baker Street. Prompted the investigation." ;
    ex:authorOf :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:mycroftSpyList a ex:Document ;
    ex:prefLabel "Mycroft's Spy List" ;
    ex:description "Note from Mycroft listing foreign spies and international agents known to be in England with full addresses. Named Adolph Mayer, Louis La Rothiere, and Hugo Oberstein. Sent by government messenger to Baker Street. Also contained update that Oberstein had left town and that the Cabinet awaited Holmes's report." ;
    ex:authorOf :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:neliganCandle a ex:Object ;
    ex:prefLabel "Neligan's candle" ;
    skos:altLabel "candle-end" ;
    ex:description "A candle-end that John Hopley Neligan lit after successfully breaking into Peter Carey's cabin on his second attempt. He placed it on the table while examining the log-books." ;
    ex:usedBy :johnNeligan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:neliganNotebook a ex:Object, ex:Document ;
    ex:prefLabel "Neligan's notebook" ;
    skos:altLabel "J.H.N. notebook" ;
    skos:altLabel "drab-covered note-book" ;
    ex:description "A drab-covered notebook with rough and worn exterior and discoloured leaves. Initials J.H.N. and date 1883 on the first page. Contained listings of securities: C.P.R. (Canadian Pacific Railway), Argentine, Costa Rica, and San Paulo, with pages of signs and figures. Some securities were marked with ticks (those traced on the London market). Found blood-stained on the floor near the door of Peter Carey's cabin, having been dropped after the crime was committed. Belonged to John Hopley Neligan, who had brought it to question Carey about the securities." ;
    ex:locatedIn :peterCareyCabin ;
    ex:ownedBy :johnNeligan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:neliganTinBox a ex:Object ;
    ex:prefLabel "Neligan's tin box" ;
    skos:altLabel "tin box" ;
    ex:description "A tin box containing securities and papers belonging to the banker Neligan Senior. The only baggage taken from Neligan's yacht when he was picked up by the Sea Unicorn in 1883. Kept by Peter Carey on a shelf in his cabin after murdering Neligan Senior. Taken by Patrick Cairns after he killed Carey, but found to contain only papers he dared not sell, no money. To be returned to young John Neligan." ;
    ex:locatedIn :peterCareyCabin ;
    ex:ownedBy :neliganSenior ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:neliganYacht a ex:Object, ex:Vessel ;
    ex:prefLabel "Neligan Senior's yacht" ;
    skos:altLabel "little yacht" ;
    skos:altLabel "little craft" ;
    ex:description "A small yacht belonging to the banker Neligan Senior. He sailed it toward Norway in 1883 just before the warrant for his arrest was issued. It was blown north by southerly gales and picked up by the Sea Unicorn. The crew had abandoned it in a dinghy, making for the Norwegian coast. Only Neligan Senior and his tin box of securities remained aboard when found." ;
    ex:ownedBy :neliganSenior ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:neliganYachtDinghy a ex:Object, ex:Vessel ;
    ex:prefLabel "Yacht dinghy" ;
    skos:altLabel "the dinghy" ;
    ex:description "The dinghy from Neligan Senior's yacht. The crew used it to make for the Norwegian coast when they feared the yacht would founder, presumably drowning in the attempt." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:noteToGarcia a ex:Object, ex:Letter ;
    ex:prefLabel "Note to Garcia" ;
    ex:description "A note written by Miss Burnet (Signora Durando) to Garcia with directions for the assassination attempt on Henderson/Murillo. Written on cream-laid paper without watermark, a quarter-sheet cut with bent nail scissors, folded three times, sealed with purple wax pressed with a sleeve-link (by Lopez). Signed 'D.' Contains: 'Our own colours, green and white. Green open, white shut. Main stair, first corridor, seventh right, green baize. Godspeed.' Garcia threw it in the fire but it was recovered unburned by Inspector Baynes from the dog-grate." ;
    ex:sentBy :missBurnet ;
    ex:sentTo :aloysiusGarcia ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:oakStickBrowner a ex:BluntInstrument ;
    ex:prefLabel "Oak stick" ;
    ex:description "Heavy oak stick. Jim Browner's weapon. Used to crush Fairbairn's head and kill Mary." ;
    ex:ownedBy :jimBrowner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:obersteinLifePreserver a ex:Weapon ;
    ex:prefLabel "Oberstein's Life-Preserver" ;
    skos:altLabel "life-preserver" ;
    skos:altLabel "short life-preserver" ;
    ex:description "A short life-preserver (a weighted weapon) always carried by Hugo Oberstein. Used to strike Arthur Cadogan West on the head, killing him within five minutes, when West confronted Oberstein and Colonel Walter at 13 Caulfield Gardens." ;
    ex:ownedBy :hugoOberstein ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:obersteinCashBox a ex:Object ;
    ex:prefLabel "Oberstein's Cash-Box" ;
    skos:altLabel "cash-box" ;
    ex:description "A small tin cash-box on the writing-desk at 13 Caulfield Gardens. Holmes pried it open with his chisel. Contained rolls of paper with figures and calculations about water pressure (possibly related to a submarine) and an envelope with newspaper clippings from the Daily Telegraph agony column." ;
    ex:ownedBy :hugoOberstein ;
    ex:locatedIn :13CaulfieldGardens ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:oldacreBankBook a ex:Document ;
    ex:prefLabel "Oldacre's Bank-Book" ;
    ex:description "Bank-book belonging to Jonas Oldacre showing large payments to a 'Mr. Cornelius' over several years. Holmes deduced that Cornelius was Oldacre's own alias, used to systematically transfer his wealth to a hidden identity, making himself appear poor on paper." ;
    ex:ownedBy :jonasOldacre ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:oldacreBuildingDocuments a ex:Document ;
    ex:prefLabel "Oldacre's Building Documents" ;
    ex:description "Collection of building leases, title-deeds, mortgages, and scrip found in Oldacre's safe. These were the documents McFarlane was supposedly invited to sort and arrange." ;
    ex:locatedIn :oldacreSafe ;
    ex:ownedBy :jonasOldacre ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:oldacreSafe a ex:Object ;
    ex:prefLabel "Oldacre's Safe" ;
    ex:description "Heavy safe in Jonas Oldacre's bedroom at Deep Dene House. Contains sealed envelopes and packets with building leases, title-deeds, mortgages, and scrip — the documents McFarlane was supposedly invited to review." ;
    ex:locatedIn :deepDeneHouse ;
    ex:ownedBy :jonasOldacre ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:oldacreWill a ex:Document ;
    ex:prefLabel "Oldacre's Will" ;
    ex:description "Will drafted by Jonas Oldacre on blue paper as a rough draft in his own hand, leaving all his property to John Hector McFarlane. Written on several sheets of a notebook, scribbled over with alterations. Signed and witnessed at McFarlane's office by McFarlane's clerk. The will was part of Oldacre's plot — written hastily to give McFarlane an apparent motive for murder." ;
    ex:createdBy :jonasOldacre ;
    ex:relatedTo :johnHectorMcFarlane ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:originOfTreeWorship a ex:Document ;
    ex:prefLabel "The Origin of Tree Worship" ;
    ex:description "Book carried by Holmes in his disguise as an elderly book collector. Watson observed its title when he picked up the books he had knocked down." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:oversizedCoffin a ex:Object ;
    ex:prefLabel "Oversized Coffin" ;
    skos:altLabel "the coffin" ;
    ex:description "A specially made oversized coffin ordered from Stimson and Co. on Kennington Road. It was described as 'out of the ordinary' by the shop woman because it took longer to make due to its special measurements. It had unusually deep sides. The coffin was designed by Peters to hold both Rose Spender's body and the living Lady Frances Carfax beneath it, so both would be buried under one death certificate. Holmes's key deduction was realizing why such a large coffin was needed for such a small body." ;
    ex:madeBy :stimsonAndCo ;
    ex:locatedAt :36PoultneySq ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:overtonTelegram a ex:Telegram ;
    ex:prefLabel "Overton's Telegram to Holmes" ;
    ex:description "Telegram sent by Cyril Overton to Sherlock Holmes reading: 'Please await me. Terrible misfortune. Right wing three-quarter missing; indispensable to-morrow. Overton.' Had a Strand post-mark and was dispatched at ten-thirty-six." ;
    ex:receivedBy :sherlockHolmes ;
    ex:sentBy :cyrilOverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:pailOfBlood a ex:Object ;
    ex:prefLabel "Pail of blood" ;
    ex:description "A zinc pail containing a quantity of blood found under the kitchen sink at Wisteria Lodge. Part of the voodoo ritual evidence." ;
    ex:locatedAt :wisteriaLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:palimpsest a ex:Document ;
    ex:prefLabel "Palimpsest" ;
    ex:description "An ancient palimpsest that Holmes was deciphering with a powerful lens at the opening of the story. He determined it contained nothing more exciting than an Abbey's accounts dating from the second half of the fifteenth century." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:pencilShavings a ex:Object ;
    ex:prefLabel "Pencil Shavings" ;
    skos:altLabel "pencil chips" ;
    skos:altLabel "pencil cuttings" ;
    ex:description "Several shreds from a pencil which had been sharpened, found on the side table near the window in Soames's sitting-room. A broken tip of lead was also found. Evidence that the intruder had broken his pencil while copying the proofs and sharpened a fresh point. Holmes took the pencil cuttings as evidence and used them to identify the pencil type." ;
    ex:relatedTo :fortescueExamTampering ;
    ex:locatedAt :soamesSittingRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:persianSlipper a ex:Object ;
    ex:prefLabel "Persian slipper (tobacco)" ;
    skos:altLabel "the Persian slipper" ;
    ex:description "Slipper containing tobacco, kept at 221B Baker Street. Observed by Watson upon his return to 221B with Holmes." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:petersWarrant a ex:Document ;
    ex:prefLabel "Warrant for Peters's House" ;
    skos:altLabel "the warrant" ;
    ex:description "A search warrant obtained by Lestrade from a magistrate to search 36 Poultney Square. There were difficulties of procedure and the magistrate's signature could not be obtained until the morning. Lestrade arrived with the warrant just after Holmes had already rescued Lady Frances from the coffin." ;
    ex:isAbout :36PoultneySq ;
    ex:obtainedBy :lestrade ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:phelpsBellFO a ex:Object ;
    ex:prefLabel "Bell in Phelps's Office" ;
    ex:description "A bell-rope in Phelps's office at the Foreign Office, hanging from a wire just to the right of the desk. It rings in the commissionaire's lodge at the foot of the stairs. Phelps rang it to summon coffee. It rang again when Joseph Harrison entered the room and reached the desk, alerting the commissionaire and Phelps. The ringing of the bell is described as the most distinctive feature of the case." ;
    ex:locatedAt :phelpsOfficeFO ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:pierrotAdvertisements a ex:Document ;
    ex:prefLabel "Pierrot Advertisements" ;
    skos:altLabel "Pierrot ads" ;
    skos:altLabel "agony column advertisements" ;
    ex:description "Series of coded messages in the Daily Telegraph agony column, signed 'Pierrot' (alias of Hugo Oberstein). Used to communicate with Colonel Valentine Walter about the theft of the Bruce-Partington plans. Four messages were found by Holmes in Oberstein's cash-box. Holmes placed a fifth fake Pierrot advertisement to lure Walter or Oberstein back to 13 Caulfield Gardens." ;
    ex:authorOf :hugoOberstein ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:pietroCatholicEmblem a ex:Object ;
    ex:prefLabel "Pietro's Catholic Emblem" ;
    ex:description "A Catholic emblem worn round Pietro Venucci's neck. Along with his complexion, it helped identify him as being from southern Europe." ;
    ex:ownedBy :pietroVenucci ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:pinfireRevolver a ex:Object, ex:Firearm ;
    ex:prefLabel "Pinfire revolver" ;
    ex:description "An old-fashioned pinfire revolver found among Garcia's personal property at Wisteria Lodge." ;
    ex:ownedBy :aloysiusGarcia ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:poeSketchesReference a ex:Document ;
    ex:prefLabel "Poe's sketches" ;
    ex:description "Referenced literary work. Holmes read Watson a passage from Poe's sketches in which a close reasoner follows unspoken thoughts of his companion. Likely 'The Murders in the Rue Morgue' or similar." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:pompey a ex:Animal ;
    ex:prefLabel "Pompey" ;
    ex:description "A draghound, described as a squat, lop-eared, white-and-tan dog, something between a beagle and a foxhound. The pride of the local draghounds. Obtained by Holmes from Jeremy Dixon at Trinity College. Used to follow the aniseed trail Holmes sprayed on Dr. Armstrong's brougham wheel, successfully tracking him to the cottage near Trumpington." ;
    ex:ownedBy :jeremyDixon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:practicalHandbookBeeCulture a ex:Object, ex:Document ;
    ex:prefLabel "Practical Handbook of Bee Culture" ;
    ex:description "Book written by Sherlock Holmes during his retirement. Full title: 'Practical Handbook of Bee Culture, with Some Observations upon the Segregation of the Queen.' A small blue book with golden letters on the cover. Used as a decoy, presented to Von Bork in place of the expected naval signals. Holmes called it 'the magnum opus of my latter years.'" ;
    ex:authoredBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:printedMessageSlips a ex:Document ;
    ex:prefLabel "Printed Message Slips" ;
    ex:description "Slips of foolscap with words printed in pencil (soap, match, daily gazette) used by the mysterious lodger (Emilia Lucca) to communicate requests to Mrs. Warren without revealing her handwriting or sex. They were written with a broad-pointed, violet-tinted pencil. The paper was torn at the side to remove identifying marks." ;
    ex:locatedIn :mrsWarrensHouse ;
    ex:createdBy :emiliaLucca ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:ralphDisinfectantGloves a ex:Gloves ;
    ex:prefLabel "Ralph's Disinfectant Gloves" ;
    ex:description "Brown leather gloves worn by Ralph the butler, impregnated with disinfectant that gave off a curious tarry odour. Ralph wore them when carrying meals to the lodge where Godfrey was hidden and shuffled them off when visitors arrived. Holmes detected the disinfectant scent and recognized them as key evidence confirming his hypothesis of leprosy." ;
    ex:ownedBy :ralphButler ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:ralphSmithDeathTelegram a ex:Telegram ;
    ex:prefLabel "Ralph Smith death telegram" ;
    skos:altLabel "the cable" ;
    ex:description "A short telegram received by Carruthers reading 'The old man is dead', notifying of Ralph Smith's death. This triggered the final move by Woodley and Williamson to abduct and forcibly marry Violet." ;
    ex:telegramText "The old man is dead." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:redCircleSummons a ex:Summons ;
    ex:prefLabel "Red Circle Summons" ;
    ex:description "A summons received by Gennaro Lucca from the Red Circle secret society. It had a Red Circle drawn upon the head of it, ordering his attendance at a lodge meeting on a certain date." ;
    ex:ownedBy :gennaroLucca ;
    ex:createdBy :theRedCircle ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:rockOfGibraltar a ex:Vessel ;
    ex:prefLabel "Rock of Gibraltar" ;
    ex:description """The largest and best boat of the Adelaide-Southampton shipping line. Mary Fraser and Theresa Wright travelled on her from Australia to England in June 1895, when Jack Croker served as first officer. At the time of the story, the ship was on her way to Australia, somewhere south of the Suez Canal. Her officers were the same as in 1895, except for Croker who had been promoted to captain of the Bass Rock.""" ;
    ex:operatedBy :adelaideSouthamptonLine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:roundhayTelegramToSterndale a ex:Telegram ;
    ex:prefLabel "Roundhay's Telegram to Sterndale" ;
    ex:description "A telegram sent by vicar Mr. Roundhay to Dr. Leon Sterndale at Plymouth, informing him of the Tregennis tragedy. This telegram caused Sterndale to abandon his voyage to Africa and return to Cornwall." ;
    ex:sentBy :roundhay ;
    ex:sentTo :leonSterndale ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:ruritania a ex:Vessel ;
    ex:prefLabel "Ruritania" ;
    skos:altLabel "Cunard boat Ruritania" ;
    ex:description "A Cunard steamship. Baron Gruner is booked as a passenger departing from Liverpool on Friday for the United States to settle financial business before his wedding." ;
    ex:ownedBy :cunardLine ;
    ex:departurePort :liverpool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:sailorKnifeBrowner a ex:Knife ;
    ex:prefLabel "Sailor's knife" ;
    ex:description "Big sharp knife found in Browner's box. Used to cut off the victims' ears." ;
    ex:ownedBy :jimBrowner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:sealingWaxKnife a ex:Weapon ;
    ex:prefLabel "Sealing-Wax Knife" ;
    ex:description "Small sealing-wax knife with an ivory handle and a stiff blade, of the kind found on old-fashioned writing tables. Part of the fittings of Professor Coram's desk. Used by Anna to stab Willoughby Smith in the neck, piercing the carotid artery. Found on the carpet some feet from the body." ;
    ex:ownedBy :professorCoram ;
    ex:locatedIn :yoxleyStudy ;
    ex:usedIn :murderOfWilloughbySmith ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:seaUnicornLogBooks a ex:Object, ex:Document ;
    ex:prefLabel "Sea Unicorn log-books" ;
    skos:altLabel "log-books" ;
    ex:description "A line of log-books from the Sea Unicorn kept on a shelf in Peter Carey's cabin. Young Neligan attempted to examine the log-book for August 1883 to learn his father's fate, but found the relevant pages had been torn out." ;
    ex:locatedIn :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:seaUnicornPicture a ex:Object ;
    ex:prefLabel "Picture of the Sea Unicorn" ;
    ex:description "A picture of the vessel Sea Unicorn hanging in Peter Carey's cabin at Woodman's Lee." ;
    ex:locatedIn :peterCareyCabin ;
    ex:depicts :seaUnicorn ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:severedEars a ex:BodyOfEvidence ;
    ex:prefLabel "Two severed ears" ;
    ex:description "Two human ears: one female (small, finely formed, pierced for earring), one male (sun-burned, discoloured, pierced for earring). Not a pair. Fresh, cut with blunt instrument. Belonged to Mary Browner and Alec Fairbairn." ;
    ex:ownedBy :maryBrowner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:shillingMapOfLondon a ex:Document ;
    ex:prefLabel "Shilling Map of London" ;
    ex:description "A map of London costing one shilling, found in Pietro Venucci's pocket along with other personal effects." ;
    ex:ownedBy :pietroVenucci ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:sixNapoleonBusts a ex:Bust ;
    ex:prefLabel "Six Napoleon Busts" ;
    ex:description "A batch of six plaster casts of Devine's famous head of Napoleon, manufactured at Gelder & Co. in Stepney. Made by Italian workers in two moulds joined together. Three were sold to Morse Hudson (who sold two to Dr. Barnicot) and three to Harding Brothers (who sold them to Harker, Brown, and Sandeford). Beppo hid the black pearl of the Borgias in one of the wet busts before his arrest. He then systematically smashed five of the six trying to find it. The pearl was in the sixth bust, purchased by Holmes from Sandeford." ;
    ex:sculptedBy :devine ;
    ex:manufacturedBy :gelderCoFirm ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:smithGelatineCultivations a ex:Object ;
    ex:prefLabel "Smith's Gelatine Cultivations" ;
    skos:altLabel "gelatine cultivations" ;
    skos:altLabel "disease cultures" ;
    ex:description "A row of bottles and jars on a side table in Culverton Smith's study containing gelatine cultivations of dangerous disease organisms. Smith refers to them as his 'prisons' containing 'the very worst offenders in the world doing time', reflecting his amateur hobby of studying tropical diseases." ;
    ex:ownedBy :culvertonSmith ;
    ex:locatedIn :13LowerBurkeStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:spanishPendant1 a ex:Jewelry ;
    ex:prefLabel "First Spanish Pendant" ;
    skos:altLabel "silver-and-brilliant pendant" ;
    ex:description "A silver-and-brilliant pendant of old Spanish design, part of Lady Frances Carfax's jewellery collection. It was pawned by Holy Peters (disguised as a large, clean-shaven man of clerical appearance with a false name) at Bovington's in Westminster Road." ;
    ex:partOf :ladyFrancesJewellery ;
    ex:pawnedAt :bovingtons ;
    ex:pawnedBy :henryPeters ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:spanishPendant2 a ex:Jewelry ;
    ex:prefLabel "Second Spanish Pendant" ;
    ex:description "A second silver-and-brilliant pendant, the fellow or match of the first, part of Lady Frances Carfax's jewellery collection. It was brought to Bovington's by Annie Fraser (Mrs. Peters). Philip Green followed her from the pawnshop." ;
    ex:partOf :ladyFrancesJewellery ;
    ex:pawnedAt :bovingtons ;
    ex:pawnedBy :annieFraser ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:spenderDeathCertificate a ex:Document ;
    ex:prefLabel "Rose Spender's Death Certificate" ;
    skos:altLabel "death certificate" ;
    ex:description "A death certificate for Rose Spender signed by Dr. Horsom, stating the cause of death as senile decay. Peters intended to use this single certificate to cover the burial of both Rose Spender and Lady Frances Carfax in the same coffin." ;
    ex:createdBy :drHorsom ;
    ex:isAbout :roseSpender ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:spiritLampFO a ex:Object ;
    ex:prefLabel "Spirit-lamp at the Foreign Office" ;
    ex:description "A spirit-lamp in the commissionaire's lodge at the Foreign Office, used by the commissionaire to make coffee for officials working overtime. The kettle was boiling furiously upon it when Tangey fell asleep. Phelps took off the kettle and blew out the lamp as water was spurting over the floor." ;
    ex:locatedAt :commissionaireLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holmesTelegramsWoking a ex:Telegram ; 
    ex:prefLabel "Holmes's Telegrams from Woking" ;
    ex:description "Several telegrams scribbled by Holmes and sent from Woking station to every London evening paper, containing the cab advertisement offering a £10 reward." ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:harrisonLocket a ex:Locket ;
    ex:prefLabel "Joseph Harrison's Locket" ;
    ex:description "A locket worn by Joseph Harrison bearing the monogram J H. Holmes noticed it and Joseph assumed Holmes had deduced his identity from it." ;
    ex:monogram "J H" ;
    ex:ownedBy :josephHarrison ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holdhurstLetterToPhelps a ex:Letter ;
    ex:prefLabel "Lord Holdhurst's Letter to Phelps" ;
    ex:description "A letter from Lord Holdhurst to Percy Phelps regarding the treaty theft. Cold but not harsh in tone. Repeated that the matter was of utmost importance and stated that no steps would be taken about Phelps's future (meaning dismissal) until his health was restored and he had an opportunity to repair his misfortune." ;
    ex:sentBy :lordHoldhurst ;
    ex:sentTo :percyPhelps ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holmesChemicalApparatus a ex:ScientificApparatus ;
    ex:prefLabel "Holmes's Chemical Apparatus" ;
    ex:description "Scientific equipment Holmes was using for a chemical investigation at 221B Baker Street when Watson arrived. Includes a large curved retort boiling furiously in the bluish flame of a Bunsen burner, distilled drops condensing into a two-litre measure, bottles, a glass pipette, a test-tube containing a solution, and a slip of litmus-paper. Holmes dipped the litmus paper into the test-tube and it turned crimson, prompting him to say it meant a man's life." ;
    ex:locatedAt :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:ssMayDay a ex:Vessel ;
    ex:prefLabel "S.S. May Day" ;
    ex:description "Ship/steamer. Belongs to Liverpool, Dublin, and London Steam Packet Company. Jim Browner's ship. Calls at Belfast, Dublin, Waterford. Put back to port when hogshead got loose and started a plate." ;
    ex:ownedBy :liverpoolDublinLondonSteamPacketCo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:stauntonTelegram a ex:Telegram ;
    ex:prefLabel "Staunton's Telegram to Dr. Armstrong" ;
    ex:description "Urgent telegram dispatched by Godfrey Staunton from a telegraph office near Bentley's Hotel at six-fifteen in the evening, addressed to Dr. Leslie Armstrong in Cambridge. The visible portion read: 'Stand by us for God's sake!' Written with a broad-pointed quill pen. Its impression was recovered from a blotting pad." ;
    ex:receivedBy :leslieArmstrong ;
    ex:sentBy :godfreyStaunton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:sterndaleRevolver a ex:Firearm ;
    ex:prefLabel "Sterndale's Revolver" ;
    ex:description "A revolver belonging to Dr. Leon Sterndale. He used it to threaten Mortimer Tregennis during the murder, paralyzing him in his chair at the sight of it. Sterndale stood outside the window ready to shoot Tregennis should he try to leave the room while the devil's-foot powder burned in the lamp." ;
    ex:ownedBy :leonSterndale ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:sylviusCane a ex:Weapon ;
    ex:prefLabel "Sylvius's Loaded Cane" ;
    skos:altLabel "thick stick" ;
    skos:altLabel "loaded cane" ;
    ex:description "A thick stick or loaded cane carried by Count Negretto Sylvius. He nearly strikes the wax dummy of Holmes with it, crouching for a final spring and blow before Holmes reveals himself from the bedroom door." ;
    ex:ownedBy :countNegrettoSylvius ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:sylviusRevolver a ex:Firearm ;
    ex:prefLabel "Sylvius's Revolver" ;
    ex:description "A revolver carried by Count Negretto Sylvius when he visits Holmes at Baker Street. Holmes invites him to put it on the side-table but Sylvius prefers to sit upon it. Holmes later warns him not to finger it." ;
    ex:ownedBy :countNegrettoSylvius ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:syracusanCoin a ex:Object, ex:Coin ;
    ex:prefLabel "Syracusan Coin" ;
    ex:description "An ancient Syracusan coin from Nathan Garrideb's collection, described as being 'of the best period.' Nathan was polishing it with chamois leather when Holmes and Watson first visited him. He considered Syracusan coins supreme, though noted some collectors preferred the Alexandrian school." ;
    ex:ownedBy :nathanGarrideb ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:tangVase a ex:Object ;
    ex:prefLabel "Tang Dynasty Vase" ;
    skos:altLabel "small brown vase" ;
    skos:altLabel "Tang specimen" ;
    ex:description """A small brown vase, a Tang specimen dating from the seventh century. Part of Baron Gruner's Chinese collection. He holds it when Watson arrives and shows it as an example of fine workmanship and rich glaze.""" ;
    ex:ownedBy :adelbertGruner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:tarredTwine a ex:Object ;
    ex:prefLabel "Tarred twine" ;
    ex:description "String used to tie the parcel. Sail-maker quality. Sailor's knot. Cut by Miss Cushing with scissors (double fray)." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:telegramCounterfoil a ex:Document ;
    ex:prefLabel "Telegram Counterfoil" ;
    ex:description "The counterfoil of Staunton's telegram at the telegraph office near Bentley's Hotel. Had no sender name. Holmes tricked the clerk into showing it, and later the Cambridge office counterfoil revealed the telegram was addressed to Dr. Armstrong." ;
    ex:relatedTo :stauntonTelegram ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:telegramFromAlgar a ex:Telegram ;
    ex:prefLabel "Telegram from Algar" ;
    ex:description "Reply telegram from Algar of Liverpool police confirming Mrs. Browner's house closed 3+ days and Browner departed on May Day. Received at Croydon police station." ;
    ex:hasAuthor :algar ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:telegramToAlgar a ex:Telegram ;
    ex:prefLabel "Holmes's telegram to Algar" ;
    ex:description "Telegram sent by Holmes to Algar of Liverpool police asking to verify if Mrs. Browner was at home and if Browner departed on May Day." ;
    ex:hasAuthor :sherlockHolmes ;
    ex:sentTo :algar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:theLancet a ex:MedicalJournal ;
    ex:prefLabel "The Lancet" ;
    ex:description "The Lancet is a medical journal. Holmes noted that if Mr. Kent had been reading The Lancet or the British Medical Journal, it would have helped his deduction by suggesting a medical rather than psychiatric reason for Godfrey's confinement." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:theSpectator a ex:Publication ;
    ex:prefLabel "The Spectator" ;
    ex:description "The Spectator is a weekly publication. James Dodd thought the paper Mr. Kent was reading in the lodge might have been The Spectator. Holmes asked about the paper because a medical journal would have been more suggestive of illness rather than insanity." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:thorBridgeDemonstrationStone a ex:Object ;
    ex:prefLabel "Demonstration Stone" ;
    ex:description "A considerable stone found by Holmes among the heather and ferns near Thor Bridge. He secured it to the other end of the string tied to Watson's revolver and hung it over the parapet of the bridge to demonstrate how Mrs. Gibson's suicide weapon was pulled into the mere." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:thorBridgeMurderRevolver a ex:Firearm ;
    ex:prefLabel "Thor Bridge Murder Revolver" ;
    ex:description "A revolver, one of a pair owned by Neil Gibson, with one discharged chamber and a calibre matching the fatal bullet. It was planted by Mrs. Gibson on the floor of Grace Dunbar's wardrobe to frame her for murder. The box was made for two pistols but police could not match the pair among Gibson's collection." ;
    ex:ownedBy :neilGibson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:thorBridgeSuicideRevolver a ex:Firearm ;
    ex:prefLabel "Thor Bridge Suicide Revolver" ;
    ex:description "The matching pair to the murder revolver, also owned by Neil Gibson. Used by Mrs. Gibson to shoot herself at Thor Bridge. She tied it to a string weighted with a stone so that upon release the weight would pull the revolver over the parapet into Thor Mere, concealing the weapon and making her death appear to be murder." ;
    ex:ownedBy :neilGibson ;
    ex:locatedAt :thorMere ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:thorBridgeTwine a ex:Object ;
    ex:prefLabel "Ball of Twine" ;
    ex:description "A ball of stout twine purchased from the village shop near Thor Place. Holmes requests ten yards and uses it in his demonstration at Thor Bridge, tying one end to Watson's revolver handle and the other to a heavy stone." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:threeMonthsJungleBook a ex:Document ;
    ex:prefLabel "Three Months in the Jungle" ;
    ex:description "Book authored by Colonel Sebastian Moran, published 1884." ;
    dc:date "1884"^^xsd:gYear ;
    ex:authoredBy :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:thumbprintOnWall a ex:Object ;
    ex:prefLabel "Thumbprint on Wall" ;
    ex:description "Blood thumbprint appearing on a wall in Deep Dene House, matching McFarlane's thumb. Key evidence — Holmes proved it was NOT present the day before, meaning it was planted overnight by Oldacre using a wax seal impression taken during the will signing. Lestrade smugly presents this as clinching evidence against McFarlane." ;
    ex:createdBy :jonasOldacre ;
    ex:locatedIn :deepDeneHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:timesAdvertisement a ex:Document ;
    ex:prefLabel "The Times advertisement" ;
    ex:description "An advertisement placed in The Times newspaper inquiring for the whereabouts of the Smith family, placed by or on behalf of Carruthers and Woodley." ;
    ex:publishedIn :theTimes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:tongaDartPouch a ex:Container ;
    ex:prefLabel "Tonga's Dart Pouch" ;
    ex:description "Small pocket or pouch woven out of colored grasses with tawdry beads strung round it. About the size of a cigarette-case. Contained half a dozen poisoned dark wood spines, sharp at one end and rounded at the other. Dropped by Tonga on the roof of Pondicherry Lodge during his escape. Found by Holmes, who was delighted to recover the darts." ;
    ex:ownedBy :tonga ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:treatyCopy a ex:Document ;
    ex:prefLabel "Copy of the Naval Treaty" ;
    ex:description "Percy Phelps's partial handwritten copy of the naval treaty. He had completed nine of the twenty-six articles before going downstairs for coffee. When the original was stolen, the copy remained on the desk." ;
    ex:createdBy :percyPhelps ;
    ex:locatedAt :phelpsOfficeFO ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:josephKnife a ex:Knife ;
    ex:prefLabel "Joseph Harrison's Knife" ;
    ex:description "A long-bladed knife carried by Joseph Harrison. He used it as a tool to force the window sash, push back the catch, and thrust the bar of shutters at Briarbrae. He also used it as a weapon, attacking Holmes and cutting him over the knuckles. Percy Phelps saw the gleam of the blade during the first intrusion attempt." ;
    ex:ownedBy :josephHarrison ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:navalTreaty a ex:Treaty ;
    ex:prefLabel "The Naval Treaty" ;
    skos:altLabel "the secret treaty" ;
    ex:description "Secret treaty between England and Italy defining Britain's position towards the Triple Alliance and foreshadowing policy if the French fleet gained ascendancy over Italy in the Mediterranean. A gray roll of paper with twenty-six separate articles written in the French language, bearing signatures of high dignitaries. Of enormous importance - the French or Russian embassy would pay an immense sum for its contents. Entrusted to Percy Phelps for copying by Lord Holdhurst. Stolen by Joseph Harrison and hidden as a cylinder of blue-gray paper under a floorboard at Briarbrae. Recovered by Holmes and presented under a dish cover at breakfast." ;
    ex:ownedBy :foreignOffice ;
    ex:stolenBy :josephHarrison ;
    ex:hiddenAt :briarbrae ;
    ex:recoveredBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:phelpsLetterToWatson a ex:Letter ;
    ex:prefLabel "Phelps's Letter to Watson" ;
    ex:description "A letter sent by Percy Phelps from Briarbrae, Woking, to Dr. Watson. Written by dictation in a woman's handwriting (Annie Harrison's). Appeals to Watson to bring Holmes. Holmes deduced the writer was a woman of rare character from the handwriting." ;
    ex:sentBy :percyPhelps ;
    ex:sentTo :johnWatson ;
    ex:writtenBy :annieHarrison ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:ammonia a ex:Object ;
    ex:prefLabel "Ammonia" ;
    ex:description "Used with brandy by Watson to revive Melas after charcoal poisoning." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:arcadiaMixture a ex:Object ;
    ex:prefLabel "Arcadia Mixture" ;
    ex:description "A tobacco mixture smoked by Watson from his bachelor days. Holmes recognizes it from the fluffy ash upon Watson's coat." ;
    ex:usedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:barclayCanary a ex:Animal ;
    ex:prefLabel "Barclay Canary" ;
    ex:description "Canary kept in a cage hanging in the morning-room window at Lachine. Teddy the mongoose ran up the curtain trying to reach the bird." ;
    ex:locatedIn :morningRoomLachine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:blessingtonCigarCase a ex:Object ;
    ex:prefLabel "Blessington's cigar case" ;
    ex:description "Blessington's cigar case found in his coat pocket, containing a single Havana cigar. Holmes used it to compare against the cigar ends in the fireplace." ;
    ex:ownedBy :blessington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:blessingtonCigarHolder a ex:Object ;
    ex:prefLabel "Blessington's cigar holder" ;
    ex:description "Blessington's cigar holder which was not found by Inspector Lanner at the murder scene. Two of the four cigar ends had been smoked from a holder, indicating one of the older men had used it." ;
    ex:ownedBy :blessington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:blessingtonPhotograph a ex:Photograph ;
    ex:prefLabel "Blessington's photograph" ;
    ex:description "A photograph of Blessington which Holmes found on the mantelpiece in Blessington's room and took to assist in his inquiries into Blessington's true identity." ;
    ex:depictsSubject :blessington ;
    ex:locatedIn :blessingtonBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:blessingtonPistol a ex:Firearm ;
    ex:prefLabel "Blessington's pistol" ;
    ex:description "A pistol held by the terrified Blessington when Holmes, Watson, and Dr. Trevelyan arrived at 403 Brook Street. He thrust it into his pocket when he recognized them." ;
    ex:ownedBy :blessington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:blessingtonRope a ex:Object ;
    ex:prefLabel "Blessington's rope" ;
    skos:altLabel "fire escape cord" ;
    ex:description "A large coil of rope kept under Blessington's bed as a fire escape, since he was morbidly nervous of fire and wanted to escape by window if the stairs were burning. It was used by the murderers to hang him from a hook on the ceiling." ;
    ex:ownedBy :blessington ;
    ex:locatedIn :blessingtonBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:blessingtonStrongbox a ex:Object ;
    ex:prefLabel "Blessington's strong-box" ;
    skos:altLabel "Blessington's black box" ;
    ex:description "A big black box at the end of Blessington's bed at 403 Brook Street in which he kept all his money, distrusting bankers. He showed it to Holmes to explain his fear of intruders. Blessington jumped off the top of this box when the murderers hanged him." ;
    ex:ownedBy :blessington ;
    ex:locatedIn :blessingtonBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:brandyBottle a ex:Object ;
    ex:prefLabel "Brandy Bottle" ;
    ex:description "Empty brandy bottle found on table at The Myrtles. Brandy used to revive Melas." ;
    ex:locatedIn :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:brucePinkertonPrize a ex:Prize ;
    ex:prefLabel "Bruce Pinkerton Prize" ;
    skos:altLabel "Bruce Pinkerton prize and medal" ;
    ex:description "A prize and medal won by Dr. Percy Trevelyan for his monograph on obscure nervous lesions, awarded during his time at King's College Hospital." ;
    ex:wonBy :percyTrevelyan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:budapestNewsCutting a ex:Newspaper ;
    ex:prefLabel "Budapest Newspaper Cutting" ;
    ex:description "News cutting from Budapest reporting Latimer and Kemp stabbed while traveling with a woman." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:carvedWoodenClub a ex:Weapon, ex:BluntInstrument ;
    ex:prefLabel "Carved Wooden Club" ;
    ex:description "A singular club of hard carved wood with a bone handle, found on the floor close to Colonel Barclay's body in the morning-room at Lachine. Conjectured by police to be from the Colonel's varied collection of weapons brought from different countries. The servants denied having seen it before. It is uncertain whether this club was used to strike the Colonel or was simply present in the room." ;
    ex:locatedIn :morningRoomLachine ;
    ex:possiblyOwnedBy :jamesBarclay ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:charcoalTripod a ex:Object ;
    ex:prefLabel "Brass Charcoal Tripod" ;
    skos:altLabel "brazen tripod" ;
    ex:description "Small brass tripod producing charcoal fumes used to poison Melas and Kratides. Holmes threw it into the garden." ;
    ex:locatedIn :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:cigarEnds a ex:Object ;
    ex:prefLabel "Cigar ends" ;
    ex:description "Four cigar ends found in the fireplace of Blessington's room. Two were Havana cigars smoked from a holder, and two were Dutch East Indian cigars (thinner, wrapped in straw) smoked without a holder, two cut by a knife and two bitten off. This evidence proved multiple people had been in the room, disproving the suicide theory." ;
    ex:locatedIn :blessingtonBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:dailyNews a ex:Newspaper ;
    ex:prefLabel "Daily News" ;
    ex:description "London newspaper where Mycroft placed advertisement seeking Kratides and Sophy. The Daily News is a London newspaper that reported on the case as a political crime." ;
    ex:prefLabel "Daily News" ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc ;
    dc:source :studyInScarletDoc .

:davenportLetter a ex:Letter ;
    ex:prefLabel "Davenport's Letter" ;
    ex:description "Letter from J. Davenport responding to Mycroft's ad, identifying Sophy's location at The Myrtles, Beckenham." ;
    ex:ownedBy :jDavenport ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:defangedSnake a ex:Animal ;
    ex:prefLabel "Defanged Snake" ;
    ex:description "A snake without fangs kept by Henry Wood. Teddy the mongoose catches it every night as part of Wood's entertainment performances at canteens." ;
    ex:ownedBy :henryWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:fiveSovereigns a ex:Object ;
    ex:prefLabel "Five Sovereigns" ;
    ex:description "Payment of five gold sovereigns given to Melas by Kemp for interpreting." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:henryWoodBox a ex:Object ;
    ex:prefLabel "Henry Wood's Box" ;
    ex:description "A kind of hutch or box that Henry Wood carries slung over one of his shoulders. Contains Teddy the mongoose. Also contains a defanged snake used in Wood's canteen performances. Wood's landlady was in considerable trepidation about the animal inside." ;
    ex:ownedBy :henryWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:henryWoodStick a ex:Object ;
    ex:prefLabel "Henry Wood's Walking Stick" ;
    ex:description "A singular club of hard carved wood with a bone handle, used by Henry Wood both as a walking aid and carried with him. Found on the floor of the morning-room at Lachine close to Colonel Barclay's body. The police conjectured it was from the Colonel's weapon collection, but the servants denied having seen it before. Wood dropped it while chasing Teddy the mongoose after the Colonel's death." ;
    ex:ownedBy :henryWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:holmesPocketLens a ex:Object ;
    ex:prefLabel "Holmes's pocket lens" ;
    skos:altLabel "pocket-lens" ;
    ex:description "A magnifying lens carried by Holmes which he used to examine the four cigar ends found in Blessington's fireplace." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:indianRupee a ex:Object ;
    ex:prefLabel "Indian Rupee" ;
    ex:description "An Indian rupee that Henry Wood gave to his landlady as a deposit, mistaken for a bad florin. Evidence of Wood's long years spent in India." ;
    ex:ownedBy :henryWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:interrogationSlate a ex:WritingInstrument ;
    ex:prefLabel "Interrogation Slate" ;
    skos:altLabel "slate and pencil" ;
    ex:description "Slate and pencil used by Paul Kratides to write Greek answers during interrogation." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:japaneseMail a ex:Object ;
    ex:prefLabel "Suit of Japanese Armor" ;
    skos:altLabel "Japanese mail" ;
    ex:description "Decorative Japanese armor in the interrogation room at The Myrtles." ;
    ex:locatedIn :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:kratidesPapers a ex:LegalDocument ;
    ex:prefLabel "Kratides Property Papers" ;
    skos:altLabel "the papers" ;
    skos:altLabel "the documents" ;
    ex:description "Legal papers Latimer and Kemp tried to force Kratides to sign, transferring his and Sophy's property." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:lachineKey a ex:Object ;
    ex:prefLabel "Lachine Morning-Room Key" ;
    ex:description "Key to the morning-room door at Lachine. Its disappearance was the most distinctive and suggestive point of the case. Neither the Colonel, his wife, nor the police could find it in the room. Henry Wood inadvertently took it in his pocket when he fled the scene after Colonel Barclay's death. Nancy Barclay had the key in her hand; Wood caught it up intending to unlock the door and get help, then thrust it into his pocket in his haste." ;
    ex:partOf :lachine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:latimerBludgeon a ex:BluntInstrument ;
    ex:prefLabel "Latimer's Bludgeon" ;
    skos:altLabel "life-preserver" ;
    ex:description "Lead-loaded bludgeon carried by Latimer to intimidate Melas. Also called a life-preserver." ;
    ex:ownedBy :haroldLatimer ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:latimerCarriage a ex:Carriage ;
    ex:prefLabel "Latimer's Carriage" ;
    ex:description "Carriage used to kidnap Melas. Roomier than ordinary four-wheeler, frayed rich fittings, windows papered over." ;
    ex:ownedBy :haroldLatimer ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:mycroftAdvertisement a ex:Advertisement ;
    ex:prefLabel "Mycroft's Advertisement" ;
    ex:description "Newspaper ad by Mycroft seeking info on Paul Kratides and Sophy. Reference X 2473. Appeared in Daily News and all dailies." ;
    ex:ownedBy :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:mycroftHandkerchief a ex:Clothing ;
    ex:prefLabel "Mycroft's Handkerchief" ;
    ex:description "Large red silk handkerchief Mycroft used to brush away snuff grains." ;
    ex:ownedBy :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:mycroftPocketBook a ex:Object ;
    ex:prefLabel "Mycroft's Pocket-Book" ;
    ex:description "Pocket-book from which Mycroft wrote a note to summon Melas." ;
    ex:ownedBy :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:mycroftSnuffBox a ex:Container ;
    ex:prefLabel "Mycroft's Snuff Box" ;
    skos:altLabel "tortoise-shell snuff box" ;
    ex:description "Tortoise-shell snuff box used by Mycroft Holmes at the Diogenes Club." ;
    ex:ownedBy :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:reigateRewardNotice a ex:Document ;
    ex:prefLabel "Reigate Reward Notice" ;
    skos:altLabel "reward notice" ;
    skos:altLabel "the slip of paper" ;
    ex:description "A reward notice that Holmes had prepared with a deliberate error (writing 'quarter to one' instead of 'quarter to twelve') and asked old Mr. Cunningham to sign and correct. This was a ruse to obtain a sample of Cunningham's handwriting — specifically the word 'twelve' — to compare with the handwriting on the torn note fragment. The old gentleman corrected the mistake and signed it, unknowingly providing Holmes with the evidence he needed." ;
    ex:relatedTo :reigateInvestigation ;
    ex:createdBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:reigateNotFragment a ex:Document ;
   ex:prefLabel "Reigate Note Fragment" ;
    skos:altLabel "the scrap of paper" ;
    skos:altLabel "torn paper fragment" ;
    ex:description "A small piece of torn paper found between the finger and thumb of the dead William Kirwan. It was a fragment torn from a larger sheet bearing the words 'at quarter to twelve, learn what, may be.' Inspector Forrester presented it as key evidence. Holmes's examination revealed it was written by two persons doing alternate words — the stronger hand (Alec Cunningham) wrote 'at', 'to', 'learn', 'maybe' while the weaker hand (old Cunningham) wrote 'quarter', 'twelve', 'what'. This was the critical clue that led to solving the case." ;
    ex:relatedTo :reigateNote, :williamKirwanMurder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:reigateNote a ex:Document ;
    ex:prefLabel "Reigate Murder Note" ;
    skos:altLabel "the murder note" ;
    skos:altLabel "the complete note" ;
    ex:description "The complete note used to lure William Kirwan to his death, written jointly by old Mr. Cunningham and his son Alec in alternate words. The full text reads: 'If you will only come around at quarter to twelve to the east gate you will learn what will very much surprise you and may be of the greatest service to you and also to Annie Morrison. But say nothing to anyone upon the matter.' Alec wrote all his words first in a strong hand, leaving blanks for his father to fill in with a weaker, older hand. Holmes identified the two handwritings and deduced their blood relationship." ;
    ex:relatedTo :williamKirwanMurder, :reigateNotFragment ;
    ex:createdBy :oldCunningham, :alecCunningham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:popesHomer a ex:Object ;
    ex:prefLabel "Pope's Homer" ;
    skos:altLabel "odd volume of Pope's Homer" ;
    ex:description "An odd volume of Pope's translation of Homer, one of several items stolen from Mr. Acton's library during the burglary by the Cunninghams. The theft of such an eclectic assortment of items (including plated candlesticks, an ivory letter-weight, a small oak barometer, and a ball of twine) was meant to disguise the true purpose of the break-in, which was to find legal documents related to the Acton-Cunningham lawsuit." ;
    ex:stolenFrom :mrActon ;
    ex:relatedTo :actonBurglary ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:lyonsTelegram a ex:Document ;
    ex:prefLabel "Telegram from Lyons" ;
    ex:description "A telegram received by Watson on the 14th of April informing him that Holmes was lying ill in the Hotel Dulong in Lyons. Watson traveled there within twenty-four hours." ;
    ex:sentTo :johnWatson ;
    ex:relatedTo :maupertuisInvestigation ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:alecCunninghamRevolver a ex:Firearm ;
    ex:prefLabel "Alec Cunningham's Revolver" ;
    skos:altLabel "the revolver" ;
    ex:description "A revolver used to murder William Kirwan, fired from a distance of over four yards with no powder-blackening on the clothes. During the arrest, Alec Cunningham attempted to cock this revolver but Inspector Forrester struck it from his hand. Holmes placed his foot upon it and noted it would be useful at the trial." ;
    ex:ownedBy :alecCunningham ;
    ex:usedIn :williamKirwanMurder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:agraIronBox a ex:Object ;
    ex:prefLabel "Agra Iron Box" ;
    ex:description "Solid iron chest of Indian (Benares) workmanship. Two-thirds of an inch thick. Hasp in image of a sitting Buddha. Key thrown in Thames by Small. Found empty when opened by Watson and Mary. Contained the Agra treasure." ;
    ex:material "iron (Benares metalwork)" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:agraPlan a ex:Document ;
    ex:prefLabel "Agra Plan" ;
    skos:altLabel "the sign of the four chart" ;
    ex:description "Paper of native Indian manufacture. Plan of part of a large building (Agra Fort) with red cross marking treasure location. Signed 'The sign of the four — Jonathan Small, Mahomet Singh, Abdullah Khan, Dost Akbar'. Found in Captain Morstan's desk among his papers by Mary Morstan." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:agraTreasure a ex:Treasure ;
    ex:prefLabel "Agra Treasure" ;
    skos:altLabel "the great Agra treasure" ;
    skos:altLabel "the treasure" ;
    ex:description "Iron chest of Indian (Benares) workmanship containing enormous cache of jewels: 143 first-water diamonds (including the Great Mogul, second largest stone in existence), 97 fine emeralds, 170 rubies, 40 carbuncles, 210 sapphires, 61 agates, great quantity of beryls, onyxes, cats-eyes, turquoises. Nearly 300 very fine pearls, 12 set in gold coronet. Originally belonged to a rajah. Stolen by the four conspirators at Agra Fort. Taken to England by Major Sholto. Found by Bartholomew Sholto in hidden garret. Scattered into the Thames by Jonathan Small during escape attempt. Valued at not less than half a million sterling." ;
    ex:estimatedValue "half a million sterling" ;
    ex:foundAt :pondicherryLodge ;
    ex:ownedBy :agraRajah ;
    ex:stolenFrom :agraRajah ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:americanEncyclopaedia a ex:Encyclopaedia ;
    ex:prefLabel "American Encyclopaedia" ;
    ex:description "A reference encyclopaedia kept on the shelf at 221B Baker Street. Holmes asked Watson to hand him the letter K volume, from which he read the entry on the Ku Klux Klan." ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:americanRailwayBonds a ex:Object ;
    ex:prefLabel "American Railway Bonds" ;
    ex:description "Securities worth nearly a hundred thousand pounds stolen from Mawson & Williams's safes by Beddington. Discovered in his carpet bag along with a large amount of scrip in mines and other companies." ;
    ex:stolenFrom :mawsonAndWilliams ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:ancientCrownOfEngland a ex:Crown ;
    ex:prefLabel "Ancient Crown of England" ;
    skos:altLabel "the ancient crown of the kings of England" ;
    skos:altLabel "the crown" ;
    ex:description "The ancient crown of the kings of England, a battered and shapeless diadem that once encircled the brows of the royal Stuarts. The metal was almost black and the stones lustreless and dull, but glowed when rubbed. The metalwork was in the form of a double ring but had been bent and twisted out of its original shape. It was hidden at Hurlstone by Sir Ralph Musgrave, a Cavalier supporter of Charles II, and concealed in a cellar chamber beneath a flagstone. Richard Brunton and Rachel Howells retrieved it from the chest. Rachel threw it into the mere in a linen bag. It was recovered by dragging the mere and is kept at Hurlstone after legal proceedings and a considerable sum paid." ;
    ex:hiddenBy :sirRalphMusgrave ;
    ex:recoveredFrom :hurlstoneMere ;
    ex:locatedAt :hurlstone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:ancientWoodenChest a ex:Object ;
    ex:prefLabel "Ancient Wooden Chest" ;
    skos:altLabel "the old chest" ;
    ex:description "A squat, brass-bound wooden box found in the cellar chamber at Hurlstone. Its lid was hinged upward with the old brass key projecting from the lock. Furred outside by a thick layer of dust; damp and worms had eaten through the wood, with livid fungi growing inside. It contained the coins of Charles I and originally held the ancient crown before it was removed by Brunton and Rachel." ;
    ex:locatedAt :hurlstoneCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:anonymousNote a ex:Letter ;
    ex:prefLabel "Anonymous Note to Holmes" ;
    ex:description "A sheet of thick, pink-tinted note-paper received by Holmes in the last post. Undated, unsigned, and without address. Written on Bohemian paper manufactured in Egria, with watermark containing 'Eg P Gt' (Egria Papier Gesellschaft). Announces the King of Bohemia's visit to consult Holmes at a quarter to eight that evening. The peculiar German sentence construction reveals the writer is German." ;
    ex:sentTo :sherlockHolmes ;
    ex:authoredBy :wilhelmVonOrmstein ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:baskervilleManuscript a ex:Document ;
    ex:prefLabel "Baskerville Manuscript" ;
    skos:altLabel "the legend" ;
    skos:altLabel "the manuscript" ;
    ex:description "Handwritten document dated 1742 telling the legend of Hugo Baskerville and the spectral hound. Entrusted to Dr. Mortimer by Sir Charles Baskerville. Written on stiff brown paper. Addressed to Hugo's sons Rodger and John, with instructions to say nothing to their sister Elizabeth." ;
    ex:ownedBy :jamesMortimer ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:battleAxe a ex:Weapon ;
    ex:prefLabel "Battle-Axe" ;
    ex:description "A weapon picked by Reginald Musgrave from the trophy-decorated corridor walls of Hurlstone when he went to investigate the light in the library and discovered Brunton." ;
    ex:locatedAt :hurlstone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:bayard a ex:Animal ;
    ex:prefLabel "Bayard" ;
    ex:description "Second horse at King's Pyland training stables owned by Colonel Ross. Simpson mentioned Bayard could give Silver Blaze a hundred yards in five furlongs at the weights, and that the stable had put their money on Bayard. The Colonel scratched Bayard from the Wessex Cup to put all hopes on Silver Blaze per Holmes's word." ;
    ex:ownedBy :colonelRoss ;
    ex:locatedIn :kingsPyland ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:berylCoronet a ex:Coronet ;
    ex:prefLabel "Beryl Coronet" ;
    skos:altLabel "the coronet" ;
    skos:altLabel "the diadem" ;
    ex:description "One of the most precious public possessions of the British Empire. A magnificent coronet containing thirty-nine enormous beryls set in gold chasing of incalculable value, worth at minimum double the £50,000 loan it secured. Left by an illustrious unnamed client as security for a loan from Holder & Stevenson. A corner holding three beryls was torn off during a struggle between Arthur Holder and Sir George Burnwell in the stable lane at Fairbank. The three missing beryls were sold by Burnwell to a receiver and recovered by Holmes for £3,000." ;
    ex:ownedBy :berylCoronetClient ;
    ex:stolenBy :sirGeorgeBurnwell ;
    ex:recoveredBy :sherlockHolmes ;
    ex:securityFor :berylCoronetLoan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:birlstoneHammer a ex:Weapon ;
    ex:prefLabel "Hammer (Birlstone)" ;
    ex:description "Substantial workmanlike hammer found on the rug in the study at Birlstone. Douglas had been using it to alter pictures." ;
    ex:foundAt :birlstoneManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:blackBoot a ex:Object ;
    ex:prefLabel "Sir Henry's black boot" ;
    skos:altLabel "the old boot" ;
    ex:description "Old black boot stolen from Sir Henry at the Northumberland Hotel. Labeled 'Meyers, Toronto.' Unlike the new brown boot, this carried Sir Henry's scent and was used to set the hound on his track. Found by the search party in the Grimpen Mire near the hound's island." ;
    ex:ownedBy :henryBaskerville ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:blackCatAtCottage a ex:Animal ;
    ex:prefLabel "Black Cat at the Cottage" ;
    ex:description "A large black cat found coiled up in a basket in the kitchen of the cottage at Norbury when Grant Munro entered searching for the occupants." ;
    ex:locatedIn :cottageAtNorbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:blastingPowder a ex:Weapon ;
    ex:prefLabel "Blasting Powder" ;
    ex:description "Bag of blasting powder from the quarries used to blow up Chester Wilcox's house at Iron Dike crossroad." ;
    ex:usedIn :blastingOfWilcoxHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:blowPipe a ex:Weapon ;
    ex:prefLabel "Blow-Pipe" ;
    ex:description "Short round piece of wood like a school-ruler. Used by Tonga to shoot poisoned darts. Andaman Island weapon." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:blueCarbuncle a ex:Jewelry ;
    ex:prefLabel "Blue Carbuncle" ;
    skos:altLabel "the Countess of Morcar's blue carbuncle" ;
    ex:description "The blue carbuncle is a brilliantly scintillating blue precious stone belonging to the Countess of Morcar. It is smaller than a bean in size but absolutely unique in value. It was found in the banks of the Amoy River in southern China and is not yet twenty years old. It has the characteristics of a carbuncle except that it is blue instead of ruby red. It weighs forty grains and is described as crystallised charcoal. Its history includes two murders, a vitriol-throwing, a suicide, and several robberies. A reward of £1000 was offered for its recovery, though its market value is far greater. It was stolen by James Ryder from the Hotel Cosmopolitan, hidden in a goose's crop, and eventually found by Peterson's wife." ;
    ex:reward "£1000" ;
    ex:foundBy :petersonWife ;
    ex:ownedBy :countessOfMorcar ;
    ex:stolenBy :jamesRyder ;
    ex:stolenFrom :countessOfMorcar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:boccacciosDecameron a ex:Document ;
    ex:prefLabel "Boccaccio's Decameron" ;
    ex:description "A pocket edition of Boccaccio's Decameron found in Drebber's pocket with the name Joseph Stangerson on the fly-leaf." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:bookOfLifeArticle a ex:Document ;
    ex:prefLabel "The Book of Life" ;
    ex:description "A magazine article written by Sherlock Holmes on the science of deduction and observation. Watson initially finds it preposterous until he learns Holmes is the author." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:bradstreetOrdnanceMap a ex:Map ;
    ex:prefLabel "Bradstreet's Ordnance Map" ;
    skos:altLabel "the ordnance map" ;
    ex:description "An ordnance map of Berkshire that Inspector Bradstreet spread on the train seat while travelling to Eyford. He used compasses to draw a ten-mile radius circle centred on Eyford to locate the criminals' base." ;
    ex:ownedBy :inspectorBradstreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:brandedTriangleMark a ex:Object ;
    ex:prefLabel "Branded Triangle Mark" ;
    ex:description "A circle with a triangle inside, branded on the forearm of all initiated members of the Vermissa Valley Scowrer lodge. Applied with a branding iron during the initiation ceremony." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:breckinridgeAccountBooks a ex:Document ;
    ex:prefLabel "Breckinridge's Account Books" ;
    ex:description "Breckinridge's account books consist of two volumes: a small thin book listing suppliers (with country folk on one page and town suppliers in red ink on another, with reference numbers to the ledger) and a great greasy-backed ledger with detailed accounts. The third name on the town suppliers page was Mrs. Oakshott, 117 Brixton Road, entry 249." ;
    ex:ownedBy :breckinridge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:bridalWreathAndVeil a ex:Clothing ;
    ex:prefLabel "Bridal Wreath and Veil" ;
    ex:description "Bride's wreath and veil found discoloured and soaked in water, floating in the Serpentine with the rest of Hatty Doran's wedding clothes." ;
    ex:foundAt :serpentine ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:britishMedicalJournal a ex:Document, ex:Journal ;
    ex:prefLabel "British Medical Journal" ;
    ex:description "A medical publication that Watson was reading after breakfast when Holmes visited him at his Paddington practice." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:brownBoot a ex:Object ;
    ex:prefLabel "Sir Henry's brown boot" ;
    skos:altLabel "the new tan boot" ;
    ex:description "New tan boot purchased by Sir Henry on the Strand for six dollars. Never worn. Stolen from outside his door at the Northumberland Hotel, then mysteriously returned. Stapleton stole it first to give the hound Sir Henry's scent, but returned it because a new unworn boot carried no scent." ;
    ex:ownedBy :henryBaskerville ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:brownHuntingCrop a ex:Object ;
    ex:prefLabel "Silas Brown's Hunting-Crop" ;
    skos:altLabel "hunting-crop" ;
    ex:description "Hunting-crop carried by Silas Brown, swinging in his hand as he strode out from the gate of Mapleton stables. Wagged like a branch in the wind as Brown's hands shook after Holmes's confrontation." ;
    ex:ownedBy :silasBrown ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:bruntonsChart a ex:Document ;
    ex:prefLabel "Brunton's Chart" ;
    skos:altLabel "chart-like paper" ;
    ex:description "A chart-like paper that Richard Brunton was studying alongside the Musgrave Ritual in the library. He thrust it into his breast when discovered by Musgrave. It appeared to be a map he was comparing with the Ritual manuscript to decode its directions." ;
    ex:ownedBy :richardBrunton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:bruntonsMuffler a ex:Clothing ;
    ex:prefLabel "Brunton's Muffler" ;
    ex:description "A thick shepherd's-check muffler belonging to Richard Brunton, found attached to the rusted iron ring in the centre of the cellar flagstone. Identified by Reginald Musgrave as definitely belonging to Brunton. It was used to provide a grip for pulling the flagstone." ;
    ex:ownedBy :richardBrunton ;
    ex:locatedAt :hurlstoneCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:burnwellLifePreserver a ex:LifePreserver ;
    ex:prefLabel "Sir George Burnwell's Life-Preserver" ;
    ex:description "A life-preserver (weighted bludgeon) that Sir George Burnwell took down from the wall when confronted by Holmes at his house. Holmes clapped a pistol to his head before Burnwell could strike." ;
    ex:ownedBy :sirGeorgeBurnwell ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:burnwellShoes a ex:Clothing ;
    ex:prefLabel "Sir George Burnwell's Cast-off Shoes" ;
    skos:altLabel "old elastic-sided boot" ;
    ex:description "A pair of Sir George Burnwell's cast-off shoes, including an old elastic-sided boot, purchased by Holmes from Burnwell's valet for six shillings. Holmes used them to confirm that the booted tracks in the snow in the stable lane at Fairbank matched Burnwell's footwear." ;
    ex:ownedBy :sirGeorgeBurnwell ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:carpetBag a ex:Object ;
    ex:prefLabel "Carpet Bag" ;
    ex:description "A bag used by Beddington to carry the stolen securities out of Mawson & Williams. Sergeant Tuson noticed the gentleman carrying it down the steps at twenty minutes past one on Saturday." ;
    ex:ownedBy :beddingtonBrother2 ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:cataractKnife a ex:Weapon ;
    ex:prefLabel "Cataract Knife" ;
    skos:altLabel "Straker's knife" ;
    ex:description "Ivory-handled knife with a very delicate, inflexible blade marked Weiss & Co., London. Found in John Straker's right hand, clotted with blood up to the handle. Identified by Watson as a cataract knife - a surgical instrument designed for very delicate work. Had lain on the dressing-table and Straker picked it up as he left the house. The tip was guarded by a disk of cork found beside the body. Holmes deduced Straker intended to use it to nick Silver Blaze's tendon subcutaneously. The knife gashed Straker's own thigh when he fell after being kicked by the horse." ;
    ex:ownedBy :johnStraker ;
    ex:madeBy :weissAndCo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:cellarFlagstone a ex:Object ;
    ex:prefLabel "Cellar Flagstone" ;
    ex:description "A large and heavy flagstone with a rusted iron ring in the centre, covering the hidden cellar chamber at Hurlstone. Too heavy for one person to move unaided. Brunton attached his muffler to the ring. He and Rachel used billets of wood as levers to raise it. When the support was removed (accidentally or by Rachel), it trapped Brunton in the chamber below." ;
    ex:locatedAt :hurlstoneCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:chamoisLeatherBag a ex:Object ;
    ex:prefLabel "Chamois Leather Bag" ;
    ex:description "A heavy chamois leather bag produced by the King of Bohemia from under his cloak. Contains three hundred pounds in gold and seven hundred in notes, totaling one thousand pounds, as payment for Holmes's expenses." ;
    ex:ownedBy :wilhelmVonOrmstein ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:charlesMcCarthyBoots a ex:Object ;
    ex:prefLabel "Charles McCarthy's Boots" ;
    ex:description "Boots worn by Charles McCarthy at the time of his death. Shown to Holmes at Hatherley Farm by the maid. Holmes measured them carefully from seven or eight different points." ;
    ex:ownedBy :charlesMcCarthy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:childrensBricks a ex:Toy ;
    ex:prefLabel "Box of Children's Bricks" ;
    ex:description "A box of children building bricks that Neville St. Clair promised to bring home for his little boy. Found in a small deal box on the table in Hugh Boone room. Its discovery, along with Boone evident confusion, convinced Inspector Barton that the matter was serious." ;
    ex:ownedBy :nevilleStClair ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :manWithTheTwistedLipDoc .

:chronicleAdvertisement a ex:Document ;
    ex:prefLabel "Chronicle Advertisement" ;
    skos:altLabel "the slip" ;
    ex:description "A missing persons advertisement placed by Mary Sutherland in last Saturday's Chronicle for Hosmer Angel. Contains a physical description: about five feet seven inches, strongly built, sallow complexion, black hair slightly bald, bushy black side-whiskers and moustache, tinted glasses, slight infirmity of speech, wearing black frock-coat faced with silk, black waistcoat, gold Albert chain, grey Harris tweed trousers with brown gaiters over elastic-sided boots." ;
    ex:authoredBy :marySutherland ;
    ex:publishedIn :saturdayChronicle ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:cipherMessage a ex:Document ;
    ex:prefLabel "Porlock's Cipher Message" ;
    ex:description "Coded message from Porlock to Holmes using numbers referring to words in Whitaker's Almanac. Decoded to read: There is danger may come very soon one Douglas rich country now at Birlstone House Birlstone confidence is pressing." ;
    ex:sentBy :fredPorlock ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:codedLetter a ex:Letter ;
    ex:prefLabel "Coded Cipher Letter" ;
    skos:altLabel "the warning letter" ;
    skos:altLabel "the cipher letter" ;
    ex:description "A letter sent by Beddoes to old Mr. Trevor, bearing the Fordingbridge post-mark. The apparently innocuous message read: 'The supply of game for London is going steadily up. Head-keeper Hudson, we believe, has been now told to receive all orders for fly-paper and for preservation of your hen-pheasant's life.' Holmes decoded it using every-third-word cipher: 'The game is up. Hudson has told all. Fly for your life.' The sporting filler words suggested the sender was an ardent sportsman. Written on a half-sheet of slate gray paper. Reading this letter caused old Trevor to suffer a fatal stroke." ;
    ex:postmark "Fordingbridge" ;
    ex:writtenBy :beddoes ;
    ex:decodedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:coffinNotices a ex:Document ;
    ex:prefLabel "Coffin Notices" ;
    ex:description "Threatening notices hung outside the doors of Scowrer targets as warnings before violence." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:coiningMoulds a ex:Object ;
    ex:prefLabel "Coining Moulds" ;
    ex:description "Counterfeit coin-making equipment that McMurdo/Edwards used as part of his cover story. Kept in his bedroom, later hidden under the floor." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:coinsOfCharlesI a ex:Object ;
    ex:prefLabel "Coins of Charles I" ;
    skos:altLabel "rusty discs of metal" ;
    ex:description "Several old coins bearing the name of Charles the First, scattered over the bottom of the ancient chest in the cellar chamber. Some were also kept by Holmes among his case relics. They helped date the Musgrave Ritual and confirm its connection to the English Civil War era." ;
    ex:locatedAt :hurlstoneCellar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:continentalGazetteer a ex:Object ;
    ex:prefLabel "Continental Gazetteer" ;
    ex:description "A heavy brown volume from Holmes's shelves. A reference book used to look up Egria and identify the origin of the note paper as Bohemian." ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:counterfeiterMetals a ex:Object ;
    ex:prefLabel "Counterfeiter's Metals" ;
    skos:altLabel "nickel and tin stores" ;
    ex:description "Large masses of nickel and tin discovered stored in an out-house at Dr. Becher's property after the fire. These were raw materials for the counterfeiting operation. No actual coins were found at the site." ;
    ex:locatedIn :becherHouse ;
    ex:ownedBy :starkCounterfeitingGang ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:counterfeitHalfCrowns a ex:Object ;
    ex:prefLabel "Counterfeit Half-Crowns" ;
    ex:description "Fraudulent half-crown coins produced by Stark's counterfeiting gang using a hydraulic press and an amalgam that replaced silver. The police had known for some time that a gang was turning them out by the thousand." ;
    ex:createdBy :starkCounterfeitingGang ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:countessMorcarJewelCase a ex:Object ;
    ex:prefLabel "Countess of Morcar's Jewel Case" ;
    skos:altLabel "morocco casket" ;
    ex:description "The Countess of Morcar's jewel case is a small morocco casket in which she was accustomed to keep her jewel (the blue carbuncle). It was found lying empty on the dressing-table after the bureau had been forced open during the robbery at the Hotel Cosmopolitan." ;
    ex:ownedBy :countessOfMorcar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:dailyTelegraph a ex:Newspaper ;
    ex:prefLabel "The Daily Telegraph" ;
    skos:altLabel "Daily Telegraph" ;
    ex:description "The Daily Telegraph is a London newspaper that reported on the Brixton Mystery. Published the long telegram from Paris connecting M. Henri Fournaye to Eduardo Lucas and revealing the murder was committed by Mme. Fournaye. Its agony column was used for coded correspondence between Hugo Oberstein (as 'Pierrot') and Colonel Valentine Walter to arrange the theft and sale of the Bruce-Partington plans." ;
    ex:locatedIn :london ;
    ex:publishedBy :dailyTelegraphOrg ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc  ;
    dc:source :copperBeechesDoc ;
    dc:source :secondStainDoc  ;
    dc:source :brucePartingtonPlansDoc .

:darkLantern a ex:Lantern ;
    ex:prefLabel "Dark Lantern" ;
    ex:description "Lantern used in the bank vault. Merryweather lights it. Holmes slides the screen across to plunge the vault into darkness for the ambush. He flashes it when Clay emerges." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:darkLanternRoylott a ex:Lantern ;
    ex:prefLabel "Roylott's Dark Lantern" ;
    ex:description "A dark-lantern found on the table in Dr. Roylott's room after his death, with the shutter half open, throwing a brilliant beam of light upon the iron safe. Holmes and Watson first noticed a momentary gleam of light from the ventilator when Roylott lit it in the adjacent room." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:desborough a ex:Animal ;
    ex:prefLabel "Desborough" ;
    ex:description "Racehorse, second favorite for the Wessex Cup. Owned by Lord Backwater and trained at Mapleton stables by Silas Brown. Wore yellow cap and sleeves in the race. Showed to the front halfway through the Wessex Cup but its bolt was shot and it was passed by Silver Blaze." ;
    ex:ownedBy :lordBackwater ;
    ex:locatedIn :mapleton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:devonCountyChronicle a ex:Newspaper ;
    ex:prefLabel "Devon County Chronicle" ;
    ex:description "Local newspaper. The May 14th issue contained the account of Sir Charles Baskerville's death, which Dr. Mortimer read to Holmes." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:dogWhip a ex:Object ;
    ex:prefLabel "Dog Whip" ;
    skos:altLabel "dog lash" ;
    skos:altLabel "dog-whip" ;
    ex:description "A small dog lash found in Dr. Roylott's room, hung on one corner of the bed. The lash was curled upon itself and tied to make a loop of whipcord. Found across Roylott's lap after his death. Holmes used it to throw a noose around the snake's neck and place it back in the safe." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:douglasManuscript a ex:Document ;
    ex:prefLabel "Douglas's Manuscript" ;
    ex:description "Written account by John Douglas of his experiences as Birdy Edwards in Vermissa Valley, which forms Part II of the novel." ;
    ex:authoredBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:douglasWeddingRing a ex:Jewelry ;
    ex:prefLabel "Douglas's Wedding Ring" ;
    ex:description "Plain gold wedding ring worn on the little finger of Douglas's left hand below a nugget ring. Could not be removed due to tight fit, which was a flaw in the deception plan." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:drebbersGoldWatch a ex:Object ;
    ex:prefLabel "Drebber's Gold Watch" ;
    ex:description "A gold watch, No. 97163, by Barraud of London. Found on Drebber's body." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:drebbersHat a ex:Clothing ;
    ex:prefLabel "Drebber's Hat" ;
    ex:description "A hat found beside Drebber's body. Made by John Underwood and Sons, 129 Camberwell Road." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:dumbbell a ex:Object ;
    ex:prefLabel "Dumbbell" ;
    ex:description "One of a pair of dumbbells belonging to Douglas. The missing second dumbbell was used by Barker to weight Baldwin's clothes bundle sunk in the moat. Holmes deduced its significance." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:dummyBellRope a ex:Object ;
    ex:prefLabel "Dummy Bell-Rope" ;
    skos:altLabel "bell-pull" ;
    ex:description "A thick bell-rope hanging beside the bed in the second bedroom at Stoke Moran, with its tassel lying on the pillow. Holmes discovered it was a dummy—not attached to any wire. It was fastened to a hook above the ventilator opening. Installed about two years before the main events (around the time of Julia's death). It served as a bridge for the swamp adder to descend from the ventilator to the bed." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:dynamicsOfAnAsteroid a ex:Publication ;
    ex:prefLabel "The Dynamics of an Asteroid" ;
    ex:description "Book by Professor Moriarty that ascends to such rarefied heights of pure mathematics that no one in the scientific press was capable of criticizing it. A book written by Professor Moriarty which ascends to such rarefied heights of pure mathematics that it is said no man in the scientific press was capable of criticizing it." ;
    ex:authoredBy :professorMoriarty ;
    ex:authoredBy :professorMoriarty ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc ;
    dc:source :finalProblemDoc .

:effiePhotograph a ex:Photograph ;
    ex:prefLabel "Effie's Photograph" ;
    ex:description "A full-length photograph of Effie Munro, taken at Grant Munro's request only three months before the events of the story. Found by Munro on the mantelpiece in the comfortable upstairs room of the cottage at Norbury, fueling his suspicions about his wife's connection to the cottage's occupants." ;
    ex:depicts :effieMunro ;
    ex:locatedIn :cottageAtNorbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:eliasOpenshawDiaryPage a ex:Diary, ex:Document ;
    ex:prefLabel "Elias Openshaw's Diary Page" ;
    skos:altLabel "blue-tinted paper" ;
    skos:altLabel "diary page" ;
    ex:description "A single sheet of discoloured blue-tinted paper. A surviving fragment from the papers Colonel Elias Openshaw burned after receiving the KKK letter. Found on the floor of Elias's room by John Openshaw. Headed 'March, 1869' with entries recording KKK activities: '4th. Hudson came. Same old platform. 7th. Set the pips on McCauley, Paramore, and John Swain, of St. Augustine. 9th. McCauley cleared. 10th. John Swain cleared. 12th. Visited Paramore. All well.' John showed this page to Holmes, who instructed him to place it in the brass box on the sundial." ;
    ex:foundAt :openshawEstate ;
    ex:ownedBy :eliasOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:emeraldSnakeRing a ex:Jewelry ;
    ex:prefLabel "Emerald Snake Ring" ;
    ex:description "An emerald snake ring slipped from the King of Bohemia's finger, offered as a reward to Holmes. Holmes declines, preferring the photograph of Irene Adler instead." ;
    ex:ownedBy :wilhelmVonOrmstein ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:encyclopaediaBritannica a ex:Book ;
    ex:prefLabel "Encyclopaedia Britannica" ;
    ex:description "Reference encyclopedia that Wilson is instructed to copy as his Red-headed League duty. He starts with the letter A, getting through Abbots, Archery, Armour, Architecture, and Attica over eight weeks. The first volume is provided in a press at the League office." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:esmeralda a ex:Vessel ;
    ex:prefLabel "Esmeralda" ;
    ex:description "Vessel at Gravesend, outward bound for Brazil. Jonathan Small and Tonga planned to escape on her." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:eveningNews a ex:Newspaper ;
    ex:prefLabel "Evening News" ;
    ex:description "The Evening News is an evening newspaper in London. Holmes instructed Peterson to place an advertisement in it." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:eveningStandardClerk a ex:Document, ex:Newspaper ;
    ex:prefLabel "Evening Standard (Stock-Broker's Clerk)" ;
    skos:altLabel "Evening Standard" ;
    ex:description "An early edition of the London Evening Standard newspaper purchased by Pinner from a newsboy on Corporation Street. It contained the report of the crime at Mawson & Williams under the headlines: Crime in the City, Murder at Mawson and Williams's, Gigantic attempted Robbery, Capture of the Criminal. Reading this paper caused Pinner to attempt suicide. Holmes used it to understand the full scope of the case." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:fhmNote a ex:Letter ;
    ex:prefLabel "F.H.M. Note" ;
    ex:description "A note found in a card-case in the pocket of Hatty's wedding dress. Written in pencil: 'You will see me when all is ready. Come at once. F.H.M.' The initials are those of Francis Hay Moulton. Lestrade believed it was written by Flora Millar to lure the bride. On the reverse side is a fragment of a hotel bill. Holmes recognized the bill fragment as the crucial evidence." ;
    ex:author :francisHayMoulton ;
    ex:foundAt :serpentine ;
    ex:recipient :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:fieldGlass a ex:Object ;
    ex:prefLabel "Watson's Field-Glass" ;
    skos:altLabel "field-glass" ;
    ex:description "Watson's field-glass (binoculars) that Holmes requested he bring on the journey to Dartmoor. Used by Holmes at the Winchester racecourse to watch the Wessex Cup race." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:fishingRod a ex:Object ;
    ex:prefLabel "Fishing Rod" ;
    ex:description "Two lengths of a fishing rod that together came to exactly six feet, used by Holmes to calculate the shadow proportions needed to decode the Musgrave Ritual. The six-foot rod cast a nine-foot shadow, allowing calculation of the sixty-four-foot elm's ninety-six-foot shadow." ;
    ex:locatedAt :hurlstone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:fiveOrangePips a ex:Object ;
    ex:prefLabel "Five Orange Pips" ;
    skos:altLabel "dried orange pips" ;
    skos:altLabel "orange pips" ;
    ex:description "Five dried orange pips used as a warning token by the Ku Klux Klan. Sent three times to the Openshaw family: to Colonel Elias from Pondicherry (March 1883), to Joseph from Dundee (January 1885), and to John from East London (September 1887). Each time accompanied by the letters 'K.K.K.' Holmes also sent five orange pips to Captain James Calhoun in an envelope inscribed 'S.H. for J.O.'" ;
    ex:usedBy :kuKluxKlan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:footstepsMonograph a ex:Document ;
    ex:prefLabel "Monograph on Footsteps" ;
    ex:description "Holmes's monograph on tracing of footsteps, with some remarks upon the uses of plaster of Paris as a preserver of impresses." ;
    ex:writtenBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:franklandsTelescopeObj a ex:Object ;
    ex:prefLabel "Frankland's telescope" ;
    ex:description "Formidable astronomical instrument mounted on a tripod on the flat leads of Lafter Hall roof. Frankland used it for amateur stargazing and to survey the moor, inadvertently spotting the boy carrying food to Holmes in his stone hut." ;
    ex:locatedIn :lafterHall ;
    ex:ownedBy :frankland ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:frenchGold a ex:Treasure ;
    ex:prefLabel "French Gold" ;
    skos:altLabel "30,000 napoleons" ;
    ex:description "Thirty thousand napoleons (French gold coins) borrowed from the Bank of France by the City and Suburban Bank some months prior. Stored in the bank vault in crates packed between layers of lead foil. The crate upon which Merryweather sits contains 2,000 napoleons. This gold is the target of John Clay's tunnel robbery attempt." ;
    ex:amount "30,000 napoleons" ;
    ex:locatedIn :cityAndSuburbanBankCoburgBranch ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:germanBooks a ex:Object ;
    ex:prefLabel "German Books" ;
    ex:description "Several German books scattered on a round table in the waiting room at Dr. Becher's house. Two were treatises on science and the others were volumes of poetry. They indicated the German nationality of the house's occupants." ;
    ex:locatedIn :becherHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:gloriaScottShip a ex:Bark ;
    ex:prefLabel "Gloria Scott" ;
    skos:altLabel "the bark Gloria Scott" ;
    skos:altLabel "the Gloria Scott" ;
    ex:description "A bark (sailing vessel) that had formerly been in the Chinese tea-trade. An old-fashioned, heavy-bowed, broad-beamed craft that had been cut out by the new clippers. A five-hundred-ton boat that was pressed into service as a convict transport during the Crimean War when the usual convict ships were being used in the Black Sea. Carried thirty-eight convicts, twenty-six crew, eighteen soldiers, a captain, three mates, a doctor, a chaplain, and four warders — nearly a hundred souls in all. Sailed from Falmouth on October 8, 1855. After a mutiny led by Jack Prendergast, the ship was destroyed by an explosion in the after-hold on November 6, 1855, at approximately N. Lat. 15° 20', W. Long. 25° 14'. Set down by the Admiralty as lost at sea." ;
    ex:tonnage "Five hundred tons" ;
    ex:destroyedIn :gloriaScottExplosion ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:grantMunroHat a ex:Clothing ;
    ex:prefLabel "Grant Munro's Hat" ;
    skos:altLabel "the brown wide-awake" ;
    ex:description "A brown wide-awake hat carried by Grant Munro when he visited Holmes. His name was written on the lining, which is how Holmes knew his name before being told." ;
    ex:ownedBy :grantMunro ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:grantMunroPipe a ex:Object ;
    ex:prefLabel "Grant Munro's Pipe" ;
    skos:altLabel "the old brier pipe" ;
    ex:description "An old brier pipe with a good long amber stem, originally costing seven shillings and sixpence. Twice mended with silver bands, once in the wooden stem and once in the amber mouthpiece, each repair costing more than the original pipe. Left behind at 221B Baker Street by Grant Munro. Holmes deduced from it that the owner was muscular, left-handed, with excellent teeth, careless habits, and no need to practise economy. Filled with Grosvenor mixture tobacco at eightpence an ounce. Charred on the right side from being lit at lamps and gas-jets, indicating left-handedness. The amber was bitten through, indicating muscular jaw and good teeth." ;
    ex:ownedBy :grantMunro ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:gregsonsLetter a ex:Letter ;
    ex:prefLabel "Gregson's Letter" ;
    ex:description "A letter from Tobias Gregson to Holmes informing him of the body found at 3 Lauriston Gardens." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:greyCloak a ex:Object ;
    ex:prefLabel "Grey Cloak" ;
    skos:altLabel "grey garment" , "grey coat" , "grey plaid" ;
    ex:description "A grey cloak worn by John Turner. James McCarthy had a vague impression of something grey lying on the ground near his father's body — a coat or plaid — which disappeared while his back was turned. Turner confirmed he dropped the cloak in his flight from the murder scene and had to go back for it." ;
    ex:ownedBy :johnTurner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:handcuffs a ex:Handcuffs ;
    ex:prefLabel "Handcuffs" ;
    skos:altLabel "bracelets" ;
    skos:altLabel "derbies" ;
    ex:description "Handcuffs placed on John Clay's wrists by Peter Jones after his capture in the bank vault. Also referred to as 'derbies' and 'bracelets.'" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:hatherleyHandkerchief a ex:Object ;
    ex:prefLabel "Hatherley's Handkerchief" ;
    ex:description "A handkerchief belonging to Victor Hatherley that he wrapped around his wounded hand to stop the bleeding after his thumb was severed. It was mottled all over with bloodstains when Watson first saw it. Hatherley had tied one end tightly round his wrist and braced it with a twig." ;
    ex:ownedBy :victorHatherley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:hatherleyOilLamp a ex:Object ;
    ex:prefLabel "Hatherley's Oil Lamp" ;
    skos:altLabel "the lamp" ;
    ex:description "An oil lamp that Hatherley used while examining the hydraulic press. When the press was activated, the lamp was crushed and set fire to the wooden walls of the press chamber, ultimately causing the entire house to burn down." ;
    ex:locatedIn :becherHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:hatherleySeveredThumb a ex:Object ;
    ex:prefLabel "Hatherley's Severed Thumb" ;
    skos:altLabel "Mr. Hatherley's thumb" ;
    ex:description "Victor Hatherley's right thumb, severed by Colonel Lysander Stark's cleaver as Hatherley escaped through a window. The firemen later found the newly severed thumb on a window-sill of the second floor of Dr. Becher's house." ;
    ex:ownedBy :victorHatherley ;
    ex:locatedIn :becherHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:hatherleyVisitingCard a ex:Document ;
    ex:prefLabel "Hatherley's Visiting Card" ;
    ex:description "Victor Hatherley's visiting card, which read 'Mr. Victor Hatherley, hydraulic engineer, 16A, Victoria Street (3rd floor).' He gave it to Watson's maid, who left it on the side-table." ;
    ex:ownedBy :victorHatherley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:hattyBouquet a ex:Object ;
    ex:prefLabel "Hatty's Bridal Bouquet" ;
    ex:description "Hatty Doran's bridal bouquet, dropped near the front pew at St. George's church as the wedding party walked towards the vestry. Francis Moulton, seated in the pew, handed it back with a note slipped inside. The bouquet served as the mechanism for Moulton to communicate with Hatty during the ceremony." ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hattyCardCase a ex:Object ;
    ex:prefLabel "Card-Case" ;
    ex:description "A card-case found in the pocket of Hatty Doran's wedding dress. Contained the note signed F.H.M. with the hotel bill fragment on the reverse." ;
    ex:foundAt :serpentine ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hattyDoranMiniature a ex:Miniature ;
    ex:prefLabel "Ivory Miniature of Hatty Doran" ;
    ex:description "An ivory miniature portrait of Hatty Doran, kept in a locket by Lord St. Simon. Not a photograph. The artist brought out the full effect of the lustrous black hair, the large dark eyes, and the exquisite mouth. Holmes gazed at it long and earnestly." ;
    ex:depictsEntity :hattyDoran ;
    ex:ownedBy :lordRobertStSimon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hattyUlster a ex:Clothing ;
    ex:prefLabel "Hatty's Ulster" ;
    ex:description "A long ulster (overcoat) that Hatty Doran put on over her bride's dress when fleeing the wedding breakfast at Lancaster Gate. She caught it up from her room and hurried down to the passage." ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hattyWeddingDress a ex:Clothing ;
    ex:prefLabel "Hatty's Wedding Dress" ;
    ex:description "A wedding dress of watered silk worn by Hatty Doran at her wedding to Lord St. Simon. Found discoloured and soaked in water, floating near the margin of the Serpentine. Had a pocket containing a card-case with a note from F.H.M. Frank Moulton made a bundle of the wedding clothes and dropped them to prevent Hatty from being traced." ;
    ex:foundAt :serpentine ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hattyWeddingRing a ex:Jewelry ;
    ex:prefLabel "Hatty's Wedding Ring" ;
    ex:description "A new wedding ring found in the Serpentine with the wedding clothes. Lestrade placed it on top of the pile of recovered items. Symbolically discarded along with the rest of the wedding attire." ;
    ex:foundAt :serpentine ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hattyWeddingShoes a ex:Clothing ;
    ex:prefLabel "Hatty's White Satin Shoes" ;
    ex:description "Pair of white satin shoes found floating in the Serpentine with the rest of Hatty Doran's wedding clothes." ;
    ex:foundAt :serpentine ;
    ex:ownedBy :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:haylingAdvertisement a ex:Advertisement ;
    ex:prefLabel "Hayling Disappearance Advertisement" ;
    ex:description "A newspaper advertisement that appeared in all the papers about a year before the Engineer's Thumb case, reporting the disappearance of Jeremiah Hayling, a 26-year-old hydraulic engineer who left his lodgings at ten o'clock at night and was not heard of since. Holmes found it in his commonplace books." ;
    ex:mentionedIn :holmesCommonplaceBooks ;
    ex:mentions :jeremiahHayling ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:hebronDeathCertificate a ex:Document ;
    ex:prefLabel "John Hebron's Death Certificate" ;
    ex:description "A certificate of death for John Hebron. The original was destroyed in a great fire in Atlanta shortly after Hebron's death. A duplicate was obtained afterward by Effie, who showed it to Grant Munro. Holmes noted the significance of her having a duplicate certificate despite claiming all papers were destroyed." ;
    ex:ownedBy :effieMunro ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:hebronSilverLocket a ex:Jewelry ;
    ex:prefLabel "John Hebron's Silver Locket" ;
    skos:altLabel "the silver locket" ;
    ex:description "A large silver locket worn by Effie Munro containing a portrait of her first husband John Hebron. Grant Munro understood that it did not open. At the climax of the story, Effie touched a spring and the front hinged back to reveal the portrait of Hebron, described as a strikingly handsome and intelligent-looking man bearing unmistakable signs of his African descent." ;
    ex:ownedBy :effieMunro ;
    ex:depicts :johnHebron ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:henryBakerGoose a ex:Animal ;
    ex:prefLabel "Henry Baker's Goose" ;
    ex:description "Henry Baker's goose is a white goose with a black bar across the tail and a card reading 'For Mrs. Henry Baker' tied to its left leg. It was found by Peterson on Tottenham Court Road on Christmas morning. The blue carbuncle was found in its crop by Peterson's wife. The goose was one of 24 supplied by Mrs. Oakshott to Breckinridge, then sold to Windigate of the Alpha Inn for the goose club. There were two barred-tailed geese, and James Ryder had hidden the carbuncle in the other one, receiving the wrong bird." ;
    ex:foundBy :peterson ;
    ex:ownedBy :henryBaker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:henryBakerHat a ex:Clothing ;
    ex:prefLabel "Henry Baker's Hat" ;
    ex:description "Henry Baker's hat is a very ordinary black hard-felt hat of the usual round shape, seedy and disreputable, cracked in several places. It was of the very best quality three years ago with a band of ribbed silk and excellent red silk lining, now discoloured. The initials 'H. B.' are scrawled on one side. It had a hat-securer with a broken elastic. It was spotted with tallow stains and smeared with ink to hide discoloured patches. Holmes deduced the owner's character from examining it." ;
    ex:foundBy :peterson ;
    ex:ownedBy :henryBaker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:herefordshireNewspaper a ex:Newspaper ;
    ex:prefLabel "Herefordshire Newspaper" ;
    skos:altLabel "the local Herefordshire paper" , "the weekly county paper" ;
    ex:description "Local Herefordshire newspaper containing a detailed account of the Boscombe Valley case. Holmes had a copy on the train which he showed Watson, containing James McCarthy's testimony at the inquest. Watson also obtained a copy at the hotel containing the surgeon's deposition." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:holderBureau a ex:Bureau ;
    ex:prefLabel "Holder's Bureau" ;
    ex:description "A large bureau in Alexander Holder's dressing-room at Fairbank where the beryl coronet was locked for safekeeping. Has a noiseless lock that could be opened with the key to the lumber-room cupboard, a fact known to Arthur Holder from childhood." ;
    ex:locatedIn :fairbank ;
    ex:ownedBy :alexanderHolder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:hollandRing a ex:Jewelry ;
    ex:prefLabel "Ring from Holland" ;
    skos:altLabel "remarkable brilliant" ;
    ex:description "A remarkable brilliant (ring) sparkling on Holmes's finger. A gift from the reigning family of Holland for a matter of such delicacy that Holmes cannot confide it even to Watson." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:holmesCane a ex:Object ;
    ex:prefLabel "Holmes's Cane" ;
    ex:description "A long thin cane that Holmes brought to the night vigil at Stoke Moran. He placed it on the bed beside him. When the snake descended the bell-rope, Holmes sprang from the bed and lashed furiously at it with the cane, driving it back through the ventilator." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:holmesClayPipe a ex:Object ;
    ex:prefLabel "Holmes's Black Clay Pipe" ;
    ex:description "Black clay pipe used by Holmes while thinking about the Red-headed League case. He describes it as a 'three pipe problem' and sits curled up with it thrusting out like the bill of a strange bird." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc ;
    dc:source :redHeadedLeagueDoc .

:holmesCommonplaceBook a ex:Document ;
    ex:prefLabel "Holmes's Commonplace Book" ;
    skos:altLabel "common-place book" ;
    ex:description "A scrapbook into which Holmes was pasting extracts at 221B Baker Street in the framing narrative. Watson suggested that after finishing with it, Holmes might tidy the room, prompting the discovery of the Musgrave Ritual relics." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc  ;
    dc:source :missingThreeQuarterDoc .

:holmesEnvelopeToCalhoun a ex:Letter ;
    ex:prefLabel "Holmes's Envelope to Calhoun" ;
    ex:description "An envelope prepared by Sherlock Holmes containing five orange pips. On the inside of the flap, Holmes wrote 'S.H. for J.O.' He sealed it and addressed it to 'Captain James Calhoun, Barque Lone Star, Savannah, Georgia.' Intended to arrive before Calhoun when the ship reached port." ;
    ex:sentBy :sherlockHolmes ;
    ex:sentTo :captainJamesCalhoun ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:holmesGladstoneBag a ex:Bag ;
    ex:prefLabel "Holmes's Gladstone Bag" ;
    ex:description "A Gladstone bag that Holmes brought to Bow Street containing a very large bath sponge. He retrieved the sponge from the bathroom at The Cedars and used it to wash the disguise off Neville St. Clair face in the police cell." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :manWithTheTwistedLipDoc .

:holmesGoldSnuffbox a ex:Object ;
    ex:prefLabel "Holmes's Gold Snuffbox" ;
    ex:description "A snuffbox of old gold with a great amethyst in the centre of the lid. A souvenir from the King of Bohemia given to Holmes in return for his assistance in the case of the Irene Adler papers. Its splendour contrasts with Holmes's homely ways and simple life." ;
    ex:givenBy :wilhelmVonOrmstein ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:holmesHuntingCrop a ex:Weapon ;
    ex:prefLabel "Holmes's Hunting Crop" ;
    ex:description "Heavy hunting crop taken by Holmes from the rack at 221B Baker Street. Used to strike the revolver from John Clay's wrist during the vault confrontation." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc ;
    dc:source :redHeadedLeagueDoc .

:holmesIndex a ex:Object ;
    ex:prefLabel "Holmes's Index" ;
    ex:description "Sherlock Holmes's personal biographical index. A system of docketing all paragraphs concerning men and things, accumulated over many years. Difficult to name a subject or person on which Holmes could not at once furnish information. Used to look up Irene Adler's biography. Her entry was sandwiched between that of a Hebrew rabbi and a staff-commander who had written a monograph on deep-sea fishes." ;
    ex:locatedIn :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:holmesLens a ex:Tool ;
    ex:prefLabel "Holmes's Magnifying Lens" ;
    ex:description "Powerful convex lens used by Holmes for examination of evidence. Used extensively in The Sign of the Four to study footprints, the murder scene, and the garret. Holmes whips his lens from his pocket to examine the chipped stonework on the parapet of Thor Bridge." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc ;
    dc:source :thorBridgeDoc .

:holmesMagnifyingLens a ex:Object ;
    ex:prefLabel "Holmes's Magnifying Lens" ;
    ex:description "Magnifying lens used by Holmes in the bank vault to examine the cracks between the stones on the floor. Holmes used his magnifying lens to examine the cover of the J.H.N. notebook in the Black Peter case." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc ;
    dc:source :redHeadedLeagueDoc ;
    dc:source :blackPeterDoc .

:holmesPackOfCards a ex:PlayingCards ;
    ex:prefLabel "Holmes's Pack of Cards" ;
    ex:description "Pack of cards Holmes brought in his pocket, intending to offer Merryweather a rubber while waiting in the vault. Not used because of the need for darkness." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:holmesTinBox a ex:Object ;
    ex:prefLabel "Holmes's Tin Box" ;
    ex:description "A large tin box of early case records stored in Holmes's bedroom at 221B Baker Street. Already a third full of bundles of paper tied up with red tape into separate packages. Contains records of cases from before Watson's time as Holmes's biographer." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:holmesViolin a ex:Object ;
    ex:prefLabel "Holmes's Violin" ;
    ex:description "Sherlock Holmes's violin. He plays Mendelssohn's Lieder and other pieces. Scrapes carelessly when thinking. Sometimes produces sonorous, melancholy chords. In The Sign of the Four, Holmes plays a low, dreamy, melodious air on his violin, improvising as a recreation. Holmes scrapes on his violin while pondering the Norwood Builder case." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc ;
    dc:source :studyInScarletDoc ;
    dc:source :norwoodBuilderDoc .

:hosmerAngelLetters a ex:Letter ;
    ex:prefLabel "Hosmer Angel's Letters" ;
    ex:description "Four typewritten letters from Hosmer Angel to Mary Sutherland. All typewritten including the signature at the bottom. No superscription except Leadenhall Street with a date. Quotes Balzac once. The typewriter shows the same defects as James Windibank's typewritten note: slurring of the e, tailless r, and fourteen other characteristics, proving Angel and Windibank used the same machine." ;
    ex:authoredBy :hosmerAngel ;
    ex:ownedBy :marySutherland ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:hotelBillFragment a ex:Document ;
    ex:prefLabel "Hotel Bill Fragment" ;
    ex:description "Fragment of a hotel bill found on the reverse side of the F.H.M. note. 'Oct. 4th, rooms 8s., breakfast 2s. 6d., cocktail 1s., lunch 2s. 6d., glass sherry, 8d.' The select prices (eight shillings for a bed, eightpence for a glass of sherry) led Holmes to identify it as one of the most expensive London hotels and trace Moulton to a hotel on Northumberland Avenue." ;
    ex:foundAt :serpentine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:hotspurBrig a ex:Brig ;
    ex:prefLabel "Hotspur" ;
    skos:altLabel "the brig Hotspur" ;
    ex:description "A brig bound for Australia that picked up the dissenting group of convicts and sailors the day after the Gloria Scott's destruction. The captain found no difficulty in believing they were survivors of a passenger ship that had foundered. Landed them at Sydney." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:hugoPortrait a ex:Object ;
    ex:prefLabel "Portrait of Hugo Baskerville" ;
    ex:description "Painting from 1647 hanging in Baskerville Hall depicting Hugo in black velvet and lace, resembling a cavalier. Holmes covered the hat and ringlets with his hands to reveal a striking resemblance to Stapleton, proving him a Baskerville descendant." ;
    ex:depicts :hugoBaskerville ;
    ex:locatedIn :baskervilleHall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:hundredPoundNote a ex:Object ;
    ex:prefLabel "Hundred Pound Note" ;
    skos:altLabel "advance on salary" ;
    ex:description "A banknote for one hundred pounds given by Arthur Pinner to Hall Pycroft as an advance on his salary for the Franco-Midland Hardware Company position." ;
    ex:ownedBy :hallPycroft ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:huntingCrop a ex:Object ;
    ex:prefLabel "Hunting-crop" ;
    ex:description "Sir Henry's weapon when he and Watson pursued Selden across the moor at night." ;
    ex:ownedBy :henryBaskerville ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:indianCigar a ex:Object ;
    ex:prefLabel "Indian Cigar" ;
    ex:description "An Indian cigar of the variety rolled in Rotterdam, smoked by John Turner behind a beech tree near Boscombe Pool while he waited for Charles McCarthy to be alone. Holmes found the ash and stump, identifying it through his special knowledge of tobacco ashes. The tip had been cut off with a blunt pen-knife rather than bitten, indicating use of a cigar-holder." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:ireneLetterToHolmes a ex:Letter ;
    ex:prefLabel "Irene's Letter to Holmes" ;
    ex:description "A letter from Irene Norton née Adler to Sherlock Holmes, dated at midnight of the preceding night. Superscribed 'Sherlock Holmes, Esq. To be left till called for.' Found in the recess behind the sliding panel at Briony Lodge alongside the photograph of Irene. Explains how she was warned about Holmes months ago, recognized him despite his clergyman disguise, followed him home in male costume, wished him good-night at his door, then decided to flee with her husband." ;
    ex:sentTo :sherlockHolmes ;
    ex:authoredBy :ireneAdler ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:irenePhotographOfHerself a ex:Photograph ;
    ex:prefLabel "Photograph of Irene Adler in Evening Dress" ;
    skos:altLabel "Irene's photograph" ;
    ex:description "A photograph of Irene Adler herself in evening dress. Left behind in the recess at Briony Lodge where the compromising photograph had been hidden. Holmes requests this photograph as his reward from the King instead of the offered emerald snake ring." ;
    ex:depicts :ireneAdler ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:iris a ex:Animal ;
    ex:prefLabel "Iris" ;
    ex:description "Racehorse owned by the Duke of Balmoral that ran in the Wessex Cup at Winchester. Wore yellow and black stripes. Finished a bad third behind Silver Blaze and Desborough." ;
    ex:ownedBy :dukeOfBalmoral ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:jamesMcCarthyGun a ex:Firearm ;
    ex:prefLabel "James McCarthy's Gun" ;
    ex:description "A gun carried by James McCarthy when he walked toward Boscombe Pool. Found lying on the grass within a few paces of his father's body. Its butt-end was initially suspected as the murder weapon, as the injuries were consistent with such a weapon. James dropped it to hold his dying father." ;
    ex:ownedBy :jamesMcCarthy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:japaneseCabinet a ex:Cabinet ;
    ex:prefLabel "Japanese Cabinet" ;
    ex:description "A cabinet in the Trevor estate at Donnithorpe. Old Mr. Trevor's dying message was that the papers (his confession) were in the back drawer of the Japanese cabinet. Victor Trevor found the confession there." ;
    ex:locatedIn :trevorEstate ;
    ex:ownedBy :jamesArmitage ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:johnClaysPistol a ex:Firearm ;
    ex:prefLabel "John Clay's Pistol" ;
    ex:description "Revolver drawn by John Clay when emerging from the tunnel in the bank vault. Holmes strikes it from his hand with the hunting crop and it clinks upon the stone floor." ;
    ex:ownedBy :johnClay ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:juliaMatchbox a ex:Object ;
    ex:prefLabel "Julia's Matchbox and Match" ;
    ex:description "A charred stump of a match found in Julia Stoner's right hand and a match-box in her left hand when she collapsed dying in the corridor. Holmes concluded she had struck a light and looked about her when the alarm took place." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:kingsPylandDog a ex:Animal ;
    ex:prefLabel "King's Pyland Watchdog" ;
    skos:altLabel "the dog" ;
    skos:altLabel "the hound" ;
    ex:description "Watchdog kept in the stables at King's Pyland. Ned Hunter rushed out with the hound to chase Fitzroy Simpson away. Central to Holmes's deduction: the dog did not bark during the night when Straker took out Silver Blaze, proving the midnight visitor was someone the dog knew well - not a stranger like Simpson." ;
    ex:locatedIn :kingsPyland ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:kkkBrassBox a ex:Cashbox ;
    ex:prefLabel "KKK Brass Box" ;
    skos:altLabel "brass box" ;
    skos:altLabel "cashbox" ;
    ex:description "A small brass box, like a cashbox, belonging to Colonel Elias Openshaw. Kept in the locked attic lumber-room at the Openshaw estate. Had the treble K ('K.K.K.') printed on its lid. On the inside of the cover was a paper label with 'K.K.K.' and beneath it 'Letters, memoranda, receipts, and a register.' After receiving the threatening pips, Elias burned the papers from the box. The box was found empty when Joseph and John later examined the attic. Holmes instructed John to place the surviving diary page and a note in the brass box and put it on the sundial." ;
    ex:locatedIn :openshawEstate ;
    ex:ownedBy :eliasOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:lestradesWarrant a ex:Document ;
    ex:prefLabel "Lestrade's warrant" ;
    ex:description "Unsigned warrant for the arrest of Jack Stapleton, brought from London by Inspector Lestrade. Remained unsigned because Stapleton had not yet committed an overt act." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:linenBag a ex:Object ;
    ex:prefLabel "Linen Bag" ;
    ex:description "A linen bag recovered from the mere at Hurlstone by dragging. It contained the ancient crown and several dull-colored pieces of pebble or glass (the crown's stones). Thrown into the mere by Rachel Howells to remove the last trace of her crime." ;
    ex:recoveredFrom :hurlstoneMere ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:lloydsRegisters a ex:Document ;
    ex:prefLabel "Lloyd's Registers" ;
    skos:altLabel "Lloyd's registers" ;
    ex:description "Shipping registers maintained by Lloyd's of London. Holmes spent a whole day examining Lloyd's registers and old newspaper files, tracing every vessel which touched at Pondicherry in January and February 1883. Thirty-six ships of fair tonnage were reported there during those months; the Lone Star attracted Holmes's attention due to its American-sounding name." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:loneStar a ex:Vessel ;
    ex:prefLabel "Lone Star" ;
    skos:altLabel "barque Lone Star" ;
    ex:description "A barque (sailing ship) commanded by Captain James Calhoun, registered at Savannah, Georgia. The vessel carried the KKK agents who terrorised and murdered the Openshaw family. Holmes traced it through Lloyd's registers: it was at Pondicherry in January-February 1883, at Dundee in January 1885, and at Albert Dock in London in September 1887. The ship's name refers to Texas (the Lone Star State), confirming its American origin. The Lone Star departed London for Savannah but was lost at sea during equinoctial gales somewhere far out in the Atlantic. A shattered stern-post with the letters 'L.S.' carved upon it was found swinging in the trough of a wave." ;
    ex:commandedBy :captainJamesCalhoun ;
    ex:registeredAt :savannah ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:lucysWeddingRing a ex:Jewelry ;
    ex:prefLabel "Lucy's Wedding Ring" ;
    ex:description "A plain gold wedding ring taken by Jefferson Hope from Lucy Ferrier's dead finger. Dropped at the crime scene under Drebber's body. Found by Lestrade. Used by Holmes as bait in a newspaper advertisement. Central object in the mystery." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:lumberRoomKey a ex:Object ;
    ex:prefLabel "Lumber-Room Cupboard Key" ;
    ex:description "A key to the lumber-room (box-room) cupboard at Fairbank that also fits the lock of Alexander Holder's bureau. Arthur indicated this key when asked how the bureau was opened. He had known since youth that it could open the bureau." ;
    ex:locatedIn :fairbank ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:luminousPaste a ex:Object ;
    ex:prefLabel "Luminous paste" ;
    skos:altLabel "phosphorescent preparation" ;
    ex:description "Substance found in a tin on the island in Grimpen Mire. Used by Stapleton to coat the hound, making it appear to glow with supernatural fire. When Holmes and Watson examined the dead hound, they could smell and see the phosphorescent coating." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:lyonsLetter a ex:Document ;
    ex:prefLabel "Laura Lyons's letter to Sir Charles" ;
    skos:altLabel "the L.L. letter" ;
    ex:description "Letter from Laura Lyons to Sir Charles Baskerville asking him to meet at the gate by ten o'clock on the night of his death. Dictated by Stapleton. Mostly burned by Sir Charles in the fireplace; only a fragment survived reading: 'Please, please, as you are a gentleman, burn this letter, and be at the gate by ten o'clock,' signed with initials L.L. Barrymore found the ashes." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:martyrdomOfMan a ex:Publication ;
    ex:prefLabel "The Martyrdom of Man" ;
    ex:description "Book by Winwood Reade. Holmes recommends it to Watson as one of the most remarkable books ever penned. References it during the Thames chase regarding man's treatment of individuals vs aggregates." ;
    ex:writtenBy :winwoodReade ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:maryFarewellNote a ex:Letter ;
    ex:prefLabel "Mary Holder's Farewell Note" ;
    ex:description "A farewell note left by Mary Holder on the hall table at Fairbank when she fled overnight. Addressed to 'My dearest Uncle,' expressing that she felt she had brought trouble and could not remain. Stated her future was 'provided for' and asked that no search be made. Signed 'Your loving Mary.'" ;
    ex:authoredBy :maryHolder ;
    ex:addressedTo :alexanderHolder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:marysPearls a ex:Jewelry ;
    ex:prefLabel "Mary Morstan's Pearls" ;
    ex:description "Six large lustrous pearls sent annually to Mary Morstan starting May 1882, in a small cardboard box. Sent by Thaddeus Sholto from the Agra treasure. Rare variety, considerable value." ;
    ex:ownedBy :maryMorstan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:mawsonsSafes a ex:Object ;
    ex:prefLabel "Mawson's Safes" ;
    ex:description "Safes of the very latest construction at Mawson & Williams, used to guard securities amounting to considerably over a million pounds sterling. Beddington obtained moulds of the locks from his position in the office. The watchman's body was stuffed into the largest safe." ;
    ex:locatedIn :mawsonAndWilliamsBuilding ;
    ex:ownedBy :mawsonAndWilliams ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:measuringPeg a ex:Object ;
    ex:prefLabel "Measuring Peg" ;
    skos:altLabel "peg of wood with string" ;
    ex:description "A peg of wood with a ball of string attached, with a knot at each yard. Whittled by Holmes in Musgrave's study for measuring the shadow of the elm tree as part of decoding the Ritual's directions. Kept as a case relic." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:medicalDirectory a ex:Document ;
    ex:prefLabel "Medical Directory" ;
    ex:description "Reference book Watson used to look up Dr. Mortimer's credentials, confirming him as M.R.C.S. 1882, house-surgeon at Charing Cross Hospital, winner of Jackson Prize, and author of medical papers." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:millinersAccount a ex:Document ;
    ex:prefLabel "Milliner's Account" ;
    ex:description "Bill for thirty-seven pounds fifteen shillings made out by Madame Lesurier of Bond Street to William Derbyshire. Found among John Straker's papers in his pocket. Mrs. Straker said Derbyshire was a friend of her husband's. Holmes immediately deduced it showed Straker was leading a double life with expensive tastes - twenty-two guineas for a single costume." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:morningChronicle a ex:Newspaper ;
    ex:prefLabel "The Morning Chronicle" ;
    ex:description "Newspaper dated April 27, 1890 containing the Red-headed League advertisement. Wilson brings the dirty and wrinkled paper to Holmes. Watson reads the advertisement from it." ;
    ex:narrativeDate "April 27, 1890" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:morningPost a ex:Newspaper ;
    ex:prefLabel "Morning Post" ;
    ex:description "A London newspaper. A paragraph in the Morning Post reported the sudden end of the engagement between the Honourable Miss Miles and Colonel Dorking, only two days before the wedding. Also carried the announcement that the marriage between Baron Gruner and Violet de Merville would not take place, and the first police-court hearing of Kitty Winter. A London newspaper. Milverton mentions that a paragraph in the Morning Post announced the end of the engagement between the Honourable Miss Miles and Colonel Dorking, a broken engagement caused by Milverton's blackmail." ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc ;
    dc:source :milvertonDoc ;
    dc:source :illustriousClientDoc .

:moroccoCase a ex:Object ;
    ex:prefLabel "Morocco Case" ;
    skos:altLabel "the case" ;
    skos:altLabel "the precious case" ;
    ex:description "A square, black morocco case lined with soft, flesh-coloured velvet, used to house the beryl coronet. The illustrious client brought it to Holder's bank and Holder subsequently carried it to Fairbank and locked it in his bureau." ;
    ex:contains :berylCoronet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:mortimersSpaniel a ex:Animal ;
    ex:prefLabel "Mortimer's spaniel" ;
    ex:description "Curly-haired spaniel belonging to Dr. Mortimer. Accompanied Mortimer to 221B Baker Street. Went to Dartmoor with the party. Wandered onto the moor and was lost. Its skeleton was later found on the island in the Grimpen Mire where the hound was kept, presumably killed and eaten by the hound." ;
    ex:ownedBy :jamesMortimer ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:mortimersStick a ex:Object ;
    ex:prefLabel "Mortimer's walking stick" ;
    skos:altLabel "Penang lawyer" ;
    ex:description "A thick walking stick of the sort known as a Penang lawyer, with a bulbous head an inch below the top. Silver band nearly an inch across, inscribed 'To James Mortimer, M.R.C.S., from his friends of the C.C.H., 1884.' Left behind in 221B Baker Street by Dr. Mortimer, providing Holmes and Watson the first clue about its owner." ;
    ex:ownedBy :jamesMortimer ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:munroTelegram a ex:Document ;
    ex:prefLabel "Grant Munro's Telegram" ;
    ex:description "A telegram sent by Grant Munro to Sherlock Holmes reporting that the cottage at Norbury was still tenanted and that he had seen the face again at the window. Requested Holmes meet the seven o'clock train and stated he would take no steps until Holmes arrived." ;
    ex:ownedBy :grantMunro ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:murderStone a ex:BluntInstrument ;
    ex:prefLabel "Murder Stone" ;
    ex:description "A jagged stone found by Holmes lying among the moss near a great beech tree at Boscombe Pool. Identified by Holmes as the actual murder weapon used to kill Charles McCarthy. Had grass growing under it, indicating it had only lain there a few days. Corresponded with the injuries. Holmes carried it back to Ross to show Lestrade." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:musgraveRelicsBox a ex:Object ;
    ex:prefLabel "Musgrave Relics Box" ;
    ex:description "A small wooden box with a sliding lid, similar to a children's toy box, which Holmes kept within his tin box of case records. It contained the relics of the Musgrave Ritual case: a crumpled piece of paper (the Ritual), an old-fashioned brass key, a peg of wood with a ball of string attached, and three rusty old disks of metal (coins)." ;
    ex:ownedBy :sherlockHolmes ;
    ex:locatedAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:musgraveRitualDocument a ex:ManuscriptDocument ;
    ex:prefLabel "The Musgrave Ritual" ;
    skos:altLabel "the Ritual" ;
    skos:altLabel "Musgrave Ritual" ;
    ex:description "An ancient family document of the Musgrave family, consisting of a series of questions and answers that each Musgrave has gone through on coming of age for centuries. The original has no date but is in the spelling of the mid-seventeenth century. It contains coded directions to a hidden treasure — the ancient crown of England. The questions and answers form a cryptic set of instructions involving compass directions and pacing from landmarks (an oak and an elm). Richard Brunton decoded its meaning and it led to his death. Holmes kept a crumpled copy among his case relics." ;
    ex:ownedBy :musgraveFamily ;
    ex:locatedAt :hurlstoneLibrary ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:navyRevolver a ex:Firearm ;
    ex:prefLabel "Navy Revolver" ;
    ex:description "Large navy revolver carried by McMurdo when he first arrives in Vermissa Valley on the train. Fully loaded with copper shells." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:nervousLesionsMonograph a ex:Document ;
    ex:prefLabel "Monograph on nervous lesions" ;
    ex:description "A monograph upon obscure nervous lesions authored by Dr. Percy Trevelyan, for which he won the Bruce Pinkerton prize and medal. Watson recognized the work. Trevelyan's publishers gave him a discouraging account of its sales." ;
    ex:authoredBy :percyTrevelyan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:norahCreina a ex:Vessel ;
    ex:prefLabel "Norah Creina" ;
    ex:description "An ill-fated steamer that was lost with all hands upon the Portuguese coast, some leagues to the north of Oporto. The three murderers of Blessington (Biddle, Hayward, and Moffat) were believed to have been among its passengers." ;
    ex:locatedIn :portugueseCoast ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:nuggetRing a ex:Jewelry ;
    ex:prefLabel "Nugget Ring" ;
    ex:description "Ring with a rough nugget worn above the wedding ring on Douglas's left hand." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:oldBrassKey a ex:Object ;
    ex:prefLabel "Old Brass Key" ;
    ex:description "An old-fashioned brass key found projecting from the lock of the ancient wooden chest in the cellar chamber at Hurlstone. Holmes kept it among his relics of the case in a small wooden box." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :musgraveRitualDoc .

:opalTiara a ex:Jewelry ;
    ex:prefLabel "Opal Tiara" ;
    ex:description "An opal tiara that was central to the case of Mrs. Farintosh, a previous client of Holmes. Holmes recalled the case when Helen Stoner mentioned Mrs. Farintosh's name, noting it was 'before your time, Watson.'" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:openshawGoldenPinceNez a ex:Object ;
    ex:prefLabel "John Openshaw's Golden Pince-Nez" ;
    skos:altLabel "golden pince-nez" ;
    ex:description "A pair of golden pince-nez worn by John Openshaw. He raised them to his eyes upon arriving at 221B Baker Street." ;
    ex:ownedBy :johnOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:openshawSundial a ex:Object ;
    ex:prefLabel "Openshaw Sundial" ;
    skos:altLabel "the sundial" ;
    ex:description "A sundial in the garden of the Openshaw estate near Horsham. The KKK letters to both Joseph and John Openshaw demanded 'Put the papers on the sundial.' Holmes instructed John to place the surviving diary page and a note in the brass box on the sundial." ;
    ex:locatedIn :openshawEstate ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:openshawUnbreakableTire a ex:Object ;
    ex:prefLabel "Openshaw Unbreakable Tire" ;
    ex:description "A patented invention by Joseph Openshaw. He had a small factory at Coventry which he enlarged at the time of the invention of bicycling, becoming the patentee of the Openshaw unbreakable tire. The business was successful enough to allow him to sell it and retire." ;
    ex:createdBy :josephOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:openshawWill a ex:Will, ex:Document ;
    ex:prefLabel "Elias Openshaw's Will" ;
    ex:description "A will made by Colonel Elias Openshaw in March 1883 after receiving the threatening letter with orange pips. Witnessed by John Openshaw and the lawyer Fordham. Left the estate, with all its advantages and disadvantages, to his brother Joseph Openshaw, from whom it would descend to John." ;
    ex:authoredBy :eliasOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:ordnanceMap a ex:Object ;
    ex:prefLabel "Ordnance map of Dartmoor" ;
    ex:description "Large-scale Ordnance Survey map of Dartmoor that Holmes obtained from Stamford's (a geographical supply shop). Showed the full district including Baskerville Hall, Grimpen, Lafter Hall, High Tor Farm, Foulmire, and Princetown." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:pallMallGazette a ex:Newspaper ;
    ex:prefLabel "Pall Mall Gazette" ;
    skos:altLabel "Pall Mall" ;
    ex:description "The Pall Mall Gazette is an evening newspaper in London. Holmes instructed Peterson to place an advertisement in it." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:palmyra a ex:Vessel ;
    ex:prefLabel "Palmyra" ;
    ex:description "Ship on which Douglas and his wife departed for South Africa. Douglas was lost overboard in a gale off St. Helena." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:parisDirectory a ex:Document ;
    ex:prefLabel "Paris Directory" ;
    ex:description "A big red book containing a directory of Paris with trades listed after the names of people. Given by Harry Pinner to Hall Pycroft as busywork: to mark off all hardware sellers with their addresses. Pycroft worked on it from Sunday through Friday, only reaching the letter H by Monday." ;
    ex:ownedBy :arthurPinnerBeddington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:penangLawyerStick a ex:Weapon ;
    ex:prefLabel "Penang-Lawyer Stick" ;
    skos:altLabel "Simpson's stick" ;
    skos:altLabel "heavy stick" ;
    ex:description "Fitzroy Simpson's walking stick, a Penang-lawyer weighted with lead. Just such a weapon as might, by repeated blows, have inflicted the terrible injuries to which Straker had succumbed. Initially considered a possible murder weapon but Simpson was exonerated." ;
    ex:ownedBy :fitzroySimpson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:pinkUn a ex:Newspaper ;
    ex:prefLabel "The Sporting Times" ;
    skos:altLabel "Pink Un", "Pink 'un" ;
    ex:description "The Sporting Times, colloquially known as the 'Pink Un' due to its pink paper, is a sporting newspaper. Breckinridge the poultry salesman carried a copy protruding from his pocket, which Holmes used to deduce his susceptibility to a bet." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:pinnerBraces a ex:Object, ex:Clothing ;
    ex:prefLabel "Pinner's Braces" ;
    skos:altLabel "elastic bands" ;
    skos:altLabel "suspenders" ;
    ex:description "The braces (suspenders) belonging to Arthur Pinner/Beddington, used in his suicide attempt. He hung himself from a hook behind a door in the inner room with his own braces round his neck. Watson, Holmes, and Pycroft cut the elastic bands from the livid creases in his skin to rescue him." ;
    ex:ownedBy :arthurPinnerBeddington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:pinnerBusinessCard a ex:Document ;
    ex:prefLabel "Arthur Pinner's Business Card" ;
    ex:description "A printed visiting card reading Arthur Pinner, Financial Agent, brought up to Pycroft by his landlady." ;
    ex:ownedBy :arthurPinnerBeddington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:pinnerLetterOfIntroduction a ex:Document, ex:Letter ;
    ex:prefLabel "Pinner's Letter of Introduction" ;
    ex:description "A letter from Arthur Pinner to Harry Pinner introducing Hall Pycroft and praising him. Given to Pycroft to present at the Birmingham office. Since both Pinners are the same person, the letter was written by the man to himself." ;
    ex:createdBy :arthurPinnerBeddington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:poisonedDart a ex:Poison ;
    ex:prefLabel "Poisoned Dart" ;
    skos:altLabel "poisoned thorn" ;
    ex:description "Dark thorns or spines, sharp and black, glazed near point with dried substance (poison). Shot from blow-pipe by Tonga. One killed Bartholomew Sholto through the scalp. Others nearly hit Holmes and Watson during Thames chase. Fatal on impact — causes rictus grin and rapid death." ;
    ex:usedIn :murderOfBartholomewSholto ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:poisonedPills a ex:Pill ;
    ex:prefLabel "Poisoned Pills" ;
    ex:description "Two pills in a small chip ointment box. One contained a deadly alkaloid extracted from South American arrow poison; the other was harmless. Made by Hope while working as janitor at York College. Used to force Drebber into a deadly game of chance. Found at Stangerson's murder scene. One pill killed the landlady's terrier in Holmes's experiment." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:pokerMawsons a ex:Weapon, ex:BluntInstrument ;
    ex:prefLabel "Poker (Mawson's Murder Weapon)" ;
    ex:description "A poker used by Beddington to murder the watchman at Mawson & Williams. The man's skull was shattered by a blow delivered from behind." ;
    ex:usedBy :beddingtonBrother2 ;
    ex:usedIn :murderOfMawsonsWatchman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:pugilist a ex:Animal ;
    ex:prefLabel "Pugilist" ;
    ex:description "Racehorse owned by Colonel Wardlaw that ran in the Wessex Cup at Winchester. Wore a pink cap and blue and black jacket." ;
    ex:ownedBy :colonelWardlaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:pycroftTestimonial a ex:Document ;
    ex:prefLabel "Pycroft's Testimonial" ;
    ex:description "A very good testimonial given to Hall Pycroft by old Coxon when Coxon & Woodhouse collapsed. Pycroft sent it with his application to Mawson & Williams." ;
    ex:createdBy :oldCoxon ;
    ex:ownedBy :hallPycroft ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:pycroftWrittenDeclaration a ex:Document ;
    ex:prefLabel "Pycroft's Written Declaration" ;
    skos:altLabel "handwriting specimen" ;
    ex:description "A written statement by Hall Pycroft reading 'I am perfectly willing to act as business manager to the Franco-Midland Hardware Company, Limited, at a minimum salary of 500 pounds.' Presented as a formality by Pinner, its true purpose was to obtain a specimen of Pycroft's handwriting so that his brother could learn to imitate it for the impersonation at Mawson's." ;
    ex:createdBy :hallPycroft ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:racheInscription a ex:Object ;
    ex:prefLabel "RACHE Inscription" ;
    ex:description "The word 'RACHE' (German for 'revenge') written in blood on the wall at 3 Lauriston Gardens and above Stangerson's body at Halliday's Hotel. Written by Jefferson Hope using his own blood from a nosebleed. Lestrade interpreted it as incomplete name 'Rachel'. Holmes correctly identified it as German for revenge." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:rasper a ex:Animal ;
    ex:prefLabel "Rasper" ;
    ex:description "Racehorse owned by Lord Singleford that ran in the Wessex Cup at Winchester. Wore a purple cap and black sleeves." ;
    ex:ownedBy :lordSingleford ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:redHeadedLeagueAdvertisement a ex:Advertisement ;
    ex:prefLabel "Red-headed League Advertisement" ;
    ex:description "Newspaper advertisement in The Morning Chronicle dated April 27, 1890. Announces a vacancy in the Red-headed League offering four pounds a week for nominal services, to apply to Duncan Ross at 7 Pope's Court, Fleet Street. References the bequest of Ezekiah Hopkins of Lebanon, Pennsylvania." ;
    ex:narrativeDate "April 27, 1890" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:redHeadedLeagueDissolutionNotice a ex:Notice ;
    ex:prefLabel "Red-headed League Dissolution Notice" ;
    ex:description "White cardboard notice about the size of a sheet of note-paper, hammered with a tack to the League office door. Reads: 'The Red-headed League is Dissolved. October 9, 1890.'" ;
    ex:narrativeDate "October 9, 1890" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:referenceVolume a ex:Document ;
    ex:prefLabel "Red-Covered Reference Volume" ;
    ex:description "A red-covered volume from a line of books of reference beside the mantelpiece at 221B Baker Street. Holmes picked it up to look up Lord St. Simon's family details, finding him listed as 'Lord Robert Walsingham de Vere St. Simon, second son of the Duke of Balmoral.'" ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:remingtonTypewriter a ex:Object ;
    ex:prefLabel "Remington typewriter" ;
    ex:description "Typewriter in Laura Lyons's rooms in Coombe Tracey. Watson noticed it sitting on her desk." ;
    ex:ownedBy :lauraLyons ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:roylottBaboon a ex:Animal ;
    ex:prefLabel "Dr. Roylott's Baboon" ;
    ex:description "An Indian baboon kept by Dr. Roylott which wandered freely over the grounds of Stoke Moran. When Holmes and Watson approached the manor at night, a creature darted from the laurel bushes—'what seemed to be a hideous and distorted child'—which Holmes identified as the baboon." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:roylottCheetah a ex:Animal ;
    ex:prefLabel "Dr. Roylott's Cheetah" ;
    ex:description "An Indian cheetah kept by Dr. Roylott which wandered freely over the grounds of Stoke Moran Manor House. It was feared by the villagers almost as much as their master. Holmes and Watson heard its long drawn catlike whine at the window during the night vigil." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:roylottHuntingCrop a ex:HuntingCrop ;
    ex:prefLabel "Dr. Roylott's Hunting Crop" ;
    ex:description "A hunting crop carried by Dr. Roylott when he burst into 221B Baker Street to confront Holmes. He swung it in his hand and shook it threateningly." ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:roylottIronSafe a ex:Object ;
    ex:prefLabel "Dr. Roylott's Iron Safe" ;
    ex:description "A large iron safe in Dr. Roylott's room at Stoke Moran. Helen Stoner said it contained business papers. Holmes noted a saucer of milk on top. It actually housed the swamp adder. Found ajar after Roylott's death, with the dark-lantern throwing light upon it." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:roylottVentilator a ex:Object ;
    ex:prefLabel "Ventilator between Rooms" ;
    ex:description "A small ventilator opening between Dr. Roylott's room and the second bedroom (Julia's/Helen's room) at Stoke Moran. Installed about the same time as the dummy bell-rope. It opens into the adjacent room rather than to the outside air. Holmes deduced its existence from Helen's account that Julia could smell Roylott's cigars. The swamp adder traveled through it." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:rudgeWhitworthBicycle a ex:Vehicle ;
    ex:prefLabel "Rudge-Whitworth Bicycle" ;
    ex:description "Well-used bicycle found concealed in evergreens near the Manor House. Had saddlebag with spanner and oilcan. Traced to the Eagle Commercial hotel. Brought by Baldwin." ;
    ex:foundAt :birlstoneManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:russianLetter a ex:Letter ;
    ex:prefLabel "Letter from the fake Russian nobleman" ;
    ex:description "An anonymous letter with neither address nor date, purporting to be from a Russian nobleman resident in England who suffered from cataleptic attacks and wished to consult Dr. Trevelyan. It was a ruse by the Worthingdon bank gang to gain access to 403 Brook Street." ;
    ex:sentTo :percyTrevelyan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:saturdayChronicle a ex:Newspaper ;
    ex:prefLabel "The Chronicle" ;
    skos:altLabel "Saturday's Chronicle" ;
    ex:description "The Chronicle is a newspaper. Mary Sutherland placed a missing persons advertisement for Hosmer Angel in last Saturday's edition." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:saucerOfMilk a ex:Object ;
    ex:prefLabel "Saucer of Milk" ;
    ex:description "A small saucer of milk standing on top of the iron safe in Dr. Roylott's room. Holmes noted it during the inspection. It was used to lure the swamp adder back after it had been sent through the ventilator. Holmes observed that a saucer of milk would not satisfy a cheetah's wants." ;
    ex:locatedIn :stokeMorenManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:sawedOffShotgun a ex:Firearm ;
    ex:prefLabel "Sawed-off Shotgun" ;
    ex:description "Pennsylvania Small Arms Company shotgun with barrel sawed off a foot in front of the triggers. Triggers wired together for simultaneous discharge. Less than two feet long, could be carried under a coat. Found across the dead man's chest at Birlstone." ;
    ex:usedIn :murderAtBirlstone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:scandalPhotograph a ex:Photograph ;
    ex:prefLabel "Compromising Photograph of King and Irene" ;
    skos:altLabel "the photograph" ;
    ex:description "A cabinet-sized photograph showing the King of Bohemia together with Irene Adler. The central object of contention in the case. Hidden by Irene in a recess behind a sliding panel just above the right bell-pull in the sitting-room of Briony Lodge. The King desperately wants it recovered before his marriage. Five previous attempts to recover it have failed. Holmes locates it using a fire ruse but Irene, realizing she has been tricked, takes it when she flees. She keeps it only as a safeguard against future action by the King." ;
    ex:depicts :wilhelmVonOrmstein, :ireneAdler ;
    ex:locatedIn :brionyLodge ;
    ex:ownedBy :ireneAdler ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:screwdriverAndScrews a ex:Object ;
    ex:prefLabel "Screwdriver and screws" ;
    ex:description "A screwdriver and screws found on the wash-hand stand in Blessington's room after his murder. Holmes deduced they were brought by the murderers to set up a makeshift gallows, but the existing hook made them unnecessary." ;
    ex:locatedIn :blessingtonBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:sickTerrier a ex:Animal ;
    ex:prefLabel "The Landlady's Terrier" ;
    ex:description "An old, sick terrier with a snow-white muzzle belonging to the landlady of 221B Baker Street. In laboured breathing, near death. Holmes used it to test the poisoned pills and it died from the poisoned pill." ;
    ex:causeOfDeath "poisoned by alkaloid pill in Holmes's experiment" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:silverBlaze a ex:Animal ;
    ex:prefLabel "Silver Blaze" ;
    skos:altLabel "the favorite" ;
    ex:description "Famous racehorse from the Somomy stock, in his fifth year. Owned by Colonel Ross and trained at King's Pyland by John Straker. Held a brilliant record bringing in each of the prizes of the turf. First favorite for the Wessex Cup with betting three to one. Has a white forehead which gave him his name and a mottled off-foreleg. Disappeared the night Straker was murdered. Was actually taken out by Straker to have his tendon nicked. Kicked Straker in the forehead, killing him, in self-defence when Straker struck a light. Bolted and wandered to Mapleton where Silas Brown found and concealed him. Brown disguised him by dyeing his distinctive markings. Won the Wessex Cup at Winchester while still disguised. Holmes had Silver Blaze's face and leg washed with spirits of wine to reveal his true appearance." ;
    ex:ownedBy :colonelRoss ;
    ex:locatedIn :kingsPyland ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:silverBlazeBridle a ex:Object ;
    ex:prefLabel "Silver Blaze's Bridle" ;
    ex:description "Silver Blaze's bridle which was missing from the stables after the disappearance. Holmes noted that Simpson must have put it on the horse, suggesting premeditation in the police theory." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:silverBlazeHorseshoe a ex:Object ;
    ex:prefLabel "Silver Blaze's Horseshoe" ;
    skos:altLabel "cast horseshoe" ;
    ex:description "Cast horseshoe of Silver Blaze kept in Inspector Gregory's evidence bag along with Straker's boot and Simpson's shoe. Holmes compared it with impressions in the mud. Holmes kept it in his pocket for luck and later used it to match tracks leading toward Mapleton." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:simpsonBettingBook a ex:Document ;
    ex:prefLabel "Simpson's Betting-Book" ;
    skos:altLabel "betting-book" ;
    ex:description "Fitzroy Simpson's betting book, examination of which showed that bets to the amount of five thousand pounds had been registered against Silver Blaze." ;
    ex:ownedBy :fitzroySimpson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:simpsonCravat a ex:Clothing ;
    ex:prefLabel "Simpson's Cravat" ;
    skos:altLabel "red and black silk cravat" ;
    ex:description "Red and black silk cravat belonging to Fitzroy Simpson. Found clasped in John Straker's left hand. Recognized by Edith Baxter as having been worn by the stranger the previous evening. Hunter also positive about its ownership. Simpson acknowledged it was his but declared he had lost it. Holmes deduced Simpson dropped it during his flight and Straker picked it up, perhaps intending to use it to secure the horse's leg." ;
    ex:ownedBy :fitzroySimpson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:smithAndWessonRevolver a ex:Firearm ;
    ex:prefLabel "Smith & Wesson Revolver" ;
    ex:description "McMurdo/Edwards's personal revolver, cleaned, oiled, and loaded on the night of the trap for the Scowrers." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:smokeRocket a ex:SmokeRocket ;
    ex:prefLabel "Plumber's Smoke-Rocket" ;
    skos:altLabel "smoke-rocket" ;
    ex:description "An ordinary plumber's smoke-rocket, cigar-shaped, fitted with a cap at either end to make it self-lighting. Given to Watson by Holmes to throw into the sitting-room of Briony Lodge as part of the fire ruse to locate the hidden photograph." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:snakeRing a ex:Jewelry ;
    ex:prefLabel "Snake Ring" ;
    ex:description "Twisted snake ring worn on the third finger of Douglas's left hand." ;
    ex:ownedBy :johnDouglas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:sophyAnderson a ex:Vessel ;
    ex:prefLabel "Sophy Anderson" ;
    skos:altLabel "British barque Sophy Anderson" ;
    ex:description "A British barque. Watson mentions the loss of the Sophy Anderson as one of the cases from 1887 among his records of the Sherlock Holmes cases." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:starkCarriage a ex:Vehicle ;
    ex:prefLabel "Stark's Carriage" ;
    skos:altLabel "the carriage" ;
    ex:description "A horse-drawn carriage used by Colonel Lysander Stark to transport Victor Hatherley from Eyford Station to Dr. Becher's house. It had frosted glass windows to prevent Hatherley from seeing the route. Drawn by a single fresh, glossy chestnut horse. Holmes deduced from the horse's freshness that the actual distance was short — the long drive was a ruse to disguise proximity to the station." ;
    ex:ownedBy :lysanderStark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:starkCleaver a ex:Weapon, ex:Knife ;
    ex:prefLabel "Stark's Cleaver" ;
    skos:altLabel "a butcher's cleaver" ;
    skos:altLabel "a thing like a cleaver" ;
    ex:description "A weapon like a butcher's cleaver used by Colonel Lysander Stark. He carried it while pursuing Hatherley and used it to cut off Hatherley's thumb as Hatherley hung from a window-sill." ;
    ex:ownedBy :lysanderStark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:starkHarmonium a ex:MusicalInstrument ;
    ex:prefLabel "Harmonium" ;
    ex:description "A harmonium in the waiting room at Dr. Becher's house, beside the door, upon which Colonel Stark placed the lamp." ;
    ex:locatedIn :becherHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:starkHydraulicPress a ex:HydraulicPress ;
    ex:prefLabel "Stark's Hydraulic Press" ;
    skos:altLabel "the hydraulic stamping machine" ;
    skos:altLabel "the machine" ;
    skos:altLabel "the press" ;
    ex:description "A gigantic hydraulic press located on an upper floor of Dr. Becher's house near Eyford. Ostensibly used for compressing fuller's-earth into bricks, it was actually used for counterfeiting — forming the amalgam for fraudulent half-crowns. The press chamber had iron floor and ceiling (the ceiling being the descending piston) and wooden walls. It had a slight leakage caused by a shrunken india-rubber band on a driving-rod. Stark attempted to murder Hatherley by activating the press while he was inside. The iron trough floor had a crust of metallic deposit. The press was destroyed when the house burned down, leaving only twisted cylinders and iron piping." ;
    ex:ownedBy :lysanderStark ;
    ex:locatedIn :becherHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:starkVisitingCard a ex:Document ;
    ex:prefLabel "Stark's Visiting Card" ;
    ex:description "A visiting card with the name 'Colonel Lysander Stark' engraved upon it, presented to Hatherley's clerk when Stark visited Hatherley's office." ;
    ex:ownedBy :lysanderStark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:stClairCoat a ex:Clothing ;
    ex:prefLabel "Neville St. Clair's Coat" ;
    ex:description "Neville St. Clair coat was found on the mud-bank at low tide, weighted with 421 pennies and 270 half-pennies from his begging earnings. St. Clair threw it out of the window when he heard constables approaching, having transferred the coins from his leather bag to weigh it down." ;
    ex:ownedBy :nevilleStClair ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :manWithTheTwistedLipDoc .

:stClairLetter a ex:Letter ;
    ex:prefLabel "St. Clair's Letter to Mrs. St. Clair" ;
    ex:description "A letter from Neville St. Clair to his wife, written in pencil on the fly-leaf of an octavo book. Contained in a coarse envelope stamped with the Gravesend postmark. The letter read: Dearest do not be frightened. All will come well. There is a huge error which it may take some little time to rectify. Wait in patience. Neville. Holmes deduced the envelope was addressed by someone who had to inquire about the address, and the flap was gummed by a person chewing tobacco." ;
    ex:ownedBy :nevilleStClair ;
    ex:postedFrom :gravesend ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :manWithTheTwistedLipDoc .

:stClairSignetRing a ex:Ring ;
    ex:prefLabel "St. Clair's Signet Ring" ;
    ex:description "Neville St. Clair signet ring, which he slipped off and confided to the Lascar along with a hurried note to his wife. Enclosed in the letter Mrs. St. Clair received, posted from Gravesend." ;
    ex:ownedBy :nevilleStClair ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :manWithTheTwistedLipDoc .

:steelHandcuffs a ex:Object ;
    ex:prefLabel "Steel Handcuffs" ;
    ex:description "A pair of steel handcuffs kept by Holmes in a drawer at 221B Baker Street. Spring mechanism. Used to capture Jefferson Hope." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:steelPoker a ex:Object ;
    ex:prefLabel "Steel Poker" ;
    ex:description "A steel fireplace poker at 221B Baker Street. Dr. Roylott seized it and bent it into a curve with his huge brown hands to demonstrate his strength and intimidate Holmes. After Roylott left, Holmes picked it up and straightened it out again with a sudden effort." ;
    ex:locatedIn :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:stickingPlaster a ex:Object ;
    ex:prefLabel "Sticking-Plaster" ;
    ex:description "Strips of plaster arranged over Kratides's face and mouth to prevent speech and recognition." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:stJamesGazette a ex:Newspaper ;
    ex:prefLabel "St. James's Gazette" ;
    skos:altLabel "St. James's" ;
    ex:description "The St. James's Gazette is an evening newspaper in London. Holmes instructed Peterson to place an advertisement in it." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:stoneHeadedClub a ex:BluntInstrument ;
    ex:prefLabel "Stone-Headed Club" ;
    ex:description "Brown close-grained stick with stone head like a hammer, lashed on with coarse twine. Tonga's weapon. Left at murder scene at Pondicherry Lodge." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:stonerWill a ex:Document ;
    ex:prefLabel "Mrs. Stoner's Will" ;
    ex:description "The will of the deceased Mrs. Stoner (Mrs. Roylott), examined by Holmes at Doctors' Commons. The total income at the time of Mrs. Stoner's death was little short of 1100 pounds, but through the fall in agricultural prices had decreased to not more than 750 pounds. Each daughter could claim an income of 250 pounds in case of marriage, establishing Dr. Roylott's strong financial motive for preventing the marriages." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:strakerOvercoat a ex:Clothing ;
    ex:prefLabel "Straker's Overcoat" ;
    skos:altLabel "large mackintosh" ;
    ex:description "John Straker's large mackintosh overcoat which he pulled on before leaving the house on the night of the crime despite the rain. Found flapping from a furze-bush at the brink of the hollow where his body lay. Had been placed there, not blown, as there was no wind that night. Straker had taken it off to perform the delicate tendon-nicking operation." ;
    ex:ownedBy :johnStraker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:strakerPhotograph a ex:Photograph ;
    ex:prefLabel "Photograph of John Straker" ;
    ex:description "Photograph of John Straker that Holmes requested from Inspector Gregory. Taken from an envelope by the Inspector. Holmes later used it at Madame Lesurier's millinery shop to confirm Straker's identity as the customer known as Derbyshire." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:strakerWatch a ex:Object ;
    ex:prefLabel "Straker's Silver Watch" ;
    ex:description "Silver watch with a gold chain found in John Straker's pocket along with other personal effects after his death." ;
    ex:ownedBy :johnStraker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:stSimonLetter a ex:Letter ;
    ex:prefLabel "Lord St. Simon's Letter to Holmes" ;
    ex:description "Letter from Lord St. Simon to Sherlock Holmes requesting a consultation about the disappearance of his wife. Written with a quill pen, with a huge crest and monogram on the envelope. Dated from Grosvenor Mansions. Holmes observed a smear of ink on the outer side of St. Simon's right little finger." ;
    ex:author :lordRobertStSimon ;
    ex:recipient :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:swampAdder a ex:Snake ;
    ex:prefLabel "Swamp Adder" ;
    skos:altLabel "The Speckled Band" ;
    ex:description "A swamp adder, described by Holmes as 'the deadliest snake in India.' It is the 'speckled band' of the story's title. Dr. Roylott kept it in his iron safe, trained it with milk to return when summoned by whistle, and sent it through the ventilator and down the dummy bell-rope to Julia Stoner's bed, causing her death by its venomous bite. Holmes struck it with his cane during the night vigil, driving it back through the ventilator where it bit Roylott, killing him within ten seconds. It had a squat diamond-shaped head and puffed neck, with a peculiar yellow band with brownish speckles. Holmes threw the noose of the dog-whip around its neck and placed it back in the iron safe. Note: the 'swamp adder' is not a recognized real species; Holmes's identification is fictional." ;
    ex:ownedBy :grimesByRoylott ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:tarnishedCylinder a ex:Object ;
    ex:prefLabel "Tarnished Cylinder" ;
    ex:description "A little tarnished cylinder kept in a drawer by Holmes at 221B Baker Street, containing the coded note from the Gloria Scott case, wrapped in tape." ;
    ex:locatedIn :221bBakerStreet ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:teddy a ex:Animal ;
    ex:prefLabel "Teddy" ;
    skos:altLabel "Ichneumon" ;
    ex:description "Henry Wood's pet mongoose (also called ichneumon). A beautiful reddish-brown creature, thin and lithe, with legs of a stoat, a long thin nose, and a pair of fine red eyes. Amazingly quick on cobras. Wood uses Teddy in his canteen performances with a defanged snake. During the incident at Lachine, Teddy escaped from his box, ran up a curtain trying to reach a canary in a cage by the window. Wood dropped his stick while chasing Teddy to get him back into his box." ;
    ex:ownedBy :henryWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:telegramFromCleveland a ex:Document ;
    ex:prefLabel "Telegram from Cleveland" ;
    ex:description "A telegram found on Stangerson's body, dated about a month before, containing the words 'J.H. is in Europe'. No sender's name appended." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:tenPoundNote a ex:Object ;
    ex:prefLabel "Ten-Pound Note" ;
    ex:description "A ten-pound note that Fitzroy Simpson claimed was the paper he wished Edith Baxter to give to the stable-boy. One was found in his purse. A ten-pound note given by the mysterious lodger (actually Gennaro Lucca) to Mrs. Warren as payment for a fortnight's board and lodging at five pounds a week." ;
    ex:ownedBy :fitzroySimpson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc ;
    dc:source :redCircleDoc .

:theAurora a ex:Vessel ;
    ex:prefLabel "The Aurora" ;
    skos:altLabel "Aurora" ;
    ex:description "Steam launch owned by Mordecai Smith. Black with two red streaks, funnel black with white band. Trim, fast — one of fastest on the river. Hired by Jonathan Small for escape. Hidden at Jacobson's Yard for rudder repair. Chased down Thames by police launch. Ran aground on mud bank at Plumstead Marshes." ;
    ex:ownedBy :mordecaiSmith ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:theChronicle a ex:Newspaper ;
    ex:prefLabel "The Chronicle" ;
    ex:description "Newspaper that Watson read for coverage of the Silver Blaze case. Watson said he had seen what the Telegraph and the Chronicle had to say." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:theEcho a ex:Newspaper ;
    ex:prefLabel "The Echo" ;
    ex:description "The Echo is a London newspaper whose editorial credited Scotland Yard with the capture and dismissed Holmes as an amateur." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc ;
    dc:source :studyInScarletDoc .

:theGlobe a ex:Newspaper ;
    ex:prefLabel "The Globe" ;
    ex:description "The Globe is an evening newspaper in London. Holmes instructed Peterson to place an advertisement about the found goose and hat in it." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc  ;
    dc:source :priorySchoolDoc .

:theHound a ex:Animal ;
    ex:prefLabel "The Hound" ;
    skos:altLabel "the Baskerville hound" ;
    skos:altLabel "the spectral hound" ;
    ex:description "Enormous coal-black creature resembling a hound but larger than any mortal hound. Bought by Stapleton from Ross and Mangles, dealers in Fulham Road, London. Kept on an island in the Grimpen Mire. Daubed with luminous phosphorescent paste to appear supernatural and fiery. Savage and half-starved. Killed Selden by mistake (scenting Sir Henry's old clothes) and attacked Sir Henry on the moor path. Shot and killed by Holmes and Watson. Fire blazed from its open mouth and eyes; its muzzle and hackles and dewlap outlined in flickering flame." ;
    ex:ownedBy :jackStapleton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:theNegro a ex:Animal ;
    ex:prefLabel "The Negro" ;
    ex:description "Racehorse owned by Mr. Heath Newton that ran in the Wessex Cup at Winchester. Wore a red cap and cinnamon jacket." ;
    ex:ownedBy :heathNewton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:theStandard a ex:Newspaper ;
    ex:prefLabel "The Standard" ;
    ex:description "The Standard is a London newspaper that reported on Drebber's murder. In The Sign of the Four, reports the 'Mysterious Business at Upper Norwood' including Bartholomew Sholto's murder." ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc ;
    dc:source :signOfTheFourDoc ;
    dc:source :studyInScarletDoc .

:theStar a ex:Newspaper ;
    ex:prefLabel "The Star" ;
    ex:description "The Star is an evening newspaper in London. Holmes instructed Peterson to place an advertisement in it." ;
    ex:inCity :london ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:theTimes a ex:Newspaper ;
    ex:prefLabel "The Times" ;
    ex:description "London newspaper. Source of the cut-out words for Sir Henry's warning letter. Holmes identified its distinctive typeface. Holmes sent Cartwright to search twenty-three hotels near Charing Cross for a copy with the free trade article cut out. Holmes was reading the agony column of The Times when Watson and Hatherley arrived at Baker Street. An advertisement was placed in The Times inquiring for the whereabouts of the Smith family, on behalf of Carruthers and Woodley. Mentioned in The Adventure of the Missing Three-Quarter." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc ;
    dc:source :engineersThumbDoc ;
    dc:source :houndOfTheBaskervillesDoc ;
    dc:source :solitaryCyclistDoc ;
    dc:source :missingThreeQuarterDoc .

:tissuePaperFootprints a ex:Document ;
    ex:prefLabel "Tissue Paper with Animal Footprints" ;
    ex:description "A large sheet of tissue paper on which Holmes carefully traced the footmarks of the unknown animal found at the crime scene at Lachine. The prints showed five well-marked foot-pads, long nails, nearly as large as a dessert-spoon. Holmes deduced a creature about two feet long with very short legs - probably of the weasel and stoat tribe." ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:tobaccoAshMonograph a ex:Document ;
    ex:prefLabel "Monograph on Tobacco Ashes" ;
    ex:description "A monograph written by Sherlock Holmes on the ashes of 140 different varieties of pipe, cigar, and cigarette tobacco. Referenced during the Boscombe Valley investigation when Holmes identified the Indian cigar ash found at the crime scene." ;
    ex:authoredBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:tobaccoMonograph a ex:Document ;
    ex:prefLabel "Monograph on Tobacco Ashes" ;
    ex:description "Holmes's monograph 'Upon the Distinction between the Ashes of the Various Tobaccoes'. Enumerates 140 forms of cigar, cigarette, and pipe tobacco with coloured plates." ;
    ex:writtenBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:toby a ex:Animal ;
    ex:prefLabel "Toby" ;
    ex:description "Dog belonging to Sherman. Ugly, long-haired, lop-eared creature, half spaniel and half lurcher, brown-and-white, with very clumsy waddling gait. Amazing power of scent. Used by Holmes to track creosote trail from Pondicherry Lodge through South London to Smith's Wharf. Lost scent at creosote barrel in Broderick and Nelson's timber yard." ;
    ex:ownedBy :sherman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:tradeHandsMonograph a ex:Document ;
    ex:prefLabel "Monograph on Trade and Hands" ;
    ex:description "Holmes's work on the influence of a trade upon the form of the hand, with lithotypes of the hands of slaters, sailors, corkcutters, compositors, weavers, and diamond-polishers." ;
    ex:writtenBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:trevelyanBrougham a ex:Vehicle ;
    ex:prefLabel "Trevelyan's brougham" ;
    ex:description "Dr. Trevelyan's horse-drawn carriage which was waiting at 221B Baker Street when Holmes and Watson returned from their evening walk. It contained medical instruments in a wicker basket hung in the lamplight, from which Holmes deduced the visitor was a general practitioner." ;
    ex:ownedBy :percyTrevelyan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:trevelyanNote a ex:Letter ;
    ex:prefLabel "Trevelyan's urgent note" ;
    ex:description "A sheet torn from a notebook with 'For God's sake come at once--P.T.' scrawled in pencil by Dr. Trevelyan and sent to Holmes the morning after Blessington's murder." ;
    ex:writtenBy :percyTrevelyan ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:trevorBullTerrier a ex:Animal ;
    ex:prefLabel "Victor Trevor's Bull Terrier" ;
    ex:description "A bull terrier belonging to Victor Trevor. The dog froze onto Sherlock Holmes's ankle one morning as Holmes went down to chapel at college, laying him up for ten days. This accident led to the friendship between Holmes and Victor Trevor." ;
    ex:ownedBy :victorTrevor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:trevorConfession a ex:Letter ;
    ex:prefLabel "Trevor's Confession" ;
    skos:altLabel "Trevor's statement" ;
    skos:altLabel "the papers" ;
    ex:description "A written statement drawn up by old Mr. Trevor (James Armitage) when the danger from Hudson became imminent. Found in the Japanese cabinet as Trevor told the doctor before dying. Endorsed: 'Some particulars of the voyage of the bark Gloria Scott, from her leaving Falmouth on the 8th October, 1855, to her destruction in N. Lat. 15° 20', W. Long. 25° 14' on Nov. 6th.' Written in the form of a letter to Victor Trevor, confessing his real identity as James Armitage, his conviction for embezzlement, and the full history of the Gloria Scott mutiny and its aftermath. The final line, in shaky handwriting: 'Beddoes writes in cipher to say H. has told all. Sweet Lord, have mercy on our souls!'" ;
    ex:ownedBy :victorTrevor ;
    ex:writtenBy :jamesArmitage ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:trevorWalkingStick a ex:WalkingStick ;
    ex:prefLabel "Trevor's Walking Stick" ;
    skos:altLabel "handsome stick" ;
    ex:description "A very handsome walking stick belonging to old Mr. Trevor. Less than a year old by its inscription. Trevor had bored the head and poured melted lead into the hole to make it a formidable weapon, due to threats from a poaching gang. Holmes deduced the stick's nature as evidence that Trevor feared a personal attack." ;
    ex:ownedBy :jamesArmitage ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:troopshipOrontes a ex:Vessel ;
    ex:prefLabel "Troopship Orontes" ;
    ex:description "The troopship on which Watson was dispatched from India back to England." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:trophyOrientalArms a ex:Object ;
    ex:prefLabel "Trophy of Oriental Arms" ;
    skos:altLabel "magnificent trophy of weapons" ;
    ex:description "A magnificent trophy of weapons adorning one of the walls over the fireplace at 16 Godolphin Street. The curved Indian dagger used to murder Eduardo Lucas was taken from this collection." ;
    ex:locatedIn :16GodolphinStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:trouserButtons a ex:Object ;
    ex:prefLabel "Trouser Buttons" ;
    ex:description "Buttons found in the ashes of the bonfire at Oldacre's timber-yard. One bears the name 'Hyams', who is Oldacre's tailor. Used as supposed evidence that Oldacre's body was burned, but actually planted by Oldacre himself as part of the deception." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:turnerConfession a ex:Confession ;
    ex:prefLabel "Turner's Confession" ;
    skos:altLabel "the confession" , "the statement" ;
    ex:description "A written confession by John Turner, dictated to Holmes and signed by Turner, with Watson as witness. Detailed Turner's history as Black Jack of Ballarat, the gold convoy robbery, McCarthy's blackmail, and the murder at Boscombe Pool. Holmes promised to use it only if James McCarthy were condemned at the Assizes." ;
    ex:createdBy :sherlockHolmes, :johnTurner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:tuxburyTimeTable a ex:Document ;
    ex:prefLabel "Railway Time-Table" ;
    ex:description "A railway time-table that Colonel Emsworth picked up in the hall after catching James Dodd spying on the lodge. He used it to inform Dodd of the 8:30 train to London, effectively ordering him to leave." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:twoHorseVan a ex:FictionalObject, ex:Vehicle ;
    ex:prefLabel "Two-Horse Van" ;
    ex:description "A vehicle furiously driven that nearly ran down Holmes at the corner of Bentinck Street and Welbeck Street crossing as part of an assassination attempt orchestrated by Moriarty's organization. The van dashed round by Marylebone Lane and escaped." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:unusedTheatreTicket a ex:Object ;
    ex:prefLabel "Unused Theatre Ticket" ;
    ex:description "A theatre ticket for seat thirty-one, row B, upper circle at the Haymarket Theatre. Shown by Amberley to Watson as evidence that his wife had refused to go to the theatre on the night of the supposed elopement. Holmes deduced the adjacent seats (B30 and B32) and discovered from the box-office chart that neither had been occupied, proving Amberley had not attended the theatre." ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:vandeleurPhotograph a ex:Object ;
    ex:prefLabel "Vandeleur photograph" ;
    ex:description "Photograph of Mr. and Mrs. Vandeleur (Stapleton and Beryl) taken in York four years before the Baskerville case. Obtained by Holmes as evidence. Used to prove Stapleton's identity and marriage to Laura Lyons and the authorities." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:vermissaHerald a ex:Newspaper ;
    ex:prefLabel "Vermissa Herald" ;
    skos:altLabel "Daily Herald" ;
    ex:description "Daily newspaper of Vermissa edited by James Stanger. Takes an uncompromising stand against the Scowrers." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:victoriaMap a ex:Object ;
    ex:prefLabel "Map of the Colony of Victoria" ;
    ex:description "A folded paper map of the Colony of Victoria, wired for by Holmes from Bristol the night before. Holmes used it to demonstrate to Watson that the dying word 'a rat' was actually the end of 'Ballarat.'" ;
    ex:ownedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:victorTrevorTelegram a ex:Telegram ;
    ex:prefLabel "Victor Trevor's Telegram" ;
    ex:description "A telegram sent by Victor Trevor to Holmes imploring him to return to Donnithorpe, saying he was in great need of Holmes's advice and assistance. Received by Holmes in his London rooms when the autumn was far advanced." ;
    ex:writtenBy :victorTrevor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:violetHunterLetter a ex:Letter ;
    ex:prefLabel "Violet Hunter's letter to Holmes" ;
    ex:description """A letter from Violet Hunter dated from Montague Place, received by Holmes one morning. She wrote that she was anxious to consult him about whether she should accept a situation as governess, and proposed to call at half-past ten the following day.""" ;
    ex:createdBy :violetHunter ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:violetHunterTelegram a ex:Telegram ;
    ex:prefLabel "Violet Hunter's telegram to Holmes" ;
    ex:description """An urgent telegram from Violet Hunter to Sherlock Holmes reading: 'Please be at the Black Swan Hotel at Winchester at midday to-morrow. Do come! I am at my wit's end. Hunter.' It arrived late one night while Holmes was conducting chemical researches. Holmes and Watson took a half-past nine train arriving at Winchester at 11:30.""" ;
    ex:createdBy :violetHunter ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:violetsBicycle a ex:Vehicle ;
    ex:prefLabel "Violet Smith's bicycle" ;
    ex:description "Violet Smith's bicycle, her primary means of transport between Chiltern Grange and Farnham Station every Saturday forenoon and Monday return." ;
    ex:ownedBy :violetSmith ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:violetsDogCart a ex:Vehicle ;
    ex:prefLabel "Violet's dog-cart" ;
    skos:altLabel "the horse and trap" ;
    skos:altLabel "the dog-cart" ;
    ex:description "A horse-drawn dog-cart arranged by Carruthers for Violet's final journey to Farnham Station. Driven by Peter the groom. Found empty with the horse cantering and reins trailing after the abduction. Holmes and Watson commandeered it." ;
    ex:ownedBy :bobCarruthers ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:violetsGag a ex:Handkerchief ;
    ex:prefLabel "Handkerchief gag" ;
    ex:description "A handkerchief placed round Violet Smith's mouth during the forced marriage ceremony." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:violetSmithLetter a ex:Letter ;
    ex:prefLabel "Violet Smith's Thursday letter" ;
    ex:description "A letter from Violet Smith received on Thursday, announcing she was leaving Carruthers's employment due to the strained situation and the reappearance of Woodley. She stated she would come to town on Saturday and not return." ;
    ex:createdBy :violetSmith ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:violetSmithNote a ex:Letter ;
    ex:prefLabel "Violet Smith's Monday note" ;
    ex:description "A note from Violet Smith received Monday morning, recounting the cyclist incidents and containing a postscript revealing that Carruthers had proposed marriage to her." ;
    ex:createdBy :violetSmith ;
    ex:sentTo :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:vitriol a ex:Weapon ;
    ex:prefLabel "Vitriol" ;
    skos:altLabel "sulphuric acid" ;
    ex:description """Vitriol (sulphuric acid) carried by Kitty Winter concealed under her cloak as a small packet. She throws it at Baron Gruner's face through the open window at Vernon Lodge, causing horrible disfigurement — eating into his face, dripping from ears and chin, one eye white and glazed, the other red and inflamed, features blurred, discoloured, and inhuman.""" ;
    ex:usedBy :kittyWinter ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:vonBorkValise a ex:Object, ex:Container ;
    ex:prefLabel "Von Bork's Leather Valise" ;
    ex:description "A leather valise used by Von Bork to pack the contents of his safe. Later wedged into the spare seat of the car beside the bound Von Bork. Holmes continued packing dossiers from the safe into it after Von Bork's capture." ;
    ex:ownedBy :vonBork ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:vonBorkSafe a ex:Object ;
    ex:prefLabel "Von Bork's Safe" ;
    ex:description "A large brass-bound safe in Von Bork's oak-panelled study, concealed behind a curtain. Has a double combination lock requiring both a word and set of figures (set to 'August' and '1914' four years prior). Contains rows of stuffed pigeon-holes labeled Fords, Harbour-defences, Aeroplanes, Ireland, Egypt, Portsmouth forts, The Channel, Rosythe, Naval Signals, and others, all bristling with papers and plans." ;
    ex:combinationWord "August" ;
    ex:combinationFigures "1914" ;
    ex:locatedIn :vonBorkStudy ;
    ex:ownedBy :vonBork ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:vonBorkCheck a ex:Object, ex:Document ;
    ex:prefLabel "Von Bork's Check" ;
    ex:description "A check for five hundred pounds written by Von Bork to pay Altamont for the supposed naval signals. Holmes says it should be cashed early as the drawer is quite capable of stopping it." ;
    ex:ownedBy :vonBork ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:vonHerderAirGun a ex:Weapon, ex:Firearm ;
    ex:prefLabel "Von Herder's air-gun" ;
    skos:altLabel "the air-gun" ;
    skos:altLabel "the famous air-gun" ;
    ex:description "Powerful, noiseless air-gun constructed by Von Herder, the blind German mechanic, to the order of Professor Moriarty. Used by Colonel Moran to murder Ronald Adair and to fire at Holmes's wax bust at Camden House. Assembles from what appears to be a walking stick into a gun with a curiously misshapen butt. Opens at the breech. Fires soft revolver bullets. Holmes commended it to the Scotland Yard Museum. Described by Holmes as 'an admirable and unique weapon, noiseless and of tremendous power'." ;
    ex:constructedBy :vonHerder ;
    ex:commissionedBy :professorMoriarty ;
    ex:weaponUsedIn :murderOfRonaldAdair ;
    ex:weaponUsedIn :camdenHouseStakeout ;
    ex:ownedBy :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:vonHerlingBenz a ex:Object, ex:Vehicle ;
    ex:prefLabel "Von Herling's Benz Car" ;
    ex:description "A 100-horse-power Benz described as a luxurious limousine. Blocks the country lane while Baron Von Herling visits Von Bork. Nearly passes Holmes's little Ford coming in the opposite direction in the village street." ;
    ex:ownedBy :baronVonHerling ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:voodooFetish a ex:Object, ex:Fetish ;
    ex:prefLabel "Voodoo fetish" ;
    ex:description "An extraordinary object found on the kitchen dresser at Wisteria Lodge. Black and leathery, wrinkled, shrunken, and withered, bearing resemblance to a dwarfish human figure. A double band of white shells strung round its centre. The mulatto cook's sacred fetish, for which he returned to the house and was ultimately captured." ;
    ex:ownedBy :wisteriaLodgeCook ;
    ex:locatedAt :wisteriaLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:voodooismBook a ex:Object, ex:Document ;
    ex:prefLabel "Voodooism and the Negroid Religions" ;
    ex:description "A book by Eckermann that Holmes consulted at the British Museum to research voodoo practices. Describes voodoo sacrificial rites including the plucking of a white cock alive and the cutting and burning of a black goat." ;
    ex:author :eckermann ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:vv341Card a ex:Document ;
    ex:prefLabel "V.V. 341 Card" ;
    ex:description "Rough cardboard card with the initials V.V. and number 341 scrawled in ink. Left beside the dead body at Birlstone. V.V. stands for Vermissa Valley and 341 is the lodge number." ;
    ex:foundAt :birlstoneManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:walterConfessionLetter a ex:Document ;
    ex:prefLabel "Walter's Letter to Oberstein" ;
    ex:description "Letter dictated by Holmes and written by Colonel Valentine Walter. Directed to Oberstein at the Hôtel du Louvre, Paris. Claims to have a tracing of a missing essential detail and requests a further advance of five hundred pounds. Arranges a meeting at the smoking-room of the Charing Cross Hotel at noon on Saturday. Demands payment in English notes or gold only. Used as bait to lure Oberstein back to England." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:warningLetter a ex:Document ;
    ex:prefLabel "Warning letter to Sir Henry" ;
    ex:description "Anonymous threatening letter received by Sir Henry Baskerville at the Northumberland Hotel. Words cut from the Times leading article on free trade and pasted on a sheet of foolscap paper. The word 'moor' was written in ink, as it was too uncommon to find in print. Postmarked Charing Cross. Holmes identified the type as Times print from its distinctive font." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:watsonManuscriptVolumes a ex:Document ;
    ex:prefLabel "Watson's Manuscript Volumes" ;
    ex:description "Three massive manuscript volumes containing the records of Holmes and Watson's work for the year 1894. Watson references them at the opening of the story." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:watsonPatentLeatherSlippers a ex:Object, ex:Clothing ;
    ex:prefLabel "Watson's Patent Leather Slippers" ;
    ex:description "New patent leather slippers worn by Watson. Holmes deduced Watson's recent illness from the scorched soles (from sitting with feet outstretched to the fire while unwell) and the shopman's hieroglyphic wafer still attached near the instep." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:watsonRevolverBlackPeter a ex:Weapon, ex:Firearm ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:watsonRevolverEmptyHouse a ex:Weapon, ex:Firearm ;
    ex:prefLabel "Watson's revolver" ;
    ex:description "Revolver carried by Watson in his pocket during the Camden House stakeout. Watson struck Colonel Moran on the head with the butt of the revolver during the struggle." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:watsonsArmyRevolver a ex:Firearm ;
    ex:prefLabel "Watson's Army Revolver" ;
    ex:description "Watson's army revolver. Holmes tells Watson to put it in his pocket for the evening expedition. Watson places it cocked upon the top of a wooden case in the bank vault during the ambush." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:watsonsDispatchBox a ex:Object ;
    ex:prefLabel "Watson's Dispatch Box" ;
    ex:description "A travel-worn and battered tin dispatch box belonging to Dr. Watson, stored in the vaults of the bank of Cox and Co. at Charing Cross. It has 'John H. Watson, M.D., Late Indian Army' painted upon the lid. It is crammed with papers, nearly all of which are records of cases illustrating the curious problems which Sherlock Holmes had to examine, including unsolved cases and cases involving secrets of private families." ;
    ex:ownedBy :johnWatson ;
    ex:locatedAt :coxAndCoBank ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:watsonsReports a ex:Document ;
    ex:prefLabel "Watson's reports from Dartmoor" ;
    skos:altLabel "Watson's letters" ;
    ex:description "Series of letters, diary extracts, and telegrams Watson sent to Holmes from Baskerville Hall, detailing events on the moor. Forwarded from Baker Street to Coombe Tracey where Holmes was secretly staying. Chapters 8-10 of the narrative are these reports." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:watsonsRevolver a ex:Firearm ;
    ex:prefLabel "Watson's Service Revolver" ;
    skos:altLabel "Eley's No. 2" ;
    ex:description "Watson's old service revolver from his army days. Kept with cartridges at 221B Baker Street. In The Sign of the Four, Watson keeps his old service revolver in his desk drawer and takes it for the Thames chase. In the Baskerville case, Watson carried the revolver on Holmes's instruction throughout the investigation in Devonshire and used it to help shoot the hound. Watson took his revolver on the Chiswick expedition at Holmes's suggestion. During the Thor Bridge case, Watson produces his revolver from his hip pocket — described as short, handy, but very serviceable. Holmes borrows it, removes one cartridge, ties string to the handle, and uses it to demonstrate Mrs. Gibson's suicide method at Thor Bridge, creating a matching chip on the parapet when the weighted string pulls the revolver over the side." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc ;
    dc:source :signOfTheFourDoc ;
    dc:source :speckledBandDoc ;
    dc:source :studyInScarletDoc ;
    dc:source :redHeadedLeagueDoc ;
    dc:source :sixNapoleonsDoc ;
    dc:source :thorBridgeDoc .

:watsonsWatch a ex:Object ;
    ex:prefLabel "Watson's Watch" ;
    ex:description "Pocket watch inherited by Watson from his father via elder brother. Initials H.W. Nearly 50 years old. Holmes deduced from it the brother's character: careless, untidy, drank, pawned it repeatedly. Four sets of pawnbroker scratch marks inside." ;
    ex:ownedBy :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:waxThumbSeal a ex:Object ;
    ex:prefLabel "Wax Seal with Thumbprint" ;
    ex:description "Wax impression of McFarlane's thumb, taken during the sealing of Oldacre's will at McFarlane's office. Oldacre later used this to create the fake blood thumbprint on the wall." ;
    ex:createdBy :jonasOldacre ;
    ex:relatedTo :johnHectorMcFarlane ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:waxVesta a ex:Object ;
    ex:prefLabel "Wax Vesta" ;
    skos:altLabel "half-burned match" ;
    ex:description "Half-burned wax vesta (match) found by Holmes in the mud at the crime scene hollow. So coated with mud it looked like a chip of wood. Inspector Gregory had overlooked it. Holmes said he found it because he was looking for it. Key evidence showing someone had struck a light at the scene - connecting to Straker's intent to use the cataract knife on the horse." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:waxVestas a ex:Object ;
    ex:prefLabel "Wax Vestas (Matches)" ;
    ex:description "A small stock of wax vestas (matches) that Hugh Boone pretends to sell on Threadneedle Street to avoid police regulations against begging. Serves as a cover for his real activity of professional begging." ;
    ex:ownedBy :nevilleStClair ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :manWithTheTwistedLipDoc .

:whitakersAlmanac a ex:Publication ;
    ex:prefLabel "Whitaker's Almanac" ;
    ex:description "Annual reference book used by Porlock as the key for his cipher message to Holmes." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:whiteCockSacrifice a ex:Object ;
    ex:prefLabel "Sacrificed white cock" ;
    ex:description "A large white bird torn savagely to pieces with feathers still on, found littered over the kitchen sink at Wisteria Lodge. Part of the mulatto cook's voodoo ritual. Holmes identified it by the wattles on the severed head." ;
    ex:locatedAt :wisteriaLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:whitePellet a ex:Object ;
    ex:prefLabel "White Pellet" ;
    skos:altLabel "poison pellet" ;
    ex:description "A white poison pellet that Josiah Amberley attempted to swallow when confronted by Holmes and Barker. Holmes sprang at his throat and twisted his face to the ground, causing the pellet to fall from between his gasping lips." ;
    ex:ownedBy :josiahAmberley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:williamsonsPrayerBook a ex:Object ;
    ex:prefLabel "Williamson's prayer-book" ;
    ex:description "Prayer-book used by Williamson during the forced marriage ceremony. He pocketed it as Holmes and the others appeared." ;
    ex:ownedBy :williamsonExClergyman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:williamsonsRevolver a ex:Firearm ;
    ex:prefLabel "Williamson's revolver" ;
    ex:description "A revolver pulled out by Williamson after Carruthers shot Woodley. Before he could raise it, he was looking down the barrel of Holmes's weapon. Watson was instructed to take and hold it to Williamson's head." ;
    ex:ownedBy :williamsonExClergyman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:williamsonsSurplice a ex:Clothing ;
    ex:prefLabel "Williamson's surplice" ;
    ex:description "A short surplice worn by Williamson over a light tweed suit during the forced marriage ceremony." ;
    ex:ownedBy :williamsonExClergyman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:wilsonBreastpin a ex:Breastpin ;
    ex:prefLabel "Wilson's Arc-and-Compass Breastpin" ;
    ex:description "Freemason arc-and-compass breastpin worn by Jabez Wilson. Holmes identifies it as evidence of Freemasonry membership, noting it is worn 'rather against the strict rules' of the order." ;
    ex:ownedBy :jabezWilson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:wilsonChineseCoin a ex:Coin ;
    ex:prefLabel "Wilson's Chinese Coin" ;
    ex:description "Chinese coin hanging from Jabez Wilson's watch-chain. Used by Holmes as evidence that Wilson has been to China." ;
    ex:ownedBy :jabezWilson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:winchesterRifles a ex:Firearm ;
    ex:prefLabel "Winchester Rifles" ;
    ex:description "Rifles used by Captain Marvin's mine police and the armed men who arrested the Scowrers." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:windibanksTypewrittenLetter a ex:Letter ;
    ex:prefLabel "Windibank's Typewritten Letter" ;
    ex:description "A typewritten letter from James Windibank to Holmes making an appointment for six o'clock. Shows the same typewriter defects as Hosmer Angel's letters: slurring of the e, tailless r, and fourteen other characteristics, proving the same machine was used for both." ;
    ex:authoredBy :jamesWindibank ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:woodleysRidingCrop a ex:RidingCrop ;
    ex:prefLabel "Woodley's riding crop" ;
    ex:description "A riding crop waved by Jack Woodley during the forced marriage scene, swinging it in his hand as he advanced on Carruthers." ;
    ex:ownedBy :jackWoodley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:woolwichTheatreTickets a ex:Ticket ;
    ex:prefLabel "Woolwich Theatre Tickets" ;
    skos:altLabel "dress-circle tickets" ;
    ex:description "Two dress-circle tickets for the Woolwich Theatre, dated for Monday evening. Found among Cadogan West's possessions. He and Violet Westbury were on their way to the theatre when he left her abruptly." ;
    ex:ownedBy :arthurCadoganWest ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:writingDeskGodolphinStreet a ex:Furniture ;
    ex:prefLabel "Writing-Desk at Godolphin Street" ;
    ex:description "A sumptuous writing-desk in the window at 16 Godolphin Street, part of the luxurious furnishings of Eduardo Lucas's residence." ;
    ex:locatedIn :16GodolphinStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:writingDeskHopeResidence a ex:Furniture ;
    ex:prefLabel "Writing-Desk at Hope Residence" ;
    ex:description "A writing-desk at the Trelawney Hope residence at Whitehall Terrace. Lady Hilda darted to it, unlocked it, and drew out the long blue envelope containing the diplomatic letter she had hidden there." ;
    ex:locatedIn :whitehallTerrace ;
    ex:ownedBy :ladyHildaTrelawneyHope ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:yellowBarouche a ex:Vehicle ;
    ex:prefLabel "Yellow Barouche" ;
    ex:description "A big open yellow barouche used as Lady Beatrice Falder's carriage at Shoscombe Old Place. It is drawn by two splendid, high-stepping gray carriage horses. After Lady Beatrice's death, Norlett rides in it disguised as her to maintain the appearance that she is still alive." ;
    ex:ownedBy :beatriceFalder ;
    ex:locatedIn :shoscombeOldPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:yellowMask a ex:Object ;
    ex:prefLabel "The Yellow Mask" ;
    skos:altLabel "the livid mask" ;
    skos:altLabel "the yellow face" ;
    ex:description "A mask of livid chalky white or yellow color with set, rigid, expressionless features, worn by Lucy Hebron to conceal her appearance while at the cottage in Norbury. The mask, combined with long white gloves, was intended to prevent neighbors from discovering a black child in the area. The sight of the mask at the cottage window disturbed Grant Munro and drove much of the mystery. Holmes removed it at the climax, peeling it from behind the child's ear to reveal Lucy beneath. The title of the story refers to this mask." ;
    ex:ownedBy :lucyHebron ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:brassCartridge a ex:Object ;
    ex:prefLabel "Brass cartridge" ;
    skos:altLabel "the third cartridge" ;
    ex:description "A little brazen cylinder found by Holmes in the garden flower-bed beneath the study window. It was the ejected cartridge from Slaney's revolver, proving that a third shot had been fired from outside the window. This was the key physical evidence that a third person had been present at the shooting." ;
    ex:foundBy :sherlockHolmes ;
    ex:locatedAt :ridlingThorpeManor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:cubittTelegram a ex:Telegram ;
    ex:prefLabel "Cubitt's telegram to Holmes" ;
    skos:altLabel "wire from Cubitt" ;
    ex:description "A telegram sent by Hilton Cubitt to Holmes announcing new incidents at Ridling Thorpe Manor. It prompted Cubitt's second visit to Baker Street, arriving at Liverpool Street at one-twenty." ;
    ex:sentBy :hiltonCubitt ;
    ex:receivedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:cubittsRevolver a ex:Firearm ;
    ex:prefLabel "Hilton Cubitt's revolver" ;
    skos:altLabel "the pistol" ;
    ex:description "A revolver owned by Hilton Cubitt. Found on the study floor midway between the bodies of Cubitt and his wife. It had six chambers, of which two had been fired and four remained loaded. Cubitt fired this weapon at Slaney, missing him." ;
    ex:ownedBy :hiltonCubitt ;
    ex:locatedAt :ridlingThorpeStudy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:dancingMenMessages a ex:Cipher ;
    ex:prefLabel "Dancing men messages" ;
    skos:altLabel "the dancing men" ;
    skos:altLabel "hieroglyphics" ;
    ex:description "A series of cryptographic messages using a substitution cipher consisting of stick-figure drawings of dancing men. Some figures hold flags, which serve as word separators. The cipher was invented by old Patrick, boss of the Joint criminal gang in Chicago. The dancing men appeared at Ridling Thorpe Manor in various forms: scrawled in chalk on a window-sill, drawn on the black wooden door of the tool-house, and written on papers left on the sun-dial. Holmes decoded the cipher using frequency analysis. The decoded messages included: 'Am here Abe Slaney', 'At Elriges', 'Come Elsie', 'Never' (Elsie's reply), and 'Elsie prepare to meet thy God'." ;
    ex:inventedBy :oldPatrick ;
    ex:usedBy :abeSlaney ;
    ex:usedBy :sherlockHolmes ;
    ex:usedBy :elsiePatrick ;
    ex:locatedAt :ridlingThorpeManor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:elsieLetterToSlaney a ex:Letter ;
    ex:prefLabel "Elsie's letter to Slaney" ;
    ex:description "A letter written by Elsie Cubitt to Abe Slaney, imploring him to go away and saying it would break her heart if any scandal should come upon her husband. She also agreed to come down at 3 AM to speak with him through the end window if he would go away afterwards." ;
    ex:sentBy :elsiePatrick ;
    ex:receivedBy :abeSlaney ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:elsiesHandbag a ex:Handbag ;
    ex:prefLabel "Elsie's hand-bag" ;
    ex:description "A lady's hand-bag of crocodile-skin and silver, found on the study table at Ridling Thorpe Manor after the shooting. It contained twenty fifty-pound Bank of England notes held together by an india-rubber band (one thousand pounds total), and nothing else. Elsie had brought the money to bribe Slaney to leave. Holmes noted it would figure in the trial." ;
    ex:ownedBy :elsiePatrick ;
    ex:locatedAt :ridlingThorpeStudy ;
    ex:contains :fiftyPoundNotes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:fiftyPoundNotes a ex:Object ;
    ex:prefLabel "Fifty-pound notes" ;
    ex:description "Twenty fifty-pound Bank of England notes, totalling one thousand pounds, held together by an india-rubber band. Found inside Elsie Cubitt's crocodile-skin and silver hand-bag on the study table. Elsie brought the money down at 3 AM to try to bribe Abe Slaney to leave." ;
    ex:ownedBy :elsiePatrick ;
    ex:issuedBy :bankOfEngland ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:hargreaveCable a ex:Telegram ;
    ex:prefLabel "Hargreave's cable" ;
    skos:altLabel "the cablegram" ;
    ex:description "A cablegram sent by Wilson Hargreave of the New York Police Bureau in reply to Holmes's cable inquiry about Abe Slaney. The reply identified Slaney as 'the most dangerous crook in Chicago.' It arrived on the evening when Holmes had decoded the messages, confirming the criminal nature of the threat." ;
    ex:sentBy :wilsonHargreave ;
    ex:receivedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:holmesCipherMonograph a ex:Monograph ;
    ex:prefLabel "Holmes's monograph on ciphers" ;
    ex:description "A monograph authored by Sherlock Holmes in which he analyses one hundred and sixty separate ciphers. He describes it as 'trifling.' He is fairly familiar with all forms of secret writings but noted that the dancing men cipher was entirely new to him." ;
    ex:authoredBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:holmesDecoyNote a ex:Cipher ;
    ex:prefLabel "Holmes's decoy note" ;
    ex:description "A note written by Sherlock Holmes in the dancing men cipher, containing the message 'Come here at once.' It was addressed to Mr. Abe Slaney at Elrige's Farm, East Ruston, Norfolk, written in straggling, irregular characters unlike Holmes's usual precise hand to disguise the authorship. The note successfully lured Slaney to Ridling Thorpe Manor where he was arrested." ;
    ex:authoredBy :sherlockHolmes ;
    ex:receivedBy :abeSlaney ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:letterFromAmerica a ex:Letter ;
    ex:prefLabel "Letter from America" ;
    ex:description "A letter with an American stamp received by Elsie Cubitt about a month before the main events, at the end of June. She turned deadly white upon reading it and threw it into the fire. It marked the beginning of her distress." ;
    ex:receivedBy :elsiePatrick ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:ridlingThorpeSundial a ex:Sundial ;
    ex:prefLabel "Ridling Thorpe sun-dial" ;
    skos:altLabel "the sun-dial" ;
    ex:description "A pedestalled sun-dial in the garden at Ridling Thorpe Manor, beside the tennis lawn and tool-house. Dancing men messages were left on it: a paper placed under a pebble on the sun-dial, and later a long inscription on the pedestal." ;
    ex:locatedAt :ridlingThorpeManor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:ridlingThorpeToolhouse a ex:Building ;
    ex:prefLabel "Ridling Thorpe tool-house" ;
    skos:altLabel "the tool-house" ;
    ex:description "A black tool-house at Ridling Thorpe Manor, standing beside the lawn in full view of the front windows. Dancing men figures were drawn in chalk on its black wooden door. Cubitt saw a dark creeping figure squatting in front of the door one night, leaving more messages." ;
    ex:locatedIn :ridlingThorpeManor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:slaneysRevolver a ex:Firearm ;
    ex:prefLabel "Abe Slaney's revolver" ;
    skos:altLabel "Slaney's gun" ;
    ex:description "A revolver carried by Abe Slaney, equipped with an ejector mechanism. Slaney used this weapon to shoot Hilton Cubitt through the heart. The ejected brass cartridge was found by Holmes in the garden flower-bed beneath the study window." ;
    ex:ownedBy :abeSlaney ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:dukesLetterToSaltire a ex:Letter ;
    ex:prefLabel "Duke's Letter to Lord Saltire" ;
    ex:description "Letter from the Duke of Holdernesse to Lord Saltire, written the day before the disappearance. Had the coat of arms on the envelope, addressed in the Duke's peculiar stiff hand. James Wilder opened it and inserted a note using the Duchess's name to lure Arthur to Ragged Shaw. Arthur took the letter with him." ;
    ex:authoredBy :dukeOfHoldernesse ;
    ex:addressedTo :lordSaltire ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:hayesDogCart a ex:Vehicle ;
    ex:prefLabel "Hayes's Dog-Cart" ;
    skos:altLabel "the trap" ;
    ex:description "A trap or dog-cart that departed from the Fighting Cock Inn stable yard toward Chesterfield at twilight, driven by Reuben Hayes attempting to flee. Side-lamps lit up in the stable yard before departure." ;
    ex:ownedBy :reubenHayes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:hayesPony a ex:Animal ;
    ex:prefLabel "Hayes's Pony" ;
    ex:description "A led pony provided by Reuben Hayes, waiting at Ragged Shaw at midnight on the night of May 13th. Lord Saltire mounted it and was taken to the Fighting Cock Inn." ;
    ex:ownedBy :reubenHayes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:hayesStick a ex:Weapon ;
    ex:prefLabel "Hayes's Stick" ;
    ex:description "A short, metal-headed stick carried by Reuben Hayes. Used to strike Heidegger on the head, causing a frightful blow that crushed part of his skull and killed him. Also brandished menacingly at Holmes and Watson." ;
    ex:ownedBy :reubenHayes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:heideggerBicycle a ex:Vehicle ;
    ex:prefLabel "Heidegger's Bicycle" ;
    ex:description "Bicycle belonging to Heidegger, the German master at the Priory School. Had Palmer tyres leaving longitudinal stripes. Kept in a small shed beside the lawn. Found in gorse bushes on the moor with one pedal bent and the front smeared with blood." ;
    ex:ownedBy :heidegger ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:holmesCheque a ex:Document ;
    ex:prefLabel "Holmes's Cheque" ;
    ex:description "Cheque for six thousand pounds written by the Duke of Holdernesse to Sherlock Holmes as the reward for finding Lord Saltire and naming the kidnapper. Made out to the Capital and Counties Bank, Oxford Street branch." ;
    ex:authoredBy :dukeOfHoldernesse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:lordSaltireCricketCap a ex:Clothing ;
    ex:prefLabel "Lord Saltire's Cricket Cap" ;
    ex:description "A blue cricket-cap with a white chevron on the peak, belonging to Lord Saltire. Found in the van of gipsies who had camped on the moor." ;
    ex:ownedBy :lordSaltire ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:medievalHorseshoes a ex:Object ;
    ex:prefLabel "Medieval Horseshoes" ;
    ex:description "Horseshoes dug up in the moat of Holdernesse Hall, displayed in the Hall's museum in a glass case. Shaped below with a cloven foot of iron to throw pursuers off the track. Supposed to have belonged to marauding Barons of Holdernesse in the Middle Ages. Had a thin film of recent mud, proving Hayes had used them. Holmes called them the second most interesting object he had seen in the North." ;
    ex:displayedAt :holdernesseHallMuseum ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:ordnanceMapMackleton a ex:Document ;
    ex:prefLabel "Ordnance Map of Mackleton" ;
    ex:description "Large ordnance map of the neighbourhood of Mackleton obtained by Holmes. Laid out on Watson's bed and studied by lamplight while Holmes smoked and pointed out features." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:sidelightsOnHorace a ex:Document ;
    ex:prefLabel "Huxtable's Sidelights on Horace" ;
    ex:description "Scholarly book authored by Thorneycroft Huxtable on the Roman poet Horace." ;
    ex:authoredBy :thorneycroftHuxtable ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:volumeHEncyclopaedia a ex:Document ;
    ex:prefLabel "Volume H Encyclopaedia" ;
    ex:description "Volume 'H' of Holmes's encyclopaedia of reference at 221B Baker Street, from which he reads the Duke of Holdernesse's biographical entry." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:wilderBicycle a ex:Vehicle ;
    ex:prefLabel "Wilder's Bicycle" ;
    ex:description "Bicycle ridden by James Wilder. Had a patched Dunlop tyre. Tracks found on moor path heading away from the Priory School. Later seen at the Fighting Cock Inn. Holmes confirmed the patched Dunlop tyre by matchlight." ;
    ex:ownedBy :jamesWilder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:zincPail a ex:Object ;
    ex:prefLabel "Zinc Pail" ;
    ex:description "A zinc pail used by Ronder and his wife to carry raw meat to feed the lion Sahara King at night." ;
    ex:usedBy :ronder, :eugeniaRonder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:zoologyManual a ex:FictionalObject, ex:Book ;
    ex:prefLabel "Zoology Manual" ;
    skos:altLabel "manual of zoology" ;
    ex:description "A manual of zoology taken from the shelves at Professor Presbury's house by Trevor Bennett after the discovery of Lowenstein's letter. Bennett read aloud the entry on the langur: 'the great black-faced monkey of the Himalayan slopes, biggest and most human of climbing monkeys.'" ;
    ex:locatedAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .


# ============================================================================
# EVENTS — Full Individual Definitions
# ============================================================================

:abbasParvaIncident a ex:Murder ;
    ex:prefLabel "Abbas Parva Incident" ;
    skos:altLabel "Abbas Parva Tragedy" ;
    ex:description "The Abbas Parva Incident is the murder of the showman Ronder by Leonardo using a five-clawed club, combined with the lion attack on Eugenia Ronder, occurring near midnight at Abbas Parva in Berkshire approximately seven years before the events of late 1896 (circa 1889). Leonardo struck Ronder's skull while Eugenia opened the lion's cage to make the death appear to be the work of the lion. The lion Sahara King attacked Eugenia instead, terribly mutilating her face, while Leonardo fled in terror. The inquest returned a verdict of death from misadventure." ;
    ex:hasParticipant :ronder, :eugeniaRonder, :leonardo, :saharaKing ;
    ex:occurredAt :abbasParva ;
    ex:hasVictim :ronder, :eugeniaRonder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:abbasParvaInquest a ex:Event ;
    ex:prefLabel "Abbas Parva Inquest" ;
    ex:description "The inquest held after Ronder's death at Abbas Parva. The verdict was death from misadventure, attributing Ronder's death to the lion. Mrs. Ronder was not fit to give evidence until six months after the incident. Leonardo the strong man and Griggs the clown gave evidence. Edmunds of the Berkshire Constabulary investigated but was troubled by inconsistencies." ;
    ex:hasParticipant :leonardo, :jimmyGriggs, :edmunds, :eugeniaRonder ;
    ex:occurredAt :abbasParva ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:abbeyGrangeInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Abbey Grange Case" ;
    ex:description """Holmes's investigation into the death of Sir Eustace Brackenstall at Abbey Grange. Initially called in by Inspector Hopkins who suspected the Randall gang. Holmes identified inconsistencies in the wine glass evidence and the bell-rope, deducing that the lady's story was fabricated. He traced the true killer, Captain Croker, through the Adelaide-Southampton shipping line and conducted a mock trial at Baker Street, acquitting Croker.""" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :stanleyHopkins ;
    ex:hasParticipant :jackCroker ;
    ex:hasParticipant :maryFraser ;
    ex:hasParticipant :theresaWright ;
    ex:occurredAt :abbeyGrange ;
    ex:occurredAt :221bBakerStreet ;
    ex:investigator :sherlockHolmes ;
    ex:client :stanleyHopkins ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:narrativeYear "1897" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeMockTrial a ex:MockTrial ;
    ex:prefLabel "Mock Trial at Baker Street" ;
    ex:description """An informal trial conducted by Holmes at 221B Baker Street. Holmes acted as judge, Watson as jury, and Captain Croker as the prisoner. After hearing Croker's full confession, Watson delivered a 'not guilty' verdict. Holmes declared 'Vox populi, vox Dei' and acquitted Croker, telling him to return to Lady Brackenstall in a year.""" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :jackCroker ;
    ex:occurredAt :221bBakerStreet ;
    ex:verdict "Not guilty" ;
    ex:narrativeYear "1897" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeySchoolCase a ex:Investigation ;
    ex:prefLabel "Abbey School Case" ;
    skos:altLabel "the case of the Abbey School" ;
    ex:description "A case that Holmes was clearing up at the time James Dodd visited him in January 1903. Watson described it as the case of the Abbey School, in which the Duke of Greyminster was deeply involved. Details of this case are not given in this story." ;
    ex:narrativeYear "1903" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :dukeOfGreyminster ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:abductionOfMrWarren a ex:Abduction ;
    ex:prefLabel "Abduction of Mr. Warren" ;
    ex:description "Two men abducted Mr. Warren as he left his house for work at Morton and Waylight's. They threw a coat over his head and bundled him into a cab. After driving for an hour, they dumped him on Hampstead Heath. The attack was intended for the mysterious lodger but Mr. Warren was mistaken for him in the foggy morning light." ;
    ex:hasParticipant :mrWarren ;
    ex:hasVictim :mrWarren ;
    ex:occurredAt :greatOrmeStreet ;
    ex:occurredAt :hampsteadHeath ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:abductionOfSophyKratides a ex:Abduction ;
    ex:prefLabel "Abduction of Sophy Kratides" ;
    ex:description "Latimer persuaded Sophy to elope while she was visiting England. She was held at The Myrtles." ;
    ex:hasParticipant :sophyKratides , :haroldLatimer ;
    ex:occurredAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:abductionOfVioletSmith a ex:Abduction ;
    ex:prefLabel "Abduction of Violet Smith" ;
    ex:description "Violet Smith was pulled from her dog-cart on the lonely road near Charlington, her groom Peter was clubbed unconscious, and she was dragged into Charlington Hall grounds for a forced marriage ceremony." ;
    ex:hasParticipant :violetSmith ;
    ex:hasParticipant :jackWoodley ;
    ex:hasParticipant :williamsonExClergyman ;
    ex:hasParticipant :peterTheGroom ;
    ex:hasVictim :violetSmith ;
    ex:occurredAt :charlingtonHeath ;
    ex:occurredAt :charlingtonWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:adairInquest a ex:Event ;
    ex:prefLabel "Inquest into Ronald Adair's death" ;
    ex:description "Inquest into the death of Ronald Adair. Led to a verdict of wilful murder against some person or persons unknown. Evidence was given by those who had played cards with Adair: Mr. Murray, Sir John Hardy, and Colonel Moran." ;
    ex:occurredAt :london ;
    ex:eventYear "1894" ;
    ex:hasParticipant :ronaldAdair ;
    ex:hasParticipant :murrayCardPlayer ;
    ex:hasParticipant :sirJohnHardy ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:adairMoranCardWinnings a ex:Event ;
    ex:prefLabel "Adair and Moran's card winnings" ;
    ex:description "Some weeks before the murder, Ronald Adair and Colonel Moran playing in partnership won £420 from Godfrey Milner and Lord Balmoral at the Bagatelle Card Club. Moran was cheating." ;
    ex:occurredAt :bagatellCardClub ;
    ex:eventYear "1894" ;
    ex:hasParticipant :ronaldAdair ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:hasParticipant :godfreyMilner ;
    ex:hasParticipant :lordBalmoral ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:addletonTragedy a ex:Event ;
    ex:prefLabel "Addleton Tragedy" ;
    ex:description "A tragedy mentioned in Watson's retrospective of 1894 cases, connected with the singular contents of an ancient British barrow. No further details provided." ;
    ex:narrativeYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:adelaideSaloonFight a ex:Crime ;
    ex:prefLabel "Adelaide Saloon Fight (1889)" ;
    ex:description "A saloon fight in Adelaide, Australia, in 1889, during which Holy Peters (Henry Peters) was badly bitten, leaving his left ear jagged or torn. This physical peculiarity later helped Holmes identify Peters when he was posing as Dr. Shlessinger." ;
    ex:narrativeDate "1889" ;
    ex:hasParticipant :henryPeters ;
    ex:occurredAt :adelaide ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:americanCivilWar a ex:Event ;
    ex:prefLabel "American Civil War" ;
    ex:description "Historical event referenced. Beecher's mission on behalf of the North. Watson reflects on gallantry shown by both sides and the sadness/waste of life." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:ancientBritishBarrowCase a ex:Investigation ;
    ex:prefLabel "Ancient British Barrow Case" ;
    ex:description "A case involving the singular contents of an ancient British barrow, connected with the Addleton tragedy. Mentioned in Watson's retrospective of 1894 cases. No further details provided." ;
    ex:narrativeYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:appledoreTowersBurglary a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Burglary of Appledore Towers" ;
    ex:description "Holmes and Watson burgle Charles Augustus Milverton's residence, Appledore Towers, to steal Lady Eva Brackwell's compromising letters from his safe. They enter through the greenhouse/conservatory after Agatha locks up the guard dog. Holmes cracks the safe but is interrupted by Milverton's unexpected return to his study. They hide behind curtains and witness Milverton's murder, after which Holmes empties the safe and burns all blackmail materials in the fire." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :appledoreTowers ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:arrestJimBrowner a ex:Arrest ;
    ex:prefLabel "Arrest of Jim Browner" ;
    ex:description "Lestrade went to Albert Dock, boarded S.S. May Day, found Browner in his berth, arrested him. Browner offered no resistance." ;
    ex:hasParticipant :jimBrowner ;
    ex:hasParticipant :lestrade ;
    ex:occurredAt :albertDock ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:arrestJohnMitton a ex:Arrest ;
    ex:prefLabel "Arrest of John Mitton" ;
    ex:description "John Mitton, valet to Eduardo Lucas, was arrested on suspicion of his master's murder as a counsel of despair. No case could be sustained against him as his alibi of visiting friends in Hammersmith was complete. He was subsequently released." ;
    ex:hasParticipant :johnMitton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:arrestOfBeppo a ex:Event ;
    ex:prefLabel "Arrest of Beppo at Chiswick" ;
    ex:description "Holmes, Watson, and Lestrade staked out Laburnum Lodge in Chiswick after Holmes deduced Beppo would target Josiah Brown's bust. Beppo broke in, stole the bust, and was caught smashing it in the garden. Holmes tackled him and Lestrade and Watson secured him with handcuffs. A sheath knife with blood was found on him." ;
    ex:hasParticipant :beppo ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :lestrade ;
    ex:occurredAt :laburnumLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:arrestOfCulvertonSmith a ex:Arrest ;
    ex:prefLabel "Arrest of Culverton Smith" ;
    ex:description "Inspector Morton arrests Culverton Smith at 221B Baker Street for the murder of Victor Savage, after Smith confesses while Holmes feigns illness and Watson listens from hiding. The pre-arranged signal for Morton to enter was Holmes asking Smith to turn up the gas. Smith resists arrest briefly before being handcuffed." ;
    ex:hasParticipant :inspectorMorton ;
    ex:hasParticipant :culvertonSmith ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :221bBakerStreet ;
    ex:arrested :culvertonSmith ;
    ex:arrestedBy :inspectorMorton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:arrestOfHuret a ex:Event ;
    ex:prefLabel "Arrest of Huret" ;
    ex:description "Holmes's tracking and arrest of Huret, the Boulevard assassin, in 1894. The exploit won Holmes an autograph letter of thanks from the French President and the Order of the Legion of Honour. Mentioned in Watson's retrospective of their 1894 cases." ;
    ex:narrativeYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :huret ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:arrestOfJackJames a ex:Event, ex:Arrest ;
    ex:prefLabel "Arrest of Jack James" ;
    ex:description "Jack James, an American citizen and one of Von Bork's agents, was caught and sentenced to time in Portland prison. Described as his own fault due to being too self-willed for the job." ;
    ex:hasParticipant :jackJames ;
    ex:occurredAt :england ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:arrestOfJonathanSmall a ex:Arrest ;
    ex:prefLabel "Arrest of Jonathan Small" ;
    ex:description "Jonathan Small captured on the Thames after the Aurora ran aground on a mud bank at the southern bank near Plumstead Marshes. His wooden leg sank into the sodden soil, immobilizing him. Hauled aboard the police launch with a rope. Taken to Baker Street for questioning where he gave his full confession, then taken into custody by Athelney Jones." ;
    ex:involves :jonathanSmall ;
    ex:involves :athelneyJones ;
    ex:involves :sherlockHolmes ;
    ex:occurredAt :thames ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:arrestOfKillerEvans a ex:Event ;
    ex:prefLabel "Arrest of Killer Evans" ;
    ex:description "Following the shooting at 136 Little Ryder Street, Holmes subdued Killer Evans by striking him on the head with a pistol. Watson called Scotland Yard, and Evans was arrested. He was subsequently tried and returned to prison." ;
    ex:hasParticipant :killerEvans ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :136LittleRyderStreet ;
    ex:narrativeYear "1902" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:arrestOfMoriartyGang a ex:FictionalEvent ;
    ex:prefLabel "Arrest of Moriarty's Gang" ;
    ex:description "On the Monday following Holmes and Watson's flight (late April 1891), London police arrested the entire Moriarty gang, with the exception of Professor Moriarty himself, who escaped. Holmes received the telegram with this news in Strasbourg and was bitterly disappointed that Moriarty had given them the slip." ;
    ex:hasParticipant :londonPolice ;
    ex:narrativeDate "late April 1891 (Monday)" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:arrestOfMulattoCook a ex:Event ;
    ex:prefLabel "Arrest of the mulatto cook" ;
    ex:description "Inspector Baynes set an ambush at Wisteria Lodge after the mulatto cook was first seen by Constable Walters at the window. The cook returned to retrieve his voodoo fetish and was captured. He bit Constable Downing's thumb nearly off during the struggle. Baynes deliberately publicized this arrest to make Henderson feel safe enough to flee, enabling the rescue of Miss Burnet." ;
    ex:hasParticipant :wisteriaLodgeCook ;
    ex:hasParticipant :inspectorBaynes ;
    ex:hasParticipant :constableDowning ;
    ex:occurredAt :wisteriaLodge ;
    ex:narrativeYear "1892" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:arrestOfNeligan a ex:Event ;
    ex:prefLabel "Arrest of John Hopley Neligan" ;
    ex:description "Inspector Stanley Hopkins arrested John Hopley Neligan at Peter Carey's cabin during a night ambush with Holmes and Watson. Neligan had successfully broken into the cabin on his second attempt to examine the Sea Unicorn's log-books. Hopkins took him to the police station, confident he had solved the case." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :stanleyHopkins, :johnNeligan, :sherlockHolmes, :johnWatson ;
    ex:occurredAt :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:arrestOfRandallsNewYork a ex:Arrest ;
    ex:prefLabel "Arrest of the Randall Gang in New York" ;
    ex:description """The arrest of the Randall gang in New York on the morning after the Abbey Grange murder. This proved they could not have committed the crime at Abbey Grange, undermining Hopkins's theory.""" ;
    ex:hasParticipant :randallGang ;
    ex:occurredAt :newYork ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:arrestOfSteiner a ex:Event, ex:Arrest ;
    ex:prefLabel "Arrest of Steiner" ;
    ex:description "Steiner's store was raided the night before the main events and he and his papers were taken to Portsmouth jail. Von Bork considered this the worst blow yet to his espionage operation." ;
    ex:hasParticipant :steinerAgent ;
    ex:narrativeYear "1914" ;
    ex:occurredAt :portsmouth ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:arrestOfSylviusAndMerton a ex:Arrest ;
    ex:prefLabel "Arrest of Sylvius and Merton" ;
    ex:description "The arrest of Count Negretto Sylvius and Sam Merton at 221B Baker Street after Holmes recovers the Mazarin Stone. Police rush in, handcuffs are applied, and the criminals are led to a waiting cab." ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:hasParticipant :samMerton ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:assaultOnPeter a ex:Assault ;
    ex:prefLabel "Assault on Peter the groom" ;
    ex:description "During the abduction of Violet Smith, Peter the groom was pulled from the dog-cart and clubbed, receiving a terrible cut on his head that left him insensible but alive." ;
    ex:hasVictim :peterTheGroom ;
    ex:occurredAt :charlingtonHeath ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:assaultsOnJack a ex:FictionalEvent, ex:Assault ;
    ex:prefLabel "Assaults on Jack Ferguson" ;
    ex:description "Mrs. Ferguson assaulted her stepson Jack Ferguson on two occasions. She struck him once with a stick, leaving a great weal on his arm, and once very savagely with her hands. These attacks were provoked by her knowledge that Jack was poisoning the baby with curare-dipped arrows, though she could not bring herself to reveal the truth to her husband for fear of breaking his heart. Holmes observes that there is a limit to a mother's patience." ;
    ex:perpetrator :mrsFerguson ;
    ex:victim :jackFerguson ;
    ex:location :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:attackOnLeBrun a ex:Crime ;
    ex:prefLabel "Attack on Le Brun" ;
    ex:description """The French agent Le Brun was beaten by Apaches in the Montmartre district of Paris and crippled for life. He had been inquiring into Baron Gruner's affairs only a week before the attack. Baron Gruner references this as a veiled threat to Holmes.""" ;
    ex:hasParticipant :leBrun ;
    ex:hasParticipant :apachesMontmartre ;
    ex:occurredAt :montmartre ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:attackOnHolmesRegentStreet a ex:Crime ;
    ex:prefLabel "Attack on Holmes in Regent Street" ;
    ex:description """Two respectably dressed men armed with sticks attacked Sherlock Holmes about twelve o'clock in Regent Street outside the Cafe Royal. Holmes suffered two lacerated scalp wounds and considerable bruises requiring several stitches. He was taken to Charing Cross Hospital and then insisted on returning to Baker Street. The attackers escaped through the Cafe Royal and out into Glasshouse Street. The attack was arranged by Baron Gruner.""" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :holmesRegentStreetAttackers ;
    ex:occurredAt :regentStreet ;
    ex:occurredAt :cafeRoyal ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:attackOnMurdoch a ex:Event ;
    ex:prefLabel "Attack on Ian Murdoch" ;
    ex:description "Ian Murdoch was stung by the same Cyanea capillata jellyfish at the same bathing pool where McPherson had died. He staggered to Holmes's villa, pallid and dishevelled, gasping for brandy. The same reticulated pattern of red inflamed lines appeared on his naked shoulder. He survived because his heart was stronger than McPherson's. The attack exonerated Murdoch from suspicion in McPherson's death and confirmed Holmes's jellyfish theory." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :ianMurdoch, :cyaneaCapillata ;
    ex:occurredAt :fulworthBathingPool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:attemptedMurderOfHolmes a ex:Crime ;
    ex:prefLabel "Attempted Murder of Sherlock Holmes" ;
    ex:description "Culverton Smith's attempted murder of Sherlock Holmes by sending a poisoned ivory box by post on a Wednesday. The box contained a sharp spring mechanism that delivered poison when opened, the same method used to kill Victor Savage. Smith's motive was that Holmes had investigated Victor Savage's death and suspected foul play. The attempt failed because Holmes was on guard against suspicious packages." ;
    ex:hasVictim :sherlockHolmes ;
    ex:hasPerpetrator :culvertonSmith ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :culvertonSmith ;
    ex:occurredAt :221bBakerStreet ;
    ex:usedWeapon :dyingDetectiveIvoryBox ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:babyPoisoningIncidents a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Baby Poisoning Incidents" ;
    ex:description "On at least two occasions, Jack Ferguson pricked the Ferguson baby with curare-dipped arrows from a small bird-bow that was part of the South American weapons collection at Cheeseman's. Mrs. Ferguson was caught apparently biting the baby's neck but was actually sucking the poison from the wound to save the child's life. The nurse discovered the first incident when she heard the baby cry and found the mother leaning over the child with blood on her lips and a small wound on the baby's neck." ;
    ex:perpetrator :jackFerguson ;
    ex:victim :babyFerguson ;
    ex:weapon :birdBowAndQuiver ;
    ex:location :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:batesWarningVisit a ex:Meeting ;
    ex:prefLabel "Bates's Warning Visit" ;
    ex:description "Marlow Bates, manager of Gibson's estate, visits 221B Baker Street before Gibson's appointment to warn Holmes that Gibson is a villain, brutal to his wife, and not to be taken at face value. Bates is nervous and terrified of being found by Gibson. He has given notice and will leave in two weeks. He says Gibson's public charities are a screen for private iniquities." ;
    ex:hasParticipant :marlowBates ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:battleOfBuffelsspruit a ex:Battle ;
    ex:prefLabel "Battle of Buffelsspruit" ;
    skos:altLabel "morning fight at Buffelsspruit" ;
    ex:description "A morning battle at Buffelsspruit outside Pretoria on the Eastern railway line during the Boer War. Three soldiers — Godfrey Emsworth, Baldy Simpson, and Anderson — became separated from their unit in broken country. Simpson and Anderson were killed by the Boers. Godfrey was shot through the shoulder by an elephant gun bullet. He rode several miles before fainting and falling from his horse, eventually stumbling into a leper hospital." ;
    ex:hasParticipant :godfreyEmsworth ;
    ex:hasParticipant :baldySimpson ;
    ex:hasParticipant :andersonSoldier ;
    ex:occurredAt :buffelsspruit ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:beatingOfDouglas a ex:FictionalEvent , ex:Crime ;
    ex:prefLabel "Beating of Douglas Maberley" ;
    ex:description "Barney Stockdale and his men beat Douglas Maberley under Isadora Klein's window, on her orders, to drive him away after she rejected his marriage proposal. Klein watched and smiled as Douglas was beaten. This event transformed Douglas from a debonair man into a morose, cynical one and inspired him to write his vengeful novel." ;
    ex:hasParticipant :douglasMaberley , :barneyStockdale , :isadoraKlein ;
    ex:occurredAt :isadoraKleinHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:bennettWitnessesCrawling a ex:FictionalEvent ;
    ex:prefLabel "Bennett Witnesses Presbury Crawling" ;
    ex:description "On the night of September 4th, 1903, at about two in the morning, Trevor Bennett was awakened by a dull muffled sound from the passage. He opened his door and saw Professor Presbury crawling along the passage on his hands and feet with his face sunk between his hands, moving with ease. When Bennett stepped forward to ask if he could assist, Presbury sprang up, spat out an atrocious word, and hurried past and down the staircase. He did not return for about an hour." ;
    ex:narrativeDate "1903-09-04" ;
    ex:hasParticipant :trevorBennett ;
    ex:hasParticipant :professorPresbury ;
    ex:occurredAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:beppoOriginalArrest a ex:Stabbing ;
    ex:prefLabel "Beppo's Original Stabbing and Arrest" ;
    ex:description "Beppo knifed another Italian in the street and then fled to the Gelder & Co. factory with police on his heels. He was arrested at the factory. Before his arrest, he hid the black pearl of the Borgias in a wet plaster Napoleon bust. The man he stabbed survived and Beppo received a sentence of one year." ;
    ex:hasParticipant :beppo ;
    ex:occurredAt :gelderCo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:blackmailOfAvenger a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Blackmail of Milverton's Avenger" ;
    ex:description "A past crime revealed during the confrontation at Appledore Towers. Milverton blackmailed an unnamed noblewoman by threatening to send compromising letters to her husband. When she could not or would not pay, Milverton sent the letters to her husband, who 'broke his gallant heart and died'. The woman came to Milverton one night begging for mercy but he laughed in her face. This event drove her to plan and execute his murder." ;
    ex:hasParticipant :charlesAugustusMilverton ;
    ex:hasParticipant :milvertonAvenger ;
    ex:hasParticipant :avengerHusband ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:blackmailOfLadyHilda a ex:Blackmail ;
    ex:prefLabel "Blackmail of Lady Hilda" ;
    ex:description "Eduardo Lucas blackmailed Lady Hilda Trelawney Hope using an indiscreet letter she had written before her marriage. He demanded she bring him a certain document (the diplomatic letter) from her husband's despatch-box in exchange for returning her compromising letter. He had a spy in Hope's office who had told him of the document's existence." ;
    ex:hasParticipant :eduardoLucas ;
    ex:hasParticipant :ladyHildaTrelawneyHope ;
    ex:hasVictim :ladyHildaTrelawneyHope ;
    ex:hasPerpetrator :eduardoLucas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:blackPeterInvestigation a ex:Event, ex:Investigation ;
    ex:prefLabel "Investigation of the Black Peter case" ;
    skos:altLabel "Black Peter investigation" ;
    ex:description "Holmes's investigation into the murder of Captain Peter Carey at Woodman's Lee in July 1895. Inspector Stanley Hopkins initially led the investigation and arrested John Hopley Neligan. Holmes identified the true murderer as Patrick Cairns through research into the Sea Unicorn's 1883 crew, spending three days wiring Dundee. He devised a fake Arctic expedition under the alias Captain Basil to lure Cairns to Baker Street, where he was captured." ;
    ex:eventYear "1895" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :stanleyHopkins ;
    ex:occurredAt :woodmansLee, :peterCareyCabin, :221bBakerStreet ;
    ex:hasClient :stanleyHopkins ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:blanchedSoldierInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Blanched Soldier" ;
    ex:description "Holmes's investigation into the mysterious disappearance and concealment of Godfrey Emsworth at Tuxbury Old Park near Bedford. The client was James M. Dodd, a former war comrade of Godfrey's. Holmes deduced that Godfrey was being hidden due to a suspected case of leprosy contracted in South Africa. The case was resolved when Sir James Saunders diagnosed the condition as ichthyosis (pseudo-leprosy), not actual leprosy. This is one of only two cases narrated by Holmes himself rather than Watson. Set in January 1903." ;
    ex:narrativeYear "1903" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :jamesDodd ;
    ex:hasParticipant :godfreyEmsworth ;
    ex:hasParticipant :colonelEmsworth ;
    ex:hasParticipant :mrsEmsworth ;
    ex:hasParticipant :mrKent ;
    ex:hasParticipant :sirJamesSaunders ;
    ex:hasParticipant :ralphButler ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :jamesDodd ;
    ex:occurredAt :tuxburyOldPark ;
    ex:occurredAt :221bBakerStreet ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:bludgeonAttackOnHolmes a ex:FictionalEvent, ex:Assassination ;
    ex:prefLabel "Bludgeon Attack on Holmes" ;
    ex:description "Third assassination attempt on Holmes on April 24th, 1891. On his way to Watson's house, Holmes was attacked by a rough with a bludgeon. Holmes knocked him down and the police arrested the attacker. Holmes was certain no connection would be traced between this attacker and Moriarty." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :bludgeonAttacker ;
    ex:narrativeDate "April 24, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:boerWar a ex:War ;
    ex:prefLabel "Boer War" ;
    skos:altLabel "Second Boer War" ;
    ex:description "The Boer War (Second Boer War) was a conflict in South Africa that concluded just before January 1903. James Dodd joined the Imperial Yeomanry in January 1901, and Godfrey Emsworth joined the same squadron. They served together for a year of hard fighting before Godfrey was wounded at Buffelsspruit." ;
    ex:narrativeYear "1899-1902" ;
    ex:hasParticipant :jamesDodd ;
    ex:hasParticipant :godfreyEmsworth ;
    ex:hasParticipant :baldySimpson ;
    ex:hasParticipant :andersonSoldier ;
    ex:occurredAt :southAfrica ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:breakInBarnicotSurgery a ex:Burglary ;
    ex:prefLabel "Break-in at Barnicot's Surgery" ;
    ex:description "Dr. Barnicot's branch surgery at Lower Brixton Road was broken into through a window during the night. The second Napoleon bust was smashed to atoms where it stood on the mantelpiece." ;
    ex:hasParticipant :beppo ;
    ex:occurredAt :barnicotSurgery ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:brewerHorsewhipping a ex:Crime ;
    ex:prefLabel "Horsewhipping of Sam Brewer" ;
    ex:description "A violent assault in which Sir Robert Norberton horsewhipped Sam Brewer, the well-known Curzon Street money-lender, on Newmarket Heath. Norberton nearly killed Brewer. Watson notes this nearly brought Sir Robert within Holmes's province." ;
    ex:hasParticipant :robertNorberton, :samBrewer ;
    ex:occurredAt :newmarketHeath ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:briarbraeIntrusion a ex:Intrusion ;
    ex:prefLabel "Intrusion at Briarbrae" ;
    skos:altLabel "attempted break-in at Briarbrae" ;
    ex:description "Joseph Harrison's first attempt to retrieve the hidden naval treaty from Phelps's sickroom. About two in the morning, Phelps heard gnawing sounds and a metallic snick as someone forced an instrument through the window sash. A man crouching at the window fled when Phelps sprang from bed and opened the shutters. The intruder was wrapped in a cloak and carried what appeared to be a long knife. Marks were found on the flower bed outside the window, and a rail on the wooden fence was cracked. This was the first night without a nurse present." ;
    ex:hasParticipant :josephHarrison , :percyPhelps ;
    ex:occurredAt :briarbrae ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:brickAttackOnHolmes a ex:FictionalEvent, ex:Assassination ;
    ex:prefLabel "Brick Attack on Holmes" ;
    ex:description "Second assassination attempt on Holmes on April 24th, 1891. As Holmes walked down Vere Street, a brick came down from the roof of one of the houses and shattered to fragments at his feet. Police examined the scene and found slates and bricks piled for repairs; they would have Holmes believe the wind toppled one, but he knew better." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :vereStreet ;
    ex:narrativeDate "April 24, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:brownerBreakIn a ex:Event ;
    ex:prefLabel "Browner breaks into Sarah's lodging house" ;
    ex:description "Jim Browner followed Mary to Sarah's lodging house, broke in at the door. Fairbairn escaped over the back garden wall. Browner swore to Mary he would kill her if found with Fairbairn again." ;
    ex:hasParticipant :jimBrowner ;
    ex:hasParticipant :maryBrowner ;
    ex:hasParticipant :alecFairbairn ;
    ex:occurredAt :sarahLodgingHouseLiverpool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:brownerConfessionEvent a ex:Confession ;
    ex:prefLabel "Browner's confession" ;
    ex:description "At Shadwell Police Station before Inspector Montgomery. Browner asked to make a statement. Taken down by shorthand man. Full account of the murders and events leading to them." ;
    ex:hasParticipant :jimBrowner ;
    ex:hasParticipant :inspectorMontgomery ;
    ex:occurredAt :shadwellPoliceStation ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:brownerMarriage a ex:Marriage ;
    ex:prefLabel "Marriage of Jim and Mary Browner" ;
    ex:description "Jim Browner married Mary Cushing. Sarah was 33 and Mary was 29 at the time. They set up house together in Liverpool." ;
    ex:hasParticipant :jimBrowner ;
    ex:hasParticipant :maryBrowner ;
    ex:occurredAt :liverpool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:brucePartingtonInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Bruce-Partington Plans Case" ;
    ex:description "Investigation by Sherlock Holmes at Mycroft's urgent request in November 1895. Holmes investigated at Aldgate Station, traveled to Woolwich to visit Sir James Walter's house, Mrs. Cadogan West's house, and the Arsenal office. Deduced the body was placed on a train roof from Oberstein's back window. Burglarized Oberstein's house at 13 Caulfield Gardens with Watson, finding blood marks and coded advertisements. Placed fake Pierrot advertisement in the Daily Telegraph. Captured Colonel Walter and obtained his confession. Lured Oberstein back from Paris with a forged letter. The plans were recovered and Oberstein imprisoned for fifteen years." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :mycroftHolmes ;
    ex:hasParticipant :lestrade ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :aldgateStation ;
    ex:occurredAt :woolwich ;
    ex:occurredAt :13CaulfieldGardens ;
    ex:isSolved "true" ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:burglaryBarnicotResidence a ex:Burglary ;
    ex:prefLabel "Burglary at Barnicot's Residence" ;
    ex:description "Dr. Barnicot's house on Kennington Road was burgled during the night. Nothing was taken except the plaster Napoleon bust from the hall. It was carried outside and dashed savagely against the garden wall, where its splintered fragments were found." ;
    ex:hasParticipant :beppo ;
    ex:occurredAt :barnicotResidence ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:burglaryHarkerHouse a ex:Burglary ;
    ex:prefLabel "Burglary at Harker's House" ;
    ex:description "Beppo broke into 131 Pitt Street through the window and stole the Napoleon bust from the mantelpiece. Harker heard sounds and then a horrible yell. The bust was carried to the garden of an empty house on Campden House Road and smashed under a street lamp." ;
    ex:hasParticipant :beppo ;
    ex:occurredAt :131PittStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:burglaryOfObersteinHouse a ex:Burglary ;
    ex:prefLabel "Burglary of Oberstein's House" ;
    ex:description "Holmes and Watson broke into Hugo Oberstein's house at 13 Caulfield Gardens, entering through the area door. Found blood marks on the window-sill and stairs confirming the body had been placed on a train from the back window. Discovered a small tin cash-box containing Pierrot advertisements from the Daily Telegraph agony column. Holmes then visited the Daily Telegraph offices to place a fake advertisement." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :13CaulfieldGardens ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:burglaryThreeGables a ex:FictionalEvent , ex:Crime , ex:Theft ;
    ex:prefLabel "Burglary of The Three Gables" ;
    ex:description "A nighttime burglary of The Three Gables carried out by Barney Stockdale's men on behalf of Isadora Klein. Mrs. Maberley was chloroformed. The burglars stole Douglas Maberley's manuscript novel from his trunks. Mrs. Maberley woke and seized one of the burglars, tearing away a single page. Mary the maid screamed from the window, bringing the police, but the burglars escaped." ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasParticipant :barneyStockdale , :steveDixie , :maryMaberley ;
    ex:occurredAt :theThreeGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:burglaryVernonLodge a ex:Crime ;
    ex:prefLabel "Burglary of Vernon Lodge" ;
    ex:description """While Watson distracts Baron Gruner with the Ming saucer, Holmes breaks into Vernon Lodge through the garden window to steal the incriminating brown leather book from the inner study. Holmes appears at the open window with his head girt in bloody bandages. He escapes through the gap and crashes into the laurel bushes. He successfully retrieves the book. Holmes is later threatened with prosecution for burglary.""" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :vernonLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:bustSmashingMorseHudson a ex:Crime ;
    ex:prefLabel "Bust Smashing at Morse Hudson's Shop" ;
    ex:description "The first incident in the Six Napoleons case. A plaster bust of Napoleon was smashed on the counter of Morse Hudson's shop on Kennington Road while the assistant had left the front shop. Reported to the constable on the beat as an act of hooliganism." ;
    ex:hasParticipant :beppo ;
    ex:occurredAt :morseHudsonShop ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:cabinAmbush a ex:Event ;
    ex:prefLabel "Ambush at Peter Carey's cabin" ;
    ex:description "Holmes, Watson, and Hopkins concealed themselves among the bushes outside Peter Carey's cabin from past eleven o'clock at night. At half-past two in the morning, they observed someone enter through the gate and successfully pick the lock. The intruder was John Hopley Neligan, who lit a candle and examined one of the Sea Unicorn's log-books before being seized by Hopkins." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :stanleyHopkins, :johnNeligan ;
    ex:occurredAt :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:cairnsFirstVisit a ex:Event, ex:Meeting ;
    ex:prefLabel "Cairns's first visit to Carey" ;
    ex:description "Patrick Cairns found Peter Carey at Woodman's Lee after years of searching, through a sailor who had met Carey in London. On the first night Carey was reasonable and ready to pay Cairns for his silence about the murder of Neligan Senior. They arranged to meet again two nights later to settle the matter." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :patrickCairns, :peterCarey ;
    ex:occurredAt :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:camdenHouseStakeout a ex:Event ;
    ex:prefLabel "Stakeout and arrest at Camden House" ;
    skos:altLabel "Adventure of the Empty House" ;
    ex:description "Evening of Holmes's return to London, spring 1894. Holmes and Watson stake out Camden House, the empty house opposite 221B Baker Street. Mrs. Hudson operates a wax bust decoy of Holmes in the window of 221B, moving it every quarter hour. Colonel Moran enters Camden House through the back door, assembles Von Herder's air-gun, and fires at the bust. Holmes tackles Moran, Watson strikes him with revolver butt, and Lestrade with police arrest Moran." ;
    ex:occurredAt :camdenHouse ;
    ex:occurredAt :221bBakerStreet ;
    ex:eventYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:hasParticipant :lestrade ;
    ex:hasParticipant :mrsHudson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:cancellationGrunerMarriage a ex:Event ;
    ex:prefLabel "Cancellation of Gruner-de Merville Marriage" ;
    ex:description """Three days after the vitriol attack, a paragraph appeared in the Morning Post announcing that the marriage between Baron Adelbert Gruner and Miss Violet de Merville would not take place. The incriminating book was presumably shown to Violet or her father by Sir James Damery.""" ;
    ex:hasParticipant :adelbertGruner ;
    ex:hasParticipant :violetDeMerville ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:captureOfCairns a ex:Event ;
    ex:prefLabel "Capture of Patrick Cairns" ;
    ex:description "Patrick Cairns was captured at 221B Baker Street when he responded to Holmes's fake harpooner advertisement under the alias Captain Basil. When Cairns bent to sign the agreement paper, Holmes passed both hands over his neck and fastened handcuffs on his wrists. Cairns resisted violently but was subdued by Holmes, Watson (who pressed his revolver to Cairns's temple), and Hopkins." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :sherlockHolmes, :patrickCairns, :johnWatson, :stanleyHopkins ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:captureOfOberstein a ex:Capture ;
    ex:prefLabel "Capture of Hugo Oberstein" ;
    ex:description "Holmes dictated a letter from Colonel Walter to Oberstein at the Hôtel du Louvre, Paris, claiming to have a tracing of a missing essential detail and requesting £500. Meeting arranged at the smoking-room of the Charing Cross Hotel at noon on Saturday. Oberstein came to complete the coup of his lifetime and was captured. Sentenced to fifteen years in a British prison. The Bruce-Partington plans were found in his trunk." ;
    ex:hasParticipant :hugoOberstein ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :charingCrossHotel ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:captureOfColonelWalter a ex:Capture ;
    ex:prefLabel "Capture of Colonel Walter" ;
    ex:description "The night after the burglary. Holmes, Watson, Mycroft, and Lestrade staked out Oberstein's house at 13 Caulfield Gardens. Colonel Valentine Walter arrived in disguise (broad-brimmed hat, cravat hiding face) responding to Holmes's fake Pierrot advertisement. Holmes caught him at the door, threw him into the room. Walter fainted, was identified by his long light beard and delicate features. He confessed to the theft but denied the murder, blaming Oberstein for killing West." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :mycroftHolmes ;
    ex:hasParticipant :lestrade ;
    ex:hasParticipant :colonelValentineWalter ;
    ex:occurredAt :13CaulfieldGardens ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:captureOfVonBork a ex:Event, ex:Arrest ;
    ex:prefLabel "Capture of Von Bork" ;
    ex:description "On the night of August 2, 1914, Sherlock Holmes, disguised as the Irish-American spy Altamont, revealed his true identity to German master spy Von Bork by presenting a bee culture book instead of the expected naval signals. Holmes then chloroformed Von Bork, who was bound with straps by Holmes and Watson. They transported him in a Ford car to Scotland Yard. Martha, Holmes's agent placed as Von Bork's housekeeper, had signaled that the coast was clear." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :vonBork ;
    ex:hasParticipant :marthaHisLastBow ;
    ex:narrativeYear "1914" ;
    ex:occurredAt :vonBorkCountryHouse ;
    ex:occurredAt :vonBorkStudy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:cardboardBoxInvestigation a ex:Investigation ;
    ex:prefLabel "Cardboard Box Investigation" ;
    ex:description "Holmes investigates the case of severed ears sent to Miss Cushing. Deduces Jim Browner as murderer. Investigation spans visiting Croydon, Wallington, sending telegram to Algar." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasInvestigator :lestrade ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :susanCushing ;
    ex:hasClient :lestrade ;
    ex:occurredAt :croydon ;
    ex:occurredAt :wallington ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:narrativeYear "1888"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:cardGameOnVoyage a ex:Event ;
    ex:prefLabel "Card game on the voyage" ;
    ex:description "Carruthers and Woodley played cards for who would marry Violet Smith during their voyage from South Africa to England. Woodley won." ;
    ex:hasParticipant :bobCarruthers ;
    ex:hasParticipant :jackWoodley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:cardinalToscaInvestigation a ex:Event, ex:Investigation ;
    ex:prefLabel "Cardinal Tosca investigation" ;
    ex:description "In 1895, Holmes investigated the sudden death of Cardinal Tosca at the express desire of His Holiness the Pope. Referenced only; no details given." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :sherlockHolmes, :cardinalTosca, :popeBlackPeter ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:careyAssaultOnVicar a ex:Event, ex:Crime ;
    ex:prefLabel "Carey's assault on the vicar" ;
    ex:description "Captain Peter Carey committed a savage assault upon the old vicar near Woodman's Lee, who had called upon him to remonstrate about his conduct. Carey was summoned for the assault." ;
    ex:hasParticipant :peterCarey, :forestRowVicar ;
    ex:occurredAt :woodmansLee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:carloPoisoning a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Carlo Poisoning" ;
    ex:description "Approximately four months before the main events, Jack Ferguson tested the curare poison on Carlo, the Ferguson family's spaniel. The dog suffered a sort of paralysis that a veterinarian diagnosed as spinal meningitis. Holmes deduces that Jack used the poison on the dog first to verify it had not lost its potency before using it on the baby." ;
    ex:perpetrator :jackFerguson ;
    ex:victim :carlo ;
    ex:location :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:carruthersProposalToViolet a ex:Proposal ;
    ex:prefLabel "Carruthers's proposal to Violet Smith" ;
    ex:description "Carruthers proposed marriage to Violet Smith. She refused, as she was engaged to Cyril Morton. Carruthers took the refusal seriously but gently. This strained their employer-employee relationship." ;
    ex:hasParticipant :bobCarruthers ;
    ex:hasParticipant :violetSmith ;
    ex:occurredAt :chilternGrange ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:carruthersWoodleyQuarrel a ex:Quarrel ;
    ex:prefLabel "Quarrel between Carruthers and Woodley" ;
    ex:description "A quarrel between Carruthers and Woodley after Carruthers fell in love with Violet and refused to continue with the original plan. Woodley knocked Carruthers down. They separated and Woodley began operating independently with Williamson." ;
    ex:hasParticipant :bobCarruthers ;
    ex:hasParticipant :jackWoodley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:chaseAtCanterbury a ex:FictionalEvent, ex:Chase ;
    ex:prefLabel "Chase at Canterbury" ;
    ex:description "After Holmes and Watson alighted at Canterbury, they hid behind luggage and watched Moriarty's special train fly through the station at speed. Holmes noted that Moriarty failed to deduce they would leave the train early — a limit to his intelligence." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :professorMoriarty ;
    ex:occurredAt :canterbury ;
    ex:narrativeDate "April 25, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:concealmentOfDeath a ex:ConcealmentOfDeath, ex:Impersonation ;
    ex:prefLabel "Concealment of Lady Beatrice's Death" ;
    ex:description "The criminal scheme to conceal the death of Lady Beatrice Falder. Sir Robert Norberton, with the help of maid Carrie Evans and her husband Norlett (an actor), conceals Lady Beatrice's death to prevent creditors from seizing the estate before the Derby. Norlett impersonates Lady Beatrice by riding in her carriage. The body is first hidden in the old well-house, then moved to the crypt and placed in an ancestor's coffin. The displaced ancient remains are burned in the furnace. The scheme is discovered by Holmes through the spaniel test and crypt investigation." ;
    ex:hasParticipant :robertNorberton, :carrieEvans, :norlett ;
    ex:occurredAt :shoscombeOldPlace, :shoscombeWellHouse, :shoscombeChapel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:confrontationAmberley a ex:Event ;
    ex:prefLabel "Confrontation and Arrest of Amberley" ;
    ex:description "Holmes and Barker confront Josiah Amberley at The Haven with the question 'What did you do with the bodies?' Amberley reacts with horror and attempts suicide with a poison pellet, which Holmes prevents. Amberley is dragged to a waiting cab by Holmes and Barker and taken to the police station. Inspector MacKinnon then arrives at The Haven." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :barkerDetective ;
    ex:hasParticipant :josiahAmberley ;
    ex:hasParticipant :inspectorMacKinnon ;
    ex:occurredAt :theHavenLewisham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:confrontationAtReichenbach a ex:FictionalEvent, ex:Confrontation, ex:Murder ;
    ex:prefLabel "Confrontation at Reichenbach Falls" ;
    skos:altLabel "the Reichenbach incident" ;
    ex:description "The final confrontation between Sherlock Holmes and Professor Moriarty at Reichenbach Falls on May 4, 1891. After Watson was lured away by a forged letter, Moriarty confronted Holmes on the narrow path above the falls. Holmes wrote his farewell letter to Watson while Moriarty waited. Expert examination left little doubt that a personal contest between the two ended with both reeling over the edge, locked in each other's arms, into the terrible abyss. Any attempt at recovering the bodies was absolutely hopeless. Additional details from Holmes's account: Holmes used baritsu (Japanese wrestling) to slip from Moriarty's grip. Moriarty screamed, clawed the air, fell, struck a rock, and splashed into the water. Holmes then climbed the cliff to a moss-covered ledge several feet deep. Colonel Moran, who had been watching from a distance, threw rocks at Holmes from the cliff top. Holmes scrambled down the path and fled ten miles over the mountains in darkness, arriving in Florence a week later." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :professorMoriarty ;
    ex:occurredAt :reichenbachFalls ;
    ex:narrativeDate "May 4, 1891" ;
    ex:hasOutcome :deathOfHolmesAndMoriarty ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc ;
    dc:source :emptyHouseDoc .

:confrontationAtThorBridge a ex:Meeting ;
    ex:prefLabel "Confrontation at Thor Bridge" ;
    ex:description "Mrs. Gibson confronted Grace Dunbar at Thor Bridge after luring her there with a note. Mrs. Gibson poured out her hatred in burning and horrible words, shrieking curses. Dunbar did not answer, put her hands to her ears, and rushed away. When Dunbar left, Mrs. Gibson was still standing in the mouth of the bridge, shrieking. Shortly after, Mrs. Gibson shot herself." ;
    ex:hasParticipant :mariaGibson ;
    ex:hasParticipant :graceDunbar ;
    ex:occurredAt :thorBridge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:confrontationKlein a ex:FictionalEvent , ex:Meeting ;
    ex:prefLabel "Confrontation with Isadora Klein" ;
    ex:description "Holmes and Watson visited Isadora Klein at her house on Grosvenor Square. After initial resistance, Klein confessed to orchestrating the theft of Douglas Maberley's manuscript. She revealed she had burned the manuscript. Holmes secured a check for five thousand pounds from Klein for Mrs. Maberley." ;
    ex:hasParticipant :sherlockHolmes , :johnWatson , :isadoraKlein ;
    ex:occurredAt :isadoraKleinHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:confrontationPeters a ex:Meeting ;
    ex:prefLabel "Holmes and Watson Confront Peters" ;
    ex:description "Holmes and Watson went to 36 Poultney Square and confronted Henry Peters and Annie Fraser. They found Rose Spender's body in the coffin in the dining room, but not Lady Frances. Peters mockingly explained about Rose Spender. Annie Fraser fetched police, and a sergeant and constable required Holmes and Watson to leave without a warrant." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :henryPeters, :annieFraser, :poultneySqSergeant, :poultneySqConstable ;
    ex:occurredAt :36PoultneySq ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:copperBeechesInvestigation a ex:Investigation ;
    ex:prefLabel "Copper Beeches Investigation" ;
    ex:description """Holmes's investigation into the suspicious situation at the Copper Beeches near Winchester. It began with Violet Hunter's consultation at Baker Street about a governess position with peculiar conditions offered by Jephro Rucastle. After a fortnight, Violet telegraphed from Winchester reporting a barricaded prisoner in a locked wing. Holmes deduced that Violet was hired to impersonate the imprisoned daughter Alice Rucastle and deceive her suitor. Holmes and Watson travelled to Winchester, met Violet at the Black Swan Hotel, and proceeded to the Copper Beeches at seven o'clock. They found the prisoner had already been rescued by Mr. Fowler through the skylight. Rucastle was mauled by his starved mastiff, and Mrs. Toller revealed the full story.""" ;
    ex:hasClient :violetHunter ;
    ex:hasDetective :sherlockHolmes ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :violetHunter, :jephroRucastle, :mrsTollerCB ;
    ex:locatedIn :copperBeeches, :blackSwanHotel, :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:cornishHorrorInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Cornish Horror" ;
    skos:altLabel "the Cornish Horror" ;
    ex:description "Holmes's investigation into the poisoning at Tredannick Wartha and the subsequent murder of Mortimer Tregennis at the vicarage, conducted in spring 1897 during Holmes's enforced rest in Cornwall. Holmes deduced that a poison worked by combustion was responsible, identified devil's-foot root as the agent through examination of the lamp and talc shield, followed Dr. Sterndale's movements, and ultimately confronted Sterndale who confessed. Holmes allowed Sterndale to go free to continue his work in Africa, choosing not to involve the police." ;
    ex:occurredAt :cornwall ;
    ex:occurredAt :tredannickWartha ;
    ex:occurredAt :tredannickWollasVicarage ;
    ex:occurredAt :poldhuCottage ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :roundhay ;
    ex:hasParticipant :mortimerTregennis ;
    ex:hasParticipant :leonSterndale ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :roundhay ;
    ex:eventYear "1897"^^xsd:gYear ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:creditLyonnaisForgery a ex:Crime ;
    ex:prefLabel "Credit Lyonnais Forgery" ;
    ex:description "A forged check on the Credit Lyonnais bank committed by Count Negretto Sylvius in 1892, as recorded in Holmes's crime notebook. Sylvius denies this particular charge." ;
    ex:narrativeDate "1892" ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:creepingManInvestigation a ex:FictionalEvent, ex:Investigation ;
    ex:prefLabel "Investigation of the Creeping Man" ;
    ex:description "One of the very last cases handled by Sherlock Holmes before his retirement from practice. In September 1903, Trevor Bennett and Edith Presbury consulted Holmes about the strange behavior of Professor Presbury, a famous Camford physiologist. Holmes deduced a nine-day cycle of episodes linked to a drug obtained during a secret trip to Prague. Investigation revealed that Presbury was taking rejuvenation serum derived from black-faced langur monkey, created by H. Lowenstein of Prague and supplied through A. Dorak on Commercial Road, London. The case was resolved when the contents of Presbury's wooden box and Lowenstein's letter revealed the full scheme." ;
    ex:narrativeYear "1903" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :trevorBennett ;
    ex:hasClient :edithPresbury ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :trevorBennett ;
    ex:hasParticipant :edithPresbury ;
    ex:hasParticipant :professorPresbury ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :camford ;
    ex:occurredAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:cryptConfrontation a ex:Confrontation ;
    ex:prefLabel "Crypt Confrontation" ;
    ex:description "Sir Robert Norberton discovers Holmes and Watson in the crypt. He arrives with a stable-lantern, described as a terrible figure, huge in stature and fierce in manner. He threatens them with a heavy stick. Holmes stands his ground and reveals the body in the coffin. Sir Robert staggers back and eventually agrees to explain." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :robertNorberton ;
    ex:occurredAt :shoscombeChapel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:cryptExploration a ex:Event ;
    ex:prefLabel "Crypt Exploration" ;
    ex:description "Holmes, Watson, and John Mason explore the crypt beneath the old chapel in Shoscombe Park at night. Mason shows them where the mummy remains were found, but they are gone (burned in the furnace). Holmes examines the graves from Saxon through Norman to eighteenth-century Falders. He opens a leaden coffin with a jemmy and discovers Lady Beatrice's body inside." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :johnMason ;
    ex:occurredAt :shoscombeChapel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:dameryVisitBakerStreet a ex:Meeting ;
    ex:prefLabel "Damery's Visit to Baker Street" ;
    ex:description """Sir James Damery visits Sherlock Holmes at 221B Baker Street at 4.30 on September 3, 1902, to present the case of the illustrious client. He describes Baron Gruner's threat to Violet de Merville and requests Holmes's help on behalf of an unnamed client of high standing.""" ;
    ex:hasParticipant :jamesDamery ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :221bBakerStreet ;
    ex:narrativeDate "1902-09-03" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:dawsonNeliganFailure a ex:Event ;
    ex:prefLabel "Failure of Dawson and Neligan bank" ;
    skos:altLabel "Dawson and Neligan bankruptcy" ;
    ex:description "In 1883, the West-country banking firm of Dawson and Neligan failed for a million pounds, ruining half the county families of Cornwall. Dawson had already retired. Neligan Senior took the securities and fled by yacht toward Norway, believing he could realize them and pay all creditors in full. A warrant was issued for his arrest." ;
    ex:eventYear "1883" ;
    ex:hasParticipant :neliganSenior, :dawsonBanker, :dawsonAndNeligan ;
    ex:occurredAt :cornwall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:deathOfBeatriceFalder a ex:Event ;
    ex:prefLabel "Death of Lady Beatrice Falder" ;
    ex:description "Lady Beatrice Falder dies of dropsy approximately one week before the story's resolution. Her death triggers the concealment scheme by Sir Robert Norberton, who fears that her death will cause his creditors to seize the estate before Shoscombe Prince can run in the Derby." ;
    ex:hasParticipant :beatriceFalder ;
    ex:occurredAt :shoscombeOldPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:deathOfDouglasMaberley a ex:FictionalEvent ;
    ex:prefLabel "Death of Douglas Maberley" ;
    ex:description "Douglas Maberley died of pneumonia in Rome the month before the Three Gables case. His death triggered the return of his effects to his mother, which in turn led to Isadora Klein's desperate attempt to retrieve his manuscript." ;
    ex:hasParticipant :douglasMaberley ;
    ex:occurredAt :rome ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:deathOfHolmesAndMoriarty a ex:FictionalEvent ;
    ex:prefLabel "Apparent Death of Holmes and Moriarty" ;
    ex:description "The apparent deaths of Sherlock Holmes and Professor Moriarty at Reichenbach Falls on May 4, 1891. Both fell into the abyss locked in each other's arms. Recovery of bodies was absolutely hopeless. Watson describes Holmes as 'the best and the wisest man whom I have ever known.' (Note: Holmes's death is later revealed to have been faked in 'The Adventure of the Empty House.')" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :professorMoriarty ;
    ex:occurredAt :reichenbachFalls ;
    ex:narrativeDate "May 4, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:deathOfJamesSmith a ex:Event ;
    ex:prefLabel "Death of James Smith" ;
    ex:description "The death of James Smith, Violet's father, which left the family very poor and without relations except Uncle Ralph." ;
    ex:hasParticipant :jamesSmith ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:deathOfMajorSholto a ex:Death ;
    ex:prefLabel "Death of Major John Sholto" ;
    ex:description "Major John Sholto died on 28 April 1882 at Pondicherry Lodge, Upper Norwood. Had been in increasing terror after receiving a letter from India warning that the men he had wronged were free. On his deathbed, confessed to his twin sons Thaddeus and Bartholomew about Captain Morstan's accidental death and the Agra treasure. Was about to reveal the treasure's hiding place when he saw a bearded face at the window — Jonathan Small — and died of fright. The sign of the four was found pinned to his chest the next morning." ;
    ex:involves :majorJohnSholto ;
    ex:involves :jonathanSmall ;
    ex:occurredAt :pondicherryLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:deathOfMariaGibson a ex:Suicide ;
    ex:prefLabel "Death of Maria Gibson" ;
    ex:description "Maria Gibson committed suicide at Thor Bridge on the Thor Place estate in Hampshire. She shot herself behind the right temple using a revolver tied to a string weighted with a stone, which upon release pulled the weapon over the parapet into Thor Mere — an exceedingly ingenious method to dispose of the weapon and make her death appear to be murder. Her body was found by a gamekeeper about eleven o'clock at night, lying on her back with no trace of struggle, clad in her dinner dress with a shawl over her shoulders. Grace Dunbar's note was clutched in her left hand. She had earlier planted a matching discharged revolver in Dunbar's wardrobe to frame her." ;
    ex:hasParticipant :mariaGibson ;
    ex:occurredAt :thorBridge ;
    ex:hasVictim :mariaGibson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:deathOfMcPherson a ex:Death ;
    ex:prefLabel "Death of Fitzroy McPherson" ;
    ex:description "The death of Fitzroy McPherson, science master at The Gables, killed by a Cyanea capillata (Lion's Mane jellyfish) at the bathing pool below the chalk cliffs near Fulworth in late July 1907. McPherson had gone for his usual morning swim and was stung while preparing to bathe. He managed to climb the cliff path but collapsed and died at the top, with his dying words being 'the Lion's Mane.' His back was covered with dark red welts as though flogged by a thin wire scourge. His weak heart from rheumatic fever made the sting fatal." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :fitzroyMcPherson, :cyaneaCapillata ;
    ex:occurredAt :fulworthBathingPool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:deathOfMcPhersonDog a ex:Death ;
    ex:prefLabel "Death of McPherson's Dog" ;
    ex:description "About a week after McPherson's death, his faithful Airedale terrier was found dead at the very same bathing pool where its master had died. The dog had eaten nothing for a week after its master's death. Two students from The Gables, Sudbury and Blount, found the body at the edge of the pool. The dog had been killed by the same Cyanea capillata jellyfish. This event triggered Holmes's key insight into the case." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :mcPhersonDog, :cyaneaCapillata ;
    ex:occurredAt :fulworthBathingPool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:deathOfMrsHarold a ex:Crime ;
    ex:prefLabel "Death of Mrs. Harold" ;
    ex:description "The suspicious death of old Mrs. Harold, who left Count Negretto Sylvius the Blymer estate. The real facts of her death are recorded in Holmes's crime notebook, implying Sylvius was responsible." ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:hasParticipant :mrsHarold ;
    ex:hasVictim :mrsHarold ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:deathOfMrsStewart a ex:Event ;
    ex:prefLabel "Death of Mrs. Stewart" ;
    ex:description "1887. Death of Mrs. Stewart of Lauder. Holmes believed Colonel Moran was responsible ('at the bottom of it') but nothing could be proved." ;
    ex:occurredAt :lauder ;
    ex:eventYear "1887" ;
    ex:hasParticipant :mrsStewart ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:deathOfRalphSmith a ex:Event ;
    ex:prefLabel "Death of Ralph Smith" ;
    ex:description "Ralph Smith died in great poverty in Johannesburg. His death was reported by a telegram reading 'The old man is dead', which triggered the final abduction attempt against Violet Smith." ;
    ex:hasParticipant :ralphSmith ;
    ex:occurredAt :johannesburg ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:deathOfSirJamesWalter a ex:Event ;
    ex:prefLabel "Death of Sir James Walter" ;
    ex:description "Sir James Walter died the morning after the theft was discovered. A man of sensitive honour, the scandal broke his heart. He could not survive the affair. His brother Colonel Valentine Walter believed Sir James suspected him." ;
    ex:hasParticipant :sirJamesWalter ;
    ex:occurredAt :sirJamesWalterHouse ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:deathOfStauntonWife a ex:Death ;
    ex:prefLabel "Death of Godfrey Staunton's Wife" ;
    ex:description "Godfrey Staunton's unnamed wife died of virulent consumption (tuberculosis) at the lonely cottage near Trumpington. She had been under the care of Dr. Leslie Armstrong. By the time Holmes and Watson arrived at the cottage, she was dead, lying on the bed with Staunton kneeling at its foot in grief." ;
    ex:hasParticipant :godfreyStauntonWife ;
    ex:hasParticipant :godfreyStaunton ;
    ex:hasParticipant :leslieArmstrong ;
    ex:occurredAt :stauntonCottage ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:destructionOfBlackmailLetters a ex:FictionalEvent, ex:Event ;
    ex:prefLabel "Destruction of Blackmail Letters" ;
    ex:description "After witnessing Milverton's murder, Holmes swiftly moves to the safe and fills his arms with bundles of letters, pouring them into the fire. He empties the safe completely, burning all of Milverton's blackmail materials. He also tosses in the blood-mottled letter from Milverton's desk, which had been the instrument of the avenger's admission." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :milvertonStudy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:destructionOfCyanea a ex:Event ;
    ex:prefLabel "Destruction of the Cyanea Capillata" ;
    ex:description "Holmes and Stackhurst destroyed the Cyanea capillata jellyfish responsible for McPherson's death by pushing a big boulder off a ledge into the bathing pool, crushing the creature on the rocky shelf where it lay. A thick oily scum oozed out from below the stone. Inspector Bardle was present as a witness." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :sherlockHolmes, :haroldStackhurst, :inspectorBardle ;
    ex:occurredAt :fulworthBathingPool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:devilsFootExperiment a ex:Event ;
    ex:prefLabel "Devil's-Foot Powder Experiment" ;
    ex:description "Holmes's dangerous self-experiment with the devil's-foot root powder at Poldhu Cottage. He placed the remaining powder from his envelope on a burning lamp, with both he and Watson seated facing each other by an open window. Both experienced terrifying hallucinations — thick musky odour, black swirling clouds, and visions of monstrous entities. Watson broke free, grabbed Holmes, and they escaped to the grass outside. Holmes apologized for the unjustifiable experiment." ;
    ex:occurredAt :poldhuCottage ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:eventYear "1897"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:disappearanceBlackPearl a ex:Event ;
    ex:prefLabel "Disappearance of the Black Pearl" ;
    ex:description "The disappearance of the black pearl of the Borgias from the Prince of Colonna's bedroom at the Dacre Hotel. Caused a sensation in London. The police failed to recover it. Holmes was consulted but could not shed light on the case at the time. Occurred exactly two days before Beppo's arrest at Gelder & Co." ;
    ex:occurredAt :dacreHotel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:disappearanceLadyFrancesInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation into the Disappearance of Lady Frances Carfax" ;
    ex:description "The investigation into the disappearance of Lady Frances Carfax, conducted by Sherlock Holmes with the assistance of Dr. Watson. The client is Miss Susan Dobney, Lady Frances's former governess. Watson traveled to Lausanne, Baden, and Montpellier to trace Lady Frances, while Holmes followed in disguise. The case involved the criminals Holy Peters and Annie Fraser, who lured Lady Frances to London, imprisoned her, stole her jewellery, and attempted to bury her alive in an oversized coffin alongside the body of Rose Spender. Holmes deduced the scheme from the undertaker's remark about the coffin being out of the ordinary, and rescued Lady Frances just before the funeral." ;
    ex:investigatedBy :sherlockHolmes, :johnWatson ;
    ex:hasClient :susanDobney ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :ladyFrancesCarfax, :henryPeters, :annieFraser, :philipGreen, :lestrade ;
    ex:occurredAt :221bBakerStreet, :lausanne, :badenBaden, :montpellier, :36PoultneySq ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:disappearanceOfCaptainMorstan a ex:Disappearance ;
    ex:prefLabel "Disappearance of Captain Morstan" ;
    ex:description "Captain Arthur Morstan disappeared on 3 December 1878 after arriving at the Langham Hotel in London on twelve months' leave from his regiment. Had telegraphed his daughter Mary from London. Went to visit Major Sholto at Pondicherry Lodge that night and never returned. Actually died of a heart attack during a quarrel with Sholto over the division of the Agra treasure. His body was disposed of by Major Sholto and servant Lal Chowdar. Police inquiries and newspaper advertisements yielded no result." ;
    ex:involves :captainArthurMorstan ;
    ex:involves :majorJohnSholto ;
    ex:involves :lalChowdar ;
    ex:occurredAt :pondicherryLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:disappearanceOfGodfreyStaunton a ex:Disappearance ;
    ex:prefLabel "Disappearance of Godfrey Staunton" ;
    ex:description "Godfrey Staunton left Bentley's Hotel at half-past ten at night with a bearded messenger (his father-in-law) after receiving a note about his wife's worsening condition. He ran toward the Strand and did not return. His bed was not slept in. He went directly to his wife's cottage near Trumpington where she was dying of consumption." ;
    ex:hasParticipant :godfreyStaunton ;
    ex:hasParticipant :stauntonWifeFather ;
    ex:occurredAt :bentleysHotel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:discoveryBlackPearl a ex:Event ;
    ex:prefLabel "Discovery of the Black Pearl" ;
    ex:description "Holmes smashed the sixth and final Napoleon bust at 221B Baker Street using his hunting-crop, revealing the black pearl of the Borgias fixed inside like a plum in a pudding. Watson and Lestrade broke out clapping. Holmes explained the entire chain of events linking the pearl theft, Beppo's concealment, and the systematic bust-smashing." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :lestrade ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:discoveryOfBody a ex:Event ;
    ex:prefLabel "Discovery of Cadogan West's Body" ;
    ex:description "Tuesday morning in November 1895 at 6am. Plate-layer Mason found the dead body of Arthur Cadogan West just outside Aldgate Station on the Underground, about three feet from the metals on the left-hand side going eastward, where the line emerges from the tunnel. Head was badly crushed. Seven stolen Bruce-Partington papers were in his pocket." ;
    ex:hasParticipant :mason ;
    ex:hasParticipant :arthurCadoganWest ;
    ex:occurredAt :aldgateStation ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:discoveryOfCounterfeitingPress a ex:Event ;
    ex:prefLabel "Discovery of Prescott's Counterfeiting Press" ;
    ex:description "The discovery of Rodger Prescott's counterfeiting press and equipment, hidden in a secret cellar beneath 136 Little Ryder Street. Killer Evans opened the trapdoor to access the cellar but was confronted by Holmes and Watson. The discovery was celebrated at Scotland Yard, who had known of the outfit's existence but had been unable to locate it after Prescott's death." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :killerEvans ;
    ex:occurredAt :136LittleRyderStreetCellar ;
    ex:narrativeYear "1902" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:doddTuxburyVisit a ex:Event ;
    ex:prefLabel "Dodd's Visit to Tuxbury" ;
    ex:description "James Dodd's visit to Tuxbury Old Park to investigate the disappearance of his friend Godfrey Emsworth. Dodd was invited by Mrs. Emsworth and stayed overnight. During the visit he had a confrontation with Colonel Emsworth, spoke with the butler Ralph, saw Godfrey at the window, discovered the lodge with the mysterious bearded man (Mr. Kent), and was caught spying by the Colonel who ordered him to leave on the 8:30 train." ;
    ex:hasParticipant :jamesDodd ;
    ex:hasParticipant :colonelEmsworth ;
    ex:hasParticipant :mrsEmsworth ;
    ex:hasParticipant :ralphButler ;
    ex:hasParticipant :godfreyEmsworth ;
    ex:hasParticipant :mrKent ;
    ex:occurredAt :tuxburyOldPark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:dogThroughWindowIncident a ex:Event ;
    ex:prefLabel "Dog Through Window Incident" ;
    ex:description "A past incident in which Ian Murdoch, plagued by McPherson's little dog, caught the creature up and hurled it through a plate-glass window at The Gables. Stackhurst would certainly have dismissed Murdoch had he not been such a valuable teacher. The incident illustrates Murdoch's ferocious temper and initially casts suspicion on him after McPherson's death." ;
    ex:hasParticipant :ianMurdoch, :mcPhersonDog ;
    ex:occurredAt :theGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:dutchSteamshipFrieslandAffair a ex:Investigation ;
    ex:prefLabel "Affair of the Dutch Steamship Friesland" ;
    ex:description "Case mentioned by Watson that nearly cost Holmes and Watson their lives, described as one of the few interesting cases during the post-Moriarty period." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:edithSeesPresburyAtWindow a ex:FictionalEvent ;
    ex:prefLabel "Edith Sees Presbury at Window" ;
    ex:description "On the night of September 5th, 1903, Edith Presbury was awakened by Roy barking furiously. With bright moonlight outside and her blind up, she saw her father's face pressed against her second-floor window pane, with one hand raised as if to push up the window. The face remained for about twenty seconds before vanishing. Her room was seemingly inaccessible from outside, though Holmes later noted a creeper below and water-pipe above providing some foothold. This incident drove Edith to travel to London to consult Holmes." ;
    ex:narrativeDate "1903-09-05" ;
    ex:hasParticipant :edithPresbury ;
    ex:hasParticipant :professorPresbury ;
    ex:occurredAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:escapeOfAliceRucastle a ex:Escape ;
    ex:prefLabel "Escape of Alice Rucastle" ;
    ex:description """Mr. Fowler rescued Alice Rucastle from her imprisonment in the locked wing of the Copper Beeches. He arranged for Mrs. Toller's cooperation through bribery and kept Mr. Toller supplied with drink. While the Rucastles were away on a visit, Fowler placed a ladder against the eaves and Alice escaped through the skylight of her prison room. The escape occurred just before Holmes and Watson arrived at the house.""" ;
    ex:hasParticipant :aliceRucastle, :mrFowler, :mrsTollerCB, :tollerCB ;
    ex:locatedIn :copperBeeches ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:evansArrest a ex:FictionalEvent, ex:Arrest ;
    ex:prefLabel "Arrest of Killer Evans" ;
    ex:description "After Holmes subdues Killer Evans at 136 Little Ryder Street, Watson calls Scotland Yard. Evans is arrested for attempted murder of Watson in addition to the counterfeiting charges. Despite Evans's argument that he had done a public service by eliminating Prescott, an unappreciative bench sentences him and he returns to prison." ;
    ex:arrestee :killerEvans ;
    ex:arrestedBy :sherlockHolmes ;
    ex:location :136LittleRyderStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:fergusonsSecondMarriage a ex:FictionalEvent, ex:Marriage ;
    ex:prefLabel "Ferguson's Second Marriage" ;
    ex:description "Robert Ferguson's marriage to his second wife, a Peruvian lady and the daughter of a Peruvian merchant involved in nitrates importation. The marriage took place approximately five years before the events of the story. Ferguson had met her through his business connections with the importation of nitrates. Despite the wife being very beautiful and loving, differences in background, birth, and religion caused some separation between them." ;
    ex:hasParticipant :robertFerguson ;
    ex:hasParticipant :mrsFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:fireAtBakerStreet a ex:FictionalEvent, ex:Arson ;
    ex:prefLabel "Fire at Baker Street" ;
    ex:description "Moriarty's agents set fire to 221B Baker Street the night of April 24th, 1891. Holmes learned of it from the morning paper. No great harm was done. The arson indicated that Moriarty's agents had lost Holmes's trail after the bludgeon-man was arrested and assumed Holmes had returned to his rooms." ;
    ex:occurredAt :221bBakerStreet ;
    ex:narrativeDate "night of April 24, 1891" ;
    ex:hasParticipant :moriartyCriminalOrganization ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:firstAssaultOnJack a ex:FictionalEvent ;
    ex:prefLabel "First Assault on Jack Ferguson" ;
    ex:description "Mrs. Ferguson struck her stepson Jack with a stick, leaving a great weal on his arm. This occurred during the same period as the first baby attack. Mrs. Ferguson's attack was motivated by her knowledge that Jack was poisoning the baby and her protective maternal rage." ;
    ex:hasParticipant :mrsFerguson ;
    ex:hasParticipant :jackFerguson ;
    ex:occurredAt :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:firstBabyAttack a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "First Poisoning of Baby Ferguson" ;
    ex:description "Approximately one month before the main events, the baby was left by its nurse for a few minutes. A loud cry of pain was heard and the nurse found Mrs. Ferguson leaning over the baby, apparently biting its neck. There was a small wound in the neck from which blood had escaped. In truth, Mrs. Ferguson was sucking curare poison from a wound inflicted by Jack Ferguson using a poisoned arrow. Mrs. Ferguson gave the nurse five pounds for her silence. This coincided with the first assault on Jack by Mrs. Ferguson." ;
    ex:hasParticipant :mrsFerguson ;
    ex:hasParticipant :babyFerguson ;
    ex:hasParticipant :jackFerguson ;
    ex:hasParticipant :mrsMason ;
    ex:hasPerpetrator :jackFerguson ;
    ex:hasVictim :babyFerguson ;
    ex:occurredAt :cheesemansNursery ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:firstVisitThreeGables a ex:FictionalEvent , ex:Meeting ;
    ex:prefLabel "First Visit to Three Gables" ;
    ex:description "Holmes and Watson's first visit to The Three Gables to meet Mrs. Maberley. They learned about the suspicious house purchase offer, caught Susan eavesdropping, discovered Douglas's trunks from Italy, and encountered Steve Dixie lurking outside." ;
    ex:hasParticipant :sherlockHolmes , :johnWatson , :maryMaberley , :susanStockdale ;
    ex:occurredAt :theThreeGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:flightFromAppledore a ex:FictionalEvent, ex:Pursuit ;
    ex:prefLabel "Flight from Appledore Towers" ;
    ex:description "Holmes and Watson escape from Appledore Towers after the murder of Milverton and the destruction of the blackmail letters. The house alarm is raised — the house blazes with light, the front door is open, and figures rush down the drive. They flee through a plantation of small trees, scale a six-foot wall (Watson is grabbed by the under-gardener but kicks free), and run approximately two miles across Hampstead Heath before stopping in absolute silence." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :appledoreUnderGardener ;
    ex:occurredAt :appledoreTowers ;
    ex:occurredAt :hampsteadHeath ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:flightOfLuccas a ex:Flight ;
    ex:prefLabel "Flight of the Luccas" ;
    ex:description "Gennaro and Emilia Lucca fled from New York to London to escape Giuseppe Gorgiano and the Red Circle after Gennaro refused to carry out the assassination of Tito Castalotte. Before leaving, Gennaro warned Castalotte of the danger and left information for the police." ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasParticipant :emiliaLucca ;
    ex:occurredAt :newYork ;
    ex:occurredAt :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:flightToContinent a ex:FictionalEvent, ex:Flight ;
    ex:prefLabel "Flight to the Continent" ;
    ex:description "Holmes and Watson's flight from England to escape Moriarty. Involved an elaborate evasion plan: Watson ran through Lowther Arcade to a brougham driven by Mycroft, then to Victoria Station. Holmes arrived disguised as an Italian priest. They departed on the Continental express just as Moriarty arrived at the platform. Route: Victoria → Canterbury (alighted) → Newhaven → Dieppe → Brussels (2 days) → Strasbourg → Geneva → Valley of the Rhone → Leuk → Gemmi Pass → Interlaken → Meiringen." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :mycroftHolmes ;
    ex:narrativeDate "April 25 to May 3, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:forcedMarriageOfVioletSmith a ex:ForcedMarriage ;
    ex:prefLabel "Forced marriage of Violet Smith" ;
    ex:description "An illegal forced marriage ceremony performed by the unfrocked clergyman Williamson in the bowling alley of Charlington Hall grounds. Woodley was the groom, Violet was gagged with a handkerchief. Holmes declared the marriage invalid due to Williamson being unfrocked, the license being obtained by trick, and the marriage being forced." ;
    ex:isForced "true"^^xsd:boolean ;
    ex:hasParticipant :violetSmith ;
    ex:hasParticipant :jackWoodley ;
    ex:hasParticipant :williamsonExClergyman ;
    ex:occurredAt :charlingtonBowlingAlley ;
    ex:performedBy :williamsonExClergyman ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:fortescueExamTampering a ex:ExamTampering ;
    ex:prefLabel "Fortescue Scholarship Exam Tampering" ;
    ex:description "In 1895, the student Gilchrist entered Hilton Soames's sitting-room at the College of St. Luke's using a key accidentally left in the door by the servant Bannister. Gilchrist, returning from athletic practice with his spiked jumping shoes, had seen the examination proofs on Soames's central table through the window (being tall enough to see in). He copied portions of the Greek translation paper from Thucydides but was interrupted when Soames returned unexpectedly via the side gate. Gilchrist fled to the bedroom, leaving his gloves on the chair and clay from his shoes on the desk. Bannister recognized the gloves and sat on them to conceal the evidence." ;
    ex:narrativeYear "1895" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasParticipant :gilchrist ;
    ex:hasParticipant :bannisterServant ;
    ex:hasVictim :hiltonSoames ;
    ex:occurredAt :soamesSittingRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:framingOfGraceDunbar a ex:Crime ;
    ex:prefLabel "Framing of Grace Dunbar" ;
    ex:description "Mrs. Gibson framed Grace Dunbar for her own murder as part of her suicide plan. She extracted a note from Dunbar making an appointment at Thor Bridge, planted a discharged revolver in Dunbar's wardrobe, and held Dunbar's note clutched in her hand when she died. This created false evidence making it appear Dunbar had murdered her. The framing was exposed by Holmes's investigation." ;
    ex:hasParticipant :mariaGibson ;
    ex:hasParticipant :graceDunbar ;
    ex:occurredAt :thorPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:gibsonConsultation a ex:Meeting ;
    ex:prefLabel "Gibson's Consultation at Baker Street" ;
    ex:description "Neil Gibson visits 221B Baker Street to consult Holmes about clearing Grace Dunbar. He is initially dismissed by Holmes for lying about his relations with Dunbar. Gibson leaves angrily but returns chastened and honestly confesses his feelings for Dunbar and tells the story of his marriage to Maria Pinto in Brazil. Holmes agrees to take the case for Miss Dunbar's sake." ;
    ex:hasParticipant :neilGibson ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:gilchristsConfession a ex:Confession ;
    ex:prefLabel "Gilchrist's Confession" ;
    ex:description "After Holmes deduces his guilt and Bannister inadvertently confirms it, Gilchrist breaks down and confesses to copying the Fortescue Scholarship exam proofs. He produces a letter written the previous night declaring his intention not to sit the examination, and reveals he has accepted a commission in the Rhodesian Police and plans to leave for South Africa immediately." ;
    ex:narrativeYear "1895" ;
    ex:hasParticipant :gilchrist ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :hiltonSoames ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :bannisterServant ;
    ex:occurredAt :soamesSittingRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:godfreyWindowSighting a ex:Event ;
    ex:prefLabel "Godfrey's Window Sighting" ;
    ex:description "The event at Tuxbury Old Park when James Dodd saw Godfrey Emsworth's face pressed against the window of his ground-floor bedroom at night. Godfrey was deadly pale with a face as white as cheese. When he saw Dodd looking at him, he sprang back and vanished into the darkness. Dodd pursued but only heard a closing door." ;
    ex:hasParticipant :jamesDodd ;
    ex:hasParticipant :godfreyEmsworth ;
    ex:occurredAt :tuxburyOldPark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:goldenPinceNezInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Golden Pince-Nez Case" ;
    skos:altLabel "the Yoxley case" ;
    ex:description "Sherlock Holmes's investigation into the murder of Willoughby Smith at Yoxley Old Place. Initially brought to Holmes by Stanley Hopkins. Holmes deduced the killer's physical characteristics from the golden pince-nez, realized the killer had not escaped but was hidden in the house after noticing identical cocoanut-matted corridors, and confirmed this by dropping cigarette ash to detect footprints. The case was solved when Anna emerged from behind a secret bookcase in Professor Coram's bedroom." ;
    ex:narrativeYear "1894" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasInvestigator :stanleyHopkins ;
    ex:hasClient :stanleyHopkins ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :stanleyHopkins ;
    ex:hasParticipant :professorCoram ;
    ex:hasParticipant :annaCoram ;
    ex:occurredAt :yoxleyOldPlace ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:gorgianoAssaultOnEmilia a ex:Assault ;
    ex:prefLabel "Gorgiano's Assault on Emilia" ;
    ex:description "Giuseppe Gorgiano pushed his way into the Lucca home when Gennaro was absent, seized Emilia in his arms, and declared his love for her. When Gennaro returned and attacked him, Gorgiano struck Gennaro senseless and fled. This created a deadly enmity between Gorgiano and the Luccas." ;
    ex:hasParticipant :giuseppeGorgiano ;
    ex:hasParticipant :emiliaLucca ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasVictim :emiliaLucca ;
    ex:hasPerpetrator :giuseppeGorgiano ;
    ex:occurredAt :brooklyn ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:greenAttackWatson a ex:Assault ;
    ex:prefLabel "Philip Green's Attack on Watson" ;
    ex:description "In Montpellier, when Watson confronted Philip Green in the street and accused him of harming Lady Frances, Green attacked Watson in a fury, seizing his throat. Holmes, disguised as a French workingman, emerged from a nearby cabaret and struck Green's forearm with a cudgel, forcing him to release Watson." ;
    ex:hasParticipant :philipGreen, :johnWatson, :sherlockHolmes ;
    ex:occurredAt :montpellier ;
    ex:perpetratedBy :philipGreen ;
    ex:hasVictim :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:greenFollowsMrsPeters a ex:Pursuit ;
    ex:prefLabel "Green Follows Mrs. Peters to Poultney Square" ;
    ex:description "After witnessing Annie Fraser pawn the second pendant at Bovington's, Philip Green followed her on foot up Kennington Road to Stimson and Co. undertaker's, then by cab to 36 Poultney Square, Brixton. There he witnessed a covered van deliver a coffin to the house." ;
    ex:hasParticipant :philipGreen, :annieFraser ;
    ex:occurredAt :kenningtonRoad, :poultneySq ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:gunRoomConfession a ex:Confession ;
    ex:prefLabel "Gun-Room Confession" ;
    ex:description "Sir Robert Norberton takes Holmes and Watson to the gun-room at Shoscombe Old Place and introduces Mr. and Mrs. Norlett. He explains the full truth: Lady Beatrice died of dropsy a week ago, and he concealed her death to prevent creditors from seizing the estate before the Derby. Norlett impersonated Lady Beatrice while Carrie Evans assisted. The body was moved from the well-house to the crypt." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :robertNorberton, :carrieEvans, :norlett ;
    ex:occurredAt :shoscombeGunRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:harpoonExperiment a ex:Event ;
    ex:prefLabel "Holmes's harpoon experiment" ;
    ex:description "During the first week of July 1895, Holmes drove to Allardyce's butcher shop where a dead pig was swung from a hook in the ceiling. Holmes spent a morning furiously stabbing the pig with a barbed-headed spear to test whether a single blow could transfix it. He concluded that no exertion of his strength could drive the spear through with a single blow, establishing that the murderer of Peter Carey must have been a man of amazing strength with skill in harpoon use." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :allardycesShop ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:hildaRetrievalLetter a ex:Event ;
    ex:prefLabel "Lady Hilda's Retrieval of the Letter" ;
    ex:description "Lady Hilda returned to 16 Godolphin Street disguised as a respectable young woman claiming to be answering a typewriting advertisement. She tricked Constable MacPherson into letting her see the crime scene. When she saw the bloodstain she feigned fainting. MacPherson went to the back for water and then to the Ivy Plant pub for brandy. While alone, Lady Hilda turned the drugget carpet, opened the floorboard hiding-place, and retrieved the diplomatic letter. She had recovered and left by the time MacPherson returned." ;
    ex:hasParticipant :ladyHildaTrelawneyHope ;
    ex:hasParticipant :constableMacPherson ;
    ex:occurredAt :16GodolphinStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:holmesAgathaEngagement a ex:FictionalEvent, ex:Event ;
    ex:prefLabel "Holmes's Engagement to Agatha" ;
    ex:description "Holmes disguises himself as Escott, a plumber with a rising business, and becomes engaged to Milverton's housemaid Agatha to gather intelligence about Appledore Towers. He walks out with her each evening over several days, learning the house layout, Milverton's habits (heavy sleeper, retires at 10:30), the location of the safe, and the secretary's daytime presence in the study. Agatha locks up the guard dog for Holmes. He mentions a 'hated rival' who will replace him." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :agatha ;
    ex:occurredAt :hampstead ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:holmesBicyclePursuit a ex:Pursuit ;
    ex:prefLabel "Holmes's Bicycle Pursuit of Armstrong" ;
    ex:description "Holmes hired a bicycle from the shop next to the inn and followed Dr. Armstrong's brougham out of Cambridge. Armstrong detected Holmes, stopped his carriage, and sardonically confronted him about the narrow road. Holmes was forced to ride past and lost the carriage on the country side roads." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :leslieArmstrong ;
    ex:occurredAt :cambridgeshire ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:holmesBurglaryHaven a ex:Event ;
    ex:prefLabel "Holmes's Burglary of The Haven" ;
    ex:description "While Amberley and Watson were away at Little Purlington, Holmes burgled The Haven in the early dawn. He discovered the gas pipe mechanism concealed in the strong-room ceiling. While slipping through the pantry window he was caught by Mr. Barker, who had also been investigating. They then continued the case together." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :barkerDetective ;
    ex:occurredAt :theHavenLewisham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:holmesCounterEspionageMission a ex:Event, ex:Investigation ;
    ex:prefLabel "Holmes's Counter-Espionage Mission" ;
    ex:description "A two-year undercover mission by Sherlock Holmes at the request of the Foreign Minister and the Premier. Holmes adopted the identity of Altamont, an Irish-American, starting in Chicago, joining an Irish secret society in Buffalo, causing trouble for the constabulary at Skibbareen, and infiltrating Von Bork's spy network. He got five of Von Bork's best agents imprisoned while feeding Von Bork deliberately untrustworthy intelligence." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :vonBork ;
    ex:hasParticipant :marthaHisLastBow ;
    ex:investigator :sherlockHolmes ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:occurredAt :chicago ;
    ex:occurredAt :buffalo ;
    ex:occurredAt :skibbareen ;
    ex:occurredAt :vonBorkCountryHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:holmesFeignedIllness a ex:Event ;
    ex:prefLabel "Holmes's Feigned Illness" ;
    ex:description "Sherlock Holmes feigns a deadly tropical illness over three days to lure Culverton Smith into confessing to the murder of Victor Savage. He fasts for three days and uses vaseline on his forehead, belladonna in his eyes, rouge on his cheekbones, and crusts of beeswax round his lips to simulate the appearance of a dying man. He deliberately impresses Mrs Hudson with the reality of his condition so she will convey it convincingly to Watson, who in turn conveys it to Smith. Holmes also performs delirium by talking about half-crowns, oysters, and other extraneous subjects." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :mrsHudson ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:holmesFireRuse a ex:Event ;
    ex:prefLabel "Holmes's Fire Ruse" ;
    ex:description "Holmes's stratagem to flush Jonas Oldacre from hiding. Holmes sets fire to straw on the upper landing of Deep Dene House with the help of three constables, creating alarm that forces Oldacre to emerge from his secret room behind the lath-and-plaster partition." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :jonasOldacre ;
    ex:occurredAt :deepDeneHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:holmesFirstVisitGruner a ex:Meeting ;
    ex:prefLabel "Holmes's First Visit to Gruner" ;
    ex:description """Holmes visits Baron Gruner at Vernon Lodge after receiving Damery's case. The Baron is affable but threatening, likened to a purring cat. He warns Holmes that Violet is pre-armed against any accusations and references the fate of Le Brun as a veiled threat.""" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :adelbertGruner ;
    ex:occurredAt :vernonLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:holmesGreatHiatus a ex:Event ;
    ex:prefLabel "Holmes's Great Hiatus" ;
    skos:altLabel "Holmes's three-year absence" ;
    ex:description "1891-1894. After surviving the Reichenbach Falls confrontation, Holmes traveled incognito for three years. Used the alias 'Sigerson', a Norwegian explorer. Visited Tibet and Lhassa (spent days with the head Llama), passed through Persia, visited Mecca, paid a visit to the Khalifa at Khartoum (results communicated to the Foreign Office), then conducted research into coal-tar derivatives at a laboratory in Montpelier, France. Only Mycroft Holmes knew he was alive and provided financial support. Holmes remained hidden because the trial of the Moriarty gang left two of its most dangerous members at liberty." ;
    ex:occurredAt :florence ;
    ex:occurredAt :tibet ;
    ex:occurredAt :lhassa ;
    ex:occurredAt :mecca ;
    ex:occurredAt :khartoum ;
    ex:occurredAt :montpelier ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesJosephConfrontation a ex:Confrontation ;
    ex:prefLabel "Holmes's Confrontation with Joseph Harrison" ;
    ex:description "The physical confrontation between Holmes and Joseph Harrison outside the window at Briarbrae. After Joseph retrieved the treaty from under the floorboard, he walked straight into Holmes's arms as Holmes waited outside. Joseph flew at Holmes with his knife, and Holmes had to grasp him twice, receiving a cut over the knuckles. Joseph 'looked murder out of the only eye he could see with' when they finished, but listened to reason and gave up the papers." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :josephHarrison ;
    ex:occurredAt :briarbrae ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holmesPresburyConfrontation a ex:FictionalEvent, ex:Confrontation ;
    ex:prefLabel "Holmes and Presbury Confrontation" ;
    ex:description "Holmes and Watson visited Professor Presbury at his Camford home, claiming to have been summoned. Presbury became suspicious and called Bennett to confirm no correspondence. Presbury then became furious, his face convulsed, blocking the door and shaking his fists at Holmes and Watson. Bennett intervened to prevent violence, appealing to the professor's position and the potential university scandal. Holmes and Watson were allowed to leave." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :professorPresbury ;
    ex:hasParticipant :trevorBennett ;
    ex:occurredAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:holmesRefusesKnighthood a ex:Event ;
    ex:prefLabel "Holmes Refuses Knighthood" ;
    ex:description "In the same month as the Three Garridebs case (June 1902), Holmes refused a knighthood for unspecified services. Watson mentions this in passing as it helps fix the date of the narrative." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:narrativeYear "1902" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:holmesReturnToLondon a ex:Event ;
    ex:prefLabel "Holmes's return to London" ;
    ex:description "Spring 1894. Sherlock Holmes returned to London after a three-year absence following Reichenbach Falls, prompted by the Park Lane Mystery. Revealed himself to Watson at Watson's Kensington home disguised as an elderly deformed book collector. Returned to 221B Baker Street, where Mrs. Hudson and Mycroft had preserved his rooms." ;
    ex:occurredAt :kensington ;
    ex:occurredAt :221bBakerStreet ;
    ex:eventYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :mrsHudson ;
    ex:hasParticipant :mycroftHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:holmesRevelation a ex:FictionalEvent ;
    ex:prefLabel "Holmes's Revelation" ;
    ex:description "Holmes reveals the truth about the Sussex Vampire case to Robert Ferguson in Mrs. Ferguson's room. He explains that the apparent vampirism was actually Mrs. Ferguson sucking curare poison from the baby's wound to save its life. The poison was administered by Jack Ferguson using arrows from the South American weapons collection. Holmes identified the empty quiver beside the bird-bow as evidence, noticed Jack's jealous expression reflected in the window glass, and connected the dog Carlo's paralysis to a test poisoning. Holmes prescribes a year at sea for Jack and Mrs. Ferguson confirms the truth." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :robertFerguson ;
    ex:hasParticipant :mrsFerguson ;
    ex:hasParticipant :dolores ;
    ex:occurredAt :mrsFergusonsRoom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:holmesStakeoutBriarbrae a ex:Stakeout ;
    ex:prefLabel "Holmes's Stakeout at Briarbrae" ;
    ex:description "Holmes's overnight stakeout at Briarbrae to catch the intruder. After walking to Ripley for tea, he returned to Briarbrae after sunset, climbed the fence where three fir-trees screened him, crouched among bushes, and crawled to the rhododendron clump opposite Phelps's window. He watched Miss Harrison read until 10:15pm, heard her lock the door, and waited through the night until Joseph Harrison emerged at 2am." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :briarbrae ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holmesVisitForbes a ex:Meeting ;
    ex:prefLabel "Holmes's Visit to Forbes" ;
    ex:description "Holmes and Watson visited Forbes at Scotland Yard after a hasty luncheon at the Waterloo Station buffet. Forbes was initially hostile, accusing Holmes of taking credit for police work. Holmes countered that his name appeared in only 4 of his last 53 cases. Forbes shared his investigation details: Tangey and Gorot had been shadowed without result, Mrs. Tangey was being watched by a female agent. No evidence of any kind had been found." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :forbes ;
    ex:occurredAt :scotlandYard ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holmesWindsorVisit a ex:Event ;
    ex:prefLabel "Holmes's Visit to Windsor" ;
    ex:description "Some weeks after the case, Holmes spent a day at Windsor and returned with a remarkably fine emerald tie-pin. He said it was a present from 'a certain gracious lady' in whose interests he had carried out a small commission. Watson guessed the lady's identity as Queen Victoria." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :queenVictoria ;
    ex:occurredAt :windsor ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:holmesWoodleyFight a ex:Assault ;
    ex:prefLabel "Holmes-Woodley boxing match" ;
    ex:description "Woodley attacked Holmes at the country pub near Charlington after overhearing Holmes's inquiries about Williamson. Woodley landed a backhander that Holmes failed to entirely avoid. Holmes defeated him with boxing skill. Woodley went home in a cart; Holmes returned to Baker Street with a cut lip and discoloured lump on his forehead." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :jackWoodley ;
    ex:occurredAt :charlingtonPublicHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:howeStreetSignaling a ex:SignalEvent ;
    ex:prefLabel "Howe Street Candle Signaling" ;
    ex:description "Coded candle signals sent from the third floor window of the Howe Street flats using a pre-agreed code (one flash = A, two = B, etc.). Gennaro Lucca signaled warnings to Emilia: 'ATTENTA' (Italian for 'Beware') three times, then 'PERICOLO' (Italian for 'Danger') which was cut short, apparently when Gorgiano discovered him. Holmes and Watson observed the signals from Mrs. Warren's house. Holmes later used the same method to flash 'VIENI' ('Come') to summon Emilia." ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasParticipant :emiliaLucca ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :howeStreetFlats ;
    ex:occurredAt :mrsWarrensHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:identificationOfAvenger a ex:FictionalEvent, ex:Event ;
    ex:prefLabel "Identification of Milverton's Avenger" ;
    ex:description "The day after the murder, Holmes suddenly springs to his feet during lunch exclaiming 'I've got it!' He rushes down Baker Street and along Oxford Street to near Regent Circus, where a photograph shop displays pictures of celebrities. Holmes identifies one photograph — of a regal and stately lady in Court dress with a diamond tiara — as the woman who killed Milverton. Watson reads the title beneath identifying her as the wife of a great nobleman and statesman. Holmes puts his finger to his lips as they turn away." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :photographShop ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:illustriousClientInvestigation a ex:Investigation ;
    ex:prefLabel "The Illustrious Client Investigation" ;
    ex:description """Holmes's investigation into Baron Adelbert Gruner, commissioned through Sir James Damery on behalf of an unnamed illustrious client, to prevent Gruner's marriage to Violet de Merville. The investigation begins on September 3, 1902 and involves: Damery's visit presenting the case; Holmes's first visit to Gruner at Vernon Lodge; Shinwell Johnson's underworld inquiries; the introduction of Kitty Winter; the failed visit to Violet de Merville; Holmes's beating in Regent Street; Watson's crash course in Chinese pottery; Watson's visit to Gruner as Dr. Hill Barton; Holmes's burglary of the inner study; Kitty Winter's vitriol attack; and the eventual cancellation of the marriage.""" ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :illustriousClient ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :jamesDamery ;
    ex:hasParticipant :shinwellJohnson ;
    ex:hasParticipant :kittyWinter ;
    ex:hasParticipant :adelbertGruner ;
    ex:hasParticipant :violetDeMerville ;
    ex:hasParticipant :generalDeMerville ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :vernonLodge ;
    ex:occurredAt :104BerkeleySquare ;
    ex:narrativeYear "1902" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:imprisonmentOfAliceRucastle a ex:Imprisonment ;
    ex:prefLabel "Imprisonment of Alice Rucastle" ;
    ex:description """Jephro Rucastle imprisoned his daughter Alice in a locked wing of the Copper Beeches to prevent her marriage to Mr. Fowler and to maintain control over her inheritance. Alice had rights by will but refused to sign a paper giving her father control of her money. After worrying her until she got brain-fever, during which she nearly died and her hair was cut off, Rucastle locked her in a room barricaded with a broad iron bar padlocked to the wall. The room contained only a pallet bed, a small table, and a basketful of linen, with a skylight above. He told others she had gone to Philadelphia.""" ;
    ex:hasPerpetrator :jephroRucastle ;
    ex:hasVictim :aliceRucastle ;
    ex:hasParticipant :jephroRucastle, :aliceRucastle ;
    ex:locatedIn :copperBeeches ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:inquestEduardoLucas a ex:Inquest ;
    ex:prefLabel "Inquest on Eduardo Lucas" ;
    ex:description "The coroner's inquest into the death of Eduardo Lucas. The jury returned a verdict of 'Wilful Murder' but the perpetrator remained unknown at the time. The dead man's papers were carefully examined, revealing him to be a keen student of international politics." ;
    ex:hasParticipant :eduardoLucas ;
    ex:hasVerdict "Wilful Murder" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:investigationMissingThreeQuarter a ex:Investigation ;
    ex:prefLabel "Investigation of the Missing Three-Quarter" ;
    ex:description "Holmes's investigation into the disappearance of Godfrey Staunton, crack Cambridge rugby three-quarter, on the eve of the Varsity match against Oxford. The case was referred by Inspector Stanley Hopkins. Holmes traced Staunton's telegram to Dr. Armstrong, traveled to Cambridge, and ultimately used a draghound to track Armstrong's carriage to a cottage near Trumpington where Staunton was found mourning his dead wife. Not a criminal matter—Holmes agreed to keep the secret." ;
    ex:client :cyrilOverton ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :cyrilOverton ;
    ex:hasParticipant :godfreyStaunton ;
    ex:hasParticipant :leslieArmstrong ;
    ex:hasParticipant :lordMountJames ;
    ex:investigator :sherlockHolmes ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:occurredAt :london ;
    ex:occurredAt :cambridge ;
    ex:occurredAt :stauntonCottage ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:investigationOfMoriartyOrg a ex:FictionalEvent, ex:Investigation ;
    ex:prefLabel "Holmes's Investigation of Moriarty's Organization" ;
    ex:description "A years-long investigation by Sherlock Holmes into Professor Moriarty's criminal organization, culminating in three months of intensive final work. Holmes deduced the existence of a deep organizing power behind London's criminal world and followed the thread to Moriarty. He accumulated evidence sufficient to convict the entire gang. The investigation was described by Holmes as 'the most brilliant bit of thrust-and-parry work in the history of detection.' Three days before the planned arrests (Monday), Moriarty confronted Holmes at 221B." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :professorMoriarty ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:narrativeDate "years, culminating January-April 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:investigationParkLaneMystery a ex:Investigation ;
    ex:prefLabel "Investigation of the Park Lane Mystery" ;
    ex:description "Holmes's investigation of the murder of Ronald Adair at 427 Park Lane. Led to the identification and capture of Colonel Sebastian Moran as the murderer. Holmes used the wax bust stratagem to lure Moran into revealing himself. Year: 1894." ;
    ex:occurredAt :427ParkLane ;
    ex:occurredAt :camdenHouse ;
    ex:occurredAt :221bBakerStreet ;
    ex:eventYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :lestrade ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:investigationRetiredColourman a ex:Investigation ;
    ex:prefLabel "Investigation of the Retired Colourman Case" ;
    skos:altLabel "The Haven Horror investigation" ;
    ex:description "Holmes's investigation of the supposed elopement of Mrs. Amberley and Dr. Ray Ernest. Initially sent to Holmes by Scotland Yard as a routine case. Holmes discovers it is actually a double murder committed by Josiah Amberley using gas in a sealed strong-room. Key deductions include the significance of the paint smell, the unoccupied theatre seats disproving Amberley's alibi, and the gas pipe concealed in the ceiling. Holmes works alongside private detective Barker and allows Inspector MacKinnon to take public credit." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :barkerDetective ;
    ex:hasParticipant :inspectorMacKinnon ;
    ex:hasParticipant :josiahAmberley ;
    ex:occurredAt :theHavenLewisham ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:investigatedBy :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:investigationSecondStain a ex:Investigation ;
    ex:prefLabel "Investigation of the Second Stain" ;
    ex:description "Holmes's investigation into the theft of a diplomatic letter from Trelawney Hope's despatch-box. The most important international case Holmes has ever handled and the crowning glory of his career. Clients were Lord Bellinger (Prime Minister) and Trelawney Hope (Secretary for European Affairs). The letter from a foreign potentate could cause European war if published. Holmes identified Eduardo Lucas as the likely recipient, but Lucas was murdered. Holmes eventually deduced that Lady Hilda had stolen the letter under blackmail from Lucas, and that she had retrieved it from Lucas's hiding-place after his murder. Holmes confronted Lady Hilda and returned the letter to the despatch-box without revealing her involvement to her husband or the Prime Minister." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :lordBellinger ;
    ex:hasClient :trelawneyHope ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :lestrade ;
    ex:hasParticipant :ladyHildaTrelawneyHope ;
    ex:hasParticipant :eduardoLucas ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :16GodolphinStreet ;
    ex:occurredAt :whitehallTerrace ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:investigationSixNapoleons a ex:Investigation ;
    ex:prefLabel "Investigation of the Six Napoleons" ;
    skos:altLabel "the singular adventure of the Napoleonic busts" ;
    ex:description "Holmes's investigation into the systematic destruction of six plaster Napoleon busts in London and Reading. Initially reported by Lestrade as possible monomania, Holmes deduced the busts were being searched for something hidden inside. He traced the busts from Gelder & Co. through the retailers to the buyers, identified Beppo as the culprit, caught him at Chiswick, and recovered the black pearl of the Borgias from the final bust." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :lestrade ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:investigationThreeGables a ex:FictionalEvent , ex:Investigation ;
    ex:prefLabel "Investigation of the Three Gables Case" ;
    ex:description "Sherlock Holmes's investigation into the strange incidents at The Three Gables, Harrow Weald. Client: Mrs. Mary Maberley. The case involved the attempted purchase of the house and all contents, a burglary to steal a manuscript, and the unmasking of Isadora Klein as the mastermind. Holmes resolved the case by securing five thousand pounds compensation for Mrs. Maberley." ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasClient :maryMaberley ;
    ex:hasParticipant :sherlockHolmes , :johnWatson , :maryMaberley ;
    ex:occurredAt :theThreeGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:investigationVictorSavageDeath a ex:Investigation ;
    ex:prefLabel "Investigation into Victor Savage's Death" ;
    ex:description "Holmes's investigation into the death of Victor Savage, the nephew of Culverton Smith. Holmes had suspicions of foul play and allowed Smith to see it. This investigation led Smith to attempt to murder Holmes using the same method he used on Savage. Holmes's investigation culminated in his elaborate ruse of feigning illness to trap Smith into confessing." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :culvertonSmith ;
    ex:hasParticipant :inspectorMorton ;
    ex:occurredAt :221bBakerStreet ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:jacksChildhoodAccident a ex:FictionalEvent, ex:Accident ;
    ex:prefLabel "Jack's Childhood Accident" ;
    ex:description "A fall in childhood that caused Jack Ferguson's twisted spine and physical disability, leaving him with a weak back and shambling gait. The accident is described by Ferguson as occurring some years before the events of the story." ;
    ex:hasParticipant :jackFerguson ;
    ex:hasVictim :jackFerguson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:journeyLittlePurlington a ex:Journey ;
    ex:prefLabel "Journey to Little Purlington" ;
    ex:description "Watson and Amberley travel by train from Liverpool Street to Little Purlington in Essex, in response to a forged telegram purportedly from the vicar J.C. Elman. The vicar denies all knowledge. The journey was orchestrated by Holmes to get Amberley away from The Haven so Holmes could search the house. Watson and Amberley stayed overnight at the Railway Arms." ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :josiahAmberley ;
    ex:occurredAt :littlePurlington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:journeyToLamberley a ex:FictionalEvent, ex:Journey ;
    ex:prefLabel "Journey to Lamberley" ;
    ex:description "Holmes and Watson travel by train from Victoria station at two o'clock to Lamberley, Sussex, arriving on the evening of a dull, foggy November day. They leave their bags at the Chequers inn and drive through the Sussex clay of a long winding lane to reach Cheeseman's." ;
    ex:arrivesAt :lamberley ;
    ex:departsFrom :victoriaStation ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:kidnappingLadyFrances a ex:Kidnapping ;
    ex:prefLabel "Kidnapping of Lady Frances Carfax" ;
    ex:description "Holy Peters and Annie Fraser lured Lady Frances Carfax from Baden to London under the guise of being the missionary Dr. Shlessinger and his wife. Once in London, they made her a prisoner in a furnished house at 36 Poultney Square, Brixton, and became possessed of her valuable Spanish jewellery." ;
    ex:hasParticipant :henryPeters, :annieFraser, :ladyFrancesCarfax ;
    ex:occurredAt :36PoultneySq ;
    ex:perpetratedBy :henryPeters, :annieFraser ;
    ex:hasVictim :ladyFrancesCarfax ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:killingOfPerkins a ex:FictionalEvent , ex:Crime , ex:Murder ;
    ex:prefLabel "Killing of Young Perkins" ;
    ex:description "The killing of a young man named Perkins outside the Holborn Bar. Steve Dixie is implicated. Holmes uses knowledge of this crime as leverage to control Dixie. Not the central case of this story." ;
    ex:hasParticipant :youngPerkins , :steveDixie ;
    ex:occurredAt :holbornBar ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:ladyFrancesDepartureLausanne a ex:Journey ;
    ex:prefLabel "Lady Frances's Departure from Lausanne" ;
    ex:description "Lady Frances Carfax departed the Hotel National in Lausanne at a single day's notice, forfeiting a week's rent. Her departure was connected to Philip Green's visit to the hotel. She traveled to Baden by a circuitous route to avoid being tracked." ;
    ex:destination :badenBaden ;
    ex:hasParticipant :ladyFrancesCarfax ;
    ex:occurredAt :hotelNationalLausanne ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:leonardoDrowning a ex:Event ;
    ex:prefLabel "Leonardo's Drowning" ;
    ex:description "Leonardo drowned while bathing near Margate approximately a month before Holmes and Watson's visit to Mrs. Ronder in late 1896. Mrs. Ronder learned of his death from a newspaper report. His death removed her reason for concealing the truth about the Abbas Parva tragedy." ;
    ex:hasParticipant :leonardo ;
    ex:occurredAt :margate ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:madnessOfHollis a ex:Event ;
    ex:prefLabel "Madness of Hollis" ;
    ex:description "Hollis, one of Von Bork's agents, went mad ('a bit woozy') towards the end from the constant strain of maintaining his cover identity with many people ready to expose him." ;
    ex:hasParticipant :hollisAgent ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :hisLastBowDoc .

:marieLeavesService a ex:Event ;
    ex:prefLabel "Marie Devine Leaves Lady Frances's Service" ;
    ex:description "Marie Devine left Lady Frances Carfax's service at Baden, departing in floods of tears after informing the other maids she was leaving service forever. Lady Frances gave her fifty pounds as a wedding present. Marie left because her approaching marriage made separation inevitable and because Lady Frances had shown irritability toward her." ;
    ex:hasParticipant :marieDevine, :ladyFrancesCarfax ;
    ex:occurredAt :badenBaden ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:marriageOfBrackenstalls a ex:Marriage ;
    ex:prefLabel "Marriage of Sir Eustace and Mary Fraser" ;
    ex:description """The marriage of Sir Eustace Brackenstall and Mary Fraser in January of the year before the story (approximately January 1896). They met in July 1895, shortly after Mary arrived in London in June 1895.""" ;
    ex:hasParticipant :eustaceBrackenstall ;
    ex:hasParticipant :maryFraser ;
    ex:narrativeYear "1896" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:marriageOfFowlerAndAlice a ex:Marriage ;
    ex:prefLabel "Marriage of Fowler and Alice Rucastle" ;
    ex:description """Mr. Fowler and Alice Rucastle were married by special license in Southampton the day after their flight from the Copper Beeches. Fowler subsequently obtained a government appointment in the island of Mauritius.""" ;
    ex:hasParticipant :mrFowler, :aliceRucastle ;
    ex:locatedIn :southampton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:marriageOfLuccas a ex:Marriage ;
    ex:prefLabel "Marriage of Gennaro and Emilia Lucca" ;
    ex:description "Gennaro and Emilia Lucca (née Barelli) eloped from Posilippo and were married at Bari, Italy. They sold Emilia's jewels to gain money for passage to America." ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasParticipant :emiliaLucca ;
    ex:occurredAt :bari ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:maulingOfJephroRucastle a ex:Assault ;
    ex:prefLabel "Mauling of Jephro Rucastle" ;
    ex:description """The starved mastiff Carlo attacked Jephro Rucastle at the Copper Beeches. Someone had loosed the dog, which had not been fed for two days. The huge famished brute buried its black muzzle in Rucastle's throat while he writhed and screamed on the ground. Watson shot the dog dead, but Rucastle was horribly mangled. He survived but was always a broken man afterwards, kept alive solely through the care of his devoted wife.""" ;
    ex:hasPerpetrator :carloMastiff ;
    ex:hasVictim :jephroRucastle ;
    ex:hasParticipant :jephroRucastle, :carloMastiff, :johnWatson ;
    ex:locatedIn :copperBeeches ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:mazarinStoneInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Mazarin Stone Theft" ;
    ex:description "Sherlock Holmes's investigation into the theft of the Crown diamond (Mazarin Stone) from Whitehall. He is commissioned by the Prime Minister and Home Secretary. Holmes follows Count Sylvius in disguise, uses a wax dummy and gramophone as a ruse, tricks Sylvius and Merton into revealing the stone, snatches it, and has them arrested. The case is successful." ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:investigatedBy :sherlockHolmes ;
    ex:hasClient :mazarinPrimeMinister ;
    ex:hasClient :mazarinHomeSecretary ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :billy ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:hasParticipant :samMerton ;
    ex:hasParticipant :lordCantlemere ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:mcFarlaneArrest a ex:Event ;
    ex:prefLabel "McFarlane's Arrest" ;
    ex:description "Inspector Lestrade arrests John Hector McFarlane at 221B Baker Street on suspicion of murdering Jonas Oldacre. McFarlane had come to Holmes for help." ;
    ex:hasParticipant :lestrade ;
    ex:hasParticipant :johnHectorMcFarlane ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:mcFarlaneVisitDeepDene a ex:Event ;
    ex:prefLabel "McFarlane's Visit to Deep Dene House" ;
    ex:description "McFarlane visits Jonas Oldacre at Deep Dene House in the evening to discuss documents in Oldacre's safe. Oldacre shows him building leases and documents. McFarlane leaves very late (around midnight), is followed from London Bridge Station, and stays overnight at the Anerley Arms." ;
    ex:hasParticipant :johnHectorMcFarlane ;
    ex:hasParticipant :jonasOldacre ;
    ex:occurredAt :deepDeneHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:mcPhersonDeathInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of McPherson's Death" ;
    ex:description "The investigation into the death of Fitzroy McPherson, conducted by Sherlock Holmes with the assistance of Constable Anderson and Inspector Bardle of the Sussex Constabulary. The case brought Holmes to the limit of his powers. Key investigative steps included examining the beach and cliff path for footprints, searching McPherson's pockets and desk, interviewing the Bellamy family, photographing and analyzing the wound patterns, researching the case in J. G. Wood's 'Out of Doors,' and ultimately identifying the Cyanea capillata jellyfish as the killer. The case was solved when Holmes recognized that the welts were not from a human weapon but from jellyfish tentacles." ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:narrativeYear "1907" ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :sherlockHolmes, :haroldStackhurst, :andersonFulworth, :inspectorBardle ;
    ex:occurredAt :fulworth, :holmesSussexVilla, :theGables, :theHaven, :fulworthBathingPool ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mcPhersonInquest a ex:Event ;
    ex:prefLabel "Inquest on McPherson's Death" ;
    ex:description "The inquest into Fitzroy McPherson's death, held at The Gables. It threw no light upon the matter and was adjourned for further evidence." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :fitzroyMcPherson ;
    ex:occurredAt :theGables ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:mediterraneanYachtingVoyage a ex:Journey ;
    ex:prefLabel "Mediterranean Yachting Voyage" ;
    ex:description """A yachting voyage on the Mediterranean where Baron Gruner met Violet de Merville. The company was select and paid their own passages. The promoters hardly realized the Baron's true character until it was too late. Gruner attached himself to Violet and won her heart completely.""" ;
    ex:hasParticipant :adelbertGruner ;
    ex:hasParticipant :violetDeMerville ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:milesDorkingBrokenEngagement a ex:FictionalEvent, ex:Event ;
    ex:prefLabel "Miles-Dorking Broken Engagement" ;
    ex:description "A past event mentioned by Milverton during his negotiation with Holmes. The engagement between the Honourable Miss Miles and Colonel Dorking was broken off only two days before the wedding, as reported in a paragraph in the Morning Post. Milverton implies he caused this through blackmail, noting that the 'absurd sum of twelve hundred pounds' would have settled the whole question." ;
    ex:hasParticipant :missMiles ;
    ex:hasParticipant :colonelDorking ;
    ex:hasParticipant :charlesAugustusMilverton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:milvertonMurderInvestigation a ex:FictionalEvent, ex:Investigation ;
    ex:prefLabel "Investigation of Milverton's Murder" ;
    ex:description "The official investigation into the murder of Charles Augustus Milverton at Appledore Towers. Lestrade of Scotland Yard leads the inquiry. He knows that blackmail papers were burned by the 'murderers', has footmarks and descriptions of two suspects. The suspects are described as probably men of good position whose sole object was preventing social exposure. Holmes refuses to assist, saying his sympathies are with the criminals." ;
    ex:hasParticipant :lestrade ;
    ex:investigator :lestrade ;
    ex:occurredAt :appledoreTowers ;
    ex:occurredAt :221bBakerStreet ;
    ex:isSolved "false"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:milvertonNegotiation a ex:FictionalEvent, ex:Meeting ;
    ex:prefLabel "Milverton-Holmes Negotiation" ;
    ex:description "A tense meeting at 221B Baker Street between Sherlock Holmes and Charles Augustus Milverton over Lady Eva Brackwell's compromising letters. Milverton demands seven thousand pounds; Holmes offers two thousand, arguing Lady Eva cannot afford more. Milverton refuses to negotiate, reveals he has eight to ten similar cases maturing, and shows he carries a revolver. Holmes attempts to seize Milverton's notebook but is deterred by the weapon. The negotiation fails completely." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :charlesAugustusMilverton ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:moleseyMystery a ex:Investigation ;
    ex:prefLabel "Molesey Mystery" ;
    ex:description "A case referenced by Holmes that Inspector Lestrade handled 'fairly well'. One of three undetected murders in one year that Holmes chided Lestrade about." ;
    ex:hasParticipant :lestrade ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:moriartyAtVictoria a ex:FictionalEvent, ex:Chase ;
    ex:prefLabel "Moriarty at Victoria Station" ;
    ex:description "Moriarty arrived at Victoria Station just as the Continental express began to move, pushing furiously through the crowd and waving his hand to stop the train. He was too late. Holmes explained that Moriarty had been watching Watson and followed him to Victoria." ;
    ex:hasParticipant :professorMoriarty ;
    ex:occurredAt :victoriaStation ;
    ex:narrativeDate "April 25, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:moriartyHolmesConfrontation221B a ex:FictionalEvent, ex:Confrontation ;
    ex:prefLabel "Moriarty-Holmes Confrontation at 221B" ;
    ex:description "Professor Moriarty visited Sherlock Holmes at 221B Baker Street on April 24, 1891. Moriarty threatened Holmes, demanding he withdraw his investigation. Holmes had his revolver ready throughout the conversation. Moriarty produced his memorandum book listing dates of Holmes's interference. The encounter ended with Moriarty warning that Holmes's destruction was inevitable if he persisted." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :professorMoriarty ;
    ex:occurredAt :221bBakerStreet ;
    ex:narrativeDate "April 24, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:mortimerTregennisMurder a ex:Crime, ex:Murder ;
    ex:prefLabel "Murder of Mortimer Tregennis" ;
    ex:description "Dr. Leon Sterndale murdered Mortimer Tregennis in revenge for the poisoning of the Tregennis siblings, especially Brenda whom Sterndale loved. In the early morning, Sterndale threw gravel at Tregennis's bedroom window at the vicarage, was admitted through the sitting-room window, confronted Tregennis, lit a lamp with devil's-foot powder while threatening him with a revolver, then stood outside the window watching. Tregennis died in approximately five minutes. Holmes deduced the crime but allowed Sterndale to go free." ;
    ex:occurredAt :tredannickWollasVicarage ;
    ex:hasParticipant :leonSterndale ;
    ex:hasParticipant :mortimerTregennis ;
    ex:hasVictim :mortimerTregennis ;
    ex:hasPerpetrator :leonSterndale ;
    ex:eventYear "1897"^^xsd:gYear ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:murderAmberleyErnest a ex:Murder ;
    ex:prefLabel "Murder of Mrs. Amberley and Dr. Ernest" ;
    skos:altLabel "The Haven Horror" ;
    ex:description "The murder of Mrs. Amberley and Dr. Ray Ernest by Josiah Amberley. Amberley lured them into his hermetically sealed strong-room and flooded it with gas via a concealed pipe. He then hid the bodies in a disused well concealed by a dog-kennel in the grounds. He covered the smell of gas by painting the house and staged the scene to look like his wife and Ernest had eloped with his deed-box and savings." ;
    ex:hasParticipant :josiahAmberley ;
    ex:hasParticipant :mrsAmberley ;
    ex:hasParticipant :rayErnest ;
    ex:occurredAt :theHavenLewisham ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :retiredColourmanDoc .

:murderBaronessGruner a ex:Murder ;
    ex:prefLabel "Murder of Baroness Gruner" ;
    ex:description """Baron Gruner killed his wife at the Splugen Pass in what was made to appear as an accident. He was tried at Prague but escaped conviction on a technical legal point and the suspicious death of a witness. Holmes is certain of Gruner's guilt.""" ;
    ex:hasParticipant :adelbertGruner ;
    ex:hasParticipant :grunerWifeDeceased ;
    ex:occurredAt :splugenPass ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:murderEduardoLucas a ex:Murder, ex:Stabbing ;
    ex:prefLabel "Murder of Eduardo Lucas" ;
    skos:altLabel "Murder in Westminster" ;
    ex:description "Eduardo Lucas was stabbed to the heart by his wife Mme. Henri Fournaye at 16 Godolphin Street, Westminster, on a Monday night. The murder weapon was a curved Indian dagger from a trophy of Oriental arms on the wall. The room was in wild disorder with furniture swept to one side and one chair lying on its back; Lucas was grasping one of its legs. The crime was discovered by Constable Barrett at a quarter to twelve when he found the door ajar. Robbery was not the motive. The coroner's jury returned a verdict of 'Wilful Murder'. Mme. Fournaye committed the crime in a jealous frenzy after finding Lucas with Lady Hilda. She screamed in French before attacking." ;
    ex:hasParticipant :eduardoLucas ;
    ex:hasParticipant :mmeHenriFournaye ;
    ex:hasParticipant :ladyHildaTrelawneyHope ;
    ex:occurredAt :16GodolphinStreet ;
    ex:hasVictim :eduardoLucas ;
    ex:hasPerpetrator :mmeHenriFournaye ;
    ex:hasWeapon :indianDaggerSecondStain ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:murderOfCadoganWest a ex:Murder ;
    ex:prefLabel "Murder of Arthur Cadogan West" ;
    ex:description "Monday night in November 1895. Arthur Cadogan West followed Colonel Walter to Hugo Oberstein's house at 13 Caulfield Gardens. When West confronted the thieves at the door, Oberstein struck him on the head with a short life-preserver as West forced his way into the house. The blow was fatal; West died within five minutes in the hall. His body was later placed on the roof of an Underground train from the back window." ;
    ex:hasParticipant :arthurCadoganWest ;
    ex:hasParticipant :hugoOberstein ;
    ex:hasParticipant :colonelValentineWalter ;
    ex:occurredAt :13CaulfieldGardens ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:murderOfEustaceBrackenstall a ex:Murder ;
    ex:prefLabel "Murder of Sir Eustace Brackenstall" ;
    ex:description """The killing of Sir Eustace Brackenstall by Captain Jack Croker at Abbey Grange during the winter of 1897. Sir Eustace discovered Croker visiting Lady Brackenstall, struck her with his blackthorn cudgel, and Croker responded by seizing the poker and striking Sir Eustace a fatal blow to the head. The crime was staged to look like a burglary by the Randall gang, with Lady Brackenstall and Theresa Wright providing a false account.""" ;
    ex:hasParticipant :jackCroker ;
    ex:hasParticipant :eustaceBrackenstall ;
    ex:hasParticipant :maryFraser ;
    ex:hasParticipant :theresaWright ;
    ex:occurredAt :abbeyGrangeDiningRoom ;
    ex:narrativeYear "1897" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:murderOfGarcia a ex:Event, ex:Murder ;
    ex:prefLabel "Murder of Aloysius Garcia" ;
    skos:altLabel "The Oxshott Murder" ;
    ex:description "Aloysius Garcia was murdered on Oxshott Common, nearly a mile from Wisteria Lodge, around one o'clock in the morning before the rain. His head was smashed to pulp by heavy blows of a sandbag or similar instrument. He was struck down first from behind, then beaten long after death. The murderer was Don Murillo, who waited among the gorse bushes. There was no attempt at robbery. No footsteps or clues to the criminals were found." ;
    ex:hasParticipant :aloysiusGarcia ;
    ex:hasParticipant :donMurillo ;
    ex:hasVictim :aloysiusGarcia ;
    ex:occurredAt :oxshottCommon ;
    ex:narrativeYear "1892" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:murderOfGorgiano a ex:Murder ;
    ex:prefLabel "Murder of Giuseppe Gorgiano" ;
    ex:description "Gennaro Lucca killed Giuseppe Gorgiano by stabbing him in the throat with a knife in the third floor left-hand flat of the Howe Street residential flats. Gorgiano was found dead on the floor with the knife's white haft projecting from his throat, a horn-handled dagger beside his right hand, and a black kid glove nearby. The murder was discovered by Holmes, Watson, Gregson, and Leverton." ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasParticipant :giuseppeGorgiano ;
    ex:hasVictim :giuseppeGorgiano ;
    ex:hasPerpetrator :gennaroLucca ;
    ex:occurredAt :howeStreetFlats ;
    ex:weaponUsed :gorgianoMurderKnife ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:murderOfMilverton a ex:FictionalEvent, ex:Murder ;
    ex:prefLabel "Murder of Charles Augustus Milverton" ;
    ex:description "The unnamed avenger, posing as a maid offering letters compromising the Countess d'Albert, gains entry to Milverton's study at night. She reveals herself as a woman whose husband died after Milverton sent compromising letters to him. She shoots Milverton with a small revolver, emptying barrel after barrel into his body, then grinds her heel into his upturned face. Holmes and Watson witness the killing from behind the window curtains." ;
    ex:hasParticipant :milvertonAvenger ;
    ex:hasParticipant :charlesAugustusMilverton ;
    ex:hasWitness :sherlockHolmes ;
    ex:hasWitness :johnWatson ;
    ex:occurredAt :milvertonStudy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :milvertonDoc .

:murderOfMurilloInMadrid a ex:Event, ex:Assassination ;
    ex:prefLabel "Murder of Murillo and Rulli in Madrid" ;
    ex:description "About six months after Murillo's escape from England, the Marquess of Montalva (Murillo) and Signor Rulli (Lopez) were both murdered in their rooms at the Hotel Escurial in Madrid. The crime was officially ascribed to Nihilism, and the murderers were never arrested. Inspector Baynes showed Holmes and Watson printed descriptions confirming the identities." ;
    ex:hasParticipant :donMurillo ;
    ex:hasParticipant :lopez ;
    ex:hasVictim :donMurillo ;
    ex:hasVictim :lopez ;
    ex:occurredAt :hotelEscurial ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:murderOfNeliganSenior a ex:Event, ex:Crime, ex:Murder ;
    ex:prefLabel "Murder of Neligan Senior" ;
    ex:description "In August 1883, Captain Peter Carey murdered an unnamed landsman (the banker Neligan Senior) aboard the Sea Unicorn. The man had been picked up from a yacht blown north. Carey threw him overboard in the middle watch of a dark night, two days before sighting the Shetland lights. Only the spare harpooner Patrick Cairns witnessed the act." ;
    ex:eventYear "1883" ;
    ex:hasParticipant :peterCarey, :neliganSenior, :patrickCairns ;
    ex:occurredAt :arcticSeas ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:murderOfPeterCarey a ex:Event, ex:Crime, ex:Murder ;
    ex:prefLabel "Murder of Peter Carey" ;
    skos:altLabel "Death of Black Peter" ;
    ex:description "On a Wednesday in early July 1895 at approximately 2am, Patrick Cairns killed Captain Peter Carey by driving a steel harpoon through his breast in the cabin at Woodman's Lee. Cairns claimed self-defense: Carey was drunk and attacked him with a clasp-knife. The harpoon, engraved 'S.S. Sea Unicorn, Dundee', was snatched from a rack on the wall and driven with such force it pinned Carey to the wall behind him." ;
    ex:eventYear "1895" ;
    ex:hasWeapon :blackPeterHarpoon ;
    ex:hasParticipant :patrickCairns, :peterCarey ;
    ex:occurredAt :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:murderOfPietroVenucci a ex:Murder ;
    ex:prefLabel "Murder of Pietro Venucci" ;
    ex:description "Pietro Venucci was found murdered on the doorstep of 131 Pitt Street, Kensington, with a great gash in his throat. He had been tracking Beppo and was killed in a scuffle when Beppo came to steal Harker's Napoleon bust. The bust was carried to Campden House Road and smashed under a street lamp." ;
    ex:hasParticipant :beppo ;
    ex:hasParticipant :pietroVenucci ;
    ex:occurredAt :131PittStreet ;
    ex:hasVictim :pietroVenucci ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:murderOfRonaldAdair a ex:Murder ;
    ex:prefLabel "Murder of Ronald Adair" ;
    skos:altLabel "Park Lane Mystery" ;
    ex:description "March 30, 1894. Ronald Adair was shot dead through the open window of his second-floor sitting-room at 427 Park Lane by Colonel Sebastian Moran using Von Herder's air-gun with an expanding soft-nosed bullet. The door was locked from the inside. Adair was working out card winnings and losses at the time. Motive: Adair had discovered Moran was cheating at cards and threatened to expose him unless he resigned from the club." ;
    ex:occurredAt :427ParkLane ;
    ex:eventYear "1894" ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:hasParticipant :ronaldAdair ;
    ex:hasVictim :ronaldAdair ;
    ex:hasPerpetrator :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc .

:murderOfVictorDurando a ex:Event, ex:Murder ;
    ex:prefLabel "Murder of Victor Durando" ;
    ex:description "Victor Durando, the San Pedro minister in London, was recalled to San Pedro by Murillo on a pretext and shot. His estates were confiscated. His wife (Miss Burnet) was left with a pittance. Backstory event motivating Miss Burnet's involvement." ;
    ex:hasParticipant :victorDurando ;
    ex:hasParticipant :donMurillo ;
    ex:hasVictim :victorDurando ;
    ex:occurredAt :sanPedro ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:murderOfVictorSavage a ex:Murder ;
    ex:prefLabel "Murder of Victor Savage" ;
    ex:description "The murder of Victor Savage by his uncle Culverton Smith. Smith used his knowledge of tropical diseases to kill his nephew, who died horribly on the fourth day. Victor stood between Smith and a reversion (inheritance), providing the motive. Holmes had suspicions of foul play and allowed Smith to see it, provoking Smith's subsequent attempt on Holmes's life." ;
    ex:hasVictim :victorSavage ;
    ex:hasPerpetrator :culvertonSmith ;
    ex:hasParticipant :victorSavage ;
    ex:hasParticipant :culvertonSmith ;
    ex:occurredAt :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:murderOfWilloughbySmith a ex:Murder ;
    ex:prefLabel "Murder of Willoughby Smith" ;
    ex:description "The stabbing death of Willoughby Smith in Professor Coram's study at Yoxley Old Place. Anna, attempting to steal papers from the bureau, was seized by Smith who had just entered the room. In her panic she grabbed a sealing-wax knife from the writing table and struck him in the neck, severing the carotid artery. Smith's dying words were 'The Professor—it was she.' He clutched Anna's golden pince-nez in his right hand. Occurred in the forenoon between eleven and twelve, on a morning in November 1894." ;
    ex:narrativeYear "1894" ;
    ex:hasVictim :willoughbySmith ;
    ex:hasPerpetrator :annaCoram ;
    ex:hasParticipant :willoughbySmith ;
    ex:hasParticipant :annaCoram ;
    ex:occurredAt :yoxleyStudy ;
    ex:usedWeapon :sealingWaxKnife ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:murilloCase a ex:Investigation ;
    ex:prefLabel "Case of Ex-President Murillo" ;
    ex:description "Case mentioned by Watson involving the papers of ex-President Murillo, described as one of the few interesting cases during the post-Moriarty period." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :exPresidentMurillo ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:nathanGarridebBreakdown a ex:Event ;
    ex:prefLabel "Nathan Garrideb's Breakdown" ;
    ex:description "Following the exposure of Killer Evans's scheme, Nathan Garrideb never recovered from the shock of losing his dreams of inheriting five million dollars. His castle in the air fell down and buried him beneath the ruins. He lost his reason and was last heard of at a nursing-home in Brixton." ;
    ex:hasParticipant :nathanGarrideb ;
    ex:occurredAt :brixtonNursingHome ;
    ex:narrativeYear "1902" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:neliganVoyage a ex:Event, ex:Journey ;
    ex:prefLabel "Neligan Senior's voyage to Norway" ;
    ex:description "In 1883, just before the arrest warrant was issued, the banker Neligan Senior set sail in his little yacht for Norway, carrying a tin box of securities. His crew abandoned the yacht in a dinghy for the Norwegian coast. The yacht was blown north by southerly gales and picked up by the Sea Unicorn returning from the Arctic." ;
    ex:eventYear "1883" ;
    ex:hasParticipant :neliganSenior ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:newBrightonMurders a ex:Murder ;
    ex:prefLabel "Murder of Mary Browner and Alec Fairbairn" ;
    ex:description "Double murder. Jim Browner followed Mary and Fairbairn from Liverpool to New Brighton. They hired a boat; he hired another. In the haze about a mile from shore, he killed Fairbairn with oak stick (crushed head), then killed Mary. Cut off ears, sank bodies by staving boat's plank." ;
    ex:hasParticipant :jimBrowner ;
    ex:hasParticipant :maryBrowner ;
    ex:hasParticipant :alecFairbairn ;
    ex:occurredAt :newBrighton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:nihilistBetrayal a ex:Crime ;
    ex:prefLabel "Nihilist Betrayal by Sergius" ;
    ex:description "Sergius (Professor Coram) betrayed his wife Anna and his fellow Nihilist companions to the Russian police in order to save his own life and earn a great reward. A police officer had been killed during their activities. Some of the betrayed members were sent to the gallows, others to Siberia. Sergius also tried to have Alexis convicted using Anna's diary and letters, but failed to get him executed; Alexis was sent to a salt mine in Siberia instead. Sergius fled to England with his ill-gotten gains." ;
    ex:hasVictim :annaCoram ;
    ex:hasVictim :alexis ;
    ex:hasPerpetrator :professorCoram ;
    ex:hasParticipant :professorCoram ;
    ex:hasParticipant :annaCoram ;
    ex:hasParticipant :alexis ;
    ex:occurredAt :russia ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:norwoodBuilderCase a ex:Investigation ;
    ex:prefLabel "The Norwood Builder Case" ;
    ex:description "Investigation into the apparent murder of Jonas Oldacre at Deep Dene House, Lower Norwood. John Hector McFarlane is arrested as the prime suspect. Holmes deduces that Oldacre faked his own death to frame McFarlane as revenge against McFarlane's mother, who had rejected Oldacre years earlier. Holmes proves the thumbprint was planted and flushes Oldacre from a hidden room using a fire ruse. Case is solved." ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:narrativeYear "1894" ;
    ex:hasClient :johnHectorMcFarlane ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasInvestigator :lestrade ;
    ex:hasParticipant :jonasOldacre ;
    ex:hasParticipant :mrsLexington ;
    ex:hasParticipant :mrsMcFarlaneNorwood ;
    ex:occurredAt :deepDeneHouse ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :torringtonLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:oldacreBankingFraud a ex:Crime ;
    ex:prefLabel "Oldacre's Banking Fraud" ;
    ex:description "Jonas Oldacre systematically transferred his wealth to a bank account under the alias 'Mr. Cornelius' over several years, fraudulently concealing his assets. This was part of his long-term plan to fake his death and start a new life under a different identity." ;
    ex:hasPerpetrator :jonasOldacre ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:oldacreFakedMurder a ex:Crime ;
    ex:prefLabel "Oldacre's Faked Murder" ;
    ex:description "Jonas Oldacre stages his own murder to frame John Hector McFarlane. Oldacre burns animal bones and his own trouser buttons in the timber-yard bonfire, plants blood on McFarlane's walking-stick, later plants a fake thumbprint on the wall using a wax impression, and hides in a secret room. Conspiracy also involves his housekeeper Mrs. Lexington." ;
    ex:hasAccomplice :mrsLexington ;
    ex:hasPerpetrator :jonasOldacre ;
    ex:hasVictim :johnHectorMcFarlane ;
    ex:occurredAt :deepDeneHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:overthrowOfMurillo a ex:Event, ex:Revolt ;
    ex:prefLabel "Overthrow of Don Murillo" ;
    ex:description "A universal rising against Don Murillo in San Pedro after ten or twelve years of tyrannical rule. Murillo, cunning as he was cruel, secretly conveyed his treasures aboard a ship manned by devoted adherents. He fled with his two children, his secretary Lopez, and his wealth. The insurgents stormed an empty palace." ;
    ex:hasParticipant :donMurillo ;
    ex:hasParticipant :lopez ;
    ex:occurredAt :sanPedro ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:parisAssassinationAttempt a ex:Event, ex:Assassination ;
    ex:prefLabel "Failed assassination attempt in Paris" ;
    ex:description "A previous attempt on Don Murillo's life made in Paris by the San Pedro revenge society, which failed. After this, Murillo zigzagged across Europe to throw off pursuers before returning to England." ;
    ex:hasParticipant :donMurillo ;
    ex:occurredAt :paris ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:pawningPendant1 a ex:Theft ;
    ex:prefLabel "Pawning of First Spanish Pendant" ;
    ex:description "Holy Peters, disguised as a large clean-shaven man of clerical appearance using a false name and address, pawned a silver-and-brilliant pendant of old Spanish design at Bovington's in Westminster Road. This was the first indication that Lady Frances's jewellery was being sold off." ;
    ex:hasParticipant :henryPeters ;
    ex:occurredAt :bovingtons ;
    ex:involves :spanishPendant1 ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:pawningPendant2 a ex:Theft ;
    ex:prefLabel "Pawning of Second Spanish Pendant" ;
    ex:description "Annie Fraser (Mrs. Peters) brought the second matching pendant to Bovington's. Philip Green, who had been stationed at the shop by Holmes, followed her from there to Stimson and Co. undertaker's shop on Kennington Road and then to 36 Poultney Square, Brixton." ;
    ex:hasParticipant :annieFraser ;
    ex:occurredAt :bovingtons ;
    ex:involves :spanishPendant2 ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:placingBodyOnTrain a ex:Event ;
    ex:prefLabel "Placing Body on Train Roof" ;
    ex:description "Monday night in November 1895. After killing Cadogan West, Oberstein devised a plan to dispose of the body. He and Colonel Walter stuffed seven of the ten stolen papers into West's pocket, waited half an hour at the back window for a train to stop beneath, and lowered the body onto the train roof in thick fog. The body fell off near Aldgate Station due to the points and curve, where it was found by plate-layer Mason at 6am Tuesday." ;
    ex:hasParticipant :hugoOberstein ;
    ex:hasParticipant :colonelValentineWalter ;
    ex:occurredAt :13CaulfieldGardens ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:poisoningOfCarlo a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Poisoning of Carlo" ;
    ex:description "Jack Ferguson tested the curare poison on the family spaniel Carlo approximately four months before the main events of the story. The poison caused sudden paralysis in a single night, affecting Carlo's hind legs and tail. A veterinarian diagnosed the condition as spinal meningitis. Holmes deduces that Jack used the dog as a test subject to verify the poison had not lost its power before using it on the baby." ;
    ex:hasParticipant :jackFerguson ;
    ex:hasParticipant :carlo ;
    ex:hasPerpetrator :jackFerguson ;
    ex:hasVictim :carlo ;
    ex:occurredAt :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:presburyClimbingIncident a ex:FictionalEvent ;
    ex:prefLabel "Presbury's Climbing Incident" ;
    ex:description "On the final Tuesday night observation, Holmes, Watson, and Bennett watched Professor Presbury emerge from his hall door, sink into a crouching position, and move along on his hands and feet. He climbed the ivy-covered wall with incredible agility, springing from branch to branch sure of foot and firm of grasp, looking like a huge bat against the moonlit wall. He then dropped down, squatted in his crouching attitude, and moved toward the stables where he deliberately provoked Roy by throwing pebbles and prodding with a stick." ;
    ex:hasParticipant :professorPresbury ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :trevorBennett ;
    ex:occurredAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:presburyClimbsWall a ex:FictionalEvent ;
    ex:prefLabel "Presbury Climbs Ivy Wall" ;
    ex:description "Under the influence of langur monkey serum, Professor Presbury climbs the ivy-covered wall of his house with incredible agility, springing from branch to branch sure of foot and firm of grasp. With his dressing-gown flapping on each side, he looks like some huge bat glued against the moonlit wall. This same climbing behavior previously brought him to his daughter Edith's second-floor window, terrifying her when she saw his face pressed against the glass." ;
    ex:participant :professorPresbury ;
    ex:location :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:presburyPragueTrip a ex:FictionalEvent, ex:Journey ;
    ex:prefLabel "Presbury's Trip to Prague" ;
    ex:description "A secret fortnight trip to Prague undertaken by Professor Presbury without informing his household. He returned looking rather travel-worn and made no allusion to where he had been. His destination was only discovered when Bennett received a letter from a fellow-student in Prague who reported seeing Presbury there. The trip was to consult H. Lowenstein about rejuvenation serum treatment." ;
    ex:hasParticipant :professorPresbury ;
    ex:occurredAt :prague ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:recoveryOfMazarinStone a ex:Event ;
    ex:prefLabel "Recovery of the Mazarin Stone" ;
    ex:description "Holmes's recovery of the Mazarin Stone at 221B Baker Street. While Sylvius and Merton believe Holmes is in his bedroom playing violin, he has substituted a gramophone and hidden behind the curtain in the dummy's alcove. When Sylvius shows the stone to Merton by the window, Holmes leaps from the chair and snatches it, holding the criminals at gunpoint until police arrive." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:hasParticipant :samMerton ;
    ex:occurredAt :221bBakerStreet ;
    ex:hasObject :mazarinStone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:redCircleMeetingNY a ex:Meeting ;
    ex:prefLabel "Red Circle Meeting in New York" ;
    ex:description "A meeting of the Red Circle secret society in New York at which lots were drawn to determine who would carry out the dynamite assassination of Tito Castalotte. Gennaro Lucca drew the fatal disc with the Red Circle upon it, the mandate for murder. The drawing was likely prearranged by Gorgiano." ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasParticipant :giuseppeGorgiano ;
    ex:occurredAt :newYork ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:redLeechCase a ex:Investigation ;
    ex:prefLabel "Red Leech Case" ;
    skos:altLabel "the repulsive story of the red leech" ;
    ex:description "A repulsive case involving the terrible death of Crosby the banker, mentioned in Watson's retrospective of 1894 cases. No further details provided." ;
    ex:narrativeYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :crosby ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:rescueLadyFrances a ex:Rescue ;
    ex:prefLabel "Rescue of Lady Frances Carfax" ;
    ex:description "Holmes, Watson, and the coffin bearers opened the oversized coffin at 36 Poultney Square just as it was being taken out for the funeral at eight o'clock. Lady Frances Carfax was found alive inside, chloroformed, with cotton-wool soaked in chloroform around her head. She was revived through artificial respiration and injected ether after half an hour of effort. Lestrade arrived with the warrant shortly after, but Peters and Fraser had fled." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :ladyFrancesCarfax, :philipGreen, :lestrade ;
    ex:occurredAt :36PoultneySq ;
    ex:rescued :ladyFrancesCarfax ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :disappearanceLadyFrancesCarfaxDoc .

:rescueOfCastalotte a ex:Rescue ;
    ex:prefLabel "Rescue of Castalotte in the Bowery" ;
    ex:description "Gennaro Lucca saved Tito Castalotte from ruffians in the Bowery, New York. This act earned Castalotte's friendship and patronage, leading to Gennaro's employment at Castalotte and Zamba." ;
    ex:hasParticipant :gennaroLucca ;
    ex:hasParticipant :titoCastalotte ;
    ex:occurredAt :theBowery ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redCircleDoc .

:rescueOfMissBurnet a ex:Event, ex:Rescue ;
    ex:prefLabel "Rescue of Miss Burnet" ;
    ex:description "When Henderson/Murillo attempted to flee by train with his household, Miss Burnet (drugged with opium) struggled free at the station. John Warner, Holmes's agent watching the gates, intercepted her and put her in a cab. She was brought to Holmes and Baynes at the Bull inn." ;
    ex:hasParticipant :missBurnet ;
    ex:hasParticipant :johnWarner ;
    ex:hasParticipant :donMurillo ;
    ex:occurredAt :esher ;
    ex:narrativeYear "1892" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:rivieraTrainRobbery a ex:Theft ;
    ex:prefLabel "Riviera Train Robbery" ;
    ex:description "A robbery committed by Count Negretto Sylvius on the train de-luxe to the Riviera on February 13, 1892, as recorded in Holmes's crime notebook." ;
    ex:narrativeDate "1892-02-13" ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:occurredAt :theRiviera ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:rockIncidentDaubensee a ex:FictionalEvent ;
    ex:prefLabel "Rock Incident at Daubensee" ;
    ex:description "While Holmes and Watson walked along the border of the melancholy Daubensee near the Gemmi Pass, a large rock was dislodged from the ridge and clattered down into the lake behind them. The guide assured them it was common in springtime, but Holmes raced up the ridge and searched in every direction, convinced it was Moriarty's doing." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :daubensee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:royAttackOnPresbury a ex:FictionalEvent, ex:AnimalAttack ;
    ex:prefLabel "Roy's Attack on Presbury" ;
    ex:description "During the final Tuesday night observation, after Presbury had been provoking Roy while in his simian state, Roy's collar slipped off (it had been made for a thick-necked Newfoundland). Dog and man rolled on the ground together, Roy roaring in rage and Presbury screaming in a shrill falsetto of terror. Roy bit Presbury fairly by the throat near the carotid artery, causing serious haemorrhage. Presbury was senseless before Holmes, Watson, and Bennett could reach them and drag them apart. Bennett's voice brought Roy instantly to reason. The coachman Macphail was woken by the uproar. Watson and Bennett (who had a medical degree) dressed the wound, Watson gave a morphia injection, and the danger passed in half an hour." ;
    ex:hasParticipant :professorPresbury ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :trevorBennett ;
    ex:hasParticipant :macphail ;
    ex:occurredAt :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:royAttacksPresbury a ex:FictionalEvent, ex:Assault ;
    ex:prefLabel "Roy Attacks Professor Presbury" ;
    ex:description "Professor Presbury, under the influence of langur monkey serum, crouches frog-like on the ground and taunts his chained wolfhound Roy by throwing pebbles at his face, prodding him with a stick, and flicking his hands near the dog's mouth. The collar, made for a thick-necked Newfoundland, slips off and Roy attacks, biting Presbury's throat near the carotid artery with serious haemorrhage. Bennett's voice brings the wolfhound to reason, and together they carry the professor to his room where Bennett and Watson dress the wound and administer a morphia injection." ;
    ex:perpetrator :roy ;
    ex:victim :professorPresbury ;
    ex:location :presburyHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

:rugbyMatchOldDeerPark a ex:FictionalEvent, ex:SportsEvent ;
    ex:prefLabel "Rugby Match at Old Deer Park" ;
    ex:description "A past Rugby match at Old Deer Park in Richmond where Ferguson threw Watson over the ropes into the crowd, recalled by Ferguson when he visits Baker Street. This establishes the prior acquaintance between Watson and Ferguson through Rugby." ;
    ex:hasParticipant :robertFerguson ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :oldDeerPark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:sarahDepartureLiverpool a ex:Event ;
    ex:prefLabel "Sarah's departure from Browner's house" ;
    ex:description "After Jim confronted Sarah about Fairbairn and threatened to send her one of Fairbairn's ears, Sarah left Jim and Mary's house the same evening." ;
    ex:hasParticipant :sarahCushing ;
    ex:hasParticipant :jimBrowner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:searchOfMrsTangey a ex:Investigation ;
    ex:prefLabel "Search of Mrs. Tangey" ;
    ex:description "Forbes and Phelps went to 16 Ivy Lane, Brixton, to search for the stolen treaty. Tangey's eldest daughter opened the door and alerted her mother. Mrs. Tangey ran to the back kitchen, claiming she had money to pay brokers. The kitchen and especially the kitchen fire were examined for signs of destroyed papers. Mrs. Tangey was taken to Scotland Yard in a four-wheeler and searched by a female searcher. No signs of the papers were found." ;
    ex:hasParticipant :forbes ;
    ex:hasParticipant :percyPhelps ;
    ex:hasParticipant :mrsTangey ;
    ex:hasParticipant :tangeyDaughter ;
    ex:hasParticipant :femaleSearcherSY ;
    ex:occurredAt :16IvyLane ;
    ex:occurredAt :scotlandYard ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:holmesVisitHoldhurst a ex:Meeting ;
    ex:prefLabel "Holmes's Visit to Lord Holdhurst" ;
    ex:description "Holmes and Watson visited Lord Holdhurst at his chambers in Downing Street to discuss the naval treaty theft. Holdhurst confirmed no one else knew about the copying commission. He revealed the treaty had not leaked despite ten weeks passing but would cease to be secret in a few months. Holmes insinuated Holdhurst himself might benefit from the treaty's destruction, and Holdhurst hinted at the possibility of brain-fever in the thief." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :lordHoldhurst ;
    ex:occurredAt :downingStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:navalTreatyRecovery a ex:Event ;
    ex:prefLabel "Recovery of the Naval Treaty" ;
    ex:description "Holmes's recovery of the stolen naval treaty at Briarbrae. After walking to Ripley for tea, Holmes returned to Briarbrae after sunset, climbed the fence screened by three fir-trees, and hid in rhododendron bushes opposite Phelps's window. Miss Harrison locked the room at quarter past ten. At two in the morning, Joseph Harrison emerged from the servant's door, forced the window and shutters with his long-bladed knife, lifted the carpet, removed a board covering a gas-pipe T-joint, and retrieved the cylinder of blue-gray paper. Holmes caught him outside the window. Harrison attacked with the knife, cutting Holmes over the knuckles, but was subdued and surrendered the papers. Holmes presented the treaty to Phelps under a breakfast dish cover at 221B Baker Street." ;
    ex:hasParticipant :sherlockHolmes , :josephHarrison , :annieHarrison ;
    ex:occurredAt :briarbrae ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:phelpsBrainFever a ex:Illness ;
    ex:prefLabel "Percy Phelps's Brain-Fever" ;
    ex:description "Percy Phelps suffered nine weeks of brain-fever following the theft of the naval treaty. He had a fit at Waterloo station and was practically a raving maniac before reaching home. Dr. Ferrier took charge of him. He was unconscious and raving at Briarbrae, nursed by Annie Harrison during the day and a hired nurse at night. His reason slowly cleared, with full memory returning only in the last three days before Holmes's visit." ;
    ex:hasParticipant :percyPhelps ;
    ex:hasParticipant :drFerrier ;
    ex:hasParticipant :annieHarrison ;
    ex:hasParticipant :hiredNurseNT ;
    ex:occurredAt :briarbrae ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:navalTreatyInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Naval Treaty Theft" ;
    ex:description "Sherlock Holmes's investigation into the theft of the secret naval treaty. Holmes was consulted by Percy Phelps via letter. He visited Briarbrae in Woking, interviewed Forbes at Scotland Yard, visited Lord Holdhurst at Downing Street, placed a cab advertisement in London evening papers, and ultimately staked out Briarbrae to catch the thief Joseph Harrison retrieving the treaty from its hiding place under a floorboard. The investigation was successful, with Holmes recovering the treaty and presenting it to Phelps at breakfast at 221B Baker Street." ;
    ex:isSolved "true" ;
    ex:hasClient :percyPhelps ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasInvestigator :forbes ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :percyPhelps ;
    ex:hasParticipant :forbes ;
    ex:occurredAt :briarbrae ;
    ex:occurredAt :scotlandYard ;
    ex:occurredAt :downingStreet ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:secondAssaultOnJack a ex:FictionalEvent ;
    ex:prefLabel "Second Assault on Jack Ferguson" ;
    ex:description "Mrs. Ferguson attacked her stepson Jack very savagely with her hands. This was the second incident, occurring without a corresponding baby attack. Mrs. Mason had no complaint about the baby during this period. Mrs. Ferguson's repeated statement that she hated Jack was driven by her knowledge of his attempts to poison the baby." ;
    ex:hasParticipant :mrsFerguson ;
    ex:hasParticipant :jackFerguson ;
    ex:occurredAt :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:secondBabyAttack a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Second Poisoning of Baby Ferguson" ;
    ex:description "The incident witnessed by Robert Ferguson himself. While Ferguson and the nurse were talking, a sudden cry of pain was heard from the nursery. They rushed in to find Mrs. Ferguson rising from a kneeling position beside the cot with blood on the child's exposed neck and on the sheet, and blood around her lips. Ferguson assumed his wife was drinking the baby's blood, but she was in fact sucking curare poison from the wound. This led to Mrs. Ferguson's confinement to her room." ;
    ex:hasParticipant :mrsFerguson ;
    ex:hasParticipant :babyFerguson ;
    ex:hasParticipant :robertFerguson ;
    ex:hasParticipant :mrsMason ;
    ex:hasPerpetrator :jackFerguson ;
    ex:hasVictim :babyFerguson ;
    ex:occurredAt :cheesemansNursery ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:secretMarriageOfGodfreyStaunton a ex:Marriage ;
    ex:prefLabel "Secret Marriage of Godfrey Staunton" ;
    ex:description "About a year before the main events, Godfrey Staunton lodged in London and became passionately attached to his landlady's daughter, whom he secretly married. The marriage was kept secret to preserve his inheritance from Lord Mount-James. Known only to Dr. Armstrong and one trusted servant." ;
    ex:hasParticipant :godfreyStaunton ;
    ex:hasParticipant :godfreyStauntonWife ;
    ex:occurredAt :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:sendingCardboardBox a ex:Event ;
    ex:prefLabel "Sending of the cardboard box" ;
    ex:description "After the murders, Browner made up the packet with the severed ears for Sarah Cushing and posted it from Belfast (first port of call on May Day)." ;
    ex:hasParticipant :jimBrowner ;
    ex:occurredAt :belfast ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:shootingOfWatson a ex:FictionalEvent, ex:Crime ;
    ex:prefLabel "Shooting of Watson" ;
    ex:description "During the stakeout at 136 Little Ryder Street, after Killer Evans discovers Prescott's hidden counterfeiting press beneath the floor, Holmes and Watson confront him. Evans whips out a revolver and fires two shots, hitting Watson in the thigh with a superficial wound. Holmes subdues Evans by striking him on the head with his pistol. The incident provokes a famous emotional reaction from Holmes, who reveals the depth of his loyalty and love for Watson, asking desperately if Watson is hurt." ;
    ex:perpetrator :killerEvans ;
    ex:victim :johnWatson ;
    ex:location :136LittleRyderStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:shootingOfWatsonGarridebs a ex:Event, ex:Crime ;
    ex:prefLabel "Shooting of Watson at Ryder Street" ;
    ex:description "During the confrontation at 136 Little Ryder Street, Killer Evans drew a revolver from his breast pocket and fired two shots. Watson was hit in the thigh, though the wound proved superficial. Holmes struck Evans on the head with his pistol, subduing him. The incident provoked a rare display of deep emotion from Holmes, who showed intense concern for Watson's welfare." ;
    ex:hasParticipant :killerEvans ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :136LittleRyderStreet ;
    ex:narrativeYear "1902" ;
    ex:hasVictim :johnWatson ;
    ex:hasPerpetrator :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:shootingOfRodgerPrescott a ex:Event, ex:Crime, ex:Murder ;
    ex:prefLabel "Shooting of Rodger Prescott" ;
    ex:description "In January 1895, Killer Evans shot and killed Rodger Prescott, a famous forger and coiner from Chicago, in a night-club on the Waterloo Road in London during a card game. Prescott was shown to have been the aggressor in the altercation. Evans was convicted and served five years in prison, being released in 1901." ;
    ex:hasParticipant :killerEvans ;
    ex:hasParticipant :rodgerPrescott ;
    ex:occurredAt :waterlooRoadNightClub ;
    ex:narrativeYear "1895" ;
    ex:hasVictim :rodgerPrescott ;
    ex:hasPerpetrator :killerEvans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:shootingOfWoodley a ex:Shooting ;
    ex:prefLabel "Shooting of Jack Woodley" ;
    ex:description "Bob Carruthers shot Jack Woodley with his revolver during the confrontation at Charlington Hall, hitting him in the front of his waistcoat. Woodley spun round and fell but survived." ;
    ex:hasParticipant :bobCarruthers ;
    ex:hasParticipant :jackWoodley ;
    ex:hasVictim :jackWoodley ;
    ex:occurredAt :charlingtonBowlingAlley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:shoscombeDerbyRace a ex:HorseRace ;
    ex:prefLabel "The Derby" ;
    ex:description "The Derby horse race in which Shoscombe Prince is entered by Sir Robert Norberton. Everything Sir Robert could raise or borrow is wagered on the horse at long odds. Shoscombe Prince wins the Derby, netting Sir Robert eighty thousand pounds in bets, which enables him to pay his creditors in full." ;
    ex:hasParticipant :shoscombePrince ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombeInvestigation a ex:Investigation ;
    ex:prefLabel "Shoscombe Old Place Investigation" ;
    ex:description "An investigation undertaken by Sherlock Holmes at the request of John Mason, head trainer at Shoscombe Old Place. Mason is concerned about Sir Robert Norberton's erratic behavior, Lady Beatrice Falder's changed habits, and mysterious nighttime visits to the crypt. Holmes and Watson travel to Shoscombe, stay at the Green Dragon inn, and discover that Lady Beatrice has died and her death is being concealed. The case is resolved when Sir Robert confesses the concealment scheme." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :johnMason ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :johnMason, :robertNorberton, :beatriceFalder, :carrieEvans, :norlett ;
    ex:occurredAt :shoscombeOldPlace, :greenDragon, :shoscombeChapel, :221bBakerStreet ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:slaterSighting a ex:Event ;
    ex:prefLabel "Slater's sighting at the cabin" ;
    ex:description "On the Monday night before the murder, the stonemason Slater, walking from Forest Row at about one o'clock in the morning, stopped at the grounds of Woodman's Lee and observed a square of light from the cabin window. He saw the shadow of a man's head turned sideways on the blind, with a short beard bristling forward — clearly not Peter Carey. Hopkins noted Slater had been two hours in the public-house and it was some distance from the road to the window." ;
    ex:eventYear "1895" ;
    ex:hasParticipant :slaterStonemason, :patrickCairns ;
    ex:occurredAt :peterCareyCabin ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:smithConfessionAt221B a ex:Event ;
    ex:prefLabel "Smith's Confession at 221B Baker Street" ;
    ex:description "Culverton Smith confesses to the murder of Victor Savage and the attempted murder of Sherlock Holmes while visiting Holmes at 221B Baker Street. Smith believes Holmes is truly dying and gloats over his handiwork, revealing that he sent the poisoned ivory box and that Victor Savage was killed by the same method. Watson witnesses the confession from hiding behind Holmes's bed, and Inspector Morton arrests Smith immediately after." ;
    ex:hasParticipant :culvertonSmith ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

:smithMortimerCase a ex:Investigation ;
    ex:prefLabel "Smith-Mortimer Succession Case" ;
    ex:description "A famous succession case mentioned in Watson's retrospective of 1894 cases. No further details provided." ;
    ex:narrativeYear "1894" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:solitaryCyclistInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Solitary Cyclist" ;
    ex:description "Holmes's investigation into the mysterious cyclist following Violet Smith on the lonely road between Chiltern Grange and Farnham Station. Set in April 1895. Led to the discovery of a conspiracy by Carruthers and Woodley to marry Violet for her inheritance from Ralph Smith. Culminated in the forced marriage, shooting, and arrests at Charlington Hall." ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:narrativeYear "1895" ;
    ex:hasClient :violetSmith ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :violetSmith ;
    ex:hasParticipant :bobCarruthers ;
    ex:hasParticipant :jackWoodley ;
    ex:hasParticipant :williamsonExClergyman ;
    ex:investigatedBy :sherlockHolmes ;
    ex:occurredAt :charlington ;
    ex:occurredAt :chilternGrange ;
    ex:occurredAt :charlingtonHall ;
    ex:occurredAt :farnham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:southAfricanWarConclusion a ex:Event ;
    ex:prefLabel "Conclusion of the South African War" ;
    skos:altLabel "End of the Boer War" ;
    ex:description "The conclusion of the South African War (Second Boer War), referenced as a temporal marker for the Three Garridebs case, which took place shortly afterwards in June 1902." ;
    ex:narrativeYear "1902" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:spanielTest a ex:Event ;
    ex:prefLabel "Spaniel Test at Park Gates" ;
    ex:description "An experiment devised by Holmes to test whether the woman in Lady Beatrice's carriage is genuine. Holmes borrows Lady Beatrice's spaniel from the Green Dragon and releases it near the carriage at the park gates. Watson stops the coachman with a question while Holmes watches from behind a holly bush. The spaniel initially greets the carriage joyously but then reacts with furious rage, snapping at the occupant's skirt. A harsh male voice shrieks 'Drive on!' confirming the impersonation." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :beatriceSpaniel, :norlett, :carrieEvans ;
    ex:occurredAt :shoscombePark ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:stackhurstFiresMurdoch a ex:Event ;
    ex:prefLabel "Stackhurst Dismisses Murdoch" ;
    ex:description "Outside The Haven, Stackhurst confronts Ian Murdoch about his visit to the Bellamy home and, losing his temper, fires Murdoch from The Gables. Murdoch responds by stating he had intended to leave anyway, having lost the only person who made The Gables habitable (referring to McPherson). They later reconcile after Murdoch is exonerated." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :haroldStackhurst, :ianMurdoch ;
    ex:occurredAt :fulworth ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:steveDixieThreatEvent a ex:FictionalEvent , ex:Meeting ;
    ex:prefLabel "Steve Dixie's Threat to Holmes" ;
    ex:description "Steve Dixie burst into 221B Baker Street to warn Sherlock Holmes to stay away from the Harrow Weald case. He was sent by Barney Stockdale on behalf of an unknown employer. Holmes identified Dixie and used knowledge of the Perkins killing to intimidate him. Watson picked up a poker during the confrontation." ;
    ex:hasParticipant :sherlockHolmes , :johnWatson , :steveDixie ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGablesDoc .

:stPancrasCase a ex:Investigation ;
    ex:prefLabel "St. Pancras Case" ;
    ex:description "A case that Inspector Merivale of Scotland Yard asks Holmes to examine. A cap was found beside a dead policeman. The accused man, a picture-frame maker, denies the cap is his, but Holmes demonstrates through microscopic analysis that the cap contains glue, which the accused habitually handles in his profession." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :merivale ;
    ex:hasParticipant :sherlockHolmes, :merivale, :stPancrasPoliceman, :pictureFrameMaker ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:sultanOfTurkeyCommission a ex:Event ;
    ex:prefLabel "Sultan of Turkey Commission" ;
    ex:description "A commission Holmes received from the Sultan of Turkey in January 1903 which called for immediate action, as political consequences of the gravest kind might arise from its neglect. This commission, along with the Abbey School case, delayed Holmes's ability to travel to Bedfordshire with Dodd." ;
    ex:narrativeYear "1903" ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :sultanOfTurkey ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:sussexVampireInvestigation a ex:FictionalEvent, ex:Investigation ;
    ex:prefLabel "Sussex Vampire Investigation" ;
    skos:altLabel "The Adventure of the Sussex Vampire" ;
    ex:description "The central investigation of the story, in which Holmes and Watson travel to Cheeseman's, Lamberley, Sussex, to investigate the apparent vampirism of Mrs. Ferguson. Robert Ferguson, referred by his lawyers Morrison, Morrison, and Dodd, consults Holmes after his wife is caught apparently biting their baby's neck. Holmes deduces the solution before leaving Baker Street: the wife was sucking curare poison from the baby's wound to save its life. The poison was administered by Jack Ferguson, Ferguson's crippled fifteen-year-old son from his first marriage, using arrows from the South American weapons collection. Jack's motive was jealous hatred of the baby. Holmes also deduces Jack tested the poison on the family dog Carlo. The case is solved when Holmes reveals the truth in Mrs. Ferguson's room." ;
    ex:hasClient :robertFerguson ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :mrsFerguson ;
    ex:hasParticipant :jackFerguson ;
    ex:hasParticipant :mrsMason ;
    ex:hasParticipant :dolores ;
    ex:hasParticipant :babyFerguson ;
    ex:isSolved "true" ;
    ex:narrativeYear "unknown (November)" ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :cheesemans ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:sydenhamRobbery a ex:Theft ;
    ex:prefLabel "Sydenham Robbery" ;
    ex:description """A robbery committed by the Randall gang at Sydenham a fortnight before the Abbey Grange case. The gang were seen and described during this job.""" ;
    ex:hasParticipant :randallGang ;
    ex:occurredAt :sydenham ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:theftDiplomaticLetter a ex:Theft ;
    ex:prefLabel "Theft of the Diplomatic Letter" ;
    ex:description "Lady Hilda Trelawney Hope stole the diplomatic letter from her husband's despatch-box at Whitehall Terrace on a Tuesday evening between 7:30 and 11:30 PM, while her husband was at dinner and she was ostensibly at the theatre. She used a duplicate key furnished by Eduardo Lucas. She conveyed the letter to Lucas at 16 Godolphin Street in exchange for her compromising pre-marriage letter." ;
    ex:hasParticipant :ladyHildaTrelawneyHope ;
    ex:hasParticipant :eduardoLucas ;
    ex:occurredAt :whitehallTerrace ;
    ex:hasVictim :trelawneyHope ;
    ex:hasPerpetrator :ladyHildaTrelawneyHope ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:theftOfBlackPearl a ex:Theft ;
    ex:prefLabel "Theft of the Black Pearl" ;
    ex:description "The famous black pearl of the Borgias was stolen from the Prince of Colonna's bedroom at the Dacre Hotel. The disappearance caused a sensation. Suspicion fell on the Princess's maid, Lucretia Venucci, who was Italian and had a brother in London. The pearl's disappearance occurred exactly two days before Beppo's arrest." ;
    ex:hasParticipant :lucretiaVenucci ;
    ex:hasParticipant :pietroVenucci ;
    ex:hasParticipant :beppo ;
    ex:occurredAt :dacreHotel ;
    ex:hasVictim :princeOfColonna ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

:theftOfBrucePartingtonPlans a ex:Treason, ex:Theft ;
    ex:prefLabel "Theft of the Bruce-Partington Plans" ;
    ex:description "Monday night in November 1895. Colonel Valentine Walter, pressed for money due to Stock Exchange debts, used an impress of his brother Sir James's keys to enter the Woolwich Arsenal office and steal all ten Bruce-Partington submarine plans from the safe. He took them to Hugo Oberstein at 13 Caulfield Gardens, Kensington, as arranged through coded advertisements in the Daily Telegraph. Oberstein had offered five thousand pounds. Walter was followed unknowingly by Arthur Cadogan West." ;
    ex:hasParticipant :colonelValentineWalter ;
    ex:hasParticipant :hugoOberstein ;
    ex:occurredAt :submarineDepartmentOffice ;
    ex:occurredAt :13CaulfieldGardens ;
    ex:narrativeYear "1895"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:theftOfMazarinStone a ex:Theft ;
    ex:prefLabel "Theft of the Mazarin Stone" ;
    ex:description "The theft of the Crown diamond (Mazarin Stone) from Whitehall by Count Negretto Sylvius and Sam Merton. The stone is worth one hundred thousand pounds. Holmes has evidence from the cabman who took Sylvius to Whitehall and brought him away, the commissionaire who saw him near the case, and Ikey Sanders who refused to cut the stone." ;
    ex:hasParticipant :countNegrettoSylvius ;
    ex:hasParticipant :samMerton ;
    ex:occurredAt :whitehall ;
    ex:hasObject :mazarinStone ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:theftOfNavalTreaty a ex:Theft ;
    ex:prefLabel "Theft of the Naval Treaty" ;
    ex:description "The theft of the secret naval treaty from the Foreign Office on the evening of May 23rd at approximately quarter to ten. Joseph Harrison entered via the Charles Street side door, found Phelps's office empty (Phelps had gone downstairs for coffee), saw the treaty on the desk, and stole it. He rang the bell (either accidentally or deliberately), which alerted the sleeping commissionaire Tangey and Phelps. Harrison escaped before they could return to the room. He took the treaty to Woking by the first train and hid it under a floorboard at Briarbrae." ;
    ex:narrativeDate "May 23" ;
    ex:hasParticipant :josephHarrison ;
    ex:hasParticipant :percyPhelps ;
    ex:hasParticipant :tangey ;
    ex:occurredAt :phelpsOfficeFO ;
    ex:occurredAt :foreignOffice ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :navalTreatyDoc .

:actonBurglary a ex:Crime, ex:Theft ;
    ex:prefLabel "Acton Burglary" ;
    skos:altLabel "Burglary at Acton's House" ;
    ex:description "A burglary at Mr. Acton's house on a Monday night, several days before the murder of William Kirwan. The Cunninghams broke in and ransacked the library, searching for legal documents related to their lawsuit with Acton — specifically a paper that would have crippled Acton's claim on half their estate. Finding nothing (the document was in Acton's solicitors' strong-box), they stole an odd assortment of items to make it appear an ordinary burglary: a volume of Pope's Homer, two plated candlesticks, an ivory letter-weight, a small oak barometer, and a ball of twine." ;
    ex:hasParticipant :oldCunningham, :alecCunningham ;
    ex:hasVictim :mrActon ;
    ex:occurredAt :actonHouse ;
    ex:narrativeYear "1887"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:attackOnHolmes a ex:Crime ;
    ex:prefLabel "Attack on Holmes by the Cunninghams" ;
    ex:description "When Holmes slipped away from the group during the house tour to retrieve the torn note from Alec Cunningham's dressing-gown pocket, both Cunninghams discovered him and attacked. The younger Alec clutched Holmes's throat with both hands while the elder twisted one of his wrists trying to get the paper. Watson, the Colonel, and Inspector Forrester tore them away. Holmes staggered to his feet, very pale and greatly exhausted, and ordered their arrest." ;
    ex:hasParticipant :oldCunningham, :alecCunningham, :sherlockHolmes ;
    ex:occurredAt :cunninghamHouse ;
    ex:narrativeYear "1887"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:betrayalOfHenryWood a ex:Crime, ex:Event ;
    ex:prefLabel "Betrayal of Henry Wood" ;
    ex:description "During the Siege of Bhurtee, Sergeant James Barclay drew up the escape route for Corporal Henry Wood, who had volunteered to reach General Neill's column. Barclay then betrayed Wood by means of a native servant, informing the enemy of his route. Wood was captured, stunned, and bound. This betrayal led to thirty years of captivity, torture, and exile for Wood, and allowed Barclay to marry Nancy Devoy." ;
    ex:hasParticipant :henryWood, :jamesBarclay ;
    ex:occurredAt :bhurtee ;
    ex:perpetrator :jamesBarclay ;
    ex:victim :henryWood ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:blessingtonInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of the Blessington case" ;
    skos:altLabel "Brook Street Mystery" ;
    ex:description "Holmes's investigation into the mysterious intrusions at 403 Brook Street and the subsequent murder of Mr. Blessington. Holmes deduced that the apparent suicide was actually a carefully planned revenge killing by former associates from the Worthingdon bank gang. He identified Blessington as Sutton, the informer, and the murderers as Biddle, Hayward, and Moffat." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :percyTrevelyan ;
    ex:hasParticipant :inspectorLanner ;
    ex:hasParticipant :blessington ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :percyTrevelyan ;
    ex:occurredAt :403BrookStreet ;
    ex:occurredAt :221bBakerStreet ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:cunninghamArrest a ex:Event, ex:Arrest ;
    ex:prefLabel "Arrest of the Cunninghams" ;
    ex:description "The arrest of both Mr. Cunningham and Alec Cunningham by Inspector Forrester at Holmes's instruction, following the attack on Holmes and the recovery of the torn note. The guilt was plain on their faces — the old man numbed and dazed with a sullen expression, the son dropping his jaunty style with the ferocity of a dangerous wild beast in his dark eyes. Alec attempted to grab and cock a revolver but the Inspector struck it from his hand. Two constables were summoned by whistle." ;
    ex:hasParticipant :oldCunningham, :alecCunningham, :inspectorForrester, :sherlockHolmes, :johnWatson, :colonelHayter ;
    ex:occurredAt :cunninghamHouse ;
    ex:narrativeYear "1887"^^xsd:gYear ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:deathOfColonelBarclay a ex:Event ;
    ex:prefLabel "Death of Colonel Barclay" ;
    ex:description "Colonel James Barclay died of apoplexy in the morning-room at Lachine upon seeing Henry Wood enter through the French window during a quarrel with his wife. His face was contorted in dreadful fear and horror. He fell with his head hitting the corner of the fender, causing a jagged cut. Found stone dead in a pool of blood. Initially suspected as murder. The inquest concluded death due to apoplexy." ;
    ex:hasParticipant :jamesBarclay, :nancyBarclay, :henryWood ;
    ex:occurredAt :morningRoomLachine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:deathOfPaulKratides a ex:Murder ;
    ex:prefLabel "Death of Paul Kratides" ;
    ex:description "Paul Kratides died of charcoal poisoning at The Myrtles despite rescue attempt." ;
    ex:hasParticipant :paulKratides , :haroldLatimer , :wilsonKemp ;
    ex:occurredAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:diogenesWindowDeduction a ex:Deduction ;
    ex:prefLabel "Deduction at Diogenes Club Window" ;
    ex:description "Holmes brothers deduced details about passersby from the Diogenes Club window, demonstrating Mycroft's superior observational skills." ;
    ex:hasParticipant :sherlockHolmes , :mycroftHolmes , :johnWatson , :billiardMarker , :oldSoldierDiogenes ;
    ex:occurredAt :diogenesClub ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:encounterHudsonStreet a ex:Meeting ;
    ex:prefLabel "Encounter on Hudson Street" ;
    ex:description "On Monday evening about a quarter to nine, Mrs. Barclay and Miss Morrison encountered Henry Wood on Hudson Street while returning from the Guild meeting. Wood, a deformed man carrying a box, recognized Nancy and cried out 'My God, it's Nancy!' Mrs. Barclay turned white but spoke civilly to him, saying 'I thought you had been dead this thirty years, Henry.' They spoke privately for a few minutes. Mrs. Barclay then returned home with blazing eyes while Wood shook his fists in rage by the lamp-post." ;
    ex:hasParticipant :nancyBarclay, :missMorrison, :henryWood ;
    ex:occurredAt :hudsonStreetAldershot ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:eveningWalkFleetStreet a ex:Journey ;
    ex:prefLabel "Evening walk through London" ;
    ex:description "A three-hour evening stroll taken by Holmes and Watson through Fleet Street and the Strand before returning to Baker Street to find Dr. Trevelyan waiting." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :fleetStreet ;
    ex:occurredAt :strand ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:firstKidnappingOfMelas a ex:Kidnapping ;
    ex:prefLabel "First Kidnapping of Melas" ;
    ex:description "Latimer kidnapped Melas from Pall Mall by carriage to The Myrtles for interpreting. Melas dropped at Wandsworth Common after." ;
    ex:hasParticipant :mrMelas , :haroldLatimer ;
    ex:occurredAt :mycroftLodgings , :theMyrtles , :wandsworthCommon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:firstRussianVisit a ex:Meeting ;
    ex:prefLabel "First visit of the fake Russians" ;
    ex:description "The first visit of the fake Russian count and his son to Dr. Trevelyan's practice at 403 Brook Street. The old man feigned a cataleptic attack while the young man, supposedly waiting, secretly ascended to Blessington's rooms. The patients left abruptly during Trevelyan's absence to fetch medication." ;
    ex:hasParticipant :fakeRussianCount ;
    ex:hasParticipant :fakeRussianSon ;
    ex:hasParticipant :percyTrevelyan ;
    ex:occurredAt :403BrookStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:flightFromMyrtles a ex:Flight ;
    ex:prefLabel "Flight from The Myrtles" ;
    ex:description "Latimer, Kemp, and Sophy fled The Myrtles with heavy luggage after their scheme was exposed. Left Kratides and Melas to die." ;
    ex:hasParticipant :haroldLatimer , :wilsonKemp , :sophyKratides ;
    ex:occurredAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:greekInterpreterInvestigation a ex:Investigation ;
    ex:prefLabel "Greek Interpreter Investigation" ;
    skos:altLabel "the singular case of the Grecian Interpreter" ;
    ex:description "Investigation into kidnapping of Paul Kratides. Case from Mycroft via Melas. Partially solved: Melas rescued, Kratides died, villains escaped but killed in Budapest." ;
    ex:hasClient :mycroftHolmes , :mrMelas ;
    ex:hasParticipant :sherlockHolmes , :johnWatson , :mycroftHolmes , :mrMelas , :gregson ;
    ex:investigator :sherlockHolmes ;
    ex:isSolved "partially" ;
    ex:occurredAt :diogenesClub , :theMyrtles , :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:guildMeetingMonday a ex:Meeting ;
    ex:prefLabel "Guild of St. George Meeting, Monday Evening" ;
    ex:description "Meeting of the Guild of St. George held at Watt Street Chapel on Monday evening at eight o'clock. Lasted forty minutes. Mrs. Barclay attended, accompanied by Miss Morrison." ;
    ex:hasParticipant :nancyBarclay, :missMorrison ;
    ex:occurredAt :wattStreetChapel ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:imprisonmentOfKratides a ex:Imprisonment ;
    ex:prefLabel "Imprisonment of Paul Kratides" ;
    ex:description "Kratides held at The Myrtles 3+ weeks by Latimer and Kemp. Starved and tortured to force signing property papers." ;
    ex:hasParticipant :paulKratides , :haroldLatimer , :wilsonKemp ;
    ex:occurredAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:inquestBarclay a ex:Event ;
    ex:prefLabel "Inquest on Colonel Barclay" ;
    ex:description "Official inquest into the death of Colonel Barclay. Medical evidence showed conclusively that death was due to apoplexy. Major Murphy reported the conclusion to Holmes, calling it 'quite a simple case after all.'" ;
    ex:hasParticipant :jamesBarclay ;
    ex:occurredAt :aldershot ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:interrogationOfKratides a ex:Interrogation ;
    ex:prefLabel "Interrogation of Paul Kratides" ;
    ex:description "Melas interpreted as Kemp interrogated Kratides at The Myrtles. Kratides refused to sign papers. Melas secretly gathered information. Sophy recognized Paul." ;
    ex:hasParticipant :mrMelas , :wilsonKemp , :paulKratides , :haroldLatimer , :sophyKratides ;
    ex:occurredAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:investigationBarclayCase a ex:Investigation ;
    ex:prefLabel "Investigation into the Death of Colonel Barclay" ;
    ex:description "Holmes investigates the death of Colonel Barclay at the request of Major Murphy. Travels to Aldershot on Tuesday, examines the morning-room and lawn, discovers animal footprints alongside a man's footmarks. Cross-questions servants, learns about the word 'David'. Interviews Miss Morrison who reveals the encounter with Henry Wood. Tracks down Wood through his landlady. Interviews Wood with Watson present. Case resolved when inquest concludes death by apoplexy." ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :majorMurphy, :missMorrison, :henryWood, :janeStewart ;
    ex:occurredAt :aldershot, :lachine ;
    ex:investigator :sherlockHolmes ;
    ex:isSolved "true" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:lossOfNorahCreina a ex:Event ;
    ex:prefLabel "Loss of the Norah Creina" ;
    ex:description "The sinking of the steamer Norah Creina with all hands upon the Portuguese coast, some leagues north of Oporto. The three murderers of Blessington (Biddle, Hayward, and Moffat) were believed to have been among its passengers." ;
    ex:hasParticipant :biddle ;
    ex:hasParticipant :hayward ;
    ex:hasParticipant :moffat ;
    ex:occurredAt :portugueseCoast ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:maupertuisInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation of Baron Maupertuis" ;
    skos:altLabel "Netherland-Sumatra Company case" ;
    ex:description "Holmes's immense investigation in the spring of 1887 into Baron Maupertuis, the most accomplished swindler in Europe, and the colossal schemes of the Netherland-Sumatra Company involving politics and finance. The investigation extended over two months, during which Holmes never worked less than fifteen hours a day and more than once kept to his task for five days at a stretch. He succeeded where the police of three countries had failed, but the strain left him with nervous prostration at the Hotel Dulong in Lyons." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasParticipant :sherlockHolmes , :baronMaupertuis ;
    ex:occurredAt :lyons ;
    ex:narrativeYear "1887"^^xsd:gYear ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:murderOfBlessington a ex:Murder ;
    ex:prefLabel "Murder of Blessington" ;
    ex:description "The murder of Mr. Blessington (real name Sutton) by three former members of the Worthingdon bank gang (Biddle, Hayward, and Moffat) as revenge for his betrayal as an informer. They were admitted to 403 Brook Street by a confederate page boy, held a mock trial in Blessington's bedroom, and hanged him from a ceiling hook using his own fire escape rope. The murder was initially mistaken for suicide." ;
    ex:hasParticipant :biddle ;
    ex:hasParticipant :hayward ;
    ex:hasParticipant :moffat ;
    ex:hasParticipant :blessington ;
    ex:hasParticipant :trevelyanPageBoy ;
    ex:hasVictim :blessington ;
    ex:weaponUsed :blessingtonRope ;
    ex:occurredAt :blessingtonBedroom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:murderOfLatimerAndKemp a ex:Murder ;
    ex:prefLabel "Murder of Latimer and Kemp" ;
    skos:altLabel "Budapest murders" ;
    ex:description "Latimer and Kemp found stabbed in Budapest. Hungarian police say they quarreled. Holmes suspects Sophy avenged her brother." ;
    ex:hasParticipant :haroldLatimer , :wilsonKemp , :sophyKratides ;
    ex:occurredAt :budapest ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:murderOfTobin a ex:Murder ;
    ex:prefLabel "Murder of Tobin" ;
    ex:description "The murder of Tobin, the caretaker at the Worthingdon bank, during the 1875 robbery by the gang." ;
    ex:narrativeYear "1875" ;
    ex:hasVictim :tobin ;
    ex:occurredAt :worthingdonBank ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:quarrelBarclays a ex:Event ;
    ex:prefLabel "Quarrel Between the Barclays" ;
    ex:description "Furious altercation between Mrs. and Colonel Barclay in the morning-room at Lachine on Monday evening. Mrs. Barclay's words were most bitter: 'You coward! What can be done now? Give me back my life. I will never so much as breathe the same air with you again!' She also used the word 'David' twice as a term of reproach. The Colonel's remarks were subdued and abrupt. Ended with a sudden dreadful cry from the Colonel, a crash, and piercing screams from Mrs. Barclay." ;
    ex:hasParticipant :jamesBarclay, :nancyBarclay ;
    ex:occurredAt :morningRoomLachine ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:reigateInvestigation a ex:Investigation ;
    ex:prefLabel "Reigate Investigation" ;
    skos:altLabel "the Reigate case" ;
    ex:description "Holmes's investigation into the murder of William Kirwan and the connected burglary at Mr. Acton's house, conducted in the spring of 1887 during his convalescence near Reigate. Holmes solved the case by analyzing the handwriting on a torn paper fragment found in the dead man's hand, determining it was written by two blood-relatives doing alternate words. He identified the Cunninghams as the writers, obtained a handwriting sample through a ruse with a reward notice, feigned a fit to prevent the suspects from being alerted, and recovered the remainder of the note from Alec Cunningham's dressing-gown pocket. The investigation was conducted with Inspector Forrester." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :inspectorForrester ;
    ex:hasParticipant :johnWatson, :colonelHayter, :inspectorForrester, :oldCunningham, :alecCunningham, :mrActon ;
    ex:occurredAt :reigate, :cunninghamHouse ;
    ex:narrativeYear "1887"^^xsd:gYear ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:reliefOfBhurtee a ex:Event ;
    ex:prefLabel "Relief of Bhurtee" ;
    ex:description "Bhurtee was relieved by General Neill's column the day after Henry Wood's capture and betrayal. The rebels retreated, taking Wood with them." ;
    ex:hasParticipant :generalNeill ;
    ex:occurredAt :bhurtee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:rescueAtMyrtles a ex:Rescue ;
    ex:prefLabel "Rescue at The Myrtles" ;
    ex:description "Holmes, Watson, Mycroft, and Gregson rescued Melas and found Kratides dying at The Myrtles. Charcoal poisoning in locked room." ;
    ex:hasParticipant :sherlockHolmes , :johnWatson , :mycroftHolmes , :gregson , :mrMelas , :paulKratides ;
    ex:occurredAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:secondKidnappingOfMelas a ex:Kidnapping ;
    ex:prefLabel "Second Kidnapping of Melas" ;
    ex:description "Kemp kidnapped Melas from Pall Mall a second time. Melas beaten and locked in room with charcoal fumes at The Myrtles." ;
    ex:hasParticipant :mrMelas , :wilsonKemp ;
    ex:occurredAt :mycroftLodgings , :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:secondRussianVisit a ex:Meeting ;
    ex:prefLabel "Second visit of the fake Russians" ;
    ex:description "The second visit of the fake Russian count and his son to Dr. Trevelyan's practice, at the same hour as the first. The son again secretly went to Blessington's rooms, leaving fresh footprints on the carpet. The discovery of these footprints sent Blessington into a panic." ;
    ex:hasParticipant :fakeRussianCount ;
    ex:hasParticipant :fakeRussianSon ;
    ex:hasParticipant :percyTrevelyan ;
    ex:occurredAt :403BrookStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:siegeOfBhurtee a ex:Event ;
    ex:prefLabel "Siege of Bhurtee" ;
    ex:description "Siege during the Indian Mutiny at Bhurtee. The regiment, with half a battery of artillery, a company of Sikhs, and civilians including women and children, were besieged by ten thousand rebels. Water ran out about the second week. Henry Wood volunteered to slip through rebel lines to reach General Neill's column. He was betrayed by Sergeant Barclay and captured. Bhurtee was relieved by Neill the next day." ;
    ex:hasParticipant :henryWood, :jamesBarclay, :generalNeill, :royalMunsters, :sikhCompany ;
    ex:occurredAt :bhurtee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:thorBridgeDemonstration a ex:Event ;
    ex:prefLabel "Thor Bridge Demonstration" ;
    ex:description "Holmes demonstrates the method of Mrs. Gibson's suicide at Thor Bridge. He ties Watson's revolver to a string with a heavy stone at the other end, stands on the spot where the body was found, holds the revolver to his head and releases it. The stone's weight whisks the revolver away, striking the parapet (creating a chip matching the original) and pulling it into Thor Mere, proving the suicide-and-framing method." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :sergeantCoventry ;
    ex:occurredAt :thorBridge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:thorBridgeExperiment a ex:FictionalEvent, ex:Experiment ;
    ex:prefLabel "Thor Bridge Experiment" ;
    ex:description "Holmes demonstrates the suicide method at Thor Bridge using Watson's revolver tied to a stone with string purchased from the village shop. Standing on the fatal spot, he raises the pistol to his head and releases his grip. The weight of the stone whisks the revolver away, striking the parapet with a sharp crack and creating a second chip of the exact size and shape of the first, before vanishing into the water. This proves Mrs. Gibson's method of disposing of the weapon and vindicated Grace Dunbar." ;
    ex:conductedBy :sherlockHolmes ;
    ex:location :thorBridge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:thorBridgeInvestigation a ex:Investigation ;
    ex:prefLabel "Thor Bridge Investigation" ;
    ex:description "Holmes investigates the death of Maria Gibson at Thor Bridge, engaged by Neil Gibson to clear Grace Dunbar of the murder charge. Holmes visits Thor Place with Watson, interviews Dunbar at Winchester prison with barrister Joyce Cummings, and solves the case by deducing and demonstrating Mrs. Gibson's suicide method using Watson's revolver, a string, and a stone. The case is solved — Mrs. Gibson committed suicide while framing Dunbar." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :neilGibson ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :neilGibson ;
    ex:hasParticipant :graceDunbar ;
    ex:hasParticipant :sergeantCoventry ;
    ex:hasParticipant :joyceCummings ;
    ex:hasParticipant :marlowBates ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :thorPlace ;
    ex:occurredAt :thorBridge ;
    ex:occurredAt :winchesterPrison ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:thoughtReadingDemonstration a ex:Event ;
    ex:prefLabel "Holmes's thought-reading demonstration" ;
    ex:description "Holmes reads Watson's train of thought from his facial expressions, tracing his thoughts from the newspaper through General Gordon, Beecher, the Civil War, to the futility of war." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:occurredAt :221bBakerStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :cardboardBoxDoc .

:threeGarridebsInvestigation a ex:Event, ex:Investigation ;
    ex:prefLabel "The Three Garridebs Investigation" ;
    ex:description "An investigation conducted by Sherlock Holmes in June 1902, shortly after the conclusion of the South African War. Nathan Garrideb consulted Holmes about finding a third person named Garrideb to fulfill the terms of a will supposedly left by Alexander Hamilton Garrideb. Holmes quickly identified the supposed American lawyer John Garrideb as the criminal Killer Evans, who had concocted the entire scheme to gain access to a hidden counterfeiting press in the cellar beneath Nathan Garrideb's rooms. The case culminated in a confrontation where Evans shot Watson and was subdued by Holmes." ;
    ex:investigatedBy :sherlockHolmes ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :killerEvans ;
    ex:hasParticipant :nathanGarrideb ;
    ex:hasParticipant :lestrade ;
    ex:hasClient :nathanGarrideb ;
    ex:occurredAt :221bBakerStreet ;
    ex:occurredAt :136LittleRyderStreet ;
    ex:occurredAt :scotlandYard ;
    ex:narrativeYear "1902" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeGarridebsDoc .

:threeStudentsInvestigation a ex:Investigation ;
    ex:prefLabel "Investigation into the Fortescue Exam Tampering" ;
    ex:description "Holmes investigates who tampered with the Fortescue Scholarship examination proofs at the College of St. Luke's in 1895. Engaged by Hilton Soames to handle the matter discreetly and avoid scandal. Holmes examines the crime scene, visits the three students' rooms, checks stationers for the unusual pencil, and collects clay from the athletic grounds jumping pit. Deduces that Gilchrist is the culprit based on his height (tall enough to see proofs through the window), the clay matching the jumping pit, and the pattern of evidence. The investigation concludes with Gilchrist's confession and his decision to join the Rhodesian Police." ;
    ex:narrativeYear "1895" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :hiltonSoames ;
    ex:hasParticipant :bannisterServant ;
    ex:hasParticipant :gilchrist ;
    ex:hasParticipant :daulatRas ;
    ex:hasParticipant :milesMcLaren ;
    ex:occurredAt :collegeOfStLukes ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :hiltonSoames ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :threeStudentsDoc .

:timberYardFire a ex:Event ;
    ex:prefLabel "The Timber-Yard Fire" ;
    ex:description "Fire at Oldacre's timber-yard behind Deep Dene House. Animal bones and trouser buttons were burned to simulate Oldacre's cremation. Part of the faked murder scheme." ;
    ex:hasParticipant :jonasOldacre ;
    ex:occurredAt :oldacreTimberYard ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :norwoodBuilderDoc .

:tredannickWarthaPoisoning a ex:Crime, ex:Murder ;
    ex:prefLabel "Poisoning at Tredannick Wartha" ;
    skos:altLabel "the Cornish Horror" ;
    ex:description "On the night of March 16, 1897, Mortimer Tregennis placed devil's-foot root powder in the fire at Tredannick Wartha shortly before leaving after a game of whist. The poison's fumes killed his sister Brenda and drove his brothers George and Owen permanently insane. Motivated by a desire to gain control of the joint family property. The victims were found the next morning exactly as they had been sitting, with expressions of utmost horror on their faces." ;
    ex:occurredAt :tredannickWartha ;
    ex:hasParticipant :mortimerTregennis ;
    ex:hasParticipant :brendaTregennis ;
    ex:hasParticipant :georgeTregennis ;
    ex:hasParticipant :owenTregennis ;
    ex:hasVictim :brendaTregennis ;
    ex:hasVictim :georgeTregennis ;
    ex:hasVictim :owenTregennis ;
    ex:hasPerpetrator :mortimerTregennis ;
    ex:eventYear "1897"^^xsd:gYear ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:trialKittyWinter a ex:Event ;
    ex:prefLabel "Trial of Kitty Winter" ;
    ex:description """The police-court hearing and subsequent trial of Kitty Winter on the grave charge of vitriol-throwing. Extenuating circumstances emerged during the trial, and the sentence was the lowest possible for such an offence.""" ;
    ex:hasParticipant :kittyWinter ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:trialOfMoriartyGang a ex:Event ;
    ex:prefLabel "Trial of the Moriarty gang" ;
    ex:description "Trial that broke up the Moriarty criminal organization but left two of its most dangerous members at liberty, including Colonel Moran. Occurred after the Reichenbach Falls confrontation." ;
    ex:occurredAt :london ;
    ex:hasParticipant :moriartyCriminalOrganization ;
    ex:hasParticipant :colonelSebastianMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
