:vanSeddar a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Van Seddar" ;
    ex:prefLabel "Van Seddar" ;
    skos:altLabel "the Dutchman" ;
    ex:description "Van Seddar is a Dutch diamond cutter and fence located at Lime Street. Count Sylvius planned to send the stolen Mazarin Stone to him to be cut into four pieces in Amsterdam. He was originally going next week but was told to leave by the next boat due to Holmes's investigation. Merton refers to him as 'the Dutchman'. A false bottom was being prepared for him to transport the stone but was not ready." ;
    ex:occupation "diamond cutter, fence" ;
    ex:locatedAt :limeStreet ;
    ex:knows :countNegrettoSylvius ;
    ex:knows :samMerton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

