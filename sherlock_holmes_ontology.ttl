:nancyBarclay a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Nancy" ;
    ex:lastName "Barclay" ;
    ex:maidenName "Devoy" ;
    ex:prefLabel "Nancy Barclay" ;
    skos:altLabel "Mrs. Barclay" ;
    skos:altLabel "Nancy Devoy" ;
    skos:altLabel "Miss Nancy Devoy" ;
    ex:description "Wife of Colonel James Barclay. Maiden name Nancy Devoy, daughter of a former color-sergeant in the Royal Munsters. Member of the Roman Catholic Church and the Guild of St. George at Watt Street Chapel. Described as a woman of great beauty, still of striking and queenly appearance after thirty years of marriage. Originally loved Corporal Henry Wood, but her father wanted her to marry Barclay. Believed Henry Wood had been dead for thirty years. On the evening of the incident, attended a Guild meeting, encountered Henry Wood on Hudson Street while returning with Miss Morrison. Returned home in great agitation, quarreled violently with her husband, calling him 'You coward!' and 'David' (a biblical reproach referencing the story of Uriah). Fell insensible when her husband died. Suffered acute brain-fever. Initially suspected of murder but cleared by inquest finding of apoplexy." ;
    ex:religion "Roman Catholic" ;
    ex:livesAt :lachine ;
    ex:isMarriedTo :jamesBarclay ;
    ex:childOf :colorSergeantDevoy ;
    ex:knows :jamesBarclay, :henryWood, :missMorrison ;
    ex:memberOf :guildOfStGeorge, :romanCatholicChurch ;
    ex:hasParticipatedIn :encounterHudsonStreet, :quarrelBarclays ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

