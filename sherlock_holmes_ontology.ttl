    ex:lastName "Warrender" ;
    ex:prefLabel "Miss Minnie Warrender" ;
    ex:description "Miss Minnie Warrender is a person whose complete life history is recorded in Holmes's notebook regarding Count Negretto Sylvius's crimes. The nature of Sylvius's offence against her is not specified." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :mazarinStoneDoc .

:missBurnet a ex:FictionalPerson, ex:Governess ;
    ex:firstName "Burnet" ;
    ex:prefLabel "Miss Burnet" ;
    skos:altLabel "Signora Victor Durando" ;
    skos:altLabel "Signora Durando" ;
    ex:description "An Englishwoman of about forty who served as governess at High Gable under the alias Miss Burnet. Her real name is Signora Victor Durando, widow of the San Pedro minister in London who was recalled and shot by Murillo's order. Aquiline and emaciated face. Infiltrated Henderson's household as governess to track his movements for the San Pedro revenge society. Wrote the note to Garcia signed 'D' (for Durando) with directions to Henderson's room. Discovered by Lopez while writing the note; was gagged, confined, tortured for five days, and drugged with opium. Rescued by John Warner at the train station when Henderson tried to flee." ;
    ex:occupation "governess" ;
    ex:physicalDescription "Aquiline and emaciated face, about forty years old" ;
    ex:isMarriedTo :victorDurando ;
    ex:governessOf :hendersonElderDaughter ;
    ex:governessOf :hendersonYoungerDaughter ;
    ex:employedBy :donMurillo ;
    ex:memberOf :sanPedroRevengeSociety ;
    ex:knows :aloysiusGarcia ;
    ex:knows :donMurillo ;
    ex:knows :lopez ;
    ex:knows :johnWarner ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:missMiles a ex:FictionalPerson, ex:Victim ;
    ex:lastName "Miles" ;
    ex:prefLabel "Honourable Miss Miles" ;
    skos:altLabel "Miss Miles" ;
    ex:description "A woman mentioned by Milverton during his negotiation with Holmes. Her engagement to Colonel Dorking was broken off only two days before the wedding, as reported in the Morning Post. Milverton implies he was responsible, noting that twelve hundred pounds would have settled the matter." ;
    ex:blackmailedBy :charlesAugustusMilverton ;
    ex:engagedTo :colonelDorking ;
    ex:memberOfOntology ex:SherlockOntology ;
