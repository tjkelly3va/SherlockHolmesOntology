:shoscombe a ex:Village ;
    ex:prefLabel "Shoscombe" ;
    ex:description "Shoscombe is a village in Berkshire, England. It has a halt-on-demand railway station. It is the location of Shoscombe Old Place and Shoscombe Park." ;
    ex:locatedIn :berkshire, :england, :unitedKingdom ;
    ex:inCounty :berkshire ;
    ex:inRegion :england ;
    ex:inCountry :unitedKingdom ;
