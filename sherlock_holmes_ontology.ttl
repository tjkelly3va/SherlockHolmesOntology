    ex:lastName "Tussaud" ;
    ex:prefLabel "Madame Tussaud" ;
    ex:description "Madame Tussaud is the famous waxwork artist referenced by Sam Merton when he sees the wax dummy of Holmes, exclaiming that Madame Tussaud is not in comparison to the quality of the dummy." ;
