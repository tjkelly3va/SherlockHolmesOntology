    ex:firstName "Henry David" ;
    ex:lastName "Thoreau" ;
    ex:prefLabel "Henry David Thoreau" ;
    skos:altLabel "Thoreau" ;
    ex:description "Real historical figure referenced by Holmes: 'Circumstantial evidence is occasionally very convincing, as when you find a trout in the milk, to quote Thoreau's example.' American writer and philosopher." ;
    ex:occupation "Writer, philosopher" ;
    ex:memberOfOntology ex:SherlockOntology ;
