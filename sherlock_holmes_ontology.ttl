:neilGibson a ex:FictionalPerson ;
    ex:firstName "Neil" ;
    ex:lastName "Gibson" ;
    ex:prefLabel "Neil Gibson" ;
    skos:altLabel "Gold King" ;
    skos:altLabel "Senator Gibson" ;
    skos:altLabel "J. Neil Gibson" ;
    ex:description "Neil Gibson, known as the Gold King, is the greatest gold-mining magnate in the world and a former United States Senator for a Western state. He is a man of violent and formidable character — tall, gaunt, and craggy, with cold gray eyes and deep-lined face suggesting an Abraham Lincoln keyed to base uses. He married Maria Pinto while gold-hunting in Brazil, bought a considerable estate in Hampshire (Thor Place) about five years ago. He was brutal to his wife after his love faded, and developed strong feelings for Grace Dunbar, governess to his two children, though she refused his advances. He engages Holmes to clear Miss Dunbar of the murder charge. Gibson has a formidable collection of firearms and sleeps with a loaded revolver." ;
    ex:occupation "gold-mining magnate, former United States Senator" ;
    ex:nationality "American" ;
    ex:isMarriedTo :mariaGibson ;
    ex:parentOf :gibsonChildren ;
    ex:employs :graceDunbar ;
    ex:employs :marlowBates ;
    ex:employs :fergusonThorBridge ;
    ex:livesAt :thorPlace ;
    ex:owns :thorPlace ;
    ex:owns :gibsonFirearmsCollection ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :thorBridgeDoc .

:norlett a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Norlett" ;
    ex:prefLabel "Norlett" ;
    skos:altLabel "Mr. Norlett" ;
    ex:description "Norlett is the husband of Carrie Evans and an actor. He is described as small, rat-faced, with a disagreeably furtive manner. He impersonates Lady Beatrice Falder by riding in her carriage disguised as the invalid. He assists Sir Robert in moving Lady Beatrice's body from the well-house to the crypt and in burning the ancient remains displaced from the coffin. He entirely disclaims all responsibility for the concealment scheme." ;
    ex:occupation "actor" ;
    ex:isMarriedTo :carrieEvans ;
    ex:impersonates :beatriceFalder ;
    ex:knows :robertNorberton ;
    ex:hasParticipantIn :concealmentOfDeath, :shoscombeInvestigation ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:pictureFrameMaker a ex:FictionalPerson, ex:Suspect ;
    ex:prefLabel "Picture-Frame Maker" ;
    ex:description "An unnamed picture-frame maker who is the accused in the St. Pancras case. He denies that a cap found beside a dead policeman is his, but he habitually handles glue, which Holmes identifies on the cap. His name is not given in the text." ;
    ex:occupation "picture-frame maker" ;
    ex:hasParticipantIn :stPancrasCase ;
