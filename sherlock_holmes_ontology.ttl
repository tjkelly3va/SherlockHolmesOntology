    ex:title "Sir" ;
    ex:prefLabel "Sir Ralph Musgrave" ;
    ex:description "Ancestor of Reginald Musgrave, described as a prominent Cavalier and the right-hand man of Charles the Second in his wanderings. He presumably hid the ancient crown of England at Hurlstone using the directions encoded in the Musgrave Ritual." ;
    ex:memberOf :musgraveFamily ;
    ex:ancestorOf :reginaldMusgrave ;
    ex:supporterOf :charlesII ;
    ex:hid :ancientCrownOfEngland ;
