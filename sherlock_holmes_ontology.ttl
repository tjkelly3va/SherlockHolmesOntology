    ex:hasParticipatedIn :cardGameOnVoyage ;
    ex:hasParticipatedIn :holmesWoodleyFight ;
    ex:hasParticipatedIn :trialWilliamsonWoodley ;
    ex:knows :bobCarruthers ;
    ex:knows :williamsonExClergyman ;
    ex:knows :ralphSmith ;
    ex:knows :violetSmith ;
    ex:knows :sherlockHolmes ;
    ex:owns :woodleysRidingCrop ;
    ex:shotBy :bobCarruthers ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

