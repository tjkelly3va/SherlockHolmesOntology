:illustriousClient a ex:FictionalPerson ;
    ex:prefLabel "The Illustrious Client" ;
    ex:description """The illustrious client is an unnamed person of very high social standing who engages Holmes through Sir James Damery as intermediary to prevent Baron Gruner's marriage to Violet de Merville. He is an old friend of General de Merville who has known the General intimately for many years and taken a paternal interest in Violet since she was a child. His motives are honourable and chivalrous. He insists on remaining anonymous. He provides the Ming dynasty saucer from his own collection for Holmes's scheme. At the end of the story, Watson sees armorial bearings on the client's brougham and recognizes his identity, but Holmes prevents him from naming the person. His name is not given in the text.""" ;
    ex:knows :generalDeMerville ;
    ex:knows :jamesDamery ;
    ex:owns :mingDynastySaucer ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :illustriousClientDoc .

:inspectorBaynes a ex:FictionalPerson, ex:Detective ;
    ex:firstName "Baynes" ;
    ex:prefLabel "Inspector Baynes" ;
    skos:altLabel "Baynes" ;
    skos:altLabel "Mr. Baynes" ;
    ex:description "Inspector of the Surrey Constabulary. A stout, puffy, red-faced man with extraordinarily bright eyes almost hidden behind heavy creases of cheek and brow. A shrewd and capable detective who independently investigated Henderson/Murillo. Deliberately arrested the mulatto cook as a decoy to make Henderson feel safe enough to flee, enabling the rescue of Miss Burnet. Had a plain-clothes man watching the station. Holmes praised his instinct and intuition." ;
    ex:occupation "police inspector" ;
    ex:physicalDescription "Stout, puffy, red-faced man with extraordinarily bright eyes almost hidden behind heavy creases of cheek and brow" ;
    ex:employedBy :surreyConstabulary ;
    ex:investigates :wisteriaLodgeInvestigation ;
    ex:knows :sherlockHolmes ;
    ex:knows :tobiasGregson ;
    ex:knows :constableWalters ;
    ex:knows :constableDowning ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:inspectorForrester a ex:FictionalPerson, ex:PoliceOfficer ;
    ex:firstName "Forrester" ;
    ex:lastName "Forrester" ;
    ex:title "Inspector" ;
    ex:prefLabel "Inspector Forrester" ;
    skos:altLabel "Forrester" ;
    skos:altLabel "the Inspector" ;
    ex:description "A smart, keen-faced young fellow serving as local police inspector near Reigate. He investigated the Acton burglary and the murder of William Kirwan. He came to Colonel Hayter's house seeking Holmes's assistance. He presented the torn paper fragment found in the dead man's hand and shared details of the case. He arrested the Cunninghams on Holmes's instruction and knocked a revolver from Alec Cunningham's hand during the arrest." ;
    ex:occupation "police inspector" ;
    ex:participantIn :reigateInvestigation, :cunninghamArrest ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

