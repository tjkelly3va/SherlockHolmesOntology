:ridlingThorpeStableBoy a ex:FictionalPerson ;
    ex:prefLabel "Ridling Thorpe stable-boy" ;
    skos:altLabel "the lad" ;
    skos:altLabel "the youth" ;
    ex:description "An unnamed stable-boy at Ridling Thorpe Manor. Initially suspected of drawing the dancing men on the window-sill, but swore he knew nothing. He later remembered that a farmer named Elrige lived some miles off in the direction of East Ruston. He delivered Holmes's decoy note written in dancing men cipher to Abe Slaney at Elrige's Farm and was instructed to answer no questions." ;
    ex:occupation "Stable-boy" ;
    ex:employedBy :hiltonCubitt ;
    ex:livesAt :ridlingThorpeManor ;
    ex:memberOfOntology ex:SherlockOntology ;
