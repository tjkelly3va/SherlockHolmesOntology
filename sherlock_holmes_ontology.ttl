:woolwich a ex:Town ;
    ex:prefLabel "Woolwich" ;
    ex:description "Town in southeast London. Location of Woolwich Arsenal, the Submarine Department office, and the homes of the Cadogan Wests and Sir James Walter. Holmes and Watson traveled there to investigate." ;
    ex:locatedIn :england ;
    ex:locatedIn :london ;
    ex:locatedIn :unitedKingdom ;
