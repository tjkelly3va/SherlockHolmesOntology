:ikeySanders a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "Ikey" ;
    ex:lastName "Sanders" ;
    ex:prefLabel "Ikey Sanders" ;
    ex:description "Ikey Sanders is a criminal who refused to cut up the stolen Crown diamond for Count Negretto Sylvius. He subsequently informed on Sylvius and Sam Merton to Holmes, providing crucial evidence in the case." ;
    ex:knows :countNegrettoSylvius ;
