:deduction_missingThreeQuarter_holmes_01 a ex:Deduction ;
    ex:prefLabel "Holmes Deduces Overton Was Excited and Incoherent" ;
    ex:description "Upon receiving a cryptic telegram about a missing three-quarter, Holmes analyzes the telegram itself before the sender arrives at Baker Street." ;
    ex:deductionSequence 1 ;
    ex:deductionSummary "The telegram sender was considerably excited and somewhat incoherent when he sent the message." ;
    ex:deductionReasoning "Holmes read the telegram over repeatedly and noted the Strand post-mark, the dispatch time of ten-thirty-six, and the disjointed phrasing of the message, concluding that Mr. Overton was in a state of considerable excitement and incoherence when composing it." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :cyrilOverton ;
