:colonelGreathed a ex:RealPerson, ex:MilitaryOfficer ;
    ex:lastName "Greathed" ;
    ex:prefLabel "Colonel Greathed" ;
    ex:description "Real historical military figure. Led a flying column to Agra to clear the Pandies (rebels) after the Indian Mutiny." ;
    ex:gender "male" ;
    ex:rank "Colonel" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:colonelRoss a ex:FictionalPerson ;
    ex:lastName "Ross" ;
    ex:prefLabel "Colonel Ross" ;
    skos:altLabel "the Colonel" ;
    ex:description "Well-known sportsman and owner of racehorse Silver Blaze. Small, alert person, very neat and dapper, in a frock-coat and gaiters, with trim little side-whiskers and an eye-glass. Has been on the turf for twenty years. Owner of the King's Pyland training stables where John Straker was trainer. Sent a telegram to Holmes on Tuesday evening requesting cooperation. Met Holmes and Watson at Tavistock station. Manner was a trifle cavalier toward Holmes. Initially doubted Holmes's abilities. Considered removing Silver Blaze from Wessex Cup entries but Holmes advised against it. Accompanied Holmes to Winchester for the race. Recognized Silver Blaze after Holmes indicated the horse's face and leg could be washed with spirits of wine to reveal its true appearance." ;
    ex:occupation "sportsman" ;
    ex:employs :johnStraker ;
    ex:knows :sherlockHolmes, :inspectorGregory, :johnStraker ;
    ex:owns :silverBlaze, :kingsPyland, :bayard ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

:colonelUpwood a ex:FictionalPerson ;
    ex:lastName "Upwood" ;
    ex:prefLabel "Colonel Upwood" ;
    ex:description "Mentioned in the retrospection chapter. Holmes exposed his atrocious conduct in connection with the famous card scandal of the Nonpareil Club." ;
    ex:occupation "military officer" ;
    ex:memberOf :nonpareilClub ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:colonelWarburton a ex:FictionalPerson ;
    ex:lastName "Warburton" ;
