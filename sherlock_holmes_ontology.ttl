:barOfGoldLascar a ex:FictionalPerson, ex:Criminal ;
    ex:prefLabel "The Lascar (Bar of Gold Proprietor)" ;
    skos:altLabel "the Lascar" ;
    skos:altLabel "the rascally Lascar" ;
    ex:description "The Lascar is the unnamed proprietor of the Bar of Gold opium den in Upper Swandam Lane. Described as a sallow Malay attendant. Has sworn vengeance on Holmes for previous use of the den. Blocked Mrs. St. Clair from ascending the stairs, aided by the Dane. A man of the vilest antecedents. Was paid by St. Clair for his rooms as a changing space. Forwarded St. Clair ring and letter to Mrs. St. Clair, though with delay as he was watched by police. Name not given in text." ;
    ex:occupation "opium den proprietor" ;
    ex:nationality "Lascar (East Indian sailor)" ;
