:watsonBereavement a ex:Event ;
    ex:prefLabel "Watson's bereavement" ;
    ex:description "Watson's 'sad bereavement' mentioned in the narrative. Strongly implies the death of Mary Watson (née Morstan). Holmes had learned of it and showed sympathy in his manner rather than his words." ;
    ex:hasParticipant :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
