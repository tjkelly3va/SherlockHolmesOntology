:theGablesEstablishment a ex:EducationalInstitution ;
    ex:prefLabel "The Gables Coaching Establishment" ;
    skos:altLabel "The Gables" ;
    ex:description "The Gables is Harold Stackhurst's well-known coaching establishment near Fulworth, Sussex. It is a large place containing some score (about twenty) young fellows preparing for various professions, with a staff of several masters. Fitzroy McPherson was the science master and Ian Murdoch the mathematical coach. The Gables is where the inquest on McPherson is held." ;
    ex:hasMember :haroldStackhurst, :fitzroyMcPherson, :ianMurdoch, :sudbury, :blount ;
    ex:locatedIn :fulworth ;
    ex:ownedBy :haroldStackhurst ;
    ex:memberOfOntology ex:SherlockOntology ;
