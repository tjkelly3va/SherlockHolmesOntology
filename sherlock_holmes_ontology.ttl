    ex:lastName "Wilcox" ;
    ex:prefLabel "Chester Wilcox" ;
    skos:altLabel "Wilcox" ;
    ex:description "Chief foreman of the Iron Dike Company. Old colour sergeant of the war, all scars and grizzle. Armed and shoots quick and straight. Survived multiple assassination attempts including the blasting of his house." ;
    ex:occupation "Chief foreman; former colour sergeant" ;
    ex:employedBy :ironDikeCompany ;
    ex:memberOfOntology ex:SherlockOntology ;
