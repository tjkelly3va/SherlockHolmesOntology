:londonPolice a ex:FictionalOrganization, ex:LawEnforcement ;
    ex:prefLabel "London Police" ;
    ex:description "The London police force. Holmes telegraphed them from Strasbourg on Monday morning. They arrested Moriarty's entire gang except for Moriarty himself. Holmes's accumulated evidence exposed the criminal organization." ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:marxAndCo a ex:Organization, ex:Clothier ;
    ex:prefLabel "Marx and Co." ;
    ex:description "Clothiers at High Holborn, London. Clothing with their stamp was left behind at Wisteria Lodge. They knew nothing of their customer save that he was a good payer." ;
    ex:locatedIn :highHolborn ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:metropolitanRailway a ex:RailwayCompany ;
    ex:prefLabel "Metropolitan Railway" ;
    ex:description "Railway company operating the Underground trains in London. A courteous red-faced old gentleman represented the company at Aldgate Station during Holmes's investigation." ;
    ex:memberOfOntology ex:SherlockOntology ;
