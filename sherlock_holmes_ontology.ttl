:johnClay a ex:FictionalPerson, ex:Criminal, ex:Forger ;
    ex:firstName "John" ;
    ex:lastName "Clay" ;
    ex:prefLabel "John Clay" ;
    skos:altLabel "Clay" ;
    skos:altLabel "Vincent Spaulding" ;
    ex:description "John Clay is a murderer, thief, smasher, and forger who uses the alias Vincent Spaulding while working as Jabez Wilson's assistant at half wages. Small, stout-built, very quick, clean-shaven, about thirty years old. Has a white splash of acid upon his forehead and ears pierced for earrings. Grandfather was a royal duke; educated at Eton and Oxford. Claims royal blood. Holmes considers him the fourth smartest man in London and perhaps third for daring. Uses photography hobby as cover for cellar access. Masterminded the Red-headed League scheme to get Wilson out of the shop while tunneling to the City and Suburban Bank vault. Captured by Holmes in the vault, handcuffed by Peter Jones. Had a revolver knocked from his hand by Holmes's hunting crop. Coolly demands to be addressed as 'sir' upon arrest." ;
    ex:occupation "criminal; pawnbroker's assistant (cover)" ;
    ex:alias "Vincent Spaulding" ;
    ex:hairColor "not specified" ;
    ex:physicalDescription "Small, stout-built, very quick, clean-shaven, about thirty. White splash of acid on forehead. Ears pierced for earrings. Clean-cut, boyish face." ;
    ex:accompliceOf :duncanRoss ;
    ex:arrestedBy :peterJones ;
    ex:arrestedBy :sherlockHolmes ;
    ex:educatedAt :eton ;
    ex:educatedAt :oxford ;
    ex:employedBy :jabezWilson ;
    ex:knows :duncanRoss ;
    ex:knows :jabezWilson ;
    ex:knows :peterJones ;
    ex:knows :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:johnClayton a ex:FictionalPerson ;
    ex:firstName "John" ;
    ex:lastName "Clayton" ;
    ex:prefLabel "John Clayton" ;
    skos:altLabel "Clayton" ;
    skos:altLabel "cabman 2704" ;
    ex:description "London cabman, cab number 2704. Lives at 3 Turpey Street, the Borough. His cab operates from Shipley's Yard near Waterloo Station. Drove the spy who followed Sir Henry and Dr. Mortimer. The fare hailed him at half-past nine in Trafalgar Square, offered two guineas to follow instructions all day. The fare claimed to be a detective and upon leaving gave his name as Mr. Sherlock Holmes. Clayton described the fare as about forty, middle height, black beard cut square, and a pale face." ;
    ex:occupation "cabman" ;
    ex:livesAt :turpeyStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

