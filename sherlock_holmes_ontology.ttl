:johnDouglas a ex:FictionalPerson, ex:Detective, ex:Victim ;
    ex:firstName "John" ;
    ex:lastName "Douglas" ;
    ex:prefLabel "John Douglas" ;
    skos:altLabel "Birdy Edwards" ;
    skos:altLabel "Jack McMurdo" ;
    skos:altLabel "Mr. Douglas" ;
    ex:description "Central character of The Valley of Fear. Real identity is Birdy Edwards, a Pinkerton detective who infiltrated the Scowrers in Vermissa Valley under the alias Jack McMurdo. After breaking up the gang, he was hunted from Chicago to California to England. About fifty years old, grizzled hair and moustache, bold gray eyes, square projecting chin. Married Ettie Shafter (who died in California), then married Ivy Douglas and settled at Birlstone Manor House in Sussex. Killed Ted Baldwin in self-defense and staged his own death. Ultimately lost overboard from the ship Palmyra near St. Helena, murdered by Moriarty's agents." ;
    ex:occupation "Pinkerton detective" ;
    ex:friendOf :cecilBarker ;
    ex:isMarriedTo :ivyDouglas ;
    ex:knows :cecilBarker, :ivyDouglas, :ettieShafter, :bossMcGinty, :mikeScanlan, :captainMarvin, :brotherMorris ;
