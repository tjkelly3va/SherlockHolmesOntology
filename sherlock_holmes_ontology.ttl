:colonelSebastianMoran a ex:FictionalPerson, ex:Criminal, ex:MilitaryOfficer ;
    ex:firstName "Sebastian" ;
    ex:lastName "Moran" ;
    ex:prefLabel "Colonel Sebastian Moran" ;
    skos:altLabel "Colonel Moran" ;
    skos:altLabel "Moran" ;
    ex:description "Colonel Sebastian Moran. Formerly 1st Bengalore Pioneers. Born London, 1840. Son of Sir Augustus Moran, C.B., once British Minister to Persia. Educated at Eton and Oxford. Served in the Jowaki Campaign, Afghan Campaign, Charasiab (despatches), Sherpur, and Cabul. Author of 'Heavy Game of the Western Himalayas' (1881) and 'Three Months in the Jungle' (1884). Address: Conduit Street. Clubs: Anglo-Indian, Tankerville, Bagatelle Card Club. Best heavy game shot that the Eastern Empire has ever produced. Chief of staff to Professor Moriarty. Described by Holmes as 'the second most dangerous man in London'. Murdered Ronald Adair by firing an expanding bullet from Von Herder's air-gun through the open window at 427 Park Lane. Threw rocks at Holmes on the Reichenbach ledge. Attempted to assassinate Holmes at Camden House using the same air-gun. Captured by Holmes, Watson, and Lestrade. Referenced by Holmes as someone who, like Moriarty, had threatened to get level with him." ;
    ex:occupation "former military officer, criminal" ;
    ex:birthYear "1840"^^xsd:gYear ;
    ex:address "Conduit Street, London" ;
    ex:childOf :sirAugustusMoran ;
    ex:knows :professorMoriarty ;
    ex:knows :ronaldAdair ;
    ex:knows :sherlockHolmes ;
    ex:knows :godfreyMilner ;
    ex:knows :lordBalmoral ;
    ex:employedBy :professorMoriarty ;
    ex:memberOf :angloIndianClub ;
    ex:memberOf :tankervilleClub ;
    ex:memberOf :bagatellCardClub ;
    ex:memberOf :moriartyCriminalOrganization ;
    ex:educatedAt :eton ;
    ex:educatedAt :oxford ;
    ex:servedIn :firstBengalorePioneers ;
    ex:servedIn :herMajestysIndianArmy ;
    ex:authorOf :heavyGameBook ;
    ex:authorOf :threeMonthsJungleBook ;
    ex:usedWeapon :vonHerderAirGun ;
    ex:livesAt :conduitStreet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :emptyHouseDoc ;
    dc:source :hisLastBowDoc .

:colonelSpenceMunro a ex:FictionalPerson ;
    ex:firstName "Spence" ;
    ex:lastName "Munro" ;
    ex:prefLabel "Colonel Spence Munro" ;
    skos:altLabel "Colonel Munro" ;
    ex:description """Colonel Spence Munro was Violet Hunter's previous employer, in whose family she served as governess for five years. Two months before the story, the Colonel received an appointment at Halifax, in Nova Scotia, and took his children over to America with him, leaving Violet without a situation. He paid her four pounds a month.""" ;
    ex:occupation "military officer" ;
    ex:employs :violetHunter ;
    ex:knows :violetHunter ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :copperBeechesDoc .

:colonelValentineWalter a ex:FictionalPerson, ex:Criminal, ex:Traitor ;
    ex:firstName "Valentine" ;
    ex:lastName "Walter" ;
    ex:title "Colonel" ;
    ex:prefLabel "Colonel Valentine Walter" ;
    skos:altLabel "Colonel Walter" ;
    skos:altLabel "Colonel Valentine" ;
    ex:description "Younger brother of Sir James Walter, the head of the Submarine Department. A very tall, handsome, light-bearded man of about fifty, with soft delicate features. Pressed for money due to a Stock Exchange debt. Made an impress of his brother's keys to the Arsenal safe. Entered into correspondence with Hugo Oberstein through the advertisement columns of the Daily Telegraph (Pierrot ads). On Monday night went to the Arsenal office in the fog, stole the Bruce-Partington plans, and took them to Oberstein at 13 Caulfield Gardens. Followed unknowingly by Cadogan West. When West confronted them, Oberstein killed West. Walter helped place body on train roof. Caught by Holmes at Oberstein's house while arriving disguised in broad-brimmed hat and cravat. Confessed to the theft but denied the murder. Wrote letter to Oberstein at Holmes's dictation to lure him back. Died in prison towards the end of the second year of his sentence. His brother suspected but said nothing." ;
    ex:age "approximately 50" ;
    ex:siblingOf :sirJamesWalter ;
    ex:knows :sirJamesWalter ;
    ex:knows :hugoOberstein ;
    ex:stoleFrom :submarineDepartmentOffice ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:constableBarrett a ex:FictionalPerson, ex:Constable ;
    ex:lastName "Barrett" ;
    ex:prefLabel "Constable Barrett" ;
    skos:altLabel "Police-constable Barrett" ;
    ex:description "Police-constable who discovered the body of Eduardo Lucas. Was passing along Godolphin Street and observed that the door of No. 16 was ajar at a quarter to twelve. Knocked but received no answer. Perceiving a light in the front room, advanced into the passage and again knocked. Pushed open the door and entered, finding the room in wild disorder and Lucas dead beside a chair." ;
    ex:occupation "police constable" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:constableDowning a ex:FictionalPerson, ex:Constable ;
    ex:lastName "Downing" ;
    ex:prefLabel "Constable Downing" ;
    skos:altLabel "Downing" ;
    ex:description "Police constable badly bitten by the mulatto cook during his capture at Wisteria Lodge. His thumb was nearly bitten off." ;
    ex:occupation "police constable" ;
    ex:employedBy :surreyConstabulary ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:constableMacPherson a ex:FictionalPerson, ex:Constable ;
    ex:lastName "MacPherson" ;
    ex:prefLabel "Constable MacPherson" ;
    skos:altLabel "MacPherson" ;
    ex:description "Big constable assigned to guard the crime scene at 16 Godolphin Street. Hot and penitent when confessing to Lestrade. Admitted a young woman (actually Lady Hilda in disguise) who claimed to be answering a typewriting advertisement and had come to the wrong number. The woman asked to see where the crime was done. When she saw the bloodstain she dropped to the floor as if dead. MacPherson went to the back for water and then round the corner to the Ivy Plant pub for brandy. The woman had recovered and left by the time he returned. The drugget was rumpled. Confessed under Lestrade's questioning. Also opened the door to let Holmes and Watson out; Holmes showed him the cut-out portrait and the constable recognised it with amazement." ;
    ex:occupation "police constable" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:constableWalters a ex:FictionalPerson, ex:Constable ;
    ex:lastName "Walters" ;
    ex:prefLabel "Constable Walters" ;
    skos:altLabel "Walters" ;
    ex:description "Police constable left in possession of Wisteria Lodge after Garcia's murder. Frightened by the mulatto cook's face at the window. Pursued the intruder but lost him." ;
    ex:occupation "police constable" ;
    ex:employedBy :surreyConstabulary ;
    ex:knows :inspectorBaynes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

