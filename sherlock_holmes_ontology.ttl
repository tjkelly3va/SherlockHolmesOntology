:watsonElderBrother a ex:FictionalPerson ;
    ex:prefLabel "Watson's Elder Brother" ;
    ex:description "Watson's deceased elder brother. Initials H.W. Inherited father's watch (nearly 50 years old). Left with good prospects but threw away his chances. Lived in poverty with occasional prosperity. Took to drink and died. Careless, untidy habits. Watch pawned multiple times. Name not given in text." ;
    ex:gender "male" ;
    ex:siblingOf :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

