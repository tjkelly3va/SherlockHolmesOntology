:willoughbySmith a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Willoughby" ;
    ex:lastName "Smith" ;
    ex:prefLabel "Willoughby Smith" ;
    skos:altLabel "Mr. Willoughby Smith" ;
    skos:altLabel "young Smith" ;
    ex:description "Young secretary to Professor Coram at Yoxley Old Place. Educated at Uppingham and Cambridge. Described as decent, quiet, hardworking with no weak spot. Found murdered in the Professor's study, stabbed in the neck by a sealing-wax knife that severed the carotid artery. His dying words were 'The Professor—it was she.' Had a golden pince-nez clutched in his right hand, snatched from his killer. Had met the woman (Anna) on the road that morning and asked her about Professor Coram, not knowing she was his wife. Had excellent eyesight." ;
    ex:occupation "secretary" ;
    ex:livesAt :yoxleyOldPlace ;
    ex:employedBy :professorCoram ;
    ex:educatedAt :uppinghamSchool ;
    ex:educatedAt :cambridgeUniversity ;
    ex:killedBy :annaCoram ;
    ex:participantIn :murderOfWilloughbySmith ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:wilson a ex:FictionalPerson ;
    ex:firstName "Wilson" ;
    ex:prefLabel "Wilson" ;
    ex:description "Manager of a district messenger office in London. Holmes had previously helped him in a case, saving his good name and perhaps his life. Had Cartwright among his boys." ;
    ex:occupation "manager, district messenger office" ;
    ex:knows :cartwright ;
    ex:knows :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
