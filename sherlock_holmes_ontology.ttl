:nihilistBrotherhood a ex:Organization ;
    ex:prefLabel "Nihilist Brotherhood" ;
    skos:altLabel "the Brotherhood" ;
    skos:altLabel "the Order" ;
    skos:altLabel "the Nihilists" ;
    ex:description "A Russian revolutionary organization of Nihilists. Members included Sergius (Professor Coram), Anna, Alexis, and many others. Involved in political reform activities; a police officer was killed during their activities. Sergius betrayed the group to save himself; some members were executed, others sent to Siberia. The Brotherhood was feared by Sergius, who knew they would exact justice if they discovered his location in England." ;
    ex:locatedIn :russia ;
    ex:hasMember :professorCoram ;
    ex:hasMember :annaCoram ;
    ex:hasMember :alexis ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:oxfordUniversity a ex:University ;
    ex:prefLabel "Oxford University" ;
    ex:description "Rival university to Cambridge. Their rugby team won the Varsity match by a goal and two tries. Morton and Johnson are identified as Oxford rugby fliers." ;
    ex:inCity :oxford ;
    ex:locatedIn :oxford ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:pallMallHouseAgent a ex:HouseAgency ;
    ex:prefLabel "Pall Mall house-agent firm" ;
    ex:description "A well-known house-agent firm on Pall Mall that Watson visited to inquire about the tenant of Charlington Hall. The representative informed Watson that Mr. Williamson had let the hall about a month ago." ;
    ex:locatedIn :pallMall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:parisianPolice a ex:Organization ;
    ex:prefLabel "Parisian Police" ;
    skos:altLabel "the Parisian police" ;
    ex:description "The police force of Paris. Made the discovery connecting M. Henri Fournaye to Eduardo Lucas through comparison of photographs. Investigated Mme. Fournaye's insanity and her connection to the Westminster murder." ;
    ex:locatedIn :paris ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:privateDetectiveFirm a ex:Organization ;
    ex:prefLabel "Private Detective Firm" ;
    ex:description "An unnamed private detective firm from which Anna hired an agent who infiltrated Professor Coram's household as his second secretary. The agent obtained a key impression and house plan before departing." ;
    ex:employs :coramSecondSecretary ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :goldenPinceNezDoc .

:randallGang a ex:CriminalGang ;
    ex:prefLabel "The Randall Gang" ;
    skos:altLabel "The Randalls" ;
    skos:altLabel "the three Randalls" ;
    skos:altLabel "Lewisham gang of burglars" ;
    ex:description """A gang of three burglars from Lewisham consisting of a father and his two sons. They committed a robbery at Sydenham a fortnight before the Abbey Grange case and were seen and described. Initially suspected of the Abbey Grange burglary and murder, but were arrested in New York on the morning after the crime, proving their innocence. Hopkins describes the father as a rough customer.""" ;
    ex:locatedIn :lewisham ;
    ex:hasParticipantIn :sydenhamRobbery ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:reuters a ex:RealOrganization, ex:NewsAgency ;
    ex:prefLabel "Reuter's" ;
    skos:altLabel "Reuters" ;
    ex:description "News agency. Published a despatch in the English papers on May 7th, 1891, about the Reichenbach incident. Watson describes this account as extremely condensed." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:rhodesianPolice a ex:PoliceForce ;
    ex:prefLabel "Rhodesian Police" ;
    ex:description "A police force in Rhodesia (southern Africa). Gilchrist accepted a commission in the Rhodesian Police and planned to go to South Africa at once, as stated in his letter to Soames." ;
    ex:locatedIn :rhodesia ;
