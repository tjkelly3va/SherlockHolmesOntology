:jonathanSmall a ex:FictionalPerson, ex:Criminal, ex:Soldier ;
    ex:firstName "Jonathan" ;
    ex:lastName "Small" ;
    ex:prefLabel "Jonathan Small" ;
    skos:altLabel "Small" ;
    skos:altLabel "the wooden-legged man" ;
    ex:description "Jonathan Small is a Worcestershire man born near Pershore. Enlisted in 3rd Buffs, sent to India. Lost right leg above knee to crocodile in the Ganges; saved by Sergeant John Holder. Invalided out of army. Employed by Mr Abelwhite as indigo plantation overseer at Muttra. During Indian Mutiny, fled to Agra Fort after Abelwhite killed. Assigned to guard gate with two Sikhs (Mahomet Singh and Abdullah Khan). Joined conspiracy to rob and murder merchant Achmet for rajah's treasure. One of the sign of the four (with Abdullah Khan, Mahomet Singh, Dost Akbar). Arrested, sentenced to death then commuted to penal servitude for life. Transferred to Andaman Islands. Nursed Tonga back to health. Escaped with Tonga, killing Pathan guard. Travelled world, eventually reached England. Tracked Major Sholto, left sign on his body. Hired Mordecai Smith's Aurora for escape. Tonga killed Bartholomew against Small's wishes. Captured on Thames when Aurora grounded. Scattered Agra treasure into Thames. Planned to escape on Esmeralda to Brazil." ;
    ex:gender "male" ;
    ex:hasPhysicalTrait "wooden right leg (lost to crocodile in Ganges)" ;
    ex:nationality "British" ;
    ex:physicalDescription "About 50, sunburned, mahogany features, black curly hair shot with gray, wooden right leg worn on inner side, left boot square-toed with iron ferule on heel" ;
    ex:birthPlace :pershore ;
    ex:companionOf :tonga ;
    ex:knows :abdullahKhan ;
    ex:knows :captainArthurMorstan ;
    ex:knows :dostAkbar ;
    ex:knows :mahometSingh ;
    ex:knows :majorJohnSholto ;
    ex:knows :mordecaiSmith ;
    ex:knows :mrAbelwhite ;
    ex:memberOf :signOfFourConfederacy ;
    ex:perpetratorOf :murderOfAchmet ;
    ex:perpetratorOf :murderOfBartholomewSholto ;
    ex:servedIn :3rdBuffs ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:josephOpenshaw a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Joseph" ;
    ex:lastName "Openshaw" ;
    ex:prefLabel "Joseph Openshaw" ;
    ex:description "John Openshaw's father and brother of Colonel Elias Openshaw. Had a small factory at Coventry which he enlarged at the time of the invention of bicycling. Was the patentee of the Openshaw unbreakable tire, and his business was successful enough that he was able to sell it and retire. Inherited the Horsham estate and approximately fourteen thousand pounds from his brother Elias. In January 1885, received five orange pips from Dundee with the message 'Put the papers on the sundial.' Dismissed the threat as a practical joke and refused to contact the police. Went to visit his old friend Major Freebody at a fort on Portsdown Hill. Fell over a deep chalk-pit near Fareham while returning in the twilight. The jury returned a verdict of death from accidental causes. John suspected murder." ;
    ex:occupation "factory owner, tire patentee" ;
    ex:causeOfDeath "Fell into a deep chalk-pit near Fareham; verdict of death from accidental causes, suspected murder by KKK agents" ;
    ex:childOf :openshawGrandfather ;
    ex:inheritedFrom :eliasOpenshaw ;
    ex:isVictimOf :deathOfJosephOpenshaw ;
    ex:knows :majorFreebody ;
    ex:livesAt :openshawEstate ;
    ex:parentOf :johnOpenshaw ;
    ex:siblingOf :eliasOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

