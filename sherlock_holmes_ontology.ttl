:tedBaldwin a ex:FictionalPerson, ex:Criminal, ex:Victim ;
    ex:firstName "Ted" ;
    ex:lastName "Baldwin" ;
    ex:prefLabel "Ted Baldwin" ;
    skos:altLabel "Baldwin" ;
    ex:description "Member of the Scowrers, Lodge 341 Vermissa. Handsome, dashing young man with broad-brimmed black felt hat, fierce domineering eyes and curved hawk-bill nose. Rival suitor to McMurdo for Ettie Shafter. Participated in the beating of editor Stanger and led the killing of William Hales. After serving ten years in prison, tracked Douglas to Birlstone Manor House where Douglas killed him in self-defense. The body found at Birlstone was Baldwin's, not Douglas's. Bore the branded lodge mark on his forearm." ;
    ex:knows :bossMcGinty, :johnDouglas, :ettieShafter ;
    ex:memberOf :eminentOrderOfFreemen, :lodge341 ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:thaddeusSholto a ex:FictionalPerson ;
    ex:firstName "Thaddeus" ;
    ex:lastName "Sholto" ;
    ex:prefLabel "Thaddeus Sholto" ;
    skos:altLabel "Mr. Sholto" ;
    skos:altLabel "Mr. Thaddeus Sholto" ;
    ex:description "Thaddeus Sholto is the son of Major John Sholto and twin brother of Bartholomew Sholto. Small man with very high head, bald shining scalp with bristle of red hair around fringe, pendulous lip, yellow irregular teeth. About 30. Nervous, hypochondriac. Patron of modern French art (owns genuine Corot and Bouguereau). Lives in third house of new terrace in South London. Sent pearls to Mary Morstan annually from 1882. Sent anonymous letter summoning Mary to the Lyceum Theatre. Took Williams and the old khitmutgar when he left Pondicherry Lodge. Arrested by Athelney Jones for Bartholomew's murder, later released with alibi." ;
    ex:gender "male" ;
    ex:childOf :majorJohnSholto ;
    ex:employs :thaddeusSholtoKhitmutgar ;
    ex:employs :williams ;
    ex:knows :johnWatson ;
    ex:knows :maryMorstan ;
    ex:knows :sherlockHolmes ;
    ex:siblingOf :bartholomewSholto ;
    ex:twinOf :bartholomewSholto ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

