:worcestershire a ex:County ;
    ex:prefLabel "Worcestershire" ;
    ex:description "English county. Jonathan Small's home county." ;
    ex:locatedIn :england ;
    ex:locatedIn :unitedKingdom ;
    ex:inRegion :england ;
