:roylottCorrespondent a ex:FictionalPerson ;
    ex:prefLabel "Roylott's Indian Correspondent" ;
    ex:description "An unnamed person in India who sends Indian animals to Dr. Roylott at Stoke Moran. The cheetah, baboon, and presumably the swamp adder were obtained through this correspondent." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:roylottLad a ex:FictionalPerson ;
    ex:prefLabel "Lad Who Drove Roylott" ;
    ex:description "An unnamed boy who drove Dr. Roylott home in a trap at dusk. He had difficulty undoing the heavy iron gates, and Roylott shook his clenched fists at him and roared at him." ;
    ex:occupation "Driver" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:sallyDennis a ex:FictionalPerson ;
    ex:firstName "Sally" ;
    ex:lastName "Dennis" ;
    ex:prefLabel "Sally Dennis" ;
    ex:description "Sally Dennis is the supposed daughter of Mrs. Sawyer, married to Tom Dennis. Part of the cover story used by Hope's accomplice to retrieve the ring." ;
    ex:isMarriedTo :tomDennis ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:samBrown a ex:FictionalPerson, ex:Detective ;
    ex:firstName "Sam" ;
    ex:lastName "Brown" ;
    ex:prefLabel "Sam Brown" ;
    ex:description "Sam Brown is an inspector who accompanied Watson with the treasure box to Mrs Forrester's house. Bluff, genial. Disappointed when box was empty, lamenting lost reward." ;
    ex:occupation "police inspector" ;
    ex:gender "male" ;
    ex:knows :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:sarasate a ex:RealPerson, ex:Musician ;
    ex:lastName "Sarasate" ;
    ex:prefLabel "Sarasate" ;
    ex:description "Sarasate is a real historical figure, a violinist who plays at the St. James's Hall on the afternoon of the Red-headed League case. Holmes and Watson attend the concert. The programme includes German music, which Holmes prefers." ;
    ex:occupation "musician; violinist" ;
    ex:performsAt :stJamesHall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:scottishNurse a ex:FictionalPerson ;
    ex:prefLabel "The Scottish Nurse" ;
    skos:altLabel "the Scotch woman" ;
    ex:description "Unnamed woman. A faithful Scottish woman who had once been a servant to the Hebron family. Described as a tall, gaunt woman with a harsh, forbidding face and a Northern accent. Given care of Lucy Hebron when Effie left America. Later brought Lucy to England and lived with her in the cottage at Norbury under Effie's instructions. Rebuffed Grant Munro when he tried to introduce himself as a neighbor. Tried to bar Munro's passage when he forced entry into the cottage at the climax." ;
    ex:occupation "nurse and former servant" ;
    ex:livesAt :cottageAtNorbury ;
    ex:employedBy :effieMunro ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

:selden a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Selden" ;
    ex:prefLabel "Selden" ;
    skos:altLabel "the Notting Hill murderer" ;
    skos:altLabel "the convict" ;
    ex:description "Escaped convict from Princetown Prison, the Notting Hill murderer. Younger brother of Eliza Barrymore (Mrs. Barrymore). Committed crimes of peculiar ferocity and wanton brutality. Death sentence commuted due to doubts about his sanity. Escaped and hid on the moor in stone huts, fed by the Barrymores via candle signals. Killed when he fell from a cliff while fleeing the hound, which had been set upon him by mistake because he was wearing Sir Henry's old clothes given to him through the Barrymores. Had a beetling forehead and sunken animal eyes." ;
    ex:siblingOf :elizaBarrymore ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:sergeantTuson a ex:FictionalPerson, ex:LawEnforcement, ex:PoliceSergeant ;
    ex:lastName "Tuson" ;
    ex:prefLabel "Sergeant Tuson" ;
    ex:description "A sergeant of the City Police who was on duty near Mawson & Williams on Saturday. He was surprised to see a gentleman with a carpet bag leave the building at twenty minutes past one. His suspicions aroused, he followed the man and with the aid of Constable Pollack arrested him after a most desperate resistance." ;
    ex:rank "Sergeant" ;
    ex:memberOf :cityPolice ;
    ex:arrested :beddingtonBrother2 ;
    ex:participatesIn :arrestOfBeddington ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:sergeantWilson a ex:FictionalPerson, ex:PoliceOfficer ;
    ex:lastName "Wilson" ;
    ex:prefLabel "Sergeant Wilson" ;
    ex:description "Sergeant of the Sussex Constabulary at the Birlstone police station. First officer to arrive at the scene. Tall, formal, melancholy man." ;
    ex:occupation "Police sergeant" ;
    ex:employedBy :sussexConstabulary ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:sherman a ex:FictionalPerson, ex:Naturalist ;
    ex:lastName "Sherman" ;
    ex:prefLabel "Sherman" ;
    skos:altLabel "Mr. Sherman" ;
    ex:description "Sherman is a bird-stuffer and naturalist at No. 3 Pinchin Lane, near the water's edge at Lambeth. Lanky, lean old man with stooping shoulders, stringy neck, and blue-tinted glasses. Keeps many animals including dogs, a badger, a stoat, a slow-worm, and fowls. Owns Toby the tracking dog. Friend of Sherlock Holmes. Threatens visitors with a viper but is friendly when Holmes's name mentioned." ;
    ex:occupation "bird-stuffer, naturalist" ;
    ex:gender "male" ;
    ex:knows :sherlockHolmes ;
    ex:livesAt :pinchinLane ;
    ex:owns :toby ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:shuman a ex:FictionalPerson, ex:Victim ;
    ex:lastName "Shuman" ;
    ex:prefLabel "Shuman" ;
    ex:description "Former ironworks owner whose business was bought by West Gilmerton General Mining Company." ;
    ex:occupation "Ironworks owner" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:silasBrown a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "Silas" ;
    ex:lastName "Brown" ;
    ex:prefLabel "Silas Brown" ;
    skos:altLabel "Brown" ;
    skos:altLabel "Master Silas Brown" ;
    ex:description "Trainer at Mapleton stables, managed for Lord Backwater. Fierce-looking elderly man. Known to have had large bets on the Wessex Cup. Was no friend to John Straker. Had found Silver Blaze wandering on the moor early one morning, recognized it by its white forehead, and concealed it at Mapleton to help his own horse Desborough win. Holmes described him as a perfect compound of the bully, coward, and sneak. When Holmes whispered his deductions, Brown turned ashy pale with beads of perspiration, hands shaking, and cringed along at Holmes's side. Agreed to keep the horse safe and produce it. Had disguised Silver Blaze by dyeing its distinctive markings. An old horse-faker with many a dodge." ;
    ex:occupation "horse trainer" ;
    ex:employedBy :lordBackwater ;
    ex:knows :lordBackwater, :sherlockHolmes ;
    ex:owns :brownHuntingCrop ;
    ex:manages :mapleton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :silverBlazeDoc .

