:hafiz a ex:RealPerson ;
    ex:firstName "Hafiz" ;
    ex:prefLabel "Hafiz" ;
    ex:description "Hafiz is a real historical Persian poet. Holmes quotes a Persian saying about the danger of snatching a delusion from a woman and attributes it to Hafiz, comparing him favorably with Horace." ;
    ex:occupation "poet" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :caseOfIdentityDoc .

:hallPycroft a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Hall" ;
    ex:lastName "Pycroft" ;
    ex:prefLabel "Hall Pycroft" ;
    skos:altLabel "Mr. Hall Pycroft" ;
    skos:altLabel "Pycroft" ;
    ex:description "A young stockbroker's clerk who is the client in this case. Well-built, fresh-complexioned, with a frank honest face and slight crisp yellow mustache. Wears a shiny top hat and neat sober black suit. Previously employed at Coxon & Woodhouse for five years at three pounds per week, he was hired by Mawson & Williams at two hundred pounds per year. He was then lured away by Arthur Pinner to the fictitious Franco-Midland Hardware Company at five hundred pounds per year. He lodged at 17 Potter's Terrace, Hampstead. He realized Arthur and Harry Pinner were the same person from a matching gold-stuffed tooth, and sought Holmes's help." ;
    ex:occupation "stockbroker's clerk" ;
    ex:livesAt :17PottersTerrace ;
    ex:employedBy :coxonAndWoodhouse ;
    ex:employedBy :mawsonAndWilliams ;
    ex:impersonatedBy :beddingtonBrother2 ;
    ex:clientOf :sherlockHolmes ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:harraway a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Harraway" ;
    ex:prefLabel "Harraway" ;
    ex:description "Secretary of Lodge 341, Vermissa. Vulture-faced old graybeard. Lean, bitter man with long scraggy neck and nervous jerky limbs. Incorruptible in lodge finances but with no sense of justice beyond the order." ;
    ex:occupation "Secretary of Lodge 341" ;
    ex:memberOf :eminentOrderOfFreemen, :lodge341 ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

