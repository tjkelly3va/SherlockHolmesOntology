    ex:prefLabel "General Neill" ;
    ex:description "Historical military figure referenced in the backstory. His column was moving up country during the Indian Mutiny. Henry Wood volunteered to reach Neill's column to communicate the danger of the besieged garrison at Bhurtee. Neill relieved Bhurtee the day after Wood's capture." ;
    ex:rank "General" ;
    ex:hasParticipatedIn :reliefOfBhurtee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:haroldLatimer a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "Harold" ;
    ex:lastName "Latimer" ;
    ex:prefLabel "Harold Latimer" ;
    skos:altLabel "Latimer" ;
    skos:altLabel "Mr. Latimer" ;
    ex:description "Fashionably dressed, powerful, broad-shouldered young man. Kidnapped Melas and imprisoned Paul Kratides with Kemp. Carried lead-loaded bludgeon. Persuaded Sophy Kratides to fly with him. Found stabbed in Budapest months later." ;
    ex:gender "male" ;
    ex:physicalDescription "Very fashionably dressed young man. Powerful, broad-shouldered." ;
