    ex:prefLabel "Silvester's Bank" ;
    skos:altLabel "Silvester's" ;
    ex:description "Silvester's is the bank where Lady Frances Carfax has her account. Holmes glanced over her passbook there to trace her recent financial activity." ;
    ex:locatedIn :london ;
    ex:memberOfOntology ex:SherlockOntology ;
