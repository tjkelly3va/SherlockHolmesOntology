:honoriaWestphail a ex:FictionalPerson ;
    ex:firstName "Honoria" ;
    ex:lastName "Westphail" ;
    ex:prefLabel "Miss Honoria Westphail" ;
    ex:description "Miss Honoria Westphail is the maternal aunt of Helen and Julia Stoner—their mother's maiden sister. She lives near Harrow. Helen and Julia were occasionally allowed to pay short visits to her house. Julia met her fiance there at Christmas. After the resolution of the case, Helen was conveyed to her care at Harrow." ;
    ex:auntOf :helenStoner ;
    ex:auntOf :juliaStoner ;
    ex:knows :mrsStoner ;
    ex:livesAt :harrow ;
