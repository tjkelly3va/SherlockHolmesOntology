:wilsonChaplain a ex:FictionalPerson, ex:Criminal, ex:Chaplain ;
    ex:lastName "Wilson" ;
    ex:prefLabel "Wilson" ;
    skos:altLabel "the sham chaplain" ;
    skos:altLabel "the chaplain" ;
    ex:description "Prendergast's partner in the Gloria Scott mutiny. A rare good man according to Prendergast, 'as true as a stock to a barrel.' Posed as the ship's chaplain, coming aboard with a black coat, proper papers, and enough money to buy the ship. Bought the loyalty of the crew, two warders, and the second mate Mercer. Smuggled weapons to the convicts in a black bag supposedly full of tracts. During the mutiny, was present when the captain was killed (stood with a smoking pistol). Killed along with eight others when Lieutenant Martin's soldiers fired through the saloon skylights." ;
    ex:occupation "Sham chaplain; criminal accomplice" ;
    ex:causeOfDeath "Shot in saloon massacre aboard the Gloria Scott" ;
    ex:knows :jackPrendergast ;
    ex:knows :mercer ;
    ex:crewOf :gloriaScottShip ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:wilsonKemp a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "Wilson" ;
    ex:lastName "Kemp" ;
    ex:prefLabel "Wilson Kemp" ;
    skos:altLabel "Kemp" ;
    ex:description "Small, mean-looking, middle-aged man with rounded shoulders, glasses, peaky sallow features, pointed beard, steel gray eyes. Nervous manner with giggling laugh, St. Vitus's dance symptoms. Man of foulest antecedents. Directed interrogation of Kratides. Found stabbed in Budapest." ;
    ex:gender "male" ;
    ex:eyeColor "steel gray" ;
    ex:physicalDescription "Small, mean-looking, middle-aged man with rounded shoulders, glasses. Peaky and sallow features, little pointed thready ill-nourished beard. Lips and eyelids continually twitching. Nervous jerky speech with giggling laughs." ;
    ex:causeOfDeath "Stabbed in Budapest" ;
    ex:isDeceased "true"^^xsd:boolean ;
    ex:knows :haroldLatimer , :sophyKratides ;
    ex:livesAt :theMyrtles ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:wilsonServantGirl a ex:FictionalPerson ;
    ex:prefLabel "Wilson's Servant Girl" ;
    ex:description "An unnamed girl of fourteen who does simple cooking and keeps Jabez Wilson's place clean at Saxe-Coburg Square. One of the three people living in Wilson's house along with Wilson and Vincent Spaulding (John Clay). Name not given in text." ;
    ex:occupation "servant; cook" ;
    ex:employedBy :jabezWilson ;
    ex:livesAt :saxeCoburgSquare ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:windigate a ex:FictionalPerson ;
    ex:lastName "Windigate" ;
    ex:prefLabel "Windigate" ;
    ex:description "Windigate is the landlord of the Alpha Inn near the British Museum in Bloomsbury. He instituted a goose club where members paid a few pence each week to receive a bird at Christmas. He purchased 24 geese from Breckinridge of Covent Garden at 12 shillings." ;
    ex:occupation "innkeeper" ;
    ex:leaderOf :alphaInnGooseClub ;
    ex:owns :alphaInn ;
    ex:suppliedBy :breckinridge ;
    ex:memberOfOntology ex:SherlockOntology ;
