:ridlingThorpeSurgeon a ex:FictionalPerson, ex:Doctor ;
    ex:prefLabel "Ridling Thorpe surgeon" ;
    skos:altLabel "the country doctor" ;
    skos:altLabel "the local surgeon" ;
    ex:description "An unnamed old, white-haired local surgeon who attended to Mrs. Hilton Cubitt's injuries. He reported that her injuries were serious but not necessarily fatal, the bullet having passed through the front of her brain. He could not determine whether she had been shot or had shot herself. He noted stains on the lady's face but none on her hand. He identified the third bullet hole pointed out by Holmes." ;
    ex:occupation "Surgeon" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dancingMenDoc .

:saundersHousemaid a ex:FictionalPerson, ex:Housemaid ;
