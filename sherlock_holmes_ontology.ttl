    ex:lastName "Williams" ;
    ex:prefLabel "Charlie Williams" ;
    skos:altLabel "Williams" ;
    ex:description "Past murder victim mentioned by Lawler in conversation about previous assassination jobs." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

