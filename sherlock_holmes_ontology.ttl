:arthurCharpentier a ex:FictionalPerson, ex:MilitaryOfficer ;
    ex:firstName "Arthur" ;
    ex:lastName "Charpentier" ;
    ex:prefLabel "Arthur Charpentier" ;
    skos:altLabel "Lieutenant Charpentier" ;
    ex:description "Arthur Charpentier is a sub-lieutenant in Her Majesty's Navy, son of Madame Charpentier and brother of Alice. On leave at the time of the events. Followed Drebber after he returned to the house and attempted to abduct Alice. Struck Drebber with a stout oak cudgel and ejected him. Arrested by Gregson but innocent of the murder." ;
    ex:occupation "Sub-lieutenant, Royal Navy" ;
    ex:childOf :madameCharpentier ;
    ex:siblingOf :aliceCharpentier ;
