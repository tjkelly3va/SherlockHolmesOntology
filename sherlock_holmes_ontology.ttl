    skos:altLabel "the Dane" ;
    ex:description "The Dane is the unnamed assistant at the Bar of Gold opium den. Aided the Lascar in pushing Mrs. St. Clair out into the street when she tried to ascend the stairs. Name not given in text." ;
    ex:occupation "opium den assistant" ;
    ex:nationality "Danish" ;
