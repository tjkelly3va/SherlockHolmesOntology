    ex:prefLabel "Royal Family of Scandinavia" ;
    ex:description "The royal family of Scandinavia. Holmes mentions having recently assisted them in cases, along with the French republic, which left him in a position where he could retire to chemical research." ;
    ex:locatedIn :scandinavia ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:royalMunsters a ex:MilitaryUnit ;
    ex:prefLabel "Royal Munsters" ;
    skos:altLabel "the old 117th" ;
    skos:altLabel "the Royal Munsters" ;
    skos:altLabel "117th Foot" ;
    ex:description "One of the most famous Irish regiments in the British army. Also known as the old 117th. Distinguished itself in the Crimea and the Mutiny, and on every possible occasion since. The first battalion was stationed at Aldershot for some years. Commanded up to the night of his death by Colonel James Barclay, who had started as a full private and was raised to commissioned rank for bravery during the Mutiny. The married officers lived out of barracks." ;
    ex:hasMember :jamesBarclay, :nancyBarclay, :majorMurphy, :henryWood ;
    ex:hasLeader :jamesBarclay ;
    ex:locatedAt :aldershot ;
    ex:partOf :britishArmy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:sanPedroRevengeSociety a ex:Organization, ex:SecretSociety ;
    ex:prefLabel "San Pedro revenge society" ;
    ex:description "A society formed by those whose lives Murillo had ruined, whose nearest and dearest had suffered torture and death at his hands. Vowed never to dissolve until vengeance was achieved. Members include Garcia (leader of the assassination attempt), Miss Burnet/Signora Durando (infiltrated Henderson's household), Jose, and the mulatto cook. Eventually succeeded in killing Murillo and Lopez in Madrid." ;
    ex:hasMember :aloysiusGarcia ;
    ex:hasMember :missBurnet ;
    ex:hasMember :jose ;
    ex:hasMember :wisteriaLodgeCook ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:seaUnicorn a ex:Organization, ex:Vessel ;
    ex:prefLabel "Sea Unicorn" ;
    skos:altLabel "S.S. Sea Unicorn" ;
    ex:description "A steam sealer registered at Dundee, commanded by Captain Peter Carey in 1883. Crew included Patrick Cairns as spare harpooner. In August 1883, while returning from the Arctic through the ice-pack with head winds and a week's southerly gale, the Sea Unicorn picked up a small yacht carrying the banker Neligan Senior, who was subsequently murdered by Carey. The harpoons in Carey's cabin were engraved 'S.S. Sea Unicorn, Dundee'." ;
    ex:commandedBy :peterCarey ;
    ex:homePort :dundee ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blackPeterDoc .

:shoscombeSpaniels a ex:Organization ;
    ex:prefLabel "Shoscombe Spaniels" ;
