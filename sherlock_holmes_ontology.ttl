:johnFerrier a ex:FictionalPerson, ex:Victim ;
    ex:firstName "John" ;
    ex:lastName "Ferrier" ;
    ex:prefLabel "John Ferrier" ;
    skos:altLabel "Ferrier" ;
    ex:description "John Ferrier is an American found as a dying castaway on the Great Alkali Plain by the Mormon caravan on May 4, 1847. He adopted Lucy as his daughter. Joined the Mormons and settled in Salt Lake City. Became one of the richest farmers in the region. Refused polygamy. Refused to let Lucy marry a Mormon, defying Brigham Young and the Council of Four. Killed by the Avenging Angels during the flight from Salt Lake City on August 4, 1860. Buried in the mountains with a grave marker." ;
    ex:occupation "farmer" ;
    ex:causeOfDeath "killed by the Avenging Angels during flight from Salt Lake City" ;
    ex:nationality "American" ;
    ex:adoptiveParentOf :lucyFerrier ;
    ex:murderedBy :josephStangerson ;
    ex:knows :brighamYoung ;
    ex:knows :jeffersonHope ;
    ex:livesAt :saltLakeCity ;
    ex:victimOf :murderOfJohnFerrier ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:johnCoachman a ex:FictionalPerson, ex:Servant ;
    ex:firstName "John" ;
    ex:prefLabel "John (Coachman)" ;
    ex:description "John is Irene Adler's coachman. She calls to him to drive to the Church of St. Monica for her wedding. Later, after recognizing Holmes's fire alarm ruse, Irene sends John to watch Holmes while she changes into male disguise and follows Holmes herself." ;
