    ex:livesAt :campdenMansions ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:lucretiaVenucci a ex:FictionalPerson, ex:Maid ;
    ex:firstName "Lucretia" ;
    ex:lastName "Venucci" ;
    ex:prefLabel "Lucretia Venucci" ;
    ex:description "An Italian woman who served as maid to the Princess of Colonna. Sister of Pietro Venucci. Suspicion fell upon her regarding the disappearance of the black pearl of the Borgias from the Prince of Colonna's bedroom at the Dacre Hotel. It was proved she had a brother in London, but no connection between them could be traced at the time." ;
    ex:nationality "Italian" ;
    ex:occupation "maid" ;
    ex:employedBy :princessOfColonna ;
    ex:siblingOf :pietroVenucci ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sixNapoleonsDoc .

