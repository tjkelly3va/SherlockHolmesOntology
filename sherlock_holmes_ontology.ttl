:mrWarren a ex:FictionalPerson, ex:Timekeeper, ex:Victim ;
    ex:lastName "Warren" ;
    ex:prefLabel "Mr. Warren" ;
    ex:description "Mr. Warren is the husband of Mrs. Warren and a timekeeper at Morton and Waylight's in Tottenham Court Road. He is abducted by two men who mistake him for the mysterious lodger, having a coat thrown over his head and being bundled into a cab. He is driven for an hour and dumped on Hampstead Heath. He earns little and is nervous about the mysterious lodger." ;
    ex:occupation "timekeeper" ;
    ex:livesAt :mrsWarrensHouse ;
