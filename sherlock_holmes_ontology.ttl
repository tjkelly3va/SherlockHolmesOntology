:colorSergeantDevoy a ex:FictionalPerson, ex:MilitaryOfficer ;
    ex:lastName "Devoy" ;
    ex:prefLabel "Color-Sergeant Devoy" ;
    ex:description "Former color-sergeant in the Royal Munsters (same corps as Barclay). Father of Nancy Devoy (later Mrs. Barclay). Wanted his daughter to marry Barclay rather than the reckless Henry Wood, as Barclay had education and was marked for the sword-belt." ;
    ex:rank "Color-Sergeant" ;
    ex:parentOf :nancyBarclay ;
    ex:formerlyEmployedBy :royalMunsters ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:davidBiblical a ex:RealPerson ;
    ex:firstName "David" ;
    ex:prefLabel "King David" ;
    skos:altLabel "David" ;
    ex:description "Biblical King David, referenced by Holmes at the end of the story. Mrs. Barclay's use of the word 'David' during her quarrel with Colonel Barclay was a term of reproach, alluding to the story of David, Uriah, and Bathsheba in the Books of Samuel. David arranged for Uriah's death, paralleling Barclay's betrayal of Henry Wood." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :crookedManDoc .

:diogenesClubWaiter a ex:FictionalPerson, ex:Waiter ;
    ex:prefLabel "Diogenes Club Waiter" ;
    ex:description "Unnamed waiter at the Diogenes Club to whom Mycroft gave a note summoning Melas." ;
    ex:occupation "Waiter" ;
    ex:gender "male" ;
    ex:worksAt :diogenesClub ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :greekInterpreterDoc .

:fakeRussianCount a ex:FictionalPerson, ex:Criminal ;
    ex:prefLabel "The fake Russian count" ;
    ex:description "An elderly man, thin, demure, and commonplace, who posed as a Russian nobleman suffering from catalepsy to gain access to Dr. Trevelyan's practice. He was actually one of Biddle, Hayward, or Moffat from the Worthingdon bank gang. He visited Trevelyan twice, feigning cataleptic attacks while his companion infiltrated Blessington's rooms. He later participated in Blessington's murder." ;
    ex:memberOf :worthingdonBankGang ;
    ex:confederateOf :fakeRussianSon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

:fakeRussianSon a ex:FictionalPerson, ex:Criminal ;
    ex:prefLabel "The fake Russian count's son" ;
    ex:description "A tall young man, surprisingly handsome, with a dark fierce face and the limbs and chest of a Hercules, who spoke English with a slight lisp. He posed as the son of a Russian nobleman to infiltrate 403 Brook Street. While his confederate feigned catalepsy, he went upstairs to Blessington's rooms, leaving square-toed footprints. He was actually one of Biddle, Hayward, or Moffat from the Worthingdon bank gang." ;
    ex:memberOf :worthingdonBankGang ;
    ex:confederateOf :fakeRussianCount ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :residentPatientDoc .

