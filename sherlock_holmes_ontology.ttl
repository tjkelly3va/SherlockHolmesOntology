:winwoodReade a ex:RealPerson, ex:Author ;
    ex:firstName "Winwood" ;
    ex:lastName "Reade" ;
    ex:prefLabel "Winwood Reade" ;
    ex:description "Real historical author. Wrote The Martyrdom of Man. Holmes recommends the book to Watson and quotes Reade on the subject of man as individual vs aggregate during the Thames chase." ;
    ex:gender "male" ;
    ex:hasWritten :martyrdomOfMan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:wisteriaLodgeCook a ex:FictionalPerson, ex:Servant ;
    ex:prefLabel "The Mulatto Cook" ;
    ex:description "Garcia's cook at Wisteria Lodge. A huge and hideous mulatto with yellowish features of a pronounced negroid type. A half-breed whom Garcia had picked up in his travels. A primitive savage from the backwoods of San Pedro. Practiced voodoo: sacrificed a white cock, burned a lamb or kid, and kept a voodoo fetish. Barely speaks English. Returned to Wisteria Lodge to retrieve his fetish, frightened Constable Walters, and was eventually captured in an ambush. Bit Constable Downing's thumb during capture. Not named in the text." ;
    ex:occupation "cook" ;
    ex:physicalDescription "Huge and hideous mulatto with yellowish features of a pronounced negroid type, size twelve shoes" ;
    ex:employedBy :aloysiusGarcia ;
    ex:nationality "San Pedran" ;
    ex:memberOf :sanPedroRevengeSociety ;
    ex:knows :aloysiusGarcia ;
    ex:knows :jose ;
    ex:capturedBy :inspectorBaynes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :wisteriaLodgeDoc .

:woolwichTicketClerk a ex:FictionalPerson ;
    ex:prefLabel "Woolwich Station Ticket Clerk" ;
    ex:description "Unnamed clerk in the ticket office at Woolwich Station. Recognized Cadogan West on Monday night and confirmed he took the 8:15 train to London Bridge. Noted West's excited and nervous manner, and that he was so shaky he could hardly pick up his change." ;
    ex:occupation "ticket clerk" ;
    ex:worksAt :woolwichStation ;
    ex:memberOfOntology ex:SherlockOntology ;
