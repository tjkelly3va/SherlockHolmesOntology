:vanAttackOnHolmes a ex:FictionalEvent, ex:Assassination ;
    ex:prefLabel "Van Attack on Holmes" ;
    ex:description "First of three assassination attempts on Holmes on April 24th, 1891. A two-horse van was furiously driven at Holmes at the corner of Bentinck Street and the Welbeck Street crossing near Oxford Street. Holmes sprang for the footpath and saved himself by a fraction of a second. The van dashed round by Marylebone Lane and escaped." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:occurredAt :bentinckStreet ;
    ex:occurredAt :welbeckStreet ;
    ex:hasInstrument :twoHorseVan ;
    ex:narrativeDate "April 24, 1891" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc .

:varsityRugbyMatch a ex:Event ;
    ex:prefLabel "Cambridge vs Oxford Varsity Rugby Match" ;
    ex:description "The Varsity rugby match between Cambridge and Oxford. Cambridge lost due to the absence of Godfrey Staunton. Oxford won by a goal and two tries. The local evening paper attributed the defeat entirely to Staunton's absence." ;
    ex:hasParticipant :cambridgeUniversityRugbyTeam ;
    ex:hasParticipant :oxfordUniversity ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:veiledLodgerInvestigation a ex:Investigation ;
    ex:prefLabel "Veiled Lodger Investigation" ;
    ex:description "The Veiled Lodger Investigation is Holmes's consultation in the case of Mrs. Eugenia Ronder, the veiled lodger, in late 1896. Mrs. Merrilow brought the case to Holmes's attention when her lodger began crying 'Murder!' in the night. Holmes and Watson visited Mrs. Ronder at Mrs. Merrilow's house in South Brixton, where she confessed the truth about the Abbas Parva tragedy. The case was already closed and no formal investigation was pursued." ;
    ex:hasInvestigator :sherlockHolmes ;
    ex:hasClient :mrsMerrilow ;
    ex:hasParticipant :sherlockHolmes, :johnWatson, :mrsMerrilow, :eugeniaRonder ;
