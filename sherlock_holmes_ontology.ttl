:deduction_scarlet_holmes_06 a ex:Deduction ;
    ex:prefLabel "Holmes Deduces the Victim Was Poisoned" ;
    ex:description "Finding no wound on Drebber's body, Holmes sniffs the dead man's lips and concludes he was killed by forcible administration of poison." ;
    ex:deductionSequence 6 ;
    ex:deductionSummary "The victim was poisoned, not wounded" ;
    ex:deductionReasoning "Finding no wound on Drebber's body, Holmes sniffed the dead man's lips, detected a slightly sour smell, and concluded poison had been forcibly administered, supported by the expression of horror on the victim's face." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :enochDrebber ;
    ex:confirmedBy :poisonPillTest ;
