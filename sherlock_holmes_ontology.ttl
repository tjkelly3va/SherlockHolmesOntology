:blount a ex:FictionalPerson ;
    ex:lastName "Blount" ;
    ex:prefLabel "Blount" ;
    ex:description "Blount is a student at The Gables coaching establishment. Along with Sudbury, he found Fitzroy McPherson's dead Airedale terrier on the beach at the same spot where McPherson had died." ;
