:wildersMotherUnnamed a ex:FictionalPerson ;
    ex:prefLabel "James Wilder's Mother" ;
    ex:description "Unnamed woman loved by the Duke of Holdernesse in his youth. He offered her marriage but she refused on the grounds that such a match might mar his career. She died, leaving one child (James Wilder) whom the Duke cherished and cared for in her memory. Not named in the text." ;
    ex:parentOf :jamesWilder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :priorySchoolDoc .

:youngSquire a ex:FictionalPerson ;
    ex:prefLabel "Impecunious Young Squire" ;
    ex:description "An unnamed impecunious young squire in the country to whom Lady Eva Brackwell wrote imprudent letters. These letters form the basis of Milverton's blackmail of Lady Eva. Name is not given in the text." ;
    ex:occupation "squire" ;
    ex:knows :ladyEvaBrackwell ;
