:neliganMother a ex:FictionalPerson ;
    ex:prefLabel "Mrs. Neligan" ;
    skos:altLabel "Neligan's mother" ;
    ex:description "Wife of the banker Neligan Senior and mother of John Hopley Neligan. Her husband bade farewell to her on his last night before sailing for Norway. She and her son believed he had perished at sea with the yacht and securities. Name not given in text." ;
    ex:isMarriedTo :neliganSenior ;
    ex:parentOf :johnNeligan ;
    ex:memberOfOntology ex:SherlockOntology ;
