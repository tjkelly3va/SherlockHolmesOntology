:hattyDoran a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Hatty" ;
    ex:lastName "Doran" ;
    ex:prefLabel "Hatty Doran" ;
    skos:altLabel "Miss Hatty Doran" ;
    skos:altLabel "Lady St. Simon" ;
    skos:altLabel "Mrs. Francis Hay Moulton" ;
    skos:altLabel "Hatty" ;
    skos:altLabel "Miss Doran" ;
    ex:description "Only daughter of Aloysius Doran, California millionaire. Grew up in a mining camp near the Rockies, described as a tomboy with a strong, wild, free nature - impetuous and volcanic. Graceful figure and striking face with lustrous black hair, large dark eyes, and an exquisite mouth. Attended the Westbury House festivities. Was secretly married to Francis Hay Moulton in 1884 at McQuire's camp before her father became rich. Believed Frank dead after a newspaper reported he was killed in an Apache attack. Married Lord St. Simon at St. George's Hanover Square but saw Frank in the front pew during the ceremony. Dropped her bouquet to receive a note from him. Fled the wedding breakfast at Lancaster Gate, putting on an ulster and bonnet, and joined Frank. They went to lodgings at 226 Gordon Square. Holmes persuaded them to explain the situation to Lord St. Simon." ;
    ex:childOf :aloysiusDoran ;
    ex:isMarriedTo :francisHayMoulton ;
    ex:knows :lordRobertStSimon ;
    ex:knows :aliceMaid ;
    ex:knows :sherlockHolmes ;
    ex:livesAt :226GordonSquare ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:headGamekeeperTregellis a ex:FictionalPerson, ex:GameKeeper ;
    ex:lastName "Tregellis" ;
    ex:prefLabel "Head Game-Keeper Tregellis" ;
    ex:description "Head game-keeper at Hurlstone estate and father of Janet Tregellis. His first name is not given in the text; the surname Tregellis is inferred from his daughter's name." ;
    ex:occupation "Head game-keeper" ;
    ex:parentOf :janetTregellis ;
    ex:worksAt :hurlstone ;
    ex:employedBy :reginaldMusgrave ;
    ex:memberOfOntology ex:SherlockOntology ;
