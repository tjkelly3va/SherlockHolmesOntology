:mrFerguson a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Ferguson" ;
    ex:title "Mr." ;
    ex:prefLabel "Mr. Ferguson" ;
    skos:altLabel "the fat manager" ;
    skos:altLabel "the morose Englishman" ;
