    ex:prefLabel "Sumner" ;
    ex:description "Shipping agent based at Ratcliff Highway in London. Holmes telegraphed him under the name Basil, requesting him to send three men to Baker Street the following morning." ;
    ex:occupation "shipping agent" ;
    ex:employedBy :sumnersShippingAgency ;
