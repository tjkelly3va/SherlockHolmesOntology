:gloriaScottCaptain a ex:FictionalPerson, ex:Sailor ;
    ex:prefLabel "Captain of the Gloria Scott" ;
    ex:description "The unnamed captain of the bark Gloria Scott. During the mutiny, when the convicts rushed into his cabin, he was found dead with his brains smeared over the chart of the Atlantic pinned on the table, while the chaplain Wilson stood with a smoking pistol at his elbow. It is ambiguous whether the captain shot himself or was shot by Wilson." ;
    ex:occupation "Ship captain" ;
    ex:causeOfDeath "Gunshot wound during mutiny (self-inflicted or shot by Wilson)" ;
    ex:crewOf :gloriaScottShip ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:gloriaScottDoctor a ex:FictionalPerson, ex:Doctor ;
    ex:prefLabel "Doctor/Surgeon of the Gloria Scott" ;
    skos:altLabel "the surgeon" ;
    ex:description "The unnamed doctor and surgeon aboard the bark Gloria Scott. Described as a nervous little chap. He discovered the concealed pistols when examining a sick prisoner, cried out in surprise, and was seized, gagged, and tied down on the bed. He had unlocked the door leading to the deck, enabling the mutineers' rush. After the mutiny, Prendergast descended into the 'tween-decks and cut the surgeon's throat with his own hands." ;
    ex:occupation "Ship's doctor/surgeon" ;
    ex:causeOfDeath "Throat cut by Prendergast after the mutiny" ;
    ex:crewOf :gloriaScottShip ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:gloriaScottFirstMate a ex:FictionalPerson, ex:Sailor ;
    ex:prefLabel "First Mate of the Gloria Scott" ;
    ex:description "The unnamed first mate of the bark Gloria Scott. Described as a bold and active man. He was the only remaining prisoner after Prendergast killed the others. He kicked off his loosened bonds, rushed down the deck, and plunged into the after-hold where he sat beside an open powder-barrel with a match-box, threatening to blow up the ship. The explosion occurred shortly after — Hudson believed it was caused by a misdirected convict's bullet rather than the mate's match. The explosion destroyed the Gloria Scott." ;
    ex:occupation "First mate" ;
    ex:causeOfDeath "Killed in explosion of the Gloria Scott" ;
    ex:crewOf :gloriaScottShip ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:gloriaScottThirdMate a ex:FictionalPerson, ex:Sailor ;
    ex:prefLabel "Third Mate of the Gloria Scott" ;
    ex:description "The unnamed third mate of the bark Gloria Scott. After the mutiny, he was shot and thrown overboard by Prendergast's men along with the two warders." ;
    ex:occupation "Third mate" ;
    ex:causeOfDeath "Shot and thrown overboard after mutiny" ;
    ex:crewOf :gloriaScottShip ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :gloriaScottDoc .

:godfreyNorton a ex:FictionalPerson, ex:Lawyer ;
    ex:firstName "Godfrey" ;
    ex:lastName "Norton" ;
    ex:prefLabel "Godfrey Norton" ;
    skos:altLabel "Mr. Godfrey Norton" ;
    ex:description "Godfrey Norton is an English lawyer of the Inner Temple. Dark, handsome, aquiline, and moustached. Visits Irene Adler daily, sometimes twice. Rushes to Gross & Hankey's in Regent Street and then to the Church of St. Monica to marry Irene. Holmes serves as their unwitting witness. After the marriage, drives back to the Temple. Flees with Irene to the Continent via the 5:15 from Charing Cross. Irene describes him as 'a better man' than the King." ;
    ex:occupation "Lawyer" ;
    ex:nationality "English" ;
    ex:isMarriedTo :ireneAdler ;
    ex:knows :ireneAdler, :sherlockHolmes ;
    ex:worksAt :innerTemple ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :scandalInBohemiaDoc .

:goethe a ex:RealPerson, ex:Author ;
    ex:lastName "Goethe" ;
    ex:prefLabel "Johann Wolfgang von Goethe" ;
    skos:altLabel "Goethe" ;
    ex:description "Real historical German writer and polymath. Holmes quotes him twice in German in The Sign of the Four." ;
    ex:occupation "writer, poet" ;
    ex:gender "male" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:gower a ex:FictionalPerson, ex:Criminal ;
    ex:prefLabel "Gower" ;
    ex:description "Member of Lodge 341 chosen by Baldwin for the Stanger beating." ;
    ex:memberOf :eminentOrderOfFreemen, :lodge341 ;
    ex:memberOfOntology ex:SherlockOntology ;
