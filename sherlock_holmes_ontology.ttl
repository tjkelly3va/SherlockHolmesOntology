:hayward a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Hayward" ;
    ex:prefLabel "Hayward" ;
    ex:description "A member of the Worthingdon bank gang who participated in the 1875 bank robbery. He was arrested and sentenced to fifteen years in prison on Sutton's testimony. After release, he joined Biddle and Moffat in hunting down and murdering Sutton/Blessington. He is believed to have perished aboard the steamer Norah Creina." ;
    ex:prisonSentence "fifteen years" ;
    ex:memberOf :worthingdonBankGang ;
    ex:confederateOf :biddle ;
    ex:confederateOf :moffat ;
