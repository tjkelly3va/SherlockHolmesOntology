:majorJohnSholto a ex:FictionalPerson, ex:MilitaryOfficer ;
    ex:firstName "John" ;
    ex:lastName "Sholto" ;
    ex:prefLabel "Major John Sholto" ;
    skos:altLabel "Major Sholto" ;
    ex:description "Major John Sholto is the father of Thaddeus and Bartholomew Sholto. Officer in the 34th Bombay Infantry. In command of troops at Andaman Islands with Captain Morstan. Made deal with Jonathan Small for Agra treasure but betrayed the four — took treasure to England, never fulfilled escape bargain. Captain Morstan died of heart attack during quarrel over treasure at Pondicherry Lodge; Sholto and servant Lal Chowdar concealed the body. Retired to Pondicherry Lodge, Upper Norwood, prospered greatly. Lost heavily at cards at Andamans. Received threatening letter from India in 1882, sickened. Died April 28, 1882 of enlarged spleen. On deathbed tried to reveal treasure location but died seeing Jonathan Small's face at window. Sign of the four found on his chest. Always feared men with wooden legs; employed two prize-fighters as porters." ;
    ex:causeOfDeath "enlarged spleen" ;
    ex:deathYear "1882"^^xsd:gYear ;
    ex:gender "male" ;
    ex:rank "Major" ;
    ex:employs :mcmurdo ;
    ex:knows :captainArthurMorstan ;
    ex:knows :jonathanSmall ;
    ex:knows :lalChowdar ;
    ex:livesAt :pondicherryLodge ;
    ex:memberOf :34thBombayInfantry ;
    ex:parentOf :bartholomewSholto ;
    ex:parentOf :thaddeusSholto ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

