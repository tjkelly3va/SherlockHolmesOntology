:williamBellamy a ex:FictionalPerson ;
    ex:firstName "William" ;
    ex:lastName "Bellamy" ;
    ex:prefLabel "William Bellamy" ;
    ex:description "William Bellamy is the son of Tom Bellamy and brother of Maud Bellamy. A powerful young man with a heavy, sullen face, he helps run the family boat and bathing-cot business at Fulworth. He is of one mind with his father that McPherson's attentions to Maud were insulting, and objects to his sister being brought into the investigation." ;
    ex:occupation "Boat and bathing-cot business operator" ;
    ex:childOf :tomBellamy ;
    ex:knows :fitzroyMcPherson ;
    ex:livesAt :theHaven ;
    ex:siblingOf :maudBellamy ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:williamFalder a ex:FictionalPerson, ex:Baronet ;
    ex:firstName "William" ;
    ex:lastName "Falder" ;
    ex:title "Sir" ;
    ex:prefLabel "Sir William Falder" ;
    ex:description "Sir William Falder is an eighteenth-century ancestor of the Falder family. His grave is in the crypt beneath the old chapel at Shoscombe Park." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:williamKirwan a ex:FictionalPerson, ex:Victim ;
    ex:firstName "William" ;
    ex:lastName "Kirwan" ;
    ex:prefLabel "William Kirwan" ;
    skos:altLabel "William" ;
    skos:altLabel "William the coachman" ;
    ex:description "Coachman in the service of the Cunninghams for years, reputed to be an honest and very faithful fellow. He lived at the lodge with his mother. He secretly followed his two masters on the night they raided Mr. Acton's house and subsequently blackmailed them under threats of exposure. He was lured to the east gate of the Cunningham property by a note at quarter to twelve and shot through the heart with a revolver from a distance of over four yards. A fragment of the note was found between his finger and thumb." ;
    ex:occupation "coachman" ;
    ex:childOf :williamKirwanMother ;
    ex:livesAt :cunninghamLodge ;
    ex:employedBy :oldCunningham ;
    ex:participantIn :williamKirwanMurder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:williamKirwanMother a ex:FictionalPerson ;
    ex:prefLabel "William Kirwan's Mother" ;
    ex:description "Mother of William Kirwan the coachman. Described as very old and deaf, and never very bright. She lived with her son at the lodge on the Cunningham estate. The shock of her son's murder made her half-witted, and the investigators could get no information from her. Her name is not given in the text." ;
    ex:parentOf :williamKirwan ;
    ex:livesAt :cunninghamLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :reigateSquiresDoc .

:abdullahKhan a ex:FictionalPerson, ex:Criminal, ex:Soldier ;
    ex:firstName "Abdullah" ;
    ex:lastName "Khan" ;
    ex:prefLabel "Abdullah Khan" ;
    ex:description "Abdullah Khan is one of the sign of the four. Sikh trooper, the taller and fiercer of the two. Old fighting man who bore arms at Chilian-wallah. Proposed the treasure plot to Jonathan Small. Foster-brother of Dost Akbar. Killed merchant Achmet by stabbing him twice. Sentenced to penal servitude for life." ;
    ex:gender "male" ;
    ex:knows :dostAkbar ;
    ex:knows :jonathanSmall ;
    ex:knows :mahometSingh ;
    ex:memberOf :signOfFourConfederacy ;
    ex:perpetratorOf :murderOfAchmet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:achmet a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Achmet" ;
    ex:prefLabel "Achmet" ;
    skos:altLabel "the merchant Achmet" ;
    ex:description "Achmet is a pretended merchant carrying the rajah's treasure in an iron box to Agra Fort for safekeeping during the Indian Mutiny. Little, fat, round fellow with great yellow turban. Travelled across Rajpootana with Dost Akbar as companion. Murdered at Agra Fort — tripped by Small, stabbed twice by Abdullah Khan. Body buried in deserted hall under loose bricks." ;
    ex:occupation "servant of rajah, pretended merchant" ;
    ex:gender "male" ;
    ex:victimOf :murderOfAchmet ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:agraRajah a ex:FictionalPerson ;
    ex:prefLabel "The Rajah (Agra Treasure)" ;
    skos:altLabel "the rajah" ;
    ex:description "Unnamed rajah of the northern provinces of India. Much wealth from father and by hoarding. During Indian Mutiny tried to be friends with both sides. Hid gold and silver in vaults but sent most precious stones and pearls in iron box with Achmet to Agra Fort. Later deposed and driven out of India. Name not given in text." ;
    ex:occupation "rajah" ;
    ex:gender "male" ;
    ex:owns :agraTreasure ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:alecMacDonald a ex:FictionalPerson, ex:PoliceInspector ;
    ex:firstName "Alec" ;
    ex:lastName "MacDonald" ;
    ex:prefLabel "Inspector Alec MacDonald" ;
    skos:altLabel "MacDonald" ;
    skos:altLabel "Mr. Mac" ;
    ex:description "Young but trusted Scotland Yard detective with tall bony figure, deep-set lustrous eyes, and hard Aberdonian accent. Brings news of the Douglas murder to Holmes. Works the Birlstone case alongside White Mason." ;
    ex:occupation "Inspector, Scotland Yard" ;
    ex:employedBy :scotlandYard ;
    ex:investigates :birlstoneInvestigation ;
    ex:knows :sherlockHolmes, :johnWatson, :whiteMason ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :valleyOfFearDoc .

:alexanderHolder a ex:FictionalPerson, ex:Client, ex:Victim ;
    ex:firstName "Alexander" ;
    ex:lastName "Holder" ;
    ex:prefLabel "Alexander Holder" ;
    skos:altLabel "Mr. Holder" ;
    ex:description "Senior partner of the banking firm Holder & Stevenson on Threadneedle Street, the second largest private banking concern in the City of London. A man of about fifty, tall, portly, and imposing, with a massive, strongly marked face and a commanding figure. A widower with one son, Arthur, and an adopted niece, Mary (his deceased brother's daughter). Came to Holmes in extreme distress after the beryl coronet, left in his care as security for a £50,000 loan to an illustrious client, was found damaged with three beryls missing. Initially believed his son Arthur was the thief. Offered a £1,000 reward for recovery of the gems. Paid Holmes £4,000 (£3,000 for the gems plus reward)." ;
    ex:occupation "banker" ;
    ex:age "about fifty" ;
    ex:livesAt :fairbank ;
    ex:parentOf :arthurHolder ;
    ex:uncleOf :maryHolder ;
    ex:adopted :maryHolder ;
    ex:employs :lucyParr ;
    ex:knows :sherlockHolmes ;
    ex:clientOf :sherlockHolmes ;
    ex:knows :sirGeorgeBurnwell ;
    ex:knows :stevenson ;
    ex:hasRole :holderAndStevenson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :berylCoronetDoc .

:aliceCharpentier a ex:FictionalPerson ;
    ex:firstName "Alice" ;
    ex:lastName "Charpentier" ;
    ex:prefLabel "Alice Charpentier" ;
    ex:description "Alice Charpentier is the daughter of Madame Charpentier. Described as an uncommonly fine girl. Red-eyed from crying when police visited. Drebber harassed her, seized her, and attempted to abduct her. She bravely insisted her mother tell the truth to police." ;
    ex:childOf :madameCharpentier ;
    ex:siblingOf :arthurCharpentier ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:aliceMaid a ex:FictionalPerson, ex:Maid ;
    ex:firstName "Alice" ;
    ex:prefLabel "Alice" ;
    skos:altLabel "Alice the maid" ;
    ex:description "Hatty Doran's maid. American, came from California with Hatty. A confidential servant, allowed great liberties by her mistress. Knew Francis Moulton in California and had always been his friend. Helped Hatty prepare to flee the wedding breakfast by packing a few things and getting the ulster ready. Deposed that Hatty went to her room, covered her bride's dress with an ulster, put on a bonnet, and went out." ;
    ex:occupation "Lady's maid" ;
    ex:nationality "American" ;
    ex:employedBy :hattyDoran ;
    ex:knows :francisHayMoulton ;
    ex:knows :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:aliceTurner a ex:FictionalPerson, ex:Client ;
    ex:firstName "Alice" ;
    ex:lastName "Turner" ;
    ex:prefLabel "Alice Turner" ;
    skos:altLabel "Miss Turner" ;
    ex:description "Daughter of John Turner, about eighteen years old. One of the most lovely young women Watson had ever seen, with violet eyes and a pink flush upon her cheeks. Grew up knowing James McCarthy since childhood, having always loved each other as brother and sister. Believed firmly in James's innocence. Retained Lestrade and sought Holmes's help. Had been away five years at a boarding school. Her father was averse to a marriage between her and James. Told Holmes that the quarrel between James and his father concerned the proposed marriage." ;
    ex:age 18 ;
    ex:childOf :johnTurner, :johnTurnerWife ;
    ex:knows :jamesMcCarthy, :sherlockHolmes, :lestrade ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:aloysiusDoran a ex:FictionalPerson ;
    ex:firstName "Aloysius" ;
    ex:lastName "Doran" ;
    ex:prefLabel "Aloysius Doran" ;
    skos:altLabel "Mr. Aloysius Doran" ;
    skos:altLabel "Mr. Doran" ;
    ex:description "Father of Hatty Doran. Said to be the richest man on the Pacific slope. From San Francisco, California. Made his fortune in mining - had nothing a few years ago, then struck gold, invested it, and came up by leaps and bounds. Previously worked a claim at McQuire's camp near the Rockies. Took a furnished house at Lancaster Gate for the London season and wedding breakfast. Refused to allow Hatty's engagement to the then-poor Francis Moulton, took Hatty away to San Francisco. Later pleased by the arrangement with Lord St. Simon." ;
    ex:occupation "Mining magnate" ;
    ex:livesAt :sanFrancisco ;
    ex:locatedIn :lancasterGateHouse ;
    ex:parentOf :hattyDoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

:alphonseBertillon a ex:RealPerson ;
    ex:firstName "Alphonse" ;
    ex:lastName "Bertillon" ;
    ex:prefLabel "Alphonse Bertillon" ;
    skos:altLabel "Bertillon" ;
    skos:altLabel "Monsieur Bertillon" ;
    ex:description "Real historical figure. French forensic scientist. Mentioned by Dr. Mortimer as the highest expert in Europe to the precisely scientific mind, prompting a moment of irritation from Holmes." ;
    ex:occupation "forensic scientist" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc ;
    dc:source :navalTreatyDoc .

:ames a ex:FictionalPerson, ex:Butler ;
    ex:lastName "Ames" ;
    ex:prefLabel "Ames" ;
    ex:description "Butler at Birlstone Manor House. Quaint, gnarled, dried-up person. Previously served ten years with Sir Charles Chandos before five years with Douglas. Prim, respectable, and capable." ;
    ex:occupation "Butler" ;
    ex:employedBy :johnDouglas ;
    ex:worksAt :birlstoneManorHouse ;
    ex:memberOfOntology ex:SherlockOntology ;
