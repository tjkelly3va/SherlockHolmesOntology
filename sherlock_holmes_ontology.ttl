:johnHebron a ex:FictionalPerson, ex:Lawyer ;
    ex:firstName "John" ;
    ex:lastName "Hebron" ;
    ex:prefLabel "John Hebron" ;
    skos:altLabel "John Hebron of Atlanta" ;
    ex:description "First husband of Effie Munro. A lawyer with a good practice in Atlanta, Georgia. Of African descent, described from his portrait as strikingly handsome and intelligent-looking, bearing unmistakable signs of his African descent. Effie described him as 'a nobler man never walked the earth' and said she cut herself off from her race to wed him. Died of yellow fever during an outbreak in Atlanta. His papers were destroyed in a great fire in Atlanta shortly after his death. Father of Lucy Hebron. A duplicate death certificate was obtained after the fire." ;
    ex:occupation "lawyer" ;
    ex:isMarriedTo :effieMunro ;
    ex:parentOf :lucyHebron ;
    ex:livesAt :atlanta ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :yellowFaceDoc .

