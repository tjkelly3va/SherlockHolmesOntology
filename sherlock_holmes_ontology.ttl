:trialWilliamsonWoodley a ex:Trial ;
    ex:prefLabel "Trial of Williamson and Woodley" ;
    ex:description "Williamson and Woodley were both tried for abduction and assault. Williamson received seven years and Woodley ten years. Carruthers was also tried for his assault on Woodley but likely received only a few months." ;
    ex:hasParticipant :williamsonExClergyman ;
    ex:hasParticipant :jackWoodley ;
    ex:hasParticipant :bobCarruthers ;
