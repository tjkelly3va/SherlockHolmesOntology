    skos:altLabel "Constable Murcher" ;
    ex:description "Harry Murcher is a police constable with the Holland Grove beat. Met Rance at the corner of Henrietta Street around 1am on the night of the murder." ;
    ex:occupation "police constable" ;
    ex:employedBy :metropolitanPolice ;
    ex:memberOfOntology ex:SherlockOntology ;
