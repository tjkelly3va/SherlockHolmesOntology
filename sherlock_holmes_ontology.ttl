ex:deductionOutcome a owl:DatatypeProperty ;
    rdfs:domain ex:Deduction ;
    rdfs:range xsd:string ;
    rdfs:label "Deduction Outcome" ;
    ex:prefLabel "Deduction Outcome" ;
    ex:description "A 'Deduction Outcome' is a string recording the correctness status of a deduction; controlled vocabulary: 'correct', 'incorrect', 'partially correct', 'unverified'." ;
    ex:memberOfOntology ex:SherlockOntology ;
