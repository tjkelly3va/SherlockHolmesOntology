    ex:lastName "Cushing" ;
    ex:prefLabel "Susan Cushing" ;
    skos:altLabel "Miss Cushing" ;
    skos:altLabel "Miss Susan Cushing" ;
    skos:altLabel "Miss S. Cushing" ;
    ex:description "Miss Susan Cushing, maiden lady of fifty. Lives at Cross Street, Croydon. Previously lived at Penge where she let apartments to medical students. Placid-faced, large gentle blue eyes, grizzled hair. Has two younger sisters Sarah and Mary. Eldest sister (initial S)." ;
    ex:gender "female" ;
    ex:age "fifty" ;
    ex:occupation "retired" ;
