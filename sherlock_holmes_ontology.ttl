:woolwichArsenal a ex:Building ;
    ex:prefLabel "Woolwich Arsenal" ;
    skos:altLabel "the Arsenal" ;
    ex:description "Government military facility in Woolwich where the Bruce-Partington submarine plans were kept. Contains a confidential office with an elaborate safe, burglar-proof doors and windows, and iron shutters that do not fully close. A laurel bush grows outside the office window." ;
    ex:locatedIn :england ;
    ex:locatedIn :london ;
    ex:locatedIn :unitedKingdom ;
