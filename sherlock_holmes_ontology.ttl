:williamsonExClergyman a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Williamson" ;
    ex:prefLabel "Williamson" ;
    skos:altLabel "the ex-clergyman" ;
    skos:altLabel "the old rascal" ;
    skos:altLabel "his reverence" ;
    ex:description "White-bearded, respectable-looking elderly man. Tenant of Charlington Hall. An ordained but unfrocked clergyman with a singularly dark career. Not from South Africa — never saw Carruthers or Woodley until two months before the events. Performed the forced marriage of Violet Smith to Woodley in the grounds of Charlington Hall wearing a surplice over a tweed suit. Had obtained a marriage license by trickery. Pulled a revolver but was disarmed by Holmes. Tried for abduction and assault, sentenced to seven years." ;
    ex:occupation "unfrocked clergyman" ;
    ex:isUnfrocked "true"^^xsd:boolean ;
    ex:sentenceDuration "seven years" ;
    ex:gender "male" ;
