:susanDobney a ex:FictionalPerson, ex:Governess ;
    ex:prefLabel "Susan Dobney" ;
    ex:firstName "Susan" ;
    ex:lastName "Dobney" ;
    skos:altLabel "Miss Dobney" ;
    skos:altLabel "Old Susan Dobney" ;
    ex:description "Susan Dobney is the old governess of Lady Frances Carfax, long retired and living in Camberwell. She wears a mob cap. Lady Frances writes to her every second week. When five weeks passed without a letter, Miss Dobney consulted Sherlock Holmes. Philip Green remembers her from the past." ;
    ex:occupation "retired governess" ;
    ex:knows :ladyFrancesCarfax, :philipGreen, :sherlockHolmes ;
