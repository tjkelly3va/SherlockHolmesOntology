:josiahBrown a ex:FictionalPerson ;
    ex:firstName "Josiah" ;
    ex:lastName "Brown" ;
    ex:prefLabel "Josiah Brown" ;
    ex:description "A resident of Laburnum Lodge (also called Laburnum Villa on the gate-post), Laburnum Vale, Chiswick. Described as jovial and rotund. Purchased a Napoleon bust from Harding Brothers. Received Holmes's warning letter and locked all doors. Beppo broke into his house and was arrested in his garden." ;
    ex:livesAt :laburnumLodge ;
    ex:memberOfOntology ex:SherlockOntology ;
