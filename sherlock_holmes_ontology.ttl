:heberCKimball a ex:RealPerson, ex:HistoricalFigure ;
    ex:firstName "Heber C." ;
    ex:lastName "Kimball" ;
    ex:prefLabel "Heber C. Kimball" ;
    skos:altLabel "Kemball" ;
