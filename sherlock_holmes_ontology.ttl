    ex:owns :williamsonsPrayerBook ;
    ex:owns :williamsonsSurplice ;
    ex:performedBy :forcedMarriageOfVioletSmith ;
    ex:tenantOf :charlingtonHall ;
    ex:memberOfOntology ex:SherlockOntology ;
