:shoscombeChapel a ex:Chapel ;
    ex:prefLabel "Shoscombe Chapel" ;
    skos:altLabel "the haunted crypt" ;
    skos:altLabel "the old chapel" ;
    ex:description "An old ruined chapel in Shoscombe Park. It is so ancient that nobody can fix its date. It has a broken porch gap and heaps of loose masonry. Beneath it is a crypt with a bad reputation among locals, described as dark, damp, and lonely with ancient crumbling walls of rough-hewn stone. The crypt contains coffins of lead and stone from the Falder family ancestors, decorated with the griffin and coronet family crest. Graves range from Saxon in the centre through Norman Hugos and Odos to the eighteenth-century Sir William and Sir Denis Falder. Lady Beatrice's body was hidden in a leaden coffin here." ;
    ex:locatedIn :shoscombePark, :shoscombe, :berkshire, :england, :unitedKingdom ;
    ex:inCounty :berkshire ;
    ex:inRegion :england ;
    ex:inCountry :unitedKingdom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombeFurnaceCellar a ex:Cellar ;
    ex:prefLabel "Shoscombe Furnace Cellar" ;
    ex:description "A cellar beneath Lady Beatrice's room at Shoscombe Old Place containing a central heating furnace. It has one door from outside and another leading up by stairs to the passage near Lady Beatrice's room. Harvey tends the furnace. Ancient mummy remains were burned here, and a charred human femur condyle was found in the cinders." ;
    ex:locatedIn :shoscombeOldPlace ;
    ex:partOf :shoscombeOldPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombeGunRoom a ex:Room ;
    ex:prefLabel "Shoscombe Gun-Room" ;
    skos:altLabel "the gun-room" ;
    ex:description "A comfortably furnished room in Shoscombe Old Place containing polished barrels behind glass covers. Sir Robert brings Holmes and Watson here after the crypt confrontation and introduces the Norletts to explain the concealment scheme." ;
    ex:locatedIn :shoscombeOldPlace ;
    ex:partOf :shoscombeOldPlace ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombeMillStream a ex:Location ;
    ex:prefLabel "Shoscombe Mill-Stream" ;
    skos:altLabel "the mill-stream" ;
    ex:description "A mill-stream near Shoscombe where trout can be caught. Holmes and Watson actually use their fishing tackle here and catch trout for supper." ;
    ex:locatedIn :shoscombe, :berkshire, :england, :unitedKingdom ;
    ex:inCounty :berkshire ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombeOldPlace a ex:ManorHouse ;
    ex:prefLabel "Shoscombe Old Place" ;
    ex:description "Shoscombe Old Place is a manor house and estate at the centre of Shoscombe Park in Berkshire, England. It contains the famous Shoscombe stud and training quarters. The estate belonged to Sir James Falder and is held as a life interest by his widow Lady Beatrice Falder, reverting to Sir James's brother upon her death. Sir Robert Norberton lives there with his sister. The house contains a gun-room with polished barrels behind glass covers and Lady Beatrice's room connected by stairs to a cellar with a central heating furnace." ;
    ex:locatedIn :shoscombePark, :shoscombe, :berkshire, :england, :unitedKingdom ;
    ex:inCounty :berkshire ;
    ex:inRegion :england ;
    ex:inCountry :unitedKingdom ;
    ex:ownedBy :jamesFalder ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :shoscombeOldPlaceDoc .

:shoscombePark a ex:Park ;
    ex:prefLabel "Shoscombe Park" ;
    ex:description "Shoscombe Park is the parkland surrounding Shoscombe Old Place in Berkshire, England. It contains the old ruined chapel with its crypt, the old well-house, a hall lake with pike, and a mill-stream with trout. The park has high gates with heraldic griffins." ;
    ex:locatedIn :shoscombe, :berkshire, :england, :unitedKingdom ;
    ex:inCounty :berkshire ;
    ex:inRegion :england ;
    ex:inCountry :unitedKingdom ;
    ex:memberOfOntology ex:SherlockOntology ;
