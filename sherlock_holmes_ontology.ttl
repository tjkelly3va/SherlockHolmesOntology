:woolwichStation a ex:RailwayStation ;
    ex:prefLabel "Woolwich Station" ;
    ex:description "Railway station in Woolwich. Holmes and Watson arrived here by train. West took the 8:15 train to London Bridge from here on Monday night. The ticket clerk recognized West." ;
    ex:locatedIn :england ;
    ex:locatedIn :london ;
    ex:locatedIn :unitedKingdom ;
