    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :abbeyGrangeDoc .

:abbeyGrangeDiningRoom a ex:Room ;
    ex:prefLabel "Abbey Grange Dining Room" ;
    ex:description """A very large and high chamber at Abbey Grange with carved oak ceiling, oaken panelling, and a fine array of deer's heads and ancient weapons around the walls. Features a high French window forming a door to the lawn, three smaller windows on the right, a large deep fireplace with a massive overhanging oak mantelpiece, and a heavy oaken chair. Scene of Sir Eustace Brackenstall's murder.""" ;
    ex:locatedIn :abbeyGrange ;
    ex:locatedIn :england ;
    ex:locatedIn :kent ;
