    ex:prefLabel "Colonel Warburton" ;
    ex:description "A person whose madness was the subject of a case that Watson introduced to Holmes. Mentioned only in the opening paragraph as one of the two cases Watson personally brought to Holmes's attention. No further details provided." ;
    ex:knows :johnWatson ;
    ex:knows :sherlockHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:colonelWardlaw a ex:FictionalPerson ;
    ex:lastName "Wardlaw" ;
    ex:prefLabel "Colonel Wardlaw" ;
    ex:description "Owner of the racehorse Pugilist, which ran in the Wessex Cup at Winchester. Pugilist wore a pink cap and blue and black jacket." ;
    ex:owns :pugilist ;
