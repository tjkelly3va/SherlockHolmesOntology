    ex:title "Queen" ;
    ex:prefLabel "Queen Victoria" ;
    ex:description "Real historical person. Implied but never named directly in the text. Referred to as 'a certain gracious lady' at Windsor in whose interests Holmes had carried out a small commission. Watson guessed at 'that lady's august name.' Gave Holmes a remarkably fine emerald tie-pin as reward for recovering the Bruce-Partington plans." ;
    ex:occupation "Queen of the United Kingdom" ;
    ex:livesAt :windsor ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:ralphButler a ex:FictionalPerson, ex:Servant ;
    ex:firstName "Ralph" ;
    ex:prefLabel "Ralph" ;
    skos:altLabel "old Ralph" ;
    ex:description "Ralph is the elderly butler at Tuxbury Old Park who serves Colonel Emsworth's household. He is described as a little wrinkled old fellow in conventional black coat and pepper-and-salt trousers. His wife was Godfrey Emsworth's nurse, making Ralph Godfrey's foster-father. He wore brown leather gloves impregnated with disinfectant when carrying meals to the lodge where Godfrey was hidden, a detail that confirmed Holmes's deduction of leprosy. He spoke with great affection of Godfrey and was distressed about his condition." ;
    ex:occupation "butler" ;
    ex:isMarriedTo :ralphWife ;
    ex:fosterFatherOf :godfreyEmsworth ;
    ex:knows :colonelEmsworth ;
    ex:knows :mrsEmsworth ;
    ex:knows :jamesDodd ;
    ex:knows :godfreyEmsworth ;
    ex:livesAt :tuxburyOldPark ;
    ex:employedBy :colonelEmsworth ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

:ralphSmith a ex:FictionalPerson ;
    ex:firstName "Ralph" ;
    ex:lastName "Smith" ;
    ex:prefLabel "Ralph Smith" ;
    skos:altLabel "Uncle Ralph" ;
    ex:description "Violet Smith's uncle. Brother of James Smith. Went to Africa twenty-five years before the story and was never heard from. Died in great poverty in Johannesburg. Could not read or write. On his deathbed asked Carruthers and Woodley to find his relations. His death (reported by telegram) triggered the final abduction attempt, as Violet was next-of-kin and would inherit his fortune." ;
    ex:gender "male" ;
    ex:hasParticipatedIn :deathOfRalphSmith ;
