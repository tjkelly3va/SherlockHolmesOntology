    ex:firstName "Penrose" ;
    ex:lastName "Fisher" ;
    ex:prefLabel "Penrose Fisher" ;
    ex:description "Penrose Fisher is mentioned by Watson as one of the best doctors in London whom he offers to bring to attend Holmes during his apparent illness." ;
    ex:occupation "doctor" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

