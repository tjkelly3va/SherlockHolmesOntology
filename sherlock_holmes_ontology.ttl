:tonga a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "Tonga" ;
    ex:prefLabel "Tonga" ;
    skos:altLabel "little Tonga" ;
    skos:altLabel "the Islander" ;
    ex:description "Tonga is an Andaman Islander. Devoted to Jonathan Small who nursed him back to health from fever. Fine boatman, owned large canoe. Could climb like a cat. Used blow-pipe with poisoned darts and stone-headed club. Killed Bartholomew Sholto with poisoned dart through ceiling. Shot by Holmes and Watson during Thames chase; fell into river and drowned. Body never recovered. Small exhibited him at fairs as the black cannibal." ;
    ex:gender "male" ;
    ex:nationality "Andaman Islander" ;
    ex:physicalDescription "Very small, smallest Watson had ever seen, great misshapen head, tangled dishevelled hair, small glowing eyes, thick lips" ;
    ex:birthPlace :andamanIslands ;
    ex:companionOf :jonathanSmall ;
    ex:perpetratorOf :murderOfBartholomewSholto ;
