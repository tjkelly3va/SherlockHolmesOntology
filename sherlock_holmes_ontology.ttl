:jamesRyder a ex:FictionalPerson, ex:Criminal ;
    ex:firstName "James" ;
    ex:lastName "Ryder" ;
    ex:prefLabel "James Ryder" ;
    skos:altLabel "John Robinson", "Jem" ;
    ex:description "James Ryder is the upper-attendant at the Hotel Cosmopolitan and the true thief of the blue carbuncle. He is described as a little rat-faced fellow. He conspired with Catherine Cusack, maid to the Countess, to steal the gem and frame John Horner for the crime. After the theft, he hid the stone in the crop of a goose at his sister Mrs. Oakshott's house at 117 Brixton Road, but took the wrong bird. He gave Holmes the false name 'John Robinson' before revealing his true identity. His sister calls him 'Jem'. Holmes let him go free, reasoning it was the season of forgiveness and that Ryder would not go wrong again." ;
    ex:occupation "upper-attendant" ;
    ex:confederateOf :catherineCusack ;
    ex:framesForCrime :johnHorner ;
    ex:knows :sherlockHolmes, :johnWatson, :maudsley, :breckinridge ;
    ex:siblingOf :mrsOakshott ;
    ex:worksAt :hotelCosmopolitan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:jamesStanger a ex:FictionalPerson, ex:Victim ;
    ex:firstName "James" ;
    ex:lastName "Stanger" ;
    ex:prefLabel "James Stanger" ;
    skos:altLabel "Old Editor Stanger" ;
    skos:altLabel "Stanger" ;
    ex:description "Editor of the Vermissa Herald. Old gray-haired man with spectacles, long thin limbs. Wrote editorials against the Scowrers. Brutally beaten by Baldwin and others on McGinty's orders but survived with severe head injuries." ;
    ex:occupation "Newspaper editor" ;
    ex:memberOfOntology ex:SherlockOntology ;
