:midlandElectricalCompany a ex:ElectricalCompany ;
    ex:prefLabel "Midland Electrical Company" ;
    ex:description "Electrical company based in Coventry where Cyril Morton works as an electrical engineer." ;
    ex:employs :cyrilMorton ;
    ex:locatedIn :coventry ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:moriartyCriminalOrganization a ex:FictionalOrganization, ex:CriminalOrganization ;
    ex:prefLabel "Moriarty's Criminal Organization" ;
    skos:altLabel "the gang" ;
    skos:altLabel "Moriarty's syndicate" ;
    ex:description "A vast criminal network organized and led by Professor Moriarty. Holmes describes Moriarty as sitting 'motionless, like a spider in the center of its web' with 'a thousand radiations.' The organization was responsible for 'half that is evil and of nearly all that is undetected' in London. Agents were numerous and splendidly organized; money was provided for bail or defence of caught agents. Holmes spent years investigating and three months accumulating evidence. The entire gang except Moriarty was arrested on Monday. Holmes's accumulated evidence eventually exposed their organization and led to heavy sentences. Referred to as 'the Moriarty gang'. The trial of the gang broke up the organization but left two of its most dangerous members at liberty, including Colonel Moran. Parker served as a sentinel watching 221B Baker Street." ;
    ex:ledBy :professorMoriarty ;
    ex:locatedIn :london ;
    ex:hasMember :colonelSebastianMoran ;
    ex:hasMember :parkerGarroter ;
    skos:altLabel "the Moriarty gang" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :finalProblemDoc ;
    dc:source :emptyHouseDoc .

:morrisonMorrisonAndDodd a ex:FictionalOrganization, ex:LawFirm ;
    ex:prefLabel "Morrison, Morrison, and Dodd" ;
    ex:description "Morrison, Morrison, and Dodd is a law firm located at 46 Old Jewry, London. The firm specializes entirely in the assessment of machinery. They are the lawyers for Robert Ferguson and recommended him to consult Sherlock Holmes about the vampire matter. They reference Holmes's successful action in the case of the ship Matilda Briggs. Their letter is signed 'per E. J. C.'" ;
    ex:hasClient :robertFerguson ;
    ex:hasEmployee :ejc ;
    ex:locatedAt :46OldJewry ;
    ex:locatedIn :london ;
    ex:locatedIn :england ;
    ex:locatedIn :unitedKingdom ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:mortonAndKennedy a ex:ElectricalCompany ;
    ex:prefLabel "Morton & Kennedy" ;
    ex:description "Famous Westminster electricians. Cyril Morton became the senior partner after the events of the story." ;
    ex:locatedIn :london ;
    ex:locatedIn :westminster ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :solitaryCyclistDoc .

:mortonAndWaylights a ex:Organization ;
    ex:prefLabel "Morton and Waylight's" ;
    ex:description "Morton and Waylight's is a business located in Tottenham Court Road, London, where Mr. Warren is employed as a timekeeper." ;
    ex:locatedIn :tottenhamCourtRoad ;
    ex:locatedIn :london ;
    ex:locatedIn :england ;
    ex:locatedIn :unitedKingdom ;
