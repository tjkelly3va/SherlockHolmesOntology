:ronaldAdair a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Ronald" ;
    ex:lastName "Adair" ;
    ex:prefLabel "The Honourable Ronald Adair" ;
    skos:altLabel "Ronald Adair" ;
    skos:altLabel "Adair" ;
    ex:description "The Honourable Ronald Adair, second son of the Earl of Maynooth. Murdered at 427 Park Lane on March 30, 1894 by Colonel Sebastian Moran using Von Herder's air-gun with an expanding bullet fired through an open window. Member of the Baldwin, Cavendish, and Bagatelle card clubs. Had been engaged to Miss Edith Woodley of Carstairs but the engagement was broken off by mutual consent. Fond of cards, cautious player, usually rose a winner. Was working out card winnings/losses at the time of his death." ;
    ex:occupation "aristocrat" ;
    ex:childOf :earlOfMaynooth ;
    ex:childOf :ladyMaynooth ;
    ex:siblingOf :hildaAdair ;
