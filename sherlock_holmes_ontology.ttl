ex:deductionReasoning a owl:DatatypeProperty ;
    rdfs:domain ex:Deduction ;
    rdfs:range xsd:string ;
    rdfs:label "Deduction Reasoning" ;
    ex:prefLabel "Deduction Reasoning" ;
    ex:description "A 'Deduction Reasoning' is a string recording the chain of logic, observations, or inferences used to arrive at the conclusion, as described in the text." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

ex:deductionSequence a owl:DatatypeProperty ;
    rdfs:domain ex:Deduction ;
    rdfs:range xsd:integer ;
    rdfs:label "Deduction Sequence" ;
    ex:prefLabel "Deduction Sequence" ;
    ex:description "A 'Deduction Sequence' is an integer recording the ordinal position of a deduction within a story, preserving the narrative order in which reasoning is presented or revealed." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

ex:deductionSummary a owl:DatatypeProperty ;
