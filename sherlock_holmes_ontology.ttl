:edithPresbury a ex:FictionalPerson, ex:Client ;
    ex:firstName "Edith" ;
    ex:lastName "Presbury" ;
    ex:prefLabel "Edith Presbury" ;
    skos:altLabel "Edith" ;
    skos:altLabel "Miss Presbury" ;
    ex:description "Edith Presbury is the only daughter of Professor Presbury. She is described as a bright, handsome girl of a conventional English type. She is devoted to her father and engaged to Trevor Bennett. Her room is on the second floor of the Presbury house. She witnessed her father's face pressed against her second-floor window on the night of September 5th, which terrified her. She sleeps with her door locked due to a feeling of impending danger. She traveled to London to consult Holmes about her father's condition." ;
    ex:livesAt :presburyHouse ;
    ex:childOf :professorPresbury ;
    ex:hasFiancee :trevorBennett ;
