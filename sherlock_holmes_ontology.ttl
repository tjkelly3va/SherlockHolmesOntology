:middlesexCorps a ex:MilitaryUnit ;
    ex:prefLabel "Middlesex Corps" ;
    ex:description "The Middlesex Corps is a unit within the Imperial Yeomanry during the Boer War. James Dodd served in this corps, which Holmes deduced from Dodd's stockbroker card showing he worked on Throgmorton Street." ;
    ex:partOfUnit :imperialYeomanry ;
    ex:memberOfOntology ex:SherlockOntology ;
