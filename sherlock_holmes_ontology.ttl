    ex:perpetratorOf :murderOfDrebber ;
    ex:perpetratorOf :murderOfStangerson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :studyInScarletDoc .

:jeremiahHayling a ex:FictionalPerson, ex:Victim, ex:Engineer ;
    ex:firstName "Jeremiah" ;
    ex:lastName "Hayling" ;
    ex:prefLabel "Jeremiah Hayling" ;
    skos:altLabel "Mr. Jeremiah Hayling" ;
    ex:description "A hydraulic engineer, aged twenty-six, who disappeared after leaving his lodgings at ten o'clock one night. His disappearance was reported in all the papers about a year before Hatherley's case. Holmes connected his disappearance to Colonel Lysander Stark, implying Hayling was murdered after being brought to examine the same hydraulic press. Holmes said 'That represents the last time that the colonel needed to have his machine overhauled.'" ;
    ex:occupation "hydraulic engineer" ;
    ex:age "26" ;
    ex:victimOf :haylingDisappearance ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

