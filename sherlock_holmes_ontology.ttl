:murderOfHeidegger a ex:Murder ;
    ex:prefLabel "Murder of Heidegger" ;
    ex:description "Heidegger pursued Lord Saltire on his Palmer-tyred bicycle and was struck by Reuben Hayes with a metal-headed stick five miles from the school. The blow crushed part of his skull. Despite the mortal injury, Heidegger continued riding before dying in gorse bushes on the moor." ;
    ex:hasParticipant :heidegger ;
    ex:hasParticipant :reubenHayes ;
    ex:occurredAt :lowerGillMoor ;
    ex:hasVictim :heidegger ;
    ex:hasPerpetrator :reubenHayes ;
