:openshawGrandfather a ex:FictionalPerson ;
    ex:prefLabel "Openshaw Grandfather" ;
    ex:description "John Openshaw's unnamed grandfather. Had two sons: Elias and Joseph. His name is not given in the text." ;
    ex:grandparentOf :johnOpenshaw ;
    ex:parentOf :eliasOpenshaw, :josephOpenshaw ;
    ex:memberOfOntology ex:SherlockOntology ;
