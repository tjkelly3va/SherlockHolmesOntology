:woodhouse a ex:FictionalPerson ;
    ex:lastName "Woodhouse" ;
    ex:prefLabel "Woodhouse" ;
    ex:description "Named by Holmes alongside Brooks as one of fifty men who have good reason for taking his life. No further details provided." ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :brucePartingtonPlansDoc .

:youghal a ex:FictionalPerson, ex:PoliceOfficer ;
