:edmunds a ex:FictionalPerson, ex:PoliceOfficer ;
    ex:lastName "Edmunds" ;
    ex:prefLabel "Edmunds" ;
    skos:altLabel "Mr. Edmunds" ;
    ex:description "Edmunds is a young, thin, yellow-haired man who served as a constable and county detective with the Berkshire Constabulary. He investigated the Abbas Parva case and was troubled by inconsistencies in the evidence. He consulted Holmes about the case, smoking a pipe or two over it. He later examined Mrs. Ronder after her recovery, at which time she lied to him. He was later sent to Allahabad, India. Holmes describes him as a smart lad." ;
    ex:gender "male" ;
    ex:occupation "county detective" ;
    ex:memberOf :berkshireConstabulary ;
    ex:knows :sherlockHolmes, :eugeniaRonder ;
