:paddingtonGuard a ex:FictionalPerson ;
    ex:prefLabel "Paddington Guard" ;
    skos:altLabel "the guard" ;
    skos:altLabel "Watson's old ally" ;
    ex:description "A railway guard at Paddington Station whom Watson had previously cured of a painful and lingering disease. He was never weary of advertising Watson's virtues and sending patients to him. He brought Victor Hatherley to Watson's consulting room early in the morning, saying 'I've got him here' and 'he's all right.' Described by Watson as 'this trusty tout.'" ;
    ex:occupation "railway guard" ;
    ex:worksAt :paddingtonStation ;
    ex:knows :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:paramore a ex:FictionalPerson, ex:Victim ;
    ex:lastName "Paramore" ;
    ex:prefLabel "Paramore" ;
    ex:description "A person named in Colonel Elias Openshaw's diary. On March 7, 1869, the pips were 'set on' McCauley, Paramore, and John Swain of St. Augustine. On March 12, Elias 'visited Paramore. All well.' Holmes interprets this with sinister implication." ;
    ex:targetOf :kuKluxKlan ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :fiveOrangePipsDoc .

:parker a ex:FictionalPerson ;
    ex:lastName "Parker" ;
    ex:prefLabel "Parker" ;
    ex:description "Former manager at Coxon & Woodhouse. Referenced by Arthur Pinner as having spoken highly of Hall Pycroft's financial abilities. He is only mentioned in Pinner's dialogue and may or may not actually exist as described." ;
    ex:occupation "manager" ;
    ex:employedBy :coxonAndWoodhouse ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :stockBrokersClerkDoc .

:pathanConvictGuard a ex:FictionalPerson, ex:Victim ;
    ex:prefLabel "Pathan Convict Guard" ;
    ex:description "Unnamed convict guard at the Andaman Islands. A vile Pathan who never missed a chance of insulting and injuring Jonathan Small. Killed by Small with his wooden leg during the escape with Tonga. Name not given in text." ;
    ex:occupation "convict guard" ;
    ex:gender "male" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :signOfTheFourDoc .

:patienceMoran a ex:FictionalPerson ;
    ex:firstName "Patience" ;
    ex:lastName "Moran" ;
    ex:prefLabel "Patience Moran" ;
    ex:description "A girl of fourteen, daughter of the lodge-keeper of the Boscombe Valley estate. Key witness who was picking flowers in the woods near Boscombe Pool and saw Charles and James McCarthy quarrelling violently. Saw James raise his hand as if to strike his father. Was frightened and ran home to tell her mother." ;
    ex:age 14 ;
    ex:childOf :patienceMoranFather, :patienceMoranMother ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:patienceMoranFather a ex:FictionalPerson ;
    ex:prefLabel "Patience Moran's Father" ;
    skos:altLabel "the lodge-keeper" ;
    ex:description "The unnamed lodge-keeper of the Boscombe Valley estate. Father of Patience Moran. James McCarthy ran to his lodge to report finding his father dying. His house was the nearest to the scene of the murder. His name is not given in the text." ;
    ex:occupation "lodge-keeper" ;
    ex:employedBy :johnTurner ;
    ex:livesAt :boscombeValleyEstateLodge ;
    ex:parentOf :patienceMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:patienceMoranMother a ex:FictionalPerson ;
    ex:prefLabel "Patience Moran's Mother" ;
    ex:description "Unnamed mother of Patience Moran, wife of the lodge-keeper. Patience ran home and told her mother about the quarrel she witnessed between the McCarthys at Boscombe Pool. Her name is not given in the text." ;
    ex:livesAt :boscombeValleyEstateLodge ;
    ex:parentOf :patienceMoran ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :boscombeValleyMysteryDoc .

:percyArmitage a ex:FictionalPerson ;
    ex:firstName "Percy" ;
    ex:lastName "Armitage" ;
    ex:prefLabel "Percy Armitage" ;
    ex:description "Percy Armitage is the second son of Mr. Armitage of Crane Water near Reading. He is a dear friend of Helen Stoner for many years and has asked her hand in marriage about a month before the events of the story. Helen describes him as the one person who cares for her." ;
    ex:childOf :mrArmitage ;
    ex:engagedTo :helenStoner ;
    ex:livesAt :craneWater ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :speckledBandDoc .

:perkins a ex:FictionalPerson, ex:Servant ;
    ex:firstName "Perkins" ;
    ex:prefLabel "Perkins" ;
    skos:altLabel "the groom" ;
    ex:description "Groom at Baskerville Hall. Hard-faced, gnarled little fellow. Sent on horseback by Barrymore to fetch Dr. Mortimer on the night of Sir Charles's death. Served as driver/coachman for the wagonette. Drove Watson to Coombe Tracey. It was suggested he sleep at the Stapletons' for protection but Stapleton refused." ;
    ex:occupation "groom, coachman" ;
    ex:employedBy :henryBaskerville ;
    ex:livesAt :baskervilleHall ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :houndOfTheBaskervillesDoc .

:peterJones a ex:FictionalPerson, ex:PoliceOfficer ;
    ex:firstName "Peter" ;
    ex:lastName "Jones" ;
    ex:prefLabel "Peter Jones" ;
    skos:altLabel "Jones" ;
    skos:altLabel "Mr. Jones" ;
    ex:description "Peter Jones is an official police agent from Scotland Yard. Holmes describes him as 'not a bad fellow, though an absolute imbecile in his profession.' Brave as a bulldog and tenacious as a lobster. References the Sholto murder and the Agra treasure as cases where Holmes outperformed the official force. Arrests John Clay and puts handcuffs on him in the bank vault. Had an inspector and two officers posted at the front door of Wilson's shop." ;
    ex:occupation "police agent" ;
    ex:arrested :johnClay ;
    ex:knows :johnWatson ;
    ex:knows :mrMerryweather ;
    ex:knows :sherlockHolmes ;
    ex:memberOf :scotlandYard ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :redHeadedLeagueDoc .

:peterson a ex:FictionalPerson, ex:Commissionaire ;
    ex:lastName "Peterson" ;
    ex:prefLabel "Peterson" ;
    ex:description "Peterson is a commissionaire described as a very honest fellow. On Christmas morning around 4am, while returning from a jollification down Tottenham Court Road, he found a hard-felt hat and a white goose after a row between their owner and a knot of roughs near Goodge Street. He brought both to Sherlock Holmes. His wife found the blue carbuncle in the goose's crop." ;
    ex:occupation "commissionaire" ;
    ex:findsObject :henryBakerHat, :henryBakerGoose ;
    ex:isMarriedTo :petersonWife ;
    ex:knows :sherlockHolmes, :johnWatson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:petersonWife a ex:FictionalPerson ;
    ex:prefLabel "Peterson's Wife" ;
    ex:description "Peterson's wife is an unnamed woman who discovered the blue carbuncle in the crop of the goose that her husband had brought home from Tottenham Court Road on Christmas morning." ;
    ex:findsObject :blueCarbuncle ;
    ex:isMarriedTo :peterson ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blueCarbuncleDoc .

:policemanEvans a ex:FictionalPerson, ex:PoliceOfficer, ex:Victim ;
    ex:lastName "Evans" ;
    ex:prefLabel "Policeman Evans" ;
    skos:altLabel "Evans" ;
    ex:description "Policeman shot alongside Hunt by the Scowrers for the same offense." ;
    ex:occupation "Policeman" ;
    ex:memberOfOntology ex:SherlockOntology ;
