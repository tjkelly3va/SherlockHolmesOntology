:hatherleyClerk a ex:FictionalPerson ;
    ex:prefLabel "Hatherley's Clerk" ;
    skos:altLabel "the clerk" ;
    ex:description "A clerk employed by Victor Hatherley at his office at 16A Victoria Street. He announced Colonel Lysander Stark's arrival to Hatherley. Stark was suspicious of the clerk potentially eavesdropping." ;
    ex:occupation "clerk" ;
    ex:employedBy :victorHatherley ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :engineersThumbDoc .

:hatherleyFather a ex:FictionalPerson ;
    ex:prefLabel "Hatherley's Father" ;
    ex:description "Victor Hatherley's deceased father. His death left Hatherley a fair sum of money which enabled him to start his own hydraulic engineering practice. No name or further details are given." ;
    ex:parentOf :victorHatherley ;
