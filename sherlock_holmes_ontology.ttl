:brendaTregennis a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Brenda" ;
    ex:lastName "Tregennis" ;
    ex:prefLabel "Brenda Tregennis" ;
    skos:altLabel "Miss Brenda Tregennis" ;
    ex:description "Sister of Mortimer, George, and Owen Tregennis. A very beautiful woman with a dark, clear-cut face, verging upon middle age. Lived at Tredannick Wartha with her brothers George and Owen. Killed by devil's-foot root poison placed in the fire by her brother Mortimer on the night of March 16, 1897. Found dead in her chair with an expression of utmost horror. Had been secretly loved by Dr. Leon Sterndale for years, and loved him in return. Their love was the secret of Sterndale's Cornish seclusion. They could not marry because Sterndale's estranged wife could not be divorced under English law." ;
    ex:livesAt :tredannickWartha ;
    ex:romanticPartnerOf :leonSterndale ;
    ex:siblingOf :mortimerTregennis ;
    ex:siblingOf :georgeTregennis ;
    ex:siblingOf :owenTregennis ;
    ex:victimOf :tredannickWarthaPoisoning ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :devilsFootDoc .

:briarbraeGroom a ex:FictionalPerson, ex:Groom ;
    ex:prefLabel "Briarbrae Groom" ;
    ex:description "A groom at Briarbrae, the Harrison residence near Woking. He assisted during the investigation. His name is not given in the text." ;
    ex:occupation "groom" ;
    ex:worksAt :briarbrae ;
