    dc:source :missingThreeQuarterDoc .

:deduction_missingThreeQuarter_holmes_05 a ex:Deduction ;
    ex:prefLabel "Holmes Suspects Staunton Had a Secret Trouble" ;
    ex:description "While examining Staunton's papers at Bentley's Hotel, Holmes asks Overton whether Staunton was healthy, then suggests the young man may have had some secret trouble." ;
    ex:deductionSequence 5 ;
    ex:deductionSummary "Staunton may not have been as strong as supposed and may have had some secret trouble." ;
    ex:deductionReasoning "After finding nothing in Staunton's letters, bills, and notebooks, Holmes asked about Staunton's health. Despite Overton's assurance that Staunton was sound, Holmes suggested he may have had a secret trouble, having evidently found something in the papers — specifically a receipted bill for thirteen guineas paid to Dr. Leslie Armstrong — that indicated a concealed medical concern." ;
    ex:deductionOutcome "correct" ;
    ex:deducedBy :sherlockHolmes ;
    ex:deductionSubject :godfreyStaunton ;
    ex:deductionBasedOn :armstrongReceiptedBill ;
    ex:confirmedBy :leslieArmstrong ;
    ex:memberOfOntology ex:SherlockOntology ;
