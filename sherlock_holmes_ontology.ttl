    ex:narrativeYear "1896" ;
    ex:isSolved "true"^^xsd:boolean ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :veiledLodgerDoc .

:visitToBellamys a ex:Meeting ;
    ex:prefLabel "Visit to the Bellamys" ;
    ex:description "Holmes and Stackhurst visit the Bellamy family at The Haven to interview them about McPherson's death. They encounter Ian Murdoch leaving the house, leading to a confrontation between Stackhurst and Murdoch. Inside, they meet Tom Bellamy and William Bellamy, who are hostile about McPherson's attentions to Maud. Maud Bellamy herself appears and reveals her secret engagement to McPherson, providing information about the relationship and the notes they exchanged." ;
    ex:narrativeYear "1907" ;
    ex:hasParticipant :sherlockHolmes, :haroldStackhurst, :maudBellamy, :tomBellamy, :williamBellamy, :ianMurdoch ;
    ex:occurredAt :theHaven ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :lionsManeDoc .

:visitToNathanGarrideb a ex:Event, ex:Meeting ;
    ex:prefLabel "Visit to Nathan Garrideb" ;
    ex:description "Holmes and Watson's evening visit to Nathan Garrideb at his rooms at 136 Little Ryder Street to make his acquaintance and assess his character. They observed his extensive collection and discussed the Garrideb inheritance matter. Killer Evans arrived during the visit with the fake Howard Garrideb advertisement." ;
    ex:hasParticipant :sherlockHolmes ;
    ex:hasParticipant :johnWatson ;
    ex:hasParticipant :nathanGarrideb ;
    ex:hasParticipant :killerEvans ;
