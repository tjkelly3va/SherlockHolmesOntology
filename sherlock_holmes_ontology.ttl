:oldCunningham a ex:FictionalPerson, ex:Criminal ;
    ex:lastName "Cunningham" ;
    ex:title "Mr." ;
    ex:prefLabel "Mr. Cunningham" ;
    skos:altLabel "old Cunningham" ;
    skos:altLabel "the J.P." ;
    skos:altLabel "Mr. Cunningham senior" ;
    ex:description "An elderly county magnate and Justice of the Peace living in a fine old Queen Anne house near Reigate. Described as having a strong, deep-lined, heavy-eyed face. He was the leading man in the area and considered a very decent fellow. Together with his son Alec, he broke into Mr. Acton's house seeking legal documents related to their lawsuit, and later murdered their coachman William Kirwan who was blackmailing them over the burglary. He co-wrote the murder note (the weaker, older hand). After Holmes recovered the evidence, he became tractable and made a clean breast of everything." ;
    ex:occupation "Justice of the Peace, county magnate" ;
    ex:parentOf :alecCunningham ;
    ex:livesAt :cunninghamHouse ;
    ex:employs :williamKirwan ;
    ex:knows :mrActon, :colonelHayter ;
    ex:participantIn :actonBurglary, :williamKirwanMurder, :cunninghamArrest ;
