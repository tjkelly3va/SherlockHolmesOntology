    ex:knows :johnWatson ;
    ex:knows :lordBackwater ;
    ex:knows :ladyAliciaWhittington ;
    ex:livesAt :grosvenorMansions ;
    ex:owns :birchmoor ;
    ex:siblingOf :lordEustace ;
    ex:siblingOf :ladyClaraStSimon ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :nobleBachelorDoc .

