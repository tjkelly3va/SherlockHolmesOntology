:trevorBennett a ex:FictionalPerson, ex:Client ;
    ex:firstName "Trevor" ;
    ex:lastName "Bennett" ;
    ex:prefLabel "Trevor Bennett" ;
    skos:altLabel "Bennett" ;
    skos:altLabel "Mr. Bennett" ;
    skos:altLabel "Jack" ;
    ex:description "Trevor Bennett is the professional assistant and secretary to Professor Presbury at Camford. He is a tall, handsome youth of about thirty, well dressed and elegant, with the shyness of a student rather than the self-possession of a man of the world. He lives under Presbury's roof and is engaged to Edith Presbury, the professor's daughter. Bennett holds a medical degree and handles all of Presbury's correspondence. He kept a diary recording dates of the professor's abnormal incidents, which proved crucial in Holmes identifying the nine-day cycle. A fellow-student of Bennett's in Prague informed him of Presbury's visit there. Bennett obtained Dorak's address from Presbury's blotting-paper. He assisted in dressing Presbury's throat wound after Roy's attack and was concerned about scandal at the university." ;
    ex:occupation "professional assistant, secretary" ;
    ex:livesAt :presburyHouse ;
    ex:worksAt :camfordUniversityOrg ;
    ex:fianceeOf :edithPresbury ;
    ex:assistantOf :professorPresbury ;
    ex:knows :sherlockHolmes ;
    ex:knows :johnWatson ;
    ex:knows :edithPresbury ;
    ex:knows :professorPresbury ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :creepingManDoc .

