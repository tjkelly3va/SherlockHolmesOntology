    ex:lastName "Stevens" ;
    ex:prefLabel "Bert Stevens" ;
    ex:description "A murderer mentioned by Holmes. The most terrible case in 1887, where Stevens was the well-known canary-trainer. His innocuous appearance initially deceived people." ;
    ex:occupation "canary-trainer" ;
    ex:memberOfOntology ex:SherlockOntology ;
