    ex:knows :johnWatson ;
    ex:knows :violetSmith ;
    ex:livesAt :chilternGrange ;
    ex:owns :carrutherssBicycle ;
    ex:owns :carrutherssPistol ;
    ex:parentOf :carrutherssDaughter ;
    ex:shot :jackWoodley ;
