:mortimer a ex:FictionalPerson, ex:DomesticServant ;
    ex:lastName "Mortimer" ;
    ex:prefLabel "Mortimer" ;
    ex:description "Gardener at Yoxley Old Place. Army pensioner and old Crimean War veteran of excellent character. Wheels Professor Coram's bath-chair around the grounds. Does not live in the main house but in a three-roomed cottage at the other end of the garden. Orders were to come to the Professor at twelve o'clock to help him dress. Sent by the Professor to fetch local police after the murder." ;
    ex:occupation "gardener" ;
    ex:militaryService "Crimean War veteran, Army pensioner" ;
