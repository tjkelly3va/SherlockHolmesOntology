    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :secondStainDoc .

:lordMountJames a ex:FictionalPerson, ex:Nobleman ;
    ex:firstName "Lord" ;
    ex:lastName "Mount-James" ;
    ex:prefLabel "Lord Mount-James" ;
    ex:description "Godfrey Staunton's uncle and nearest relative, one of the richest men in England and an absolute miser. Nearly eighty years old with severe gout. Described as a queer little old man dressed in rusty black with a very broad-brimmed top-hat and loose white necktie, resembling a rustic parson or undertaker's mute. Despite his wealth, never allowed Godfrey a shilling. Concerned about his plate and treasure when Holmes suggests kidnapping. Arrived at Bentley's Hotel via Bayswater bus." ;
    ex:occupation "Nobleman" ;
    ex:knows :godfreyStaunton ;
    ex:uncleOf :godfreyStaunton ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :missingThreeQuarterDoc .

:lordRoberts a ex:RealPerson, ex:Soldier ;
    ex:prefLabel "Lord Roberts" ;
    ex:description "Lord Roberts is a real historical military figure mentioned in comparison. The prospect of an interview with Lord Roberts would not have excited greater wonder and pleasure in a raw subaltern than Sir James Saunders's name did in Mr. Kent." ;
    ex:occupation "military commander" ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :blanchedSoldierDoc .

