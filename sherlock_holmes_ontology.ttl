    ex:prefLabel "Mr. Heath Newton" ;
    ex:description "Owner of the racehorse The Negro, which ran in the Wessex Cup at Winchester. The Negro wore a red cap and cinnamon jacket." ;
    ex:owns :theNegro ;
    ex:memberOfOntology ex:SherlockOntology ;
