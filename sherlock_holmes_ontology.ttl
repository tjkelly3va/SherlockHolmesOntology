:culvertonSmith a ex:FictionalPerson, ex:Criminal, ex:Planter ;
    ex:firstName "Culverton" ;
    ex:lastName "Smith" ;
    ex:prefLabel "Culverton Smith" ;
    skos:altLabel "Mr. Culverton Smith" ;
    skos:altLabel "Mr. Smith" ;
    ex:description "Culverton Smith is a well-known resident of Sumatra who is visiting London. He is a planter whose plantation was distant from medical aid, which caused him to study tropical diseases as his 'dearest hobby'. He is described as having a great yellow face, coarse-grained and greasy, with heavy double chin, two sullen menacing gray eyes under tufted sandy brows, and a high bald head with enormous skull capacity. Despite his large head, his body is small and frail, twisted in the shoulders and back as if from childhood rickets. He wears a small velvet smoking-cap. He murdered his nephew Victor Savage using a tropical disease, and attempted to murder Sherlock Holmes by sending a poisoned ivory box with a spring mechanism by post. He is arrested by Inspector Morton at 221B Baker Street after confessing in Holmes's presence while Watson listened from hiding." ;
    ex:occupation "planter and amateur of tropical disease" ;
    ex:livesAt :13LowerBurkeStreet ;
    ex:employedBy :staples ;
    ex:uncleOf :victorSavage ;
    ex:knows :sherlockHolmes ;
    ex:knows :victorSavage ;
    ex:arrestedBy :inspectorMorton ;
    ex:participatedIn :murderOfVictorSavage ;
    ex:participatedIn :attemptedMurderOfHolmes ;
    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :dyingDetectiveDoc .

