    ex:memberOfOntology ex:SherlockOntology ;
    dc:source :sussexVampireDoc .

:cheesemansMainRoom a ex:FictionalLocation, ex:Room ;
    ex:prefLabel "Central Room at Cheeseman's" ;
    ex:description "The very large central room at Cheeseman's where Ferguson receives Holmes and Watson. It features a huge old-fashioned fireplace with an iron screen dated 1670 and a splendid log fire. The half-panelled walls have modern watercolours on the lower part and a fine collection of South American utensils and weapons above, on the yellow plaster. The room is described as a singular mixture of dates and places." ;
    ex:locatedIn :cheesemans ;
    ex:locatedIn :england ;
    ex:locatedIn :lamberley ;
    ex:locatedIn :sussex ;
