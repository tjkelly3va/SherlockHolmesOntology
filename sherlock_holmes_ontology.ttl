:sirJohnHardy a ex:FictionalPerson ;
    ex:firstName "John" ;
    ex:lastName "Hardy" ;
    ex:prefLabel "Sir John Hardy" ;
    ex:description "Played whist with Ronald Adair at the Bagatelle club on the day of Adair's death. Gave evidence at the inquest." ;
