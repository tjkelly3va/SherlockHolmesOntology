:bartholomewSholto a ex:FictionalPerson, ex:Victim ;
    ex:firstName "Bartholomew" ;
    ex:lastName "Sholto" ;
    ex:prefLabel "Bartholomew Sholto" ;
    skos:altLabel "Brother Bartholomew" ;
    skos:altLabel "Mr. Bartholomew Sholto" ;
    ex:description "Bartholomew Sholto is the son of Major John Sholto and twin brother of Thaddeus. Lived at Pondicherry Lodge, Upper Norwood. Had a chemical laboratory. Discovered the Agra treasure in a hidden garret by calculating cubic space and finding four feet unaccounted for. Found dead in his locked laboratory, killed by Tonga's poisoned dart shot through ceiling. Face frozen in ghastly grin (risus sardonicus). The sign of the four note left beside his body. Mrs Bernstone served him for ten years." ;
    ex:gender "male" ;
    ex:childOf :majorJohnSholto ;
    ex:livesAt :pondicherryLodge ;
    ex:siblingOf :thaddeusSholto ;
    ex:twinOf :thaddeusSholto ;
    ex:victimOf :murderOfBartholomewSholto ;
    ex:memberOfOntology ex:SherlockOntology ;
