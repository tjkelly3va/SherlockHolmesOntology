:mrActon a ex:FictionalPerson, ex:Victim ;
    ex:lastName "Acton" ;
    ex:title "Mr." ;
    ex:prefLabel "Mr. Acton" ;
    skos:altLabel "old Acton" ;
    skos:altLabel "Acton" ;
    ex:description "A little elderly gentleman and county magnate near Reigate whose house was broken into by the Cunninghams. He has a legal claim on half of the Cunningham estate, and a lawsuit had been ongoing between them for years, draining both parties financially. The Cunninghams burglarized his library seeking a document that would have crippled his legal case, but the paper was safely in his solicitors' strong-box. He was present when Holmes explained the solution to the case." ;
    ex:occupation "county magnate" ;
    ex:livesAt :actonHouse ;
    ex:knows :oldCunningham ;
    ex:participantIn :actonBurglary ;
    ex:memberOfOntology ex:SherlockOntology ;
